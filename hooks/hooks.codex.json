{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./bin/core/session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./bin/adapter/cdx/guard-bash-scope",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
