#!/bin/bash
# apd cdx agents — scaffold agent definitions into <project>/.apd/agents/
#
# Subcommands:
#   list                         show available templates + currently installed agents
#   add <name> [scope-path ...]  copy a template and optionally override its scope
#
# The templates live at ${APD_PLUGIN_ROOT}/templates/codex/agents/<name>.md
# and are Codex-native: no CC-specific `hooks:` frontmatter field, scope is
# a YAML list under `scope:`. Each scaffold run is idempotent for existing
# agents — the script refuses to overwrite; use `--force` to replace.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

TEMPLATE_DIR="$APD_PLUGIN_ROOT/templates/codex/agents"

if [ ! -d "$TEMPLATE_DIR" ]; then
    echo "ERROR: template dir missing at $TEMPLATE_DIR" >&2
    exit 2
fi

SUB="${1:-help}"
shift 2>/dev/null || true

_list_templates() {
    for f in "$TEMPLATE_DIR"/*.md; do
        [ -f "$f" ] || continue
        local name desc
        name=$(basename "$f" .md)
        desc=$(grep -m1 '^description:' "$f" 2>/dev/null | sed 's/description:[[:space:]]*//')
        printf "    %-22s %s\n" "$name" "$desc"
    done
}

_list_installed() {
    if [ -d "$APD_AGENTS_DIR" ]; then
        local count=0
        for f in "$APD_AGENTS_DIR"/*.md; do
            [ -f "$f" ] || continue
            local name
            name=$(basename "$f" .md)
            printf "    %-22s %s\n" "$name" "$f"
            count=$((count + 1))
        done
        [ "$count" -eq 0 ] && echo "    (none)"
    else
        echo "    (agents directory does not exist at $APD_AGENTS_DIR)"
    fi
}

case "$SUB" in
    list|ls)
        echo ""
        echo "  ${V}Available templates${R} (${TEMPLATE_DIR}):"
        echo ""
        _list_templates
        echo ""
        echo "  ${V}Installed agents${R} (${APD_AGENTS_DIR}):"
        echo ""
        _list_installed
        echo ""
        ;;
    add)
        NAME="${1:-}"
        if [ -z "$NAME" ]; then
            echo "ERROR: agent name required. Run \`apd cdx agents list\` to see templates." >&2
            exit 1
        fi
        shift

        FORCE=0
        SCOPE_ARGS=()
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --force|-f) FORCE=1; shift ;;
                --) shift; SCOPE_ARGS+=("$@"); break ;;
                *)  SCOPE_ARGS+=("$1"); shift ;;
            esac
        done

        TEMPLATE="$TEMPLATE_DIR/$NAME.md"
        if [ ! -f "$TEMPLATE" ]; then
            echo "ERROR: no template named '$NAME'. Available:" >&2
            _list_templates >&2
            exit 1
        fi

        mkdir -p "$APD_AGENTS_DIR"
        TARGET="$APD_AGENTS_DIR/$NAME.md"
        if [ -f "$TARGET" ] && [ "$FORCE" != "1" ]; then
            echo "ERROR: $TARGET already exists (pass --force to overwrite)" >&2
            exit 1
        fi

        # Project name for placeholder substitution
        PROJECT_NAME="$(basename "$PROJECT_DIR")"
        if [ -n "${APD_CONFIG_FILE:-}" ] && [ -f "$APD_CONFIG_FILE" ]; then
            CONF_PROJ=$(grep '^PROJECT_NAME=' "$APD_CONFIG_FILE" 2>/dev/null | cut -d= -f2-)
            [ -n "$CONF_PROJ" ] && PROJECT_NAME="$CONF_PROJ"
        fi

        # Copy template with {{PROJECT_NAME}} substituted
        sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g" "$TEMPLATE" > "$TARGET"

        # Scope override: if caller passed scope paths, rewrite the scope: block
        if [ "${#SCOPE_ARGS[@]}" -gt 0 ]; then
            python3 - "$TARGET" "${SCOPE_ARGS[@]}" <<'PY'
import sys
path = sys.argv[1]
scopes = sys.argv[2:]
with open(path) as f:
    text = f.read()
lines = text.split("\n")
out = []
i = 0
in_front = False
replaced = False
while i < len(lines):
    line = lines[i]
    if i == 0 and line.strip() == "---":
        in_front = True
        out.append(line); i += 1; continue
    if in_front and line.strip() == "---":
        in_front = False
        out.append(line); i += 1; continue
    if in_front and line.startswith("scope:"):
        out.append("scope:")
        for s in scopes:
            out.append(f"  - {s}")
        replaced = True
        i += 1
        # Skip existing scope list items
        while i < len(lines) and lines[i].startswith("  - "):
            i += 1
        continue
    out.append(line); i += 1
# Insert scope: if not originally present
if not replaced:
    new_out = []
    for line in out:
        new_out.append(line)
        if line.strip() == "---" and "scope:" not in text:
            # Insert after first ---
            break
    # Fallback: just append
with open(path, "w") as f:
    f.write("\n".join(out))
PY
        fi

        chmod 644 "$TARGET"
        echo "  ${G}wrote${R}  $TARGET"
        if [ "${#SCOPE_ARGS[@]}" -gt 0 ]; then
            echo "  ${D}scope:${R} ${SCOPE_ARGS[*]}"
        fi
        echo ""
        echo "  Next: open the file and refine role/model/maxTurns as needed."
        ;;
    migrate)
        DRY_RUN=0
        FORCE_MIG=0
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --dry-run) DRY_RUN=1; shift ;;
                --force|-f) FORCE_MIG=1; shift ;;
                *) echo "Unknown flag: $1" >&2; exit 1 ;;
            esac
        done

        SOURCE_DIR="$PROJECT_DIR/.apd/agents"
        TARGET_DIR="$PROJECT_DIR/.codex/agents"

        if [ ! -d "$SOURCE_DIR" ]; then
            echo "  ${D}No .apd/agents/ directory — nothing to migrate.${R}"
            exit 0
        fi

        shopt -s nullglob
        SOURCE_FILES=("$SOURCE_DIR"/*.md)
        shopt -u nullglob
        if [ "${#SOURCE_FILES[@]}" -eq 0 ]; then
            echo "  ${D}.apd/agents/ has no .md files — nothing to migrate.${R}"
            exit 0
        fi

        if [ "$DRY_RUN" = "1" ]; then
            echo "  ${V}DRY RUN${R} — no files written."
        else
            mkdir -p "$TARGET_DIR"
        fi

        MIGRATED=0
        SKIPPED=0
        for src in "${SOURCE_FILES[@]}"; do
            [ -f "$src" ] || continue
            name=$(basename "$src" .md)
            target="$TARGET_DIR/$name.toml"

            if [ -f "$target" ] && [ "$FORCE_MIG" != "1" ]; then
                echo "  ${D}skip${R}  $name (target exists; --force to overwrite)"
                SKIPPED=$((SKIPPED + 1))
                continue
            fi

            if [ "$DRY_RUN" = "1" ]; then
                echo "  ${G}would migrate${R}  $src → $target"
                MIGRATED=$((MIGRATED + 1))
                continue
            fi

            python3 - "$src" "$target" <<'PY'
import os, sys

src_path, tgt_path = sys.argv[1], sys.argv[2]
text = open(src_path).read()

if not text.startswith("---"):
    print(f"ERROR: {src_path} has no frontmatter", file=sys.stderr)
    sys.exit(1)
parts = text.split("\n---", 2)
if len(parts) < 2:
    print(f"ERROR: {src_path} has no closing ---", file=sys.stderr)
    sys.exit(1)
fm_block = parts[0].lstrip("-\n")
body = parts[1].lstrip("\n") if len(parts) >= 2 else ""

fm = {}
current_list = None
for line in fm_block.split("\n"):
    line = line.rstrip()
    if not line:
        current_list = None
        continue
    if current_list and line.startswith(("  - ", "    - ", "\t- ")):
        item = line.lstrip(" \t-").strip()
        fm[current_list].append(item)
        continue
    current_list = None
    if ":" not in line:
        continue
    key, _, val = line.partition(":")
    key, val = key.strip(), val.strip()
    if val == "":
        current_list = key
        fm[key] = []
    elif val.startswith("[") and val.endswith("]"):
        inner = val[1:-1].strip()
        items = [s.strip().strip('"').strip("'") for s in inner.split(",")] if inner else []
        fm[key] = items
    else:
        if (val.startswith('"') and val.endswith('"')) or (val.startswith("'") and val.endswith("'")):
            val = val[1:-1]
        fm[key] = val

def toml_string(s):
    s = str(s).replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")
    return f'"{s}"'

def toml_list(lst):
    return "[" + ", ".join(toml_string(s) for s in lst) + "]"

out = []
out.append(f'name = {toml_string(fm.get("name", os.path.basename(src_path).rsplit(".", 1)[0]))}')
if "description" in fm:
    out.append(f'description = {toml_string(fm["description"])}')
if "model" in fm:
    out.append(f'model = {toml_string(fm["model"])}')
if "model_reasoning_effort" in fm:
    out.append(f'model_reasoning_effort = {toml_string(fm["model_reasoning_effort"])}')

extension_lines = []
if "maxTurns" in fm:
    try:
        extension_lines.append(f'max_turns = {int(fm["maxTurns"])}')
    except (ValueError, TypeError):
        pass
if "scope" in fm and isinstance(fm["scope"], list):
    extension_lines.append(f'scope = {toml_list(fm["scope"])}')
if "readonly" in fm:
    rd = fm["readonly"]
    if isinstance(rd, str):
        rd = rd.lower() in ("true", "yes", "1")
    extension_lines.append(f'readonly = {"true" if rd else "false"}')

if extension_lines:
    out.append("")
    out.append("# APD extensions (not in documented Codex schema)")
    out.extend(extension_lines)

out.append("")
body_stripped = body.rstrip()
if '"""' in body_stripped:
    out.append("developer_instructions = '''")
    out.append(body_stripped)
    out.append("'''")
else:
    out.append('developer_instructions = """')
    out.append(body_stripped)
    out.append('"""')

with open(tgt_path, "w") as f:
    f.write("\n".join(out) + "\n")
PY
            if [ $? -eq 0 ]; then
                echo "  ${G}wrote${R}  $target"
                MIGRATED=$((MIGRATED + 1))
            else
                echo "  ${R}fail${R}  $name (see error above)"
            fi
        done

        echo ""
        echo "  Migrated: $MIGRATED  Skipped: $SKIPPED"
        if [ "$DRY_RUN" = "1" ]; then
            echo "  Re-run without --dry-run to apply."
        fi
        ;;
    help|--help|-h|"")
        echo ""
        echo "  ${V}apd cdx agents${R} — scaffold agent definitions into .apd/agents/"
        echo ""
        echo "  Subcommands:"
        echo "    list                     show available templates and installed agents"
        echo "    add <name> [scope ...]   copy a template into .apd/agents/<name>.md"
        echo "    migrate [--dry-run]      convert .apd/agents/*.md → .codex/agents/*.toml (C2)"
        echo ""
        echo "  Examples:"
        echo "    apd cdx agents list"
        echo "    apd cdx agents add code-reviewer"
        echo "    apd cdx agents add backend-builder src/ config/"
        echo "    apd cdx agents add testing tests/ src/test/"
        echo "    apd cdx agents migrate --dry-run"
        echo "    apd cdx agents migrate --force"
        echo ""
        echo "  Pass --force to overwrite an existing agent file or migration target."
        echo ""
        ;;
    *)
        echo "Unknown subcommand: $SUB" >&2
        echo "Run: apd cdx agents help" >&2
        exit 1
        ;;
esac
