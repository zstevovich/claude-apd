python3 - "$HOOKS_FILE" "$HOOK_LAUNCHER_Q track-subagent" "$SA_TMP" <<'PY'
import json
import sys
from pathlib import Path

hooks_path = Path(sys.argv[1])
command = sys.argv[2]
out_path = Path(sys.argv[3])

if hooks_path.exists():
    try:
        data = json.loads(hooks_path.read_text())
    except json.JSONDecodeError as exc:
        print(f"invalid JSON in {hooks_path}: {exc}", file=sys.stderr)
        raise SystemExit(1)
else:
    data = {}
if not isinstance(data, dict):
    raise SystemExit(1)
hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict):
    raise SystemExit(1)

desired = {"type": "command", "command": f"bash {command}", "timeout": 15}
changed = False
for event in ("SubagentStart", "SubagentStop"):
    entries = hooks.setdefault(event, [])
    if not isinstance(entries, list):
        print(f"{hooks_path}: hooks.{event} must be an array", file=sys.stderr)
        raise SystemExit(1)
    found = False
    stale = None
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        entry_hooks = entry.setdefault("hooks", [])
        if not isinstance(entry_hooks, list):
            raise SystemExit(1)
        for index, hook in enumerate(entry_hooks):
            if not isinstance(hook, dict):
                continue
            existing = hook.get("command", "")
            if existing == desired["command"]:
                found = True
                if hook != desired or entry.get("matcher") != "*":
                    entry_hooks[index] = desired
                    entry["matcher"] = "*"
                    changed = True
                break
            if "track-subagent" in existing:
                stale = (entry, entry_hooks, index)
        if found:
            break
    if not found:
        if stale is not None:
            stale[1][stale[2]] = desired
            stale[0]["matcher"] = "*"
        else:
            entries.append({"matcher": "*", "hooks": [desired]})
        changed = True

if not changed:
    print("skip")
    raise SystemExit(0)
out_path.write_text(json.dumps(data, indent=2) + "\n")
print("updated")
raise SystemExit(10)
