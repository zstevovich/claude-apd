#!/bin/bash
# apd cdx doctor — Codex-native health check for a pure-Codex APD project.
#
# Runs a runtime-aware audit of everything the Codex adapter needs:
#   - OS prerequisites (uv, python3, optional codex CLI)
#   - Global Codex config (~/.codex/config.toml) + codex_hooks feature flag
#   - Project-local .codex/ (config.toml, hooks.json, bin/apd shortcut)
#   - .apd/ content (config, rules, memory, agents, .apd-version)
#   - AGENTS.md at project root
#   - MCP server parses and exposes all expected tools
#
# Exit codes:
#   0  — no FAIL checks (may have WARN)
#   N  — N failed checks

set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

# Optional first positional argument: project path. If provided, cd there so
# resolve-project.sh resolves to that project instead of cwd.
# This lets `apd cdx doctor <project>` work from anywhere.
# Optional --fix flag: when version-mismatch detected, re-run install-codex-config
# against the latest installed plugin cache version.
FIX_MODE=false
POSITIONAL=()
while [ $# -gt 0 ]; do
    case "$1" in
        --fix) FIX_MODE=true; shift ;;
        --*)   shift ;;
        *)     POSITIONAL+=("$1"); shift ;;
    esac
done
if [ ${#POSITIONAL[@]} -ge 1 ] && [ -d "${POSITIONAL[0]}" ]; then
    cd "${POSITIONAL[0]}" || { echo "ERROR: cannot cd into ${POSITIONAL[0]}" >&2; exit 1; }
fi

source "$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

apd_header "Codex Runtime Doctor" "$PROJECT_DIR"

PASSES=0
FAILS=0
WARNS=0

_ok()   { pass "$1"; PASSES=$((PASSES + 1)); }
_bad()  { fail "$1"; FAILS=$((FAILS + 1)); }
_warn() { warn "$1"; WARNS=$((WARNS + 1)); }

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"

# -----------------------------------------------------------
# 1. Prerequisites
# -----------------------------------------------------------
section "Prerequisites"

if command -v uv >/dev/null 2>&1; then
    _ok "uv installed ($(uv --version 2>/dev/null | head -1))"
else
    _bad "uv not installed — MCP server cannot run. Install with: brew install uv"
fi

if command -v python3 >/dev/null 2>&1; then
    _ok "python3 ($(python3 --version 2>&1 | awk '{print $2}'))"
else
    _bad "python3 not found — required by MCP server"
fi

if command -v jq >/dev/null 2>&1; then
    _ok "jq ($(jq --version 2>/dev/null))"
else
    _bad "jq not found — Codex hook shim cannot parse Bash payload. Install with: brew install jq"
fi

if command -v codex >/dev/null 2>&1; then
    _ok "codex CLI ($(codex --version 2>/dev/null | head -1 || echo 'version unknown'))"
else
    _warn "codex CLI not on PATH — install to start sessions (framework works without it)"
fi

# -----------------------------------------------------------
# 2. Global Codex config
# -----------------------------------------------------------
section "Global Codex config ($CODEX_HOME)"

GLOBAL_CFG="$CODEX_HOME/config.toml"
if [ -f "$GLOBAL_CFG" ]; then
    _ok "global config.toml exists"
    if grep -qE '^\s*codex_hooks\s*=\s*true' "$GLOBAL_CFG" 2>/dev/null; then
        _ok "codex_hooks feature flag enabled"
    else
        _bad "codex_hooks feature flag NOT enabled — run: codex features enable codex_hooks"
    fi
    # Codex deprecated [features].collab in favor of [features].multi_agent.
    # Surface it so the user can silence the noisy startup warning.
    if grep -qE '^\s*collab\s*=' "$GLOBAL_CFG" 2>/dev/null; then
        _warn "[features].collab is deprecated — replace with multi_agent in $GLOBAL_CFG"
    fi
else
    _warn "$GLOBAL_CFG missing — Codex likely never started. First run: codex"
fi

# -----------------------------------------------------------
# 3. Project-local .codex/
# -----------------------------------------------------------
section "Project Codex setup (.codex/)"

CODEX_DIR="$PROJECT_DIR/.codex"
if [ ! -d "$CODEX_DIR" ]; then
    _bad ".codex/ missing — run: apd cdx init"
else
    _ok ".codex/ exists"

    CFG="$CODEX_DIR/config.toml"
    if [ ! -f "$CFG" ]; then
        _bad "$CFG missing — run: apd cdx init"
    else
        # v6.4 G1 — version-mismatch check. After `codex plugin marketplace upgrade`
        # the project's config.toml cwd often points at the prior plugin cache version
        # which the marketplace cleaned out, producing "MCP startup failed: No such
        # file or directory" on session start. Detect + offer recovery before falling
        # through to the generic config check (which would only report a generic mismatch).
        CFG_CWD=$(awk '
            /^\[mcp_servers\.apd\]/ { in_block = 1; next }
            /^\[/ && !/^\[mcp_servers\.apd\]/ { in_block = 0 }
            in_block && /^cwd[[:space:]]*=/ {
                sub(/^cwd[[:space:]]*=[[:space:]]*"/, "")
                sub(/"[[:space:]]*$/, "")
                print
                exit
            }
        ' "$CFG" 2>/dev/null)
        CACHE_BASE="$CODEX_HOME/plugins/cache/codex-apd/apd"
        if [ -n "$CFG_CWD" ] && [ -d "$CACHE_BASE" ]; then
            CFG_VER=$(echo "$CFG_CWD" | sed -nE 's|.*/cache/codex-apd/apd/([0-9]+\.[0-9]+\.[0-9]+).*|\1|p')
            LATEST_INSTALLED=$(ls -1 "$CACHE_BASE" 2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1)
            if [ -n "$CFG_VER" ] && [ -n "$LATEST_INSTALLED" ]; then
                if [ ! -d "$CACHE_BASE/$CFG_VER" ]; then
                    _bad "config.toml cwd points at v${CFG_VER} but that cache dir is gone (marketplace cleaned it). MCP will fail with 'No such file or directory'."
                    if [ "$FIX_MODE" = "true" ]; then
                        echo "    [--fix] regenerating config.toml against v${LATEST_INSTALLED}…" >&2
                        if "$CACHE_BASE/$LATEST_INSTALLED/bin/apd" cdx init "$PROJECT_DIR" >/dev/null 2>&1; then
                            _ok "config.toml regenerated against v${LATEST_INSTALLED} (restart Codex sessions to pick up)"
                        else
                            _bad "auto-fix failed — run manually: bash $CACHE_BASE/$LATEST_INSTALLED/bin/apd cdx init $PROJECT_DIR"
                        fi
                    else
                        echo "    Recovery: bash $CACHE_BASE/$LATEST_INSTALLED/bin/apd cdx init $PROJECT_DIR" >&2
                        echo "    Or re-run doctor with --fix to apply automatically." >&2
                    fi
                elif [ "$CFG_VER" != "$LATEST_INSTALLED" ]; then
                    _warn "config.toml cwd points at v${CFG_VER}, latest installed is v${LATEST_INSTALLED}. APD still works (old cache is intact) but project is on an older version. Run \`apd cdx init\` to migrate, or doctor --fix."
                    if [ "$FIX_MODE" = "true" ]; then
                        echo "    [--fix] regenerating config.toml against v${LATEST_INSTALLED}…" >&2
                        if "$CACHE_BASE/$LATEST_INSTALLED/bin/apd" cdx init "$PROJECT_DIR" >/dev/null 2>&1; then
                            _ok "config.toml regenerated against v${LATEST_INSTALLED}"
                        fi
                    fi
                fi
            fi
        fi

        MCP_CFG_STATUS="$(
python3 - "$CFG" "$APD_PLUGIN_ROOT" <<'PY'
import sys
from pathlib import Path

cfg = Path(sys.argv[1])
plugin_root = sys.argv[2]
tools = (
    "apd_ping", "apd_doctor", "apd_advance_pipeline", "apd_guard_write",
    "apd_verify_step", "apd_adversarial_pass", "apd_list_agents", "apd_pipeline_state",
)

sections = {}
current = None
for raw in cfg.read_text().splitlines():
    line = raw.strip()
    if line.startswith("[") and line.endswith("]"):
        current = line
        sections[current] = []
    elif current and line:
        sections[current].append(line)

server = sections.get("[mcp_servers.apd]", [])
required = {
    'command = "uv"',
    'args = ["run", "--with", "mcp", "--with", "tomli", "python", "mcp/apd_mcp_server.py"]',
    f'cwd = "{plugin_root}"',
}
missing_server = sorted(required - set(server))
missing_tools = [
    t for t in tools
    if 'approval_mode = "approve"' not in sections.get(f"[mcp_servers.apd.tools.{t}]", [])
]
if missing_server or missing_tools:
    details = []
    if missing_server:
        details.append("server: " + ", ".join(missing_server))
    if missing_tools:
        details.append("tools: " + ", ".join(missing_tools))
    print("; ".join(details))
    raise SystemExit(1)
PY
        )"
        if [ $? -eq 0 ]; then
            _ok "config.toml registers APD MCP server + 8 auto-approved tools"
        else
            _bad "config.toml APD MCP block incomplete or stale — run \`apd cdx init\` (${MCP_CFG_STATUS:-unknown mismatch})"
        fi
    fi

    PLUGIN_MCP="$APD_PLUGIN_ROOT/.mcp.json"
    if [ -f "$PLUGIN_MCP" ] && grep -q '"apd"' "$PLUGIN_MCP"; then
        _ok "plugin .mcp.json self-registers the APD MCP server fallback"
    else
        _bad "plugin .mcp.json missing at $PLUGIN_MCP — APD MCP tools will not load"
    fi

    HOOKS="$CODEX_DIR/hooks.json"
    if [ -f "$HOOKS" ] && grep -q 'guard-bash-scope' "$HOOKS"; then
        _ok "hooks.json wires PreToolUse Bash → guard-bash-scope"
        if command -v python3 >/dev/null && ! python3 -c "import json; json.load(open('$HOOKS'))" 2>/dev/null; then
            _bad "$HOOKS is not valid JSON"
        fi
    else
        _bad "$HOOKS missing or not wired to guard-bash-scope"
    fi

    if [ -f "$HOOKS" ] && grep -q 'guard-file-edit' "$HOOKS" && grep -q 'apply_patch|Edit|Write' "$HOOKS"; then
        _ok "hooks.json wires PreToolUse apply_patch/Edit/Write → guard-file-edit"
    else
        _bad "$HOOKS missing or not wired to guard-file-edit for apply_patch/Edit/Write"
    fi

    if [ -f "$HOOKS" ] && grep -q 'bin/adapter/cdx/session-start' "$HOOKS"; then
        _ok "hooks.json wires SessionStart → cdx session-start (TUI only; exec mode covered by MCP defaultPrompt)"
    else
        _warn "hooks.json has no SessionStart hook — TUI sessions will not get auto gap-analysis. Run: apd cdx init"
    fi

    SHORTCUT="$CODEX_DIR/bin/apd"
    if [ -x "$SHORTCUT" ] && grep -qF "$APD_PLUGIN_ROOT/bin/apd" "$SHORTCUT" 2>/dev/null; then
        _ok ".codex/bin/apd shortcut points to plugin entry"
    else
        _warn ".codex/bin/apd shortcut missing or stale — run apd cdx init or restart Codex (MCP bootstrap creates it)"
    fi
fi

# -----------------------------------------------------------
# 4. APD content (.apd/)
# -----------------------------------------------------------
section "APD content (.apd/)"

if [ -d "$CLAUDE_DIR" ]; then
    _warn ".claude/ present — hybrid project; Codex checks continue and CC-specific content is outside cdx doctor scope"
fi

APD_CFG="$PROJECT_DIR/.apd/config"
if [ -f "$APD_CFG" ]; then
    PROJ=$(grep '^PROJECT_NAME=' "$APD_CFG" 2>/dev/null | cut -d= -f2-)
    _ok ".apd/config (PROJECT_NAME=${PROJ:-?})"
elif [ -f "$CLAUDE_DIR/.apd-config" ]; then
    _ok ".claude/.apd-config (legacy CC activation marker)"
else
    _bad "no APD activation marker — run: apd cdx init"
fi

[ -f "$APD_RULES_DIR/workflow.md" ] && _ok "$APD_RULES_DIR/workflow.md" || _warn "$APD_RULES_DIR/workflow.md missing"

for f in MEMORY.md status.md session-log.md; do
    if [ -f "$APD_MEMORY_DIR/$f" ]; then
        _ok "$APD_MEMORY_DIR/$f"
    else
        _warn "$APD_MEMORY_DIR/$f missing"
    fi
done

if [ -d "$APD_AGENTS_DIR" ]; then
    AGENT_COUNT=$(find "$APD_AGENTS_DIR" -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "$AGENT_COUNT" -gt 0 ]; then
        _ok "$APD_AGENTS_DIR ($AGENT_COUNT agent file(s))"
    else
        _warn "$APD_AGENTS_DIR is empty — scaffold with: apd cdx agents add <name>"
    fi
else
    _warn "$APD_AGENTS_DIR missing — run: apd cdx init"
fi

# C2 migration availability hint (since v6.1.x Phase 2a/2b)
CODEX_AGENTS_DIR="$PROJECT_DIR/.codex/agents"
if [ -d "$APD_AGENTS_DIR" ]; then
    APD_MD_COUNT=$(find "$APD_AGENTS_DIR" -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
    CODEX_TOML_COUNT=0
    if [ -d "$CODEX_AGENTS_DIR" ]; then
        CODEX_TOML_COUNT=$(find "$CODEX_AGENTS_DIR" -maxdepth 1 -name '*.toml' -type f 2>/dev/null | wc -l | tr -d ' ')
    fi
    if [ "$APD_MD_COUNT" -gt 0 ] && [ "$CODEX_TOML_COUNT" -eq 0 ]; then
        _warn ".apd/agents/ has $APD_MD_COUNT .md agent(s) but .codex/agents/ is empty — run: apd cdx agents migrate"
    fi
fi

VER_FILE="$PROJECT_DIR/.apd/.apd-version"
if [ -f "$VER_FILE" ]; then
    _ok ".apd/.apd-version ($(tr -d '[:space:]' < "$VER_FILE"))"
else
    _warn ".apd/.apd-version missing (informational only)"
fi

# -----------------------------------------------------------
# 5. Project context
# -----------------------------------------------------------
section "Project context"

if [ -f "$PROJECT_DIR/AGENTS.md" ]; then
    if grep -q "apd_advance_pipeline" "$PROJECT_DIR/AGENTS.md" 2>/dev/null; then
        _ok "AGENTS.md at project root (references APD pipeline)"
    else
        _warn "AGENTS.md present but does not reference APD pipeline — orchestrator may miss the rules"
    fi
    MISSING_AGENTS_SECTIONS=""
    for section in "## Stack" "## APD" "### Pipeline" "### Guardrails" "### Mandatory skills" "### Human gate"; do
        if ! grep -q "^${section}$" "$PROJECT_DIR/AGENTS.md" 2>/dev/null; then
            MISSING_AGENTS_SECTIONS="${MISSING_AGENTS_SECTIONS}${section}, "
        fi
    done
    if [ -z "$MISSING_AGENTS_SECTIONS" ]; then
        _ok "AGENTS.md has required APD/Codex sections"
    else
        _warn "AGENTS.md missing sections: ${MISSING_AGENTS_SECTIONS%, }"
    fi
    if grep -q '<fill in>' "$PROJECT_DIR/AGENTS.md" 2>/dev/null; then
        _warn "AGENTS.md still contains <fill in> placeholders"
    fi
else
    _bad "AGENTS.md missing — Codex orchestrator has no project context. Run: apd cdx init"
fi

# -----------------------------------------------------------
# 6. MCP server
# -----------------------------------------------------------
section "MCP server"

MCP_PY="$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"
if [ -f "$MCP_PY" ]; then
    _ok "apd_mcp_server.py present"
    if command -v python3 >/dev/null && python3 -m py_compile "$MCP_PY" 2>/dev/null; then
        _ok "Python syntax parses cleanly"
    else
        _bad "apd_mcp_server.py does not parse — plugin install is corrupt"
    fi

    MISSING=""
    EXPECTED_TOOLS="apd_ping apd_doctor apd_advance_pipeline apd_guard_write apd_verify_step apd_adversarial_pass apd_list_agents apd_pipeline_state apd_pipeline_metrics"
    TOOL_COUNT=0
    for tool in $EXPECTED_TOOLS; do
        TOOL_COUNT=$((TOOL_COUNT + 1))
        if ! grep -qE "^def $tool\\b" "$MCP_PY"; then
            MISSING="${MISSING}${tool}, "
        fi
    done
    if [ -z "$MISSING" ]; then
        _ok "all $TOOL_COUNT MCP tools registered"
    else
        _bad "MCP tools missing: ${MISSING%, }"
    fi
else
    _bad "apd_mcp_server.py not found at $MCP_PY"
fi

# -----------------------------------------------------------
# 7. Plugin cache (stale-version detection)
# -----------------------------------------------------------
section "Plugin cache"

CODEX_PLUGIN_CACHE="$CODEX_HOME/plugins/cache"
case "$APD_PLUGIN_ROOT" in
    "$CODEX_PLUGIN_CACHE"/*)
        VERSION_PARENT=$(dirname "$APD_PLUGIN_ROOT")
        ACTIVE_BASENAME=$(basename "$APD_PLUGIN_ROOT")
        STALE_COUNT=0
        for sibling in "$VERSION_PARENT"/*/; do
            [ -d "$sibling" ] || continue
            sibling_name=$(basename "$sibling")
            [ "$sibling_name" = "$ACTIVE_BASENAME" ] && continue
            if [ "$STALE_COUNT" -eq 0 ]; then
                _warn "Stale Codex plugin cache versions detected:"
            fi
            sibling_size=$(du -sh "$sibling" 2>/dev/null | awk '{print $1}')
            sibling_path="${sibling%/}"
            echo "      $sibling_path ($sibling_size)"
            STALE_COUNT=$((STALE_COUNT + 1))
        done
        if [ "$STALE_COUNT" -eq 0 ]; then
            _ok "active version $ACTIVE_BASENAME is sole cached version"
        else
            echo "      Manual cleanup: rm -rf <stale paths above>"
            echo "      No Codex CLI command removes these (verified 2026-05-05)."
        fi
        ;;
    *)
        _ok "running from non-cache path (skip stale-version check)"
        ;;
esac

# -----------------------------------------------------------
# Summary
# -----------------------------------------------------------
echo ""
section "Summary"
echo "    ${G}PASS:${R} $PASSES  ${R}FAIL:${R} $FAILS  ${Y}WARN:${R} $WARNS"
echo ""

if [ "$FAILS" -eq 0 ]; then
    echo "  ${G}Codex adapter is ready.${R} Next: ${V}codex${R} (start a session and try \"run apd_ping\")."
    exit 0
else
    echo "  ${R}Codex adapter has problems — fix FAIL items above.${R}"
    exit "$FAILS"
fi
