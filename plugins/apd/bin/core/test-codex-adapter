# -----------------------------------------------------------
section "86. worktree config bootstrap (v6.18)"

WTB="$APD_PLUGIN_ROOT/bin/core/worktree-bootstrap"
WTB_RESOLVER="$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"

