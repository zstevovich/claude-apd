section "47. codex_hooks → hooks rename (v6.4 G2)"

H2_DIR="$(mktemp -d -t apd-h2.XXXXXX)"
H2_HOME="$(mktemp -d -t apd-h2home.XXXXXX)"
mkdir -p "$H2_DIR/.codex" "$H2_DIR/.apd" "$H2_HOME"
