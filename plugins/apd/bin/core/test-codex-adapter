import json, sys, re
from pathlib import Path

# Read the MCP server source and pull out the two helper functions by
# regex (no import of FastMCP required so this runs on any box with python3).
src = Path("$MCP").read_text()

def _extract(fn):
    m = re.search(r"(^def " + fn + r"\(.*?)(?=^def |^@mcp|\Z)", src, re.M | re.S)
    return m.group(1) if m else ""

globs: dict = {"Path": Path}
compiled = compile(_extract("_parse_agent_frontmatter") + "\n" + _extract("_agents_dir"),
                   "<mcp-helpers>", "exec")
# Use exec only on known-trusted source we just read from disk
exec(compiled, globs)  # noqa: S102 — loading our own source

adir = globs["_agents_dir"](Path("$LA"))
agents = []
for md in sorted(adir.glob("*.md")):
    fm = globs["_parse_agent_frontmatter"](md)
    agents.append(fm)

print(json.dumps({
    "agents_dir": str(adir),
    "count": len(agents),
    "names": [a.get("name") for a in agents],
    "scopes": [a.get("scope") for a in agents],
    "readonly_flags": [a.get("readonly") for a in agents],
}))
PY

