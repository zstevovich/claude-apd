#!/bin/bash
# APD Test Codex Adapter — E2E smoke test for the Codex runtime adapter
#
# Builds a throwaway project with a known agent set, runs install-codex-config,
# and verifies every enforcement layer:
#   1. MCP server: syntactically valid, all expected tools registered
#   2. plugin .mcp.json: self-registers MCP server; project config.toml carries
#      the full APD MCP override with per-tool approvals for Codex's TUI gate
#   3. hooks.json: PreToolUse Bash → guard-bash-scope
#   4. Idempotency: second run produces zero writes
#   5. Negative case: project without .codex/ dir doesn't trigger adapter
#   6. guard-scope: ALLOW and BLOCK both behave correctly
#   7. MCP Python helper: _project_dir() walks up to the right project root
#
# Standalone — does not require Codex CLI to be installed. Exercises the
# bash/Python surface the Codex runtime depends on.
#
# Usage: bash bin/core/test-codex-adapter
# Exit: 0 = pass, non-zero = number of failed checks

set -u

APD_PLUGIN_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
REPO_ROOT="$(cd "$APD_PLUGIN_ROOT/../.." && pwd)"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

apd_header "Codex Adapter E2E Test"

SCRATCH="$(mktemp -d -t apd-cdx-test.XXXXXX)"
trap 'rm -rf "$SCRATCH"' EXIT

FAILS=0
PASSES=0

_check() {
    local label="$1"; shift
    if "$@" >/dev/null 2>&1; then
        pass "$label"
        PASSES=$((PASSES + 1))
    else
        fail "$label"
        FAILS=$((FAILS + 1))
    fi
}

_check_file_contains() {
    local label="$1" file="$2" pattern="$3"
    if [ -f "$file" ] && grep -qE "$pattern" "$file"; then
        pass "$label"
        PASSES=$((PASSES + 1))
    else
        fail "$label (file=$file, pattern=$pattern)"
        FAILS=$((FAILS + 1))
    fi
}

# -----------------------------------------------------------
# 1. MCP server surface
# -----------------------------------------------------------
section "1. MCP server"

_check "apd_mcp_server.py exists" test -f "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"
_check "Python syntax valid" python3 -m py_compile "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"

EXPECTED_TOOLS=(apd_ping apd_doctor apd_advance_pipeline apd_guard_write apd_verify_step apd_adversarial_pass apd_list_agents apd_pipeline_state)
for tool in "${EXPECTED_TOOLS[@]}"; do
    _check_file_contains "tool '$tool' registered" "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py" "^def $tool\b"
done

# -----------------------------------------------------------
# 2. Scaffold a PURE-CODEX scratch project (no .claude/)
# -----------------------------------------------------------
section "2. Scratch project scaffold (pure Codex)"

mkdir -p "$SCRATCH/.codex"

_check "scratch dir has .codex" test -d "$SCRATCH/.codex"
_check "scratch dir has NO .claude/" test ! -e "$SCRATCH/.claude"

# -----------------------------------------------------------
# 3. First install-codex-config run — writes everything
# -----------------------------------------------------------
section "3. install-codex-config (first run)"

FIRST_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$SCRATCH" 2>&1)"
FIRST_EXIT=$?

[ "$FIRST_EXIT" -eq 0 ] && pass "exit code 0" && PASSES=$((PASSES + 1)) || { fail "exit code was $FIRST_EXIT"; FAILS=$((FAILS + 1)); }

echo "$FIRST_OUT" | grep -q "\[wrote\] \[mcp_servers.apd\]" && pass "wrote APD MCP block with tool approvals" && PASSES=$((PASSES + 1)) || { fail "fresh install did not write APD MCP block"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "per-agent sandbox profiles skipped" && pass "sandbox profiles deferred (MCP guard-scope path)" && PASSES=$((PASSES + 1)) || { fail "sandbox skip notice missing"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "PreToolUse Bash hook" && pass "wrote hooks.json" && PASSES=$((PASSES + 1)) || { fail "no hooks.json written"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "PreToolUse file-edit hook" && pass "wrote file-edit hook" && PASSES=$((PASSES + 1)) || { fail "no file-edit hook written"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "SessionStart hook" && pass "wrote SessionStart hook" && PASSES=$((PASSES + 1)) || { fail "no SessionStart hook written"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "\.codex/bin/apd shortcut" && pass "wrote .codex/bin/apd shortcut" && PASSES=$((PASSES + 1)) || { fail "no apd shortcut created"; FAILS=$((FAILS + 1)); }
_check ".codex/bin/apd is executable" test -x "$SCRATCH/.codex/bin/apd"
echo "$FIRST_OUT" | grep -q "\.apd/config seed" && pass "seeded .apd/config (pure-Codex activation)" && PASSES=$((PASSES + 1)) || { fail "no .apd/config seed emitted"; FAILS=$((FAILS + 1)); }
_check ".apd/config exists" test -f "$SCRATCH/.apd/config"
_check "did NOT create .claude/ anywhere" test ! -e "$SCRATCH/.claude"
_check ".apd/rules/workflow.md scaffolded" test -f "$SCRATCH/.apd/rules/workflow.md"
_check ".apd/rules/brainstorm.md scaffolded" test -f "$SCRATCH/.apd/rules/brainstorm.md"
_check ".apd/rules/tdd.md scaffolded" test -f "$SCRATCH/.apd/rules/tdd.md"
_check ".apd/rules/debug.md scaffolded" test -f "$SCRATCH/.apd/rules/debug.md"
_check ".apd/rules/finish.md scaffolded" test -f "$SCRATCH/.apd/rules/finish.md"
if [ -f "$SCRATCH/.apd/rules/workflow.md" ] && ! grep -q '\.claude/bin/apd' "$SCRATCH/.apd/rules/workflow.md"; then
    pass "scaffolded workflow.md has no .claude/bin/apd references"
    PASSES=$((PASSES + 1))
else
    fail "scaffolded workflow.md still references .claude/bin/apd"
    FAILS=$((FAILS + 1))
fi
if grep -q '\.codex/bin/apd' "$SCRATCH/.apd/rules/workflow.md" 2>/dev/null; then
    pass "scaffolded workflow.md uses .codex/bin/apd"
    PASSES=$((PASSES + 1))
else
    fail "scaffolded workflow.md missing .codex/bin/apd references"
    FAILS=$((FAILS + 1))
fi
_check ".apd/memory/MEMORY.md scaffolded" test -f "$SCRATCH/.apd/memory/MEMORY.md"
_check ".apd/memory/status.md scaffolded" test -f "$SCRATCH/.apd/memory/status.md"
_check ".apd/memory/session-log.md scaffolded" test -f "$SCRATCH/.apd/memory/session-log.md"
_check ".apd/agents/ scaffolded" test -d "$SCRATCH/.apd/agents"
_check ".apd/.apd-version scaffolded" test -f "$SCRATCH/.apd/.apd-version"
_check "AGENTS.md scaffolded at project root" test -f "$SCRATCH/AGENTS.md"
_check_file_contains "AGENTS.md references APD pipeline" "$SCRATCH/AGENTS.md" 'apd_advance_pipeline'
_check_file_contains "AGENTS.md has project name substituted" "$SCRATCH/AGENTS.md" "^# $(basename "$SCRATCH")$"
for section in "## Stack" "## APD" "### Pipeline" "### Guardrails" "### Mandatory skills" "### Human gate"; do
    _check_file_contains "AGENTS.md has $section" "$SCRATCH/AGENTS.md" "^$section$"
done
if grep -q '<fill in>' "$SCRATCH/AGENTS.md" 2>/dev/null; then
    fail "AGENTS.md still contains <fill in> placeholders"
    FAILS=$((FAILS + 1))
else
    pass "AGENTS.md has no <fill in> placeholders"
    PASSES=$((PASSES + 1))
fi
! grep -q "^\[permissions\." "$SCRATCH/.codex/config.toml" && pass "no broken [permissions.*] blocks emitted" && PASSES=$((PASSES + 1)) || { fail "broken permissions blocks present"; FAILS=$((FAILS + 1)); }

# -----------------------------------------------------------
# 4. Generated file content
# -----------------------------------------------------------
section "4. Generated file content"

CFG="$SCRATCH/.codex/config.toml"
HOOKS="$SCRATCH/.codex/hooks.json"

# v6.0+: plugin .mcp.json self-registers the server, but Codex 0.125 does
# not honor plugin-shipped approval_mode. Project config.toml therefore
# carries a full APD server override plus per-tool approvals.
PLUGIN_MCP_JSON="$APD_PLUGIN_ROOT/.mcp.json"
_check "plugins/apd/.mcp.json exists (self-registration manifest)" test -f "$PLUGIN_MCP_JSON"
if [ -f "$PLUGIN_MCP_JSON" ]; then
    _check "plugin .mcp.json is valid JSON" python3 -c "import json; json.load(open('$PLUGIN_MCP_JSON'))"
    _check_file_contains "plugin .mcp.json declares apd MCP server" "$PLUGIN_MCP_JSON" '"apd"'
    _check_file_contains "plugin .mcp.json uses cwd: \".\" (resolves to plugin root)" "$PLUGIN_MCP_JSON" '"cwd": "\."'
    _check_file_contains "plugin .mcp.json points at mcp/apd_mcp_server.py" "$PLUGIN_MCP_JSON" 'mcp/apd_mcp_server\.py'
    # Per-tool auto-approval — Codex has no server-wide default, every tool
    # must be listed explicitly. v6.0 carries this in plugin .mcp.json.
    for _t in apd_ping apd_doctor apd_advance_pipeline apd_guard_write \
             apd_verify_step apd_adversarial_pass apd_list_agents apd_pipeline_state; do
        _check_file_contains "plugin .mcp.json auto-approves $_t" "$PLUGIN_MCP_JSON" "\"$_t\""
    done
fi
_check_file_contains "config.toml has APD MCP server block" "$CFG" '^\[mcp_servers\.apd\]$'
_check_file_contains "config.toml APD command uses uv" "$CFG" '^command = "uv"$'
_check_file_contains "config.toml APD args use relative plugin MCP path" "$CFG" 'args = \["run", "--with", "mcp", "python", "mcp/apd_mcp_server\.py"\]'
if grep -qF "cwd = \"$APD_PLUGIN_ROOT\"" "$CFG" 2>/dev/null; then
    pass "config.toml APD cwd points at plugin root"
    PASSES=$((PASSES + 1))
else
    fail "config.toml APD cwd missing or stale"
    FAILS=$((FAILS + 1))
fi
for _t in apd_ping apd_doctor apd_advance_pipeline apd_guard_write \
         apd_verify_step apd_adversarial_pass apd_list_agents apd_pipeline_state; do
    _check_file_contains "config.toml auto-approves $_t" "$CFG" "^\\[mcp_servers\\.apd\\.tools\\.$_t\\]$"
done
if [ "$(grep -c '^approval_mode = "approve"$' "$CFG" 2>/dev/null | tr -d ' ')" = "8" ]; then
    pass "config.toml has exactly 8 APD approval_mode entries"
    PASSES=$((PASSES + 1))
else
    fail "config.toml approval_mode entry count is not 8"
    FAILS=$((FAILS + 1))
fi
_check_file_contains "hooks.json has PreToolUse" "$HOOKS" 'PreToolUse'
_check_file_contains "hooks.json routes to guard-bash-scope" "$HOOKS" 'guard-bash-scope'
_check_file_contains "hooks.json routes file edits to guard-file-edit" "$HOOKS" 'guard-file-edit'
_check_file_contains "hooks.json matches apply_patch/Edit/Write" "$HOOKS" 'apply_patch\|Edit\|Write'
_check_file_contains "hooks.json has SessionStart" "$HOOKS" 'SessionStart'
_check_file_contains "hooks.json routes SessionStart to adapter" "$HOOKS" 'bin/adapter/cdx/session-start'
_check "session-start script is executable" test -x "$APD_PLUGIN_ROOT/bin/adapter/cdx/session-start"
_check_file_contains "Codex plugin manifest mentions apd_doctor at session start" \
    "$APD_PLUGIN_ROOT/.codex-plugin/plugin.json" 'apd_doctor'
_check_file_contains ".apd/config has PROJECT_NAME" "$SCRATCH/.apd/config" '^PROJECT_NAME='

if command -v python3 &>/dev/null; then
    if [ -f "$CFG" ]; then
        _check "TOML parses cleanly" python3 -c "import tomllib; tomllib.load(open('$CFG','rb'))"
    fi
    _check "JSON parses cleanly" python3 -c "import json; json.load(open('$HOOKS'))"
else
    warn "python3 not found — skipping strict TOML/JSON parse checks"
fi

# -----------------------------------------------------------
# 4b. Repair existing config + merge existing hooks
# -----------------------------------------------------------
section "4b. Repair + merge behavior"

REPAIR="$(mktemp -d -t apd-cdx-repair.XXXXXX)"
mkdir -p "$REPAIR/.codex"
cat > "$REPAIR/.codex/config.toml" <<'EOF'
[mcp_servers.apd]
command = "uv"
args = ["run", "--with", "mcp", "python", "/tmp/stale/apd_mcp_server.py"]
EOF
cat > "$REPAIR/.codex/hooks.json" <<'EOF'
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /custom/other-hook",
            "timeout": 9
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /custom/post-hook",
            "timeout": 9
          }
        ]
      }
    ]
  }
}
EOF

REPAIR_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$REPAIR" 2>&1)"
if echo "$REPAIR_OUT" | grep -q "\[updated\] \[mcp_servers.apd\]"; then
    pass "installer repairs stale [mcp_servers.apd] block"
    PASSES=$((PASSES + 1))
else
    fail "installer did not report APD MCP block repair"
    FAILS=$((FAILS + 1))
fi

if grep -q '^\[mcp_servers\.apd\]' "$REPAIR/.codex/config.toml" 2>/dev/null && \
   grep -qF 'args = ["run", "--with", "mcp", "python", "mcp/apd_mcp_server.py"]' "$REPAIR/.codex/config.toml" 2>/dev/null && \
   grep -qF "cwd = \"$APD_PLUGIN_ROOT\"" "$REPAIR/.codex/config.toml" 2>/dev/null; then
    pass "config.toml carries repaired APD MCP block"
    PASSES=$((PASSES + 1))
else
    fail "config.toml APD MCP block was not repaired"
    FAILS=$((FAILS + 1))
fi

if echo "$REPAIR_OUT" | grep -q "\[updated\] PreToolUse Bash hook"; then
    pass "installer merged APD hook into existing hooks.json"
    PASSES=$((PASSES + 1))
else
    fail "installer did not report hooks.json merge"
    FAILS=$((FAILS + 1))
fi

if grep -qF '/custom/other-hook' "$REPAIR/.codex/hooks.json" 2>/dev/null; then
    pass "existing Bash hook preserved during merge"
    PASSES=$((PASSES + 1))
else
    fail "existing Bash hook was lost during merge"
    FAILS=$((FAILS + 1))
fi

if grep -qF '/custom/post-hook' "$REPAIR/.codex/hooks.json" 2>/dev/null; then
    pass "non-PreToolUse hooks preserved during merge"
    PASSES=$((PASSES + 1))
else
    fail "non-PreToolUse hooks were lost during merge"
    FAILS=$((FAILS + 1))
fi

if grep -qF "$APD_PLUGIN_ROOT/bin/adapter/cdx/guard-bash-scope" "$REPAIR/.codex/hooks.json" 2>/dev/null; then
    pass "APD Bash hook present after merge"
    PASSES=$((PASSES + 1))
else
    fail "APD Bash hook missing after merge"
    FAILS=$((FAILS + 1))
fi

if grep -qF "$APD_PLUGIN_ROOT/bin/adapter/cdx/guard-file-edit" "$REPAIR/.codex/hooks.json" 2>/dev/null && \
   grep -qF 'apply_patch|Edit|Write' "$REPAIR/.codex/hooks.json" 2>/dev/null; then
    pass "APD file-edit hook present after merge"
    PASSES=$((PASSES + 1))
else
    fail "APD file-edit hook missing after merge"
    FAILS=$((FAILS + 1))
fi

if grep -qF "$APD_PLUGIN_ROOT/bin/adapter/cdx/session-start" "$REPAIR/.codex/hooks.json" 2>/dev/null; then
    pass "APD SessionStart hook merged alongside existing PreToolUse/PostToolUse"
    PASSES=$((PASSES + 1))
else
    fail "APD SessionStart hook missing after merge"
    FAILS=$((FAILS + 1))
fi

rm -rf "$REPAIR"

# -----------------------------------------------------------
# 4c. Hybrid project install — Codex-native artifacts must still appear
#     when .claude/ exists (AGENTS.md + .apd/rules/{brainstorm,tdd,debug,
#     finish}.md), and CC-native duplicates must be skipped.
# -----------------------------------------------------------
section "4c. Hybrid project Codex-native artifacts"

HYBRID="$(mktemp -d -t apd-hybrid.XXXXXX)"
mkdir -p "$HYBRID/.claude/agents" "$HYBRID/.codex"
echo '{"name":"existing"}' > "$HYBRID/.claude/agents/code-reviewer.md"
bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$HYBRID" >/dev/null 2>&1

if [ -f "$HYBRID/AGENTS.md" ]; then
    pass "hybrid install writes AGENTS.md (Codex orchestrator context)"
    PASSES=$((PASSES + 1))
else
    fail "hybrid install did NOT write AGENTS.md — Codex orchestrator left without project context"
    FAILS=$((FAILS + 1))
fi

ALL_RULES=1
for rule in brainstorm tdd debug finish; do
    [ -f "$HYBRID/.apd/rules/$rule.md" ] || ALL_RULES=0
done
if [ "$ALL_RULES" -eq 1 ]; then
    pass "hybrid install writes all 4 Codex-native phase rules"
    PASSES=$((PASSES + 1))
else
    fail "hybrid install did NOT write all phase rules — Codex orchestrator can't enter phases"
    FAILS=$((FAILS + 1))
fi

# CC-native duplicates must NOT be created on hybrid (CC owns those paths)
if [ ! -e "$HYBRID/.apd/memory" ] && [ ! -e "$HYBRID/.apd/agents" ]; then
    pass "hybrid install skips CC-native duplicates (.apd/memory, .apd/agents)"
    PASSES=$((PASSES + 1))
else
    fail "hybrid install created CC-native duplicates that should live under .claude/"
    FAILS=$((FAILS + 1))
fi

# Re-run must be idempotent (no double-writes)
SECOND="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$HYBRID" 2>&1)"
if ! echo "$SECOND" | grep -q '\[wrote\] AGENTS.md'; then
    pass "hybrid re-install does not overwrite existing AGENTS.md"
    PASSES=$((PASSES + 1))
else
    fail "hybrid re-install overwrote AGENTS.md"
    FAILS=$((FAILS + 1))
fi
if ! echo "$SECOND" | grep -qE '\[wrote\] \.apd/rules/(brainstorm|tdd|debug|finish)\.md'; then
    pass "hybrid re-install does not rewrite existing phase rules"
    PASSES=$((PASSES + 1))
else
    fail "hybrid re-install rewrote existing phase rules"
    FAILS=$((FAILS + 1))
fi

rm -rf "$HYBRID"

# -----------------------------------------------------------
# 5. Idempotency — second run produces no writes
# -----------------------------------------------------------
section "5. Idempotency"

SECOND_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$SCRATCH" 2>&1)"

if echo "$SECOND_OUT" | grep -q "\[wrote\]"; then
    fail "second run wrote something — not idempotent"
    FAILS=$((FAILS + 1))
else
    pass "second run produced zero writes"
    PASSES=$((PASSES + 1))
fi

if echo "$SECOND_OUT" | grep -q "already up to date"; then
    pass "second run reports 'already up to date'"
    PASSES=$((PASSES + 1))
else
    fail "second run missing 'already up to date'"
    FAILS=$((FAILS + 1))
fi

# -----------------------------------------------------------
# 6. guard-scope ALLOW + BLOCK behavior
# -----------------------------------------------------------
section "6. guard-scope enforcement"

# APD activation relies on .apd/config, which the installer seeded above.
# No need to touch .claude/ for a pure-Codex project.
if (cd "$SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-scope" --file-path "src/foo.ts" "src/" >/dev/null 2>&1); then
    pass "ALLOW: src/foo.ts with allowed=src/"
    PASSES=$((PASSES + 1))
else
    fail "src/foo.ts should have been allowed"
    FAILS=$((FAILS + 1))
fi

(cd "$SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-scope" --file-path "/tmp/escape.ts" "src/" >/dev/null 2>&1)
case $? in
    2) pass "BLOCK: /tmp/escape.ts rejected (exit 2)" ; PASSES=$((PASSES + 1)) ;;
    *) fail "BLOCK test did not return exit 2 (got $?)"; FAILS=$((FAILS + 1)) ;;
esac

(cd "$SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-bash-scope" --command 'python3 -c "open(\".apd/pipeline/.guarded-writes\", \"w\").write(\"forged\")"' >/dev/null 2>&1)
case $? in
    2) pass "BLOCK: runtime write to .apd/pipeline rejected (exit 2)" ; PASSES=$((PASSES + 1)) ;;
    *) fail "runtime pipeline write did not return exit 2 (got $?)"; FAILS=$((FAILS + 1)) ;;
esac

# -----------------------------------------------------------
# 6b. apd_guard_write server-side registry enforcement
#     (scope comes from .apd/agents/<role>.md, not from client args)
# -----------------------------------------------------------
section "6b. apd_guard_write registry"

GUARD_SCRATCH="$(mktemp -d -t apd-guard.XXXXXX)"
mkdir -p "$GUARD_SCRATCH/.apd/agents" "$GUARD_SCRATCH/.apd/pipeline" "$GUARD_SCRATCH/src"
cat > "$GUARD_SCRATCH/.apd/config" <<'EOF'
PROJECT_NAME=guard-registry
APD_VERSION=test
STACK=test
EOF
cat > "$GUARD_SCRATCH/.apd/agents/backend-builder.md" <<'EOF'
---
name: backend-builder
description: Backend scope test
scope:
  - src/
  - config/
---
Backend builder role body.
EOF
cat > "$GUARD_SCRATCH/.apd/agents/code-reviewer.md" <<'EOF'
---
name: code-reviewer
description: Read-only reviewer
readonly: true
---
Reviewer role body.
EOF

GUARD_OUT="$(cd "$GUARD_SCRATCH" && python3 - <<PY
import sys, types, json
mcp_mod = types.ModuleType("mcp")
server_mod = types.ModuleType("mcp.server")
fastmcp_mod = types.ModuleType("mcp.server.fastmcp")
class DummyFastMCP:
    def __init__(self,*_a,**_kw): pass
    def tool(self,*_a,**_kw):
        def d(fn): return fn
        return d
    def run(self): return None
fastmcp_mod.FastMCP = DummyFastMCP
server_mod.fastmcp = fastmcp_mod
mcp_mod.server = server_mod
sys.modules["mcp"] = mcp_mod
sys.modules["mcp.server"] = server_mod
sys.modules["mcp.server.fastmcp"] = fastmcp_mod
sys.path.insert(0, "$APD_PLUGIN_ROOT/mcp")
import apd_mcp_server as m
out = {
    "allow_in_scope":   m.apd_guard_write("backend-builder", "src/api/users.py"),
    "block_out_scope":  m.apd_guard_write("backend-builder", "/etc/passwd"),
    "readonly_blocks":  m.apd_guard_write("code-reviewer", "src/api/users.py"),
    "unknown_role":     m.apd_guard_write("does-not-exist", "src/foo.py"),
    "missing_role":     m.apd_guard_write("", "src/foo.py"),
}
print(json.dumps({k: {"ok": v.get("ok"), "exit_code": v.get("exit_code"), "error": v.get("error")} for k,v in out.items()}))
PY
)"

if echo "$GUARD_OUT" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); sys.exit(0 if d['allow_in_scope']['ok'] is True else 1)"; then
    pass "registry ALLOW: scope from .apd/agents/backend-builder.md matches target"
    PASSES=$((PASSES + 1))
else
    fail "registry ALLOW did not succeed for in-scope target"
    FAILS=$((FAILS + 1))
fi

if echo "$GUARD_OUT" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); sys.exit(0 if d['block_out_scope'].get('exit_code') == 2 else 1)"; then
    pass "registry BLOCK: out-of-scope target rejected with exit 2"
    PASSES=$((PASSES + 1))
else
    fail "registry BLOCK did not return exit 2 for /etc/passwd"
    FAILS=$((FAILS + 1))
fi

if echo "$GUARD_OUT" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); sys.exit(0 if d['readonly_blocks'].get('exit_code') == 2 else 1)"; then
    pass "readonly role (code-reviewer) cannot write at all"
    PASSES=$((PASSES + 1))
else
    fail "readonly role did not block writes"
    FAILS=$((FAILS + 1))
fi

if echo "$GUARD_OUT" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); sys.exit(0 if 'unknown apd_role' in (d['unknown_role'].get('error') or '') else 1)"; then
    pass "unknown apd_role returns explicit error (no silent ALLOW)"
    PASSES=$((PASSES + 1))
else
    fail "unknown apd_role did not return 'unknown apd_role' error"
