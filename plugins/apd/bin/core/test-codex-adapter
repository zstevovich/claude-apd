# v6.1 B1 pre-flight gate: adversarial pass requires reviewer.done +
# .adversarial-pending to be present. Seed both so this section keeps
# testing only the empty-pass loophole guard.
echo "$(date +%s)" > "$ADV_DIR/.apd/pipeline/reviewer.done"
echo "$(date +%s)" > "$ADV_DIR/.apd/pipeline/.adversarial-pending"

ADV_OUT="$(cd "$ADV_DIR" && python3 - <<PY
import sys, types, json
mcp_mod = types.ModuleType("mcp")
server_mod = types.ModuleType("mcp.server")
fastmcp_mod = types.ModuleType("mcp.server.fastmcp")
class DummyFastMCP:
    def __init__(self,*_a,**_kw): pass
    def tool(self,*_a,**_kw):
        def d(fn): return fn
        return d
    def run(self): return None
fastmcp_mod.FastMCP = DummyFastMCP
server_mod.fastmcp = fastmcp_mod
mcp_mod.server = server_mod
sys.modules["mcp"] = mcp_mod
sys.modules["mcp.server"] = server_mod
sys.modules["mcp.server.fastmcp"] = fastmcp_mod
sys.path.insert(0, "$APD_PLUGIN_ROOT/mcp")
import apd_mcp_server as m

LONG = "Reviewed regressions in router and templates, checked migration ordering and idempotency, traced concurrent write paths in NavigationRepository, examined SQL injection surface on filter inputs, considered HTML escaping in main-nav partial. Nothing flagged."

results = {
    "empty_no_notes": m.apd_adversarial_pass(0, 0, 0),
    "empty_short_notes": m.apd_adversarial_pass(0, 0, 0, "looks fine"),
    "empty_long_notes": m.apd_adversarial_pass(0, 0, 0, LONG),
    "real_no_notes": m.apd_adversarial_pass(3, 2, 1),
    "real_with_notes": m.apd_adversarial_pass(2, 1, 1, "Found N+1 query in nav loader; the deletion cascade is also racy under concurrent writes."),
    "negative_count": m.apd_adversarial_pass(-1, 0, 0),
    "imbalanced": m.apd_adversarial_pass(2, 5, 0),
}
print(json.dumps({k: {"ok": v.get("ok"), "error": v.get("error","")} for k,v in results.items()}))
PY
)"

# Cases that MUST be rejected
for case in empty_no_notes empty_short_notes negative_count imbalanced; do
    if echo "$ADV_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
sys.exit(0 if d['$case']['ok'] is False else 1)
"; then
        pass "rejected: $case"
        PASSES=$((PASSES + 1))
    else
        fail "$case was NOT rejected (would let bypass through)"
        FAILS=$((FAILS + 1))
    fi
done

# Cases that MUST be accepted
for case in empty_long_notes real_no_notes real_with_notes; do
    if echo "$ADV_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
sys.exit(0 if d['$case']['ok'] is True else 1)
"; then
        pass "accepted: $case"
        PASSES=$((PASSES + 1))
    else
        fail "$case was rejected when it should have been accepted"
        FAILS=$((FAILS + 1))
    fi
done

# When notes provided, summary file must contain them so the audit trail survives
SUMMARY_FILE="$ADV_DIR/.apd/pipeline/.adversarial-summary"
if [ -f "$SUMMARY_FILE" ] && grep -q "^Notes:" "$SUMMARY_FILE" && grep -q "N+1 query" "$SUMMARY_FILE"; then
    pass "notes are persisted into .adversarial-summary for audit"
    PASSES=$((PASSES + 1))
else
    fail "notes missing from .adversarial-summary"
    FAILS=$((FAILS + 1))
fi

# Error message must steer the model toward the right action
if echo "$ADV_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
err = d['empty_no_notes']['error']
sys.exit(0 if all(k in err for k in ['regressions', 'concurrency', 'rubber-stamp']) else 1)
"; then
    pass "rejection message names review categories + warns about rubber-stamp"
    PASSES=$((PASSES + 1))
else
    fail "rejection message is too generic — would not steer the model"
    FAILS=$((FAILS + 1))
fi

rm -rf "$ADV_DIR"

# -----------------------------------------------------------
# 20c. apd_verify_step scope parameter (fast vs full)
#      - default scope="full"; invalid scope rejected
#      - scope="fast" exposes APD_VERIFY_SCOPE=fast to verify-all.sh
# -----------------------------------------------------------
section "20c. apd_verify_step scope"

VS_DIR="$(mktemp -d -t apd-vs.XXXXXX)"
mkdir -p "$VS_DIR/.codex/bin" "$VS_DIR/.apd/pipeline"
# Dummy verify-all.sh that echoes the scope seen in its environment.
cat > "$VS_DIR/.codex/bin/verify-all.sh" <<'VSH'
#!/bin/bash
echo "APD_VERIFY_SCOPE=${APD_VERIFY_SCOPE:-unset}"
exit 0
VSH
chmod +x "$VS_DIR/.codex/bin/verify-all.sh"

VS_OUT="$(APD_PROJECT_DIR="$VS_DIR" python3 - <<PY
import sys, types, json
mcp_mod = types.ModuleType("mcp")
server_mod = types.ModuleType("mcp.server")
fastmcp_mod = types.ModuleType("mcp.server.fastmcp")
class DummyFastMCP:
    def __init__(self,*_a,**_kw): pass
    def tool(self,*_a,**_kw):
        def d(fn): return fn
        return d
    def run(self): return None
fastmcp_mod.FastMCP = DummyFastMCP
server_mod.fastmcp = fastmcp_mod
mcp_mod.server = server_mod
sys.modules["mcp"] = mcp_mod
sys.modules["mcp.server"] = server_mod
sys.modules["mcp.server.fastmcp"] = fastmcp_mod
sys.path.insert(0, "$APD_PLUGIN_ROOT/mcp")
import apd_mcp_server as m

results = {
    "default":    m.apd_verify_step(),
    "full":       m.apd_verify_step(scope="full"),
    "fast":       m.apd_verify_step(scope="fast"),
    "invalid":    m.apd_verify_step(scope="deep"),
    "empty":      m.apd_verify_step(scope=""),
}
# Slim down to json-friendly shape — stdout is what we check for the env var
print(json.dumps({
    k: {"ok": v.get("ok"), "scope": v.get("scope"), "error": v.get("error",""), "stdout": (v.get("stdout") or "").strip()}
    for k, v in results.items()
}))
PY
)"

if echo "$VS_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
sys.exit(0 if d['default']['ok'] is True and d['default']['scope'] == 'full' and 'APD_VERIFY_SCOPE=full' in d['default']['stdout'] else 1)
" 2>/dev/null; then
    pass "default scope is 'full' and reaches verify-all.sh as env var"
    PASSES=$((PASSES + 1))
else
    fail "default scope did not resolve to 'full': $VS_OUT"
    FAILS=$((FAILS + 1))
fi

if echo "$VS_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
sys.exit(0 if d['fast']['ok'] is True and d['fast']['scope'] == 'fast' and 'APD_VERIFY_SCOPE=fast' in d['fast']['stdout'] else 1)
" 2>/dev/null; then
    pass "scope='fast' passes APD_VERIFY_SCOPE=fast to verify-all.sh"
    PASSES=$((PASSES + 1))
else
    fail "scope='fast' did not propagate: $VS_OUT"
    FAILS=$((FAILS + 1))
fi

if echo "$VS_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
ok = d['invalid']['ok'] is False and 'invalid scope' in (d['invalid']['error'] or '') and d['empty']['ok'] is True and d['empty']['scope'] == 'full'
sys.exit(0 if ok else 1)
" 2>/dev/null; then
    pass "invalid scope rejected, empty scope falls back to 'full'"
    PASSES=$((PASSES + 1))
else
    fail "scope validation not behaving correctly: $VS_OUT"
    FAILS=$((FAILS + 1))
fi

rm -rf "$VS_DIR"

# Framework-fallback path: no project-local verify-all.sh, so apd_verify_step
# drops to bin/core/verify-all. APD_VERIFY_SCOPE must reach that script too —
# otherwise scope="fast" silently degrades to full on the fallback path.
VS_FB="$(mktemp -d -t apd-vs-fb.XXXXXX)"
mkdir -p "$VS_FB/.codex"
VS_FB_OUT="$(APD_PROJECT_DIR="$VS_FB" python3 - <<PY
import sys, types, json, os
mcp_mod = types.ModuleType("mcp")
server_mod = types.ModuleType("mcp.server")
fastmcp_mod = types.ModuleType("mcp.server.fastmcp")
class DummyFastMCP:
    def __init__(self,*_a,**_kw): pass
    def tool(self,*_a,**_kw):
        def d(fn): return fn
        return d
    def run(self): return None
fastmcp_mod.FastMCP = DummyFastMCP
server_mod.fastmcp = fastmcp_mod
mcp_mod.server = server_mod
sys.modules["mcp"] = mcp_mod
sys.modules["mcp.server"] = server_mod
sys.modules["mcp.server.fastmcp"] = fastmcp_mod
sys.path.insert(0, "$APD_PLUGIN_ROOT/mcp")
import apd_mcp_server as m
# Intercept _run_core to capture the env_extra that gets forwarded.
captured = {}
orig = m._run_core
def spy(script, *args, timeout=30, env_extra=None):
    captured["script"] = script
    captured["env_extra"] = env_extra
    return {"ok": True, "exit_code": 0, "stdout": "", "stderr": ""}
m._run_core = spy
res = m.apd_verify_step(scope="fast")
print(json.dumps({"captured": captured, "source": res.get("source"), "scope": res.get("scope")}))
PY
)"

if echo "$VS_FB_OUT" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
ok = (
    d.get('source') == 'framework' and d.get('scope') == 'fast' and
    (d.get('captured') or {}).get('script') == 'verify-all' and
    ((d.get('captured') or {}).get('env_extra') or {}).get('APD_VERIFY_SCOPE') == 'fast'
)
sys.exit(0 if ok else 1)
" 2>/dev/null; then
    pass "framework-fallback path forwards APD_VERIFY_SCOPE to _run_core"
    PASSES=$((PASSES + 1))
else
    fail "framework fallback dropped scope: $VS_FB_OUT"
    FAILS=$((FAILS + 1))
fi

rm -rf "$VS_FB"

# -----------------------------------------------------------
# 21. apd cdx skills — hybrid install (marketplace default, --legacy-symlink deprecated)
# -----------------------------------------------------------
section "21. apd cdx skills"

SK_HOME="$(mktemp -d -t apd-sk.XXXXXX)"
SK_CODEX="$SK_HOME/.codex"
SK_BIN="$SK_HOME/bin"
mkdir -p "$SK_CODEX" "$SK_BIN"

# Canonical plugin package lives at plugins/apd/. Both direct-drop and
# marketplace install read from here — single physical source, no symlink layer.
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    src="$APD_PLUGIN_ROOT/skills/$name"
    if [ -f "$src/SKILL.md" ]; then
        pass "canonical skill present: $name (SKILL.md)"
        PASSES=$((PASSES + 1))
    else
        fail "missing canonical SKILL.md: $name"
        FAILS=$((FAILS + 1))
    fi
    if [ -f "$src/agents/openai.yaml" ] && grep -q '^interface:' "$src/agents/openai.yaml"; then
        pass "canonical has agents/openai.yaml with interface block: $name"
        PASSES=$((PASSES + 1))
    else
        fail "missing or malformed canonical agents/openai.yaml: $name"
        FAILS=$((FAILS + 1))
    fi
    # Prompt must not reference the old apd_guard_write signature — the skill
    # steers Codex, so stale wording would keep sending models down the wrong
    # call pattern even after the tool itself was fixed.
    if [ -f "$src/agents/openai.yaml" ]; then
        if grep -qE "apd_guard_write\(path, scope\)|apd_guard_write\(path, allowed_paths\)|apd_guard_write\(file_path, allowed_paths\)|apd_guard_write\(role, file_path\)|apd_guard_write\(role,|cache the builder scope|pass that scope list" "$src/agents/openai.yaml"; then
            fail "agents/openai.yaml has stale apd_guard_write prompt: $name"
            FAILS=$((FAILS + 1))
        else
            pass "agents/openai.yaml uses current apd_guard_write signature: $name"
            PASSES=$((PASSES + 1))
        fi
    fi
done

# Plugin manifest must live under the canonical package
if [ -f "$APD_PLUGIN_ROOT/.codex-plugin/plugin.json" ]; then
    pass "canonical plugin manifest at plugins/apd/.codex-plugin/plugin.json"
    PASSES=$((PASSES + 1))
else
    fail "canonical plugin manifest missing at plugins/apd/.codex-plugin/plugin.json"
    FAILS=$((FAILS + 1))
fi

# --- Status output structure (marketplace + legacy sections) ---
STATUS_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills status 2>&1)
if echo "$STATUS_OUT" | grep -q "Marketplace (default since v5.0.8)"; then
    pass "status shows Marketplace as default section"
    PASSES=$((PASSES + 1))
else
    fail "status missing Marketplace default section header"
    FAILS=$((FAILS + 1))
fi
if echo "$STATUS_OUT" | grep -q "Direct-drop (--legacy-symlink, deprecated"; then
    pass "status shows legacy Direct-drop section labelled deprecated"
    PASSES=$((PASSES + 1))
else
    fail "status missing legacy Direct-drop deprecation label"
    FAILS=$((FAILS + 1))
fi
if echo "$STATUS_OUT" | grep -q "apd-brainstorm.*not installed"; then
    pass "status reports apd-brainstorm not installed before install"
    PASSES=$((PASSES + 1))
else
    fail "status did not report apd-brainstorm as uninstalled"
    FAILS=$((FAILS + 1))
fi

LEGACY_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --legacy-symlink 2>&1)
ALL_LINKS=1
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    [ -L "$SK_CODEX/skills/$name" ] || ALL_LINKS=0
done
if [ "$ALL_LINKS" -eq 1 ]; then
    pass "--legacy-symlink install creates 4 symlinks in ~/.codex/skills/"
    PASSES=$((PASSES + 1))
else
    fail "--legacy-symlink install did not create all APD skill symlinks"
    FAILS=$((FAILS + 1))
fi

if echo "$LEGACY_OUT" | grep -q "DEPRECATED"; then
    pass "--legacy-symlink prints deprecation warning"
    PASSES=$((PASSES + 1))
else
    fail "--legacy-symlink missing deprecation warning"
    FAILS=$((FAILS + 1))
fi

target=$(readlink "$SK_CODEX/skills/apd-tdd")
if [ "$target" = "$APD_PLUGIN_ROOT/skills/apd-tdd" ]; then
    pass "apd-tdd symlink points to canonical source"
    PASSES=$((PASSES + 1))
else
    fail "apd-tdd symlink drifts: $target"
    FAILS=$((FAILS + 1))
fi

if [ -f "$SK_CODEX/skills/apd-brainstorm/SKILL.md" ] && \
   grep -q "^name: apd-brainstorm$" "$SK_CODEX/skills/apd-brainstorm/SKILL.md"; then
    pass "SKILL.md reachable via symlink with correct frontmatter"
    PASSES=$((PASSES + 1))
else
    fail "SKILL.md content not reachable via symlink"
    FAILS=$((FAILS + 1))
fi

CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --legacy-symlink apd-debug --copy >/dev/null 2>&1
if [ ! -L "$SK_CODEX/skills/apd-debug" ] && [ -d "$SK_CODEX/skills/apd-debug" ]; then
    pass "install --copy replaces symlink with real directory"
    PASSES=$((PASSES + 1))
else
    fail "install --copy did not switch to directory mode"
    FAILS=$((FAILS + 1))
fi

POST_STATUS=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills status 2>&1)
if echo "$POST_STATUS" | grep -q "apd-brainstorm.*symlink"; then
    pass "status reports symlinks after install"
    PASSES=$((PASSES + 1))
else
    fail "status did not reflect symlink install"
    FAILS=$((FAILS + 1))
fi
if echo "$POST_STATUS" | grep -q "apd-debug.*copy"; then
    pass "status reports copy-mode install"
    PASSES=$((PASSES + 1))
else
    fail "status did not reflect --copy install"
    FAILS=$((FAILS + 1))
fi

CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall --legacy-symlink >/dev/null 2>&1
ANY_LEFT=0
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    [ -e "$SK_CODEX/skills/$name" ] && ANY_LEFT=1
done
if [ "$ANY_LEFT" -eq 0 ]; then
    pass "--legacy-symlink uninstall removes every apd-* skill"
    PASSES=$((PASSES + 1))
else
    fail "some apd-* skills survived --legacy-symlink uninstall"
    FAILS=$((FAILS + 1))
fi

mkdir -p "$SK_CODEX/skills/some-other-skill"
touch "$SK_CODEX/skills/some-other-skill/SKILL.md"
REFUSE_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall --legacy-symlink some-other-skill 2>&1)
if echo "$REFUSE_OUT" | grep -q "refuse"; then
    pass "--legacy-symlink uninstall refuses non-apd-* names"
    PASSES=$((PASSES + 1))
else
    fail "--legacy-symlink uninstall did not refuse non-apd-* name"
    FAILS=$((FAILS + 1))
fi
rm -rf "$SK_CODEX/skills/some-other-skill"

# --- Overwrite protection: user-modified install is preserved without --force ---
mkdir -p "$SK_CODEX/skills/apd-debug"
cat > "$SK_CODEX/skills/apd-debug/SKILL.md" <<'EOF'
---
name: apd-debug
description: USER CUSTOM VERSION
---
EOF
OVW_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --legacy-symlink apd-debug --copy 2>&1)
if echo "$OVW_OUT" | grep -q "refuse"; then
    pass "install refuses to overwrite user-modified copy without --force"
    PASSES=$((PASSES + 1))
else
    fail "install silently overwrote user-modified copy"
    FAILS=$((FAILS + 1))
fi
if grep -q "USER CUSTOM VERSION" "$SK_CODEX/skills/apd-debug/SKILL.md" 2>/dev/null; then
    pass "user content preserved after refused install"
    PASSES=$((PASSES + 1))
else
    fail "user content lost even though install refused"
    FAILS=$((FAILS + 1))
fi
CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --legacy-symlink apd-debug --copy --force >/dev/null 2>&1
if ! grep -q "USER CUSTOM VERSION" "$SK_CODEX/skills/apd-debug/SKILL.md" 2>/dev/null && \
   grep -q "^name: apd-debug$" "$SK_CODEX/skills/apd-debug/SKILL.md"; then
    pass "install --force overwrites user-modified copy with canonical"
    PASSES=$((PASSES + 1))
else
    fail "install --force did not overwrite as expected"
    FAILS=$((FAILS + 1))
fi
CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall >/dev/null 2>&1

# --- Guard against embedded .git inside the canonical plugin (release blocker) ---
if [ ! -e "$APD_PLUGIN_ROOT/.git" ]; then
    pass "canonical plugin package has no embedded .git (release-safe)"
    PASSES=$((PASSES + 1))
else
    fail "canonical plugin contains embedded .git — would break git add as submodule"
    FAILS=$((FAILS + 1))
fi

# --- Root-level marketplace.json for `codex marketplace add owner/repo` ---
# Codex spec requires the manifest at <repo-root>/.agents/plugins/marketplace.json.
# Without this file, remote install via GitHub shorthand fails the pre-install
# validation step.
ROOT_MANIFEST="$REPO_ROOT/.agents/plugins/marketplace.json"
if [ -f "$ROOT_MANIFEST" ]; then
    pass "root .agents/plugins/marketplace.json exists"
    PASSES=$((PASSES + 1))
else
    fail "root .agents/plugins/marketplace.json missing — remote install blocked"
    FAILS=$((FAILS + 1))
fi

if [ -f "$ROOT_MANIFEST" ] && python3 -c "import json; json.load(open('$ROOT_MANIFEST'))" >/dev/null 2>&1; then
    pass "root marketplace.json is valid JSON"
    PASSES=$((PASSES + 1))
else
    fail "root marketplace.json is not valid JSON"
    FAILS=$((FAILS + 1))
fi

# Plugin path must resolve (Codex validates the target before install)
if [ -f "$ROOT_MANIFEST" ]; then
    PLUGIN_REL=$(python3 -c "import json; m=json.load(open('$ROOT_MANIFEST')); print(m['plugins'][0]['source']['path'])" 2>/dev/null)
    PLUGIN_ABS="$REPO_ROOT/${PLUGIN_REL#./}"
    if [ -f "$PLUGIN_ABS/.codex-plugin/plugin.json" ]; then
        pass "root marketplace plugin path resolves to a real plugin manifest"
        PASSES=$((PASSES + 1))
    else
        fail "root marketplace plugin path '$PLUGIN_REL' does not resolve to a plugin: $PLUGIN_ABS"
        FAILS=$((FAILS + 1))
    fi
fi

# --- Marketplace (--marketplace, experimental) ---
cat > "$SK_BIN/codex" <<'EOF'
#!/bin/bash
set -euo pipefail
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CFG="$CODEX_HOME/config.toml"
mkdir -p "$CODEX_HOME"
if [ "${1:-}" = "marketplace" ] && [ "${2:-}" = "add" ] && [ -n "${3:-}" ]; then
  SRC="$3"
  [ -f "$CFG" ] && grep -q '^\[marketplaces\.codex-apd\]' "$CFG" 2>/dev/null && exit 0
  printf '\n[marketplaces.codex-apd]\nsource = "%s"\n' "$SRC" >> "$CFG"
  exit 0
fi
echo "fake codex: unsupported args: $*" >&2
exit 1
EOF
chmod +x "$SK_BIN/codex"

MP_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if echo "$MP_OUT" | grep -q "Marketplace mode"; then
    pass "--marketplace install shows marketplace flow info"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install missing marketplace flow info"
    FAILS=$((FAILS + 1))
fi

if grep -q '^\[marketplaces\.codex-apd\]' "$SK_CODEX/config.toml" 2>/dev/null && \
   grep -qF "source = \"$REPO_ROOT\"" "$SK_CODEX/config.toml"; then
    pass "--marketplace install registers codex-apd marketplace at repo root"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not register marketplace at repo root"
    FAILS=$((FAILS + 1))
fi

if grep -q '^\[plugins\."apd@codex-apd"\]' "$SK_CODEX/config.toml" 2>/dev/null && \
   grep -q '^enabled = true$' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "--marketplace install enables [plugins.\"apd@codex-apd\"]"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not enable plugin block"
    FAILS=$((FAILS + 1))
fi

REINSTALL_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if echo "$REINSTALL_OUT" | grep -q "already registered"; then
    pass "--marketplace reinstall is idempotent when marketplace already matches"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace reinstall did not report already registered"
    FAILS=$((FAILS + 1))
fi

python3 - "$SK_CODEX/config.toml" <<'PY'
import re, sys
path = sys.argv[1]
text = open(path).read()
text = re.sub(
    r'(?ms)^\[plugins\."apd@codex-apd"\][^\[]*?(?=^\[|\Z)',
    '[plugins."apd@codex-apd"]\nenabled = false\n\n',
    text,
)
open(path, 'w').write(text)
PY
HEAL_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if grep -q '^enabled = true$' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "--marketplace install self-heals disabled plugin block"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not self-heal disabled plugin block"
    FAILS=$((FAILS + 1))
fi
if echo "$HEAL_OUT" | grep -q 'updated'; then
    pass "--marketplace self-heal reports plugin block update"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace self-heal did not report update"
    FAILS=$((FAILS + 1))
fi

printf '\n[plugins."other@else"]\nenabled = true\n' >> "$SK_CODEX/config.toml"
UNINSTALL_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall --marketplace 2>&1)
if ! grep -q '^\[marketplaces\.codex-apd\]' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "uninstall --marketplace removes [marketplaces.codex-apd]"
