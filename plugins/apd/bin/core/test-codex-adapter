# -----------------------------------------------------------
# 44. v6.3 audit fix — guard-bash-scope write-target identification
#     CRITICAL pre-audit bug: `cp src/innocent /etc/passwd` was allowed
#     when scope=src/ because the guard checked "any path in scope" rather
#     than "the write TARGET in scope". Lock-in: verify destination checks.
# -----------------------------------------------------------
section "44. guard-bash-scope write-target check (audit fix #1)"

GBS_DIR="$(mktemp -d -t apd-gbs.XXXXXX)"
mkdir -p "$GBS_DIR/.apd" && touch "$GBS_DIR/.apd/config"
GBS="$APD_PLUGIN_ROOT/bin/core/guard-bash-scope"

_gbs_check() {
    # $1 = label, $2 = expected exit (0=allow, 2=block), $3 = command, rest = allowed paths
    local label="$1" expected="$2" cmd="$3"; shift 3
    APD_PROJECT_DIR="$GBS_DIR" bash "$GBS" --command "$cmd" "$@" >/dev/null 2>&1
    local rc=$?
    if [ "$rc" = "$expected" ]; then
        pass "$label (rc=$rc)"
        PASSES=$((PASSES + 1))
    else
        fail "$label expected rc=$expected got rc=$rc"
        FAILS=$((FAILS + 1))
    fi
}

# Pre-audit BUG cases — these used to ALLOW (rc=0), must now BLOCK (rc=2)
_gbs_check "cp in-scope source → out-of-scope target BLOCKS" 2 "cp src/innocent.txt /etc/passwd" src/
_gbs_check "mv in-scope source → out-of-scope target BLOCKS" 2 "mv src/file /etc/destination" src/
_gbs_check "sed -i (BSD) out-of-scope file BLOCKS"           2 "sed -i '' 's/a/b/' /etc/hosts"  src/
_gbs_check "sed -i (GNU) out-of-scope file BLOCKS"           2 "sed -i 's/a/b/' /etc/hosts"     src/
_gbs_check "rm out-of-scope BLOCKS"                          2 "rm /etc/something"              src/
_gbs_check "mkdir out-of-scope BLOCKS"                       2 "mkdir /etc/newdir"              src/
_gbs_check "tee out-of-scope BLOCKS"                         2 "echo x | tee /etc/foo"          src/
_gbs_check "dd of= out-of-scope BLOCKS"                      2 "dd if=src/foo of=/dev/disk0"    src/

# Legitimate in-scope cases — must ALLOW (rc=0)
_gbs_check "cp in-scope ALLOWS"                              0 "cp src/foo src/bar"             src/
_gbs_check "redirect in-scope ALLOWS"                        0 "echo data > src/file"           src/
_gbs_check "mv into scope from /tmp ALLOWS"                  0 "mv /tmp/file src/file"          src/
_gbs_check "sed -i (BSD) in-scope ALLOWS"                    0 "sed -i '' 's/a/b/' src/file"    src/
_gbs_check "sed -i.bak in-scope ALLOWS"                      0 "sed -i.bak 's/a/b/' src/file"   src/
_gbs_check "multi-file sed both in-scope ALLOWS"             0 "sed -i '' 's/a/b/' src/f1 src/f2" src/
_gbs_check "multi-file sed mixed scope BLOCKS"               2 "sed -i '' 's/a/b/' src/f1 /etc/f2" src/

rm -rf "$GBS_DIR"

