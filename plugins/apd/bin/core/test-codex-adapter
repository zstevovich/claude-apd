#     Regression for feedback-parallel-same-agent-dispatch (BambiProject #48,
#     2026-04-16: 3× backend-api in 34s caused conflicts + panic-reset).
# -----------------------------------------------------------
section "29. Parallel same-type dispatch gate"

PAR_DIR="$(mktemp -d -t apd-par.XXXXXX)"
mkdir -p "$PAR_DIR/.apd/pipeline" "$PAR_DIR/.apd/memory"
echo "PROJECT_NAME=parallel-test" > "$PAR_DIR/.apd/config"

# A: first dispatch — ALLOW (no prior entry)
(cd "$PAR_DIR" && bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStart --agent-type backend-builder --agent-id A1 \
    >/dev/null 2>&1)
RC=$?
if [ "$RC" = "0" ]; then
    pass "first dispatch of agent type allowed"
    PASSES=$((PASSES + 1))
else
    fail "first dispatch should allow (got $RC)"
    FAILS=$((FAILS + 1))
fi

# B: immediate second dispatch of same type, no stop — BLOCK
(cd "$PAR_DIR" && bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStart --agent-type backend-builder --agent-id A2 \
    >/dev/null 2>&1)
RC=$?
if [ "$RC" = "2" ]; then
    pass "parallel same-type within window blocked"
    PASSES=$((PASSES + 1))
else
    fail "parallel same-type should block (got $RC)"
    FAILS=$((FAILS + 1))
fi

# C: different agent_type in parallel — ALLOW
(cd "$PAR_DIR" && bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStart --agent-type frontend-builder --agent-id F1 \
    >/dev/null 2>&1)
RC=$?
if [ "$RC" = "0" ]; then
    pass "different agent type in parallel allowed"
    PASSES=$((PASSES + 1))
else
    fail "different agent type should allow (got $RC)"
    FAILS=$((FAILS + 1))
fi

# D: previous instance stopped — ALLOW new dispatch of same type
(cd "$PAR_DIR" && bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStop --agent-type backend-builder --agent-id A1 \
    >/dev/null 2>&1)
(cd "$PAR_DIR" && bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStart --agent-type backend-builder --agent-id A3 \
    >/dev/null 2>&1)
RC=$?
if [ "$RC" = "0" ]; then
    pass "new dispatch allowed after previous instance stopped"
    PASSES=$((PASSES + 1))
else
    fail "new dispatch after stop should allow (got $RC)"
    FAILS=$((FAILS + 1))
fi

# E: APD_PARALLEL_WINDOW=0 — gate disabled
(cd "$PAR_DIR" && APD_PARALLEL_WINDOW=0 bash "$APD_PLUGIN_ROOT/bin/core/track-agent" \
    --event SubagentStart --agent-type backend-builder --agent-id A4 \
    >/dev/null 2>&1)
RC=$?
if [ "$RC" = "0" ]; then
    pass "APD_PARALLEL_WINDOW=0 disables the gate"
    PASSES=$((PASSES + 1))
else
    fail "APD_PARALLEL_WINDOW=0 should disable gate (got $RC)"
    FAILS=$((FAILS + 1))
fi

rm -rf "$PAR_DIR"

