# -----------------------------------------------------------
# 89. v6.21 — run-role --launch (opt-in spawn), Milestone C2
#     After prepare, --launch scrubs APD_PROJECT_DIR + CLAUDE_PLUGIN_ROOT and
#     exec's `claude` in the worktree so the new session resolves the worktree
#     as its own root (R6). Degrades to prepare-only if no `claude` on PATH (E11).
# -----------------------------------------------------------
section "89. run-role --launch (v6.21)"

RR="$APD_PLUGIN_ROOT/bin/core/run-role"

# Static A: --launch flag parsed
_check_file_contains "run-role parses --launch" "$RR" '\-\-launch\) LAUNCH=true'

# Static B: spawns via exec claude
_check_file_contains "run-role exec's claude on launch" "$RR" 'exec claude'

# Static C: scrubs leaked env before spawn (R6)
_check_file_contains "run-role scrubs APD_PROJECT_DIR + CLAUDE_PLUGIN_ROOT" "$RR" 'unset APD_PROJECT_DIR CLAUDE_PLUGIN_ROOT'

# Static D: E11 — guards on claude presence
if grep -q 'command -v claude' "$RR"; then
    pass "run-role guards on claude presence (E11)"
    PASSES=$((PASSES + 1))
else
    fail "run-role missing claude-presence guard (E11)"
    FAILS=$((FAILS + 1))
fi

# Live setup: main checkout + a mock `claude` that reports cwd + leaked env
RR_MB="$(mktemp -d -t apd-rrmock.XXXXXX)"
printf '#!/bin/bash\necho "CLAUDE_LAUNCHED cwd=$(basename "$PWD") apd_proj=${APD_PROJECT_DIR:-EMPTY}"\n' > "$RR_MB/claude"
chmod +x "$RR_MB/claude"
RR_LMAIN="$(mktemp -d -t apd-c2.XXXXXX)"
(
  cd "$RR_LMAIN"
  git init -q; git config user.email t@t.t; git config user.name t
  mkdir -p .claude/agents
  printf 'PROJECT_NAME=C2\n' > .claude/.apd-config
  echo r > .claude/agents/code-reviewer.md
  printf '.claude/\n.apd/pipeline/\n' > .gitignore
  echo "# C2" > README.md
  git add README.md .gitignore; git commit -qm init
) >/dev/null 2>&1
run_launch() { ( cd "$RR_LMAIN" && unset CLAUDE_PLUGIN_ROOT; APD_PROJECT_DIR="$RR_LMAIN" PATH="$RR_MB:$PATH" bash "$RR" "$@" 2>&1 ); }

# Live E: --launch with a (mock) claude → spawns in the worktree, env scrubbed
RR_L="$(run_launch backend --launch)"
if echo "$RR_L" | grep -q "CLAUDE_LAUNCHED cwd=backend-work" && echo "$RR_L" | grep -q "apd_proj=EMPTY"; then
    pass "--launch spawns claude in worktree with scrubbed env (R6)"
    PASSES=$((PASSES + 1))
else
    fail "--launch spawn wrong: $RR_L"
    FAILS=$((FAILS + 1))
fi

# Live F: no --launch → prepare-only, does NOT spawn (C1 behavior unchanged)
git -C "$RR_LMAIN" worktree remove --force .claude/worktrees/backend-work >/dev/null 2>&1
git -C "$RR_LMAIN" branch -D backend-work >/dev/null 2>&1
RR_NL="$(run_launch backend)"
if echo "$RR_NL" | grep -q "cd " && ! echo "$RR_NL" | grep -q "CLAUDE_LAUNCHED"; then
    pass "no --launch → prepare-only, does NOT spawn"
    PASSES=$((PASSES + 1))
else
    fail "no-launch unexpectedly spawned or missing prepare output: $RR_NL"
    FAILS=$((FAILS + 1))
fi

( cd "$RR_LMAIN" && git worktree remove --force .claude/worktrees/backend-work >/dev/null 2>&1; git worktree prune >/dev/null 2>&1 )
rm -rf "$RR_LMAIN" "$RR_MB"

# -----------------------------------------------------------
# 90. v6.22 — merge-role read-only gate, Milestone D1
#     Inspects a producer role's <role>-work branch readiness to merge into the
#     integration branch (develop/main/master auto-detect): ahead / clean /
#     idle (no spec-card — git state, NOT verifier.done) / behind (sync-first).
#     READ-ONLY — never runs `git merge` (irreversible + unguarded → human pulls
#     that trigger; D1 must be proven read-only before any D2 actuator).
# -----------------------------------------------------------
section "90. merge-role read-only gate (v6.22)"

MR="$APD_PLUGIN_ROOT/bin/core/merge-role"

# Static A: exists + executable
_check "merge-role script exists and is executable" test -x "$MR"

# Static B: dispatcher wires merge-role|mr
if grep -qE 'merge-role\|mr\)' "$APD_PLUGIN_ROOT/bin/apd"; then
    pass "dispatcher wires merge-role|mr"
    PASSES=$((PASSES + 1))
else
    fail "dispatcher missing merge-role|mr case"
    FAILS=$((FAILS + 1))
fi

# Static C: documents read-only / does-not-run-merge invariant
if grep -q 'NEVER run' "$MR" && grep -q 'read-only' "$MR"; then
    pass "merge-role documents read-only / never-runs-merge invariant"
    PASSES=$((PASSES + 1))
else
    fail "merge-role missing read-only invariant"
    FAILS=$((FAILS + 1))
fi

# Live setup: repo with develop + a backend-work worktree that's ahead by 1
MR_MAIN="$(mktemp -d -t apd-d1.XXXXXX)"
(
  cd "$MR_MAIN"
  git init -q; git config user.email t@t.t; git config user.name t
  mkdir -p .claude/agents
  printf 'PROJECT_NAME=D1\n' > .claude/.apd-config
  echo r > .claude/agents/code-reviewer.md
  printf '.claude/\n.apd/pipeline/\n' > .gitignore
  echo init > f.txt; git add f.txt .gitignore; git commit -qm init
  git branch develop
  git worktree add .claude/worktrees/backend-work -b backend-work develop
  ( cd .claude/worktrees/backend-work && echo work > w.txt && git add w.txt && git commit -qm "backend work" )
) >/dev/null 2>&1
run_mr() { ( cd "$MR_MAIN" && unset CLAUDE_PLUGIN_ROOT; APD_PROJECT_DIR="$MR_MAIN" bash "$MR" "$@" 2>&1 ); }

# Live D: READY (ahead, clean, idle, in-sync) → exit 0 + guidance
MR_DEV_BEFORE=$(git -C "$MR_MAIN" rev-parse develop)
MR_READY="$(run_mr backend)"; run_mr backend >/dev/null 2>&1; MR_RC=$?
if [ "$MR_RC" = "0" ] && echo "$MR_READY" | grep -q "READY to merge" && echo "$MR_READY" | grep -q "git checkout develop && git merge backend-work"; then
    pass "READY: ahead+clean+idle+in-sync → exit 0 + merge guidance"
    PASSES=$((PASSES + 1))
else
    fail "READY check wrong: rc=$MR_RC out=$MR_READY"
    FAILS=$((FAILS + 1))
fi

# Live E: read-only — develop is unchanged after the gate ran
MR_DEV_AFTER=$(git -C "$MR_MAIN" rev-parse develop)
if [ "$MR_DEV_BEFORE" = "$MR_DEV_AFTER" ]; then
    pass "gate is read-only (develop SHA unchanged after check)"
    PASSES=$((PASSES + 1))
else
    fail "gate mutated develop: $MR_DEV_BEFORE -> $MR_DEV_AFTER"
    FAILS=$((FAILS + 1))
fi

# Live F: unknown role → exit 1
run_mr bogus >/dev/null 2>&1; MR_RC=$?
[ "$MR_RC" = "1" ] && { pass "unknown role → exit 1"; PASSES=$((PASSES + 1)); } || { fail "unknown role exit $MR_RC (want 1)"; FAILS=$((FAILS + 1)); }

# Live G: operator role → exit 1
run_mr debug >/dev/null 2>&1; MR_RC=$?
[ "$MR_RC" = "1" ] && { pass "operator role (debug) → exit 1"; PASSES=$((PASSES + 1)); } || { fail "operator role exit $MR_RC (want 1)"; FAILS=$((FAILS + 1)); }

# Live H: producer with no <role>-work branch → BLOCK exit 1
run_mr frontend >/dev/null 2>&1; MR_RC=$?
[ "$MR_RC" = "1" ] && { pass "no <role>-work branch → BLOCK exit 1"; PASSES=$((PASSES + 1)); } || { fail "no-branch exit $MR_RC (want 1)"; FAILS=$((FAILS + 1)); }

# Live I: BEHIND (develop moves ahead) → NOT ready, sync-first, exit 1
( cd "$MR_MAIN" && git checkout -q develop && echo more > m.txt && git add m.txt && git commit -qm "develop moved" ) >/dev/null 2>&1
MR_BEHIND="$(run_mr backend)"; run_mr backend >/dev/null 2>&1; MR_RC=$?
if [ "$MR_RC" = "1" ] && echo "$MR_BEHIND" | grep -q "SYNC FIRST" && echo "$MR_BEHIND" | grep -q "git merge develop"; then
    pass "BEHIND target → NOT ready + sync-first guidance, exit 1"
    PASSES=$((PASSES + 1))
else
    fail "BEHIND check wrong: rc=$MR_RC out=$MR_BEHIND"
    FAILS=$((FAILS + 1))
fi

( cd "$MR_MAIN" && git worktree remove --force .claude/worktrees/backend-work >/dev/null 2>&1; git worktree prune >/dev/null 2>&1 )
rm -rf "$MR_MAIN"

# -----------------------------------------------------------
# Summary
# -----------------------------------------------------------
echo ""
section "Summary"
echo "  ${G}PASS:${R} $PASSES"
echo "  ${R}FAIL:${R} $FAILS"

if [ "$FAILS" -eq 0 ]; then
    echo ""
    echo "  ${G}All Codex adapter checks passed.${R}"
    exit 0
else
    echo ""
    echo "  ${R}$FAILS check(s) failed — Codex adapter has regressions.${R}"
    exit "$FAILS"
fi
