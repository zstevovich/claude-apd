section "27. guard-bash-scope read/write distinction"

READ_SCRATCH="$(mktemp -d -t apd-rw.XXXXXX)"
mkdir -p "$READ_SCRATCH/.apd/pipeline"
echo "PROJECT_NAME=read-write" > "$READ_SCRATCH/.apd/config"
touch "$READ_SCRATCH/.apd/pipeline/spec-card.md"

for cmd in "cat .apd/pipeline/spec-card.md" \
           "grep R1 .apd/pipeline/spec-card.md" \
           "head -5 .apd/pipeline/spec-card.md" \
           "tail -5 .apd/pipeline/spec-card.md" \
           "wc -l .apd/pipeline/spec-card.md" \
           "less .apd/pipeline/spec-card.md"; do
    (cd "$READ_SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-bash-scope" --command "$cmd" .apd/pipeline >/dev/null 2>&1)
    if [ $? -eq 0 ]; then
        pass "ALLOW read: $cmd"
        PASSES=$((PASSES + 1))
    else
        fail "read incorrectly blocked: $cmd"
        FAILS=$((FAILS + 1))
    fi
done

for cmd in "echo X > .apd/pipeline/spec-card.md" \
           "cp /etc/hosts .apd/pipeline/spec-card.md" \
           "rm .apd/pipeline/spec-card.md" \
           "echo X >> .apd/pipeline/spec-card.md"; do
    (cd "$READ_SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-bash-scope" --command "$cmd" .apd/pipeline >/dev/null 2>&1)
    if [ $? -eq 2 ]; then
        pass "BLOCK write: $cmd"
        PASSES=$((PASSES + 1))
    else
        fail "write incorrectly allowed: $cmd"
        FAILS=$((FAILS + 1))
    fi
done

rm -rf "$READ_SCRATCH"

