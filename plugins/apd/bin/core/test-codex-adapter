# Helper: extract max_defects value the same way the gate does
extract_max_defects() {
    grep -iE '^[-*_ 	]*adversarial[-*_ 	]*:.*max_defects[[:space:]]*[:=][[:space:]]*([0-9]+|unlimited)' "$1" 2>/dev/null \
        | sed -E 's/.*max_defects[[:space:]]*[:=][[:space:]]*//I' \
        | tr '[:upper:]' '[:lower:]' \
        | awk '{print $1}' \
        | head -1
}

