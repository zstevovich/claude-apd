#!/bin/bash
# APD Bash Scope Guard — blocks Bash commands that write outside the allowed scope
# Complements guard-scope which protects Write/Edit operations
#
# Detects:
#   1. Shell write operations: redirect (>), tee, sed -i, cp, mv, dd, install
#   2. Runtime write operations: node -e, python -c, ruby -e, php -r, perl -e
#      with write functions (writeFileSync, open().write, file_put_contents...)
#
# Interface: --command <cmd> [allowed_path_1] [allowed_path_2] ...

source "$(dirname "$0")/../lib/resolve-project.sh"
source "$(dirname "$0")/../lib/style.sh"
[ "$APD_ACTIVE" = false ] && exit 0

COMMAND=""
ALLOWED_PATHS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --command) COMMAND="$2"; shift 2 ;;
    *) ALLOWED_PATHS+=("$1"); shift ;;
  esac
done

if [ -z "$COMMAND" ]; then
  exit 0
fi

# --- 0. Protected paths — ALWAYS enforced, even without ALLOWED_PATHS ---
# .apd/pipeline/ state files must only be modified by pipeline-advance (not direct Bash writes)
# Plugin cache must never be modified by orchestrator
PROTECTED_PIPELINE=(".apd/pipeline/")
PROTECTED_PLUGIN=(".claude/plugins/cache/" "plugins/cache/")
SHELL_WRITE_CHECK=('>>' '>' 'tee ' 'sed -i' 'sed --in-place' 'cp ' 'mv ' 'dd ' 'install ' 'mkdir ' 'mkdir -p' 'touch ' 'rm ' 'rm -f' 'rm -rf' 'rmdir ')
# Write checks for plugin cache — exclude '>' and '>>' (false positives from 2>&1 redirects)
PLUGIN_WRITE_CHECK=('tee ' 'sed -i' 'sed --in-place' 'cp ' 'mv ' 'dd ' 'install ' 'mkdir ' 'mkdir -p' 'touch ' 'rm ' 'rm -f' 'rm -rf' 'rmdir ')

_runtime_write_detected() {
  local cmd="$1"
  if echo "$cmd" | grep -qE '(^|[;&|] *)node\s+(-e|--eval|--print)\s' &&
     echo "$cmd" | grep -qiE 'writeFile|writeFileSync|appendFile|appendFileSync|createWriteStream|mkdirSync|copyFile'; then
    return 0
  fi
  if echo "$cmd" | grep -qE '(^|[;&|] *)python[3]?\s+(-c)\s' &&
     echo "$cmd" | grep -qiE "open\s*\(|\.write\s*\(|Path\s*\(|shutil\.|os\.rename|os\.replace|pathlib"; then
    return 0
  fi
  if echo "$cmd" | grep -qE '(^|[;&|] *)ruby\s+(-e)\s' &&
     echo "$cmd" | grep -qiE 'File\.(write|open|rename)|FileUtils\.(cp|mv|mkdir)'; then
    return 0
  fi
  if echo "$cmd" | grep -qE '(^|[;&|] *)php\s+(-r)\s' &&
     echo "$cmd" | grep -qiE 'file_put_contents|fwrite|fopen|rename|copy|mkdir'; then
    return 0
  fi
  if echo "$cmd" | grep -qE '(^|[;&|] *)perl\s+(-e)\s' &&
     echo "$cmd" | grep -qiE 'open\s*\(|print\s+\$|File::Copy|rename'; then
    return 0
  fi
  return 1
}

# Block writes to plugin cache (executing scripts from cache is allowed)
for ppath in "${PROTECTED_PLUGIN[@]}"; do
  if [[ "$COMMAND" == *"$ppath"* ]]; then
    for wp in "${PLUGIN_WRITE_CHECK[@]}"; do
      if [[ "$COMMAND" == *"$wp"*"$ppath"* ]] || [[ "$COMMAND" == *"$wp"*plugin* ]]; then
        echo "BLOCKED: Bash write to plugin cache directory." >&2
        echo "  Plugin files are read-only. Do not modify." >&2
        log_block "plugin-cache-write" "${COMMAND:0:100}"
        exit 2
      fi
    done
    # Check redirect operators only when they TARGET the cache path (not 2>&1)
    if echo "$COMMAND" | grep -qE '>[^&].*plugins/cache|>>.*plugins/cache' 2>/dev/null; then
      echo "BLOCKED: Bash write to plugin cache directory." >&2
      echo "  Plugin files are read-only. Do not modify." >&2
      log_block "plugin-cache-write" "${COMMAND:0:100}"
      exit 2
    fi
    if _runtime_write_detected "$COMMAND"; then
      echo "BLOCKED: Runtime write to plugin cache directory." >&2
      echo "  Plugin files are read-only. Do not modify." >&2
      log_block "plugin-cache-write" "${COMMAND:0:100}"
      exit 2
    fi
  fi
done

# Block writes to .apd/pipeline/ (APD tools whitelisted)
# Uses PLUGIN_WRITE_CHECK (no > and >>) to avoid false positives from 2>/dev/null redirects
for ppath in "${PROTECTED_PIPELINE[@]}"; do
  if [[ "$COMMAND" == *"$ppath"* ]]; then
    # Allow APD's own tools to write to .apd/pipeline/
    if [[ "$COMMAND" == *"pipeline-advance"* ]] || [[ "$COMMAND" == *"apd pipeline"* ]] || [[ "$COMMAND" == *"verify-apd"* ]] || [[ "$COMMAND" == *"pipeline-post-commit"* ]] || [[ "$COMMAND" == *"pipeline-gate"* ]]; then
      break
    fi
    # Check non-redirect write operations
    for wp in "${PLUGIN_WRITE_CHECK[@]}"; do
      if [[ "$COMMAND" == *"$wp"*"$ppath"* ]] || [[ "$COMMAND" == *"$wp"*".apd/pipeline/"* ]]; then
        echo "BLOCKED: Bash write to protected pipeline state directory." >&2
        echo "" >&2
        echo "  Do not write directly to .apd/pipeline/ — use the apd command instead." >&2
        echo "  Allowed: bash $APD_SHORTCUT_DISPLAY pipeline <command>" >&2
        log_block "pipeline-state-write" "${COMMAND:0:100}"
        exit 2
      fi
    done
    # Check redirect operators only when they TARGET .apd/pipeline/ (not 2>/dev/null)
    if echo "$COMMAND" | grep -qE '>[^&].*\.apd/pipeline/|>>.*\.apd/pipeline/' 2>/dev/null; then
      echo "BLOCKED: Bash redirect to protected pipeline state directory." >&2
      echo "  Do not write directly to .apd/pipeline/ — use the apd command instead." >&2
      log_block "pipeline-state-write" "${COMMAND:0:100}"
      exit 2
    fi
    if _runtime_write_detected "$COMMAND"; then
      echo "BLOCKED: Runtime write to protected pipeline state directory." >&2
      echo "  Do not write directly to .apd/pipeline/ — use the apd command instead." >&2
      log_block "pipeline-state-write" "${COMMAND:0:100}"
      exit 2
    fi
  fi
done

if [ ${#ALLOWED_PATHS[@]} -eq 0 ]; then
  exit 0
fi

# --- 1. Shell write operations ---
# Add destructive ops too (rm, mkdir, touch, rmdir) — scope guard covers
# any filesystem modification, not just creation.
SHELL_WRITE_PATTERNS=('>>' '>' 'tee ' 'sed -i' 'sed --in-place' 'cp ' 'mv ' 'dd ' 'install ' 'rm ' 'rmdir ' 'mkdir ' 'touch ')

HAS_WRITE_OP=false
WRITE_TYPE=""

for pattern in "${SHELL_WRITE_PATTERNS[@]}"; do
  if [[ "$COMMAND" == *"$pattern"* ]]; then
    HAS_WRITE_OP=true
    WRITE_TYPE="shell"
    break
  fi
done

# --- 2. Runtime write operations ---
if [ "$HAS_WRITE_OP" = false ]; then

  if _runtime_write_detected "$COMMAND"; then
    HAS_WRITE_OP=true
    WRITE_TYPE="runtime"
  fi
fi

if [ "$HAS_WRITE_OP" = false ]; then
  exit 0
fi

# --- Check WRITE TARGETS against allowed scope ---
# Previous implementation extracted ALL path-shaped tokens and allowed if ANY
# matched scope — meant `cp src/innocent /etc/passwd` passed because "src/innocent"
# matched. v6.3 audit fix: identify the actual destination of each write op and
# check ONLY those. For runtime writes (node -e / python -c) the target lives
# inside a string literal we can't parse safely; fall back to strict per-token
# check there.

_path_in_scope() {
  local clean="$1"
  clean="${clean#./}"
  clean="${clean#~/}"
  local allowed
  for allowed in "${ALLOWED_PATHS[@]}"; do
    allowed="${allowed%/}/"
    case "$clean/" in
      "$allowed"*) return 0 ;;
    esac
  done
  return 1
}

# Collect candidate write targets (one per line)
WRITE_TARGETS=$(
  # 1. Redirect targets: > or >> followed by path (skip &> /dev/null, 2>&1)
  echo "$COMMAND" | grep -oE '[0-9]?>{1,2}[[:space:]]*[^&[:space:]|;`"]+' 2>/dev/null \
    | sed -E 's/^[0-9]?>+[[:space:]]*//' \
    | grep -vE '^&' || true
  # 2. tee <file>: target is the first non-flag arg
  echo "$COMMAND" | grep -oE '\btee\b[[:space:]]+(-[a-zA-Z]+[[:space:]]+)*[^-[:space:]|;&]+' 2>/dev/null \
    | awk '{for(i=2;i<=NF;i++) if ($i !~ /^-/) {print $i; exit}}' || true
  # 3. cp/mv/install <flags> src dst: target is the LAST positional arg
  echo "$COMMAND" | grep -oE '\b(cp|mv|install)\b[[:space:]]+[^|;&]+' 2>/dev/null \
    | while IFS= read -r seg; do
        # strip leading op name + flags, keep positional tail
        echo "$seg" | awk '{
          for (i=2; i<=NF; i++) if ($i !~ /^-/) tail=tail" "$i
          n = split(tail, a, /[[:space:]]+/)
          if (n >= 2) print a[n]  # last positional
        }'
      done || true
  # 4. dd ... of=<target>
  echo "$COMMAND" | grep -oE '\bof=[^[:space:]|;&]+' 2>/dev/null | cut -d= -f2 || true
  # 5. mkdir/touch/rm/rmdir: every non-flag arg is a target
  echo "$COMMAND" | grep -oE '\b(mkdir|touch|rm|rmdir)\b[[:space:]]+[^|;&]+' 2>/dev/null \
    | while IFS= read -r seg; do
        echo "$seg" | awk '{for(i=2;i<=NF;i++) if ($i !~ /^-/) print $i}'
      done || true
  # 6. sed -i <pattern> <files...>: every non-flag arg AFTER the pattern is a target.
  # Handles GNU (`-i 'pat' file`) and BSD (`-i '' 'pat' file`, `-i.bak 'pat' file`).
  # \47 is octal for '. \42 is octal for ". Bash single-quoting prevents literal
  # quote characters in the awk source, so we encode them as octal.
  echo "$COMMAND" | grep -oE '\bsed\b[[:space:]]+(-i[^[:space:]|;&]*|--in-place[^|;&]*)[^|;&]*' 2>/dev/null \
    | while IFS= read -r seg; do
        echo "$seg" | awk '{
          seen_pattern = 0
          for (i=1; i<=NF; i++) {
            if ($i ~ /^(sed|--in-place|-i)/) continue
            if ($i ~ /^-/) continue
            if ($i == "\47\47" || $i == "\42\42") continue
            if (!seen_pattern) { seen_pattern = 1; continue }
            print $i
          }
        }'
      done || true
)

# If we identified at least one target, check ONLY those.
TARGETS_FOUND=$(echo "$WRITE_TARGETS" | grep -v '^$' | grep -v '^/dev/null$' | head -50)

if [ -n "$TARGETS_FOUND" ]; then
  while IFS= read -r target; do
    [ -z "$target" ] && continue
    if ! _path_in_scope "$target"; then
      if [ "$WRITE_TYPE" = "shell" ]; then
        echo "BLOCKED: Bash command writes outside the allowed scope." >&2
        echo "  Out-of-scope target: $target" >&2
      else
        echo "BLOCKED: Runtime write ($WRITE_TYPE) detected outside the allowed scope." >&2
      fi
      echo "  Allowed paths: ${ALLOWED_PATHS[*]}" >&2
      log_block "out-of-scope-bash-write" "${COMMAND:0:100}"
      exit 2
    fi
  done <<< "$TARGETS_FOUND"
  exit 0
fi

# No identifiable write targets found — fall back to strict per-token check.
# This catches runtime writes (node -e, python -c) where the target lives in
# a string literal; require every path-shaped token to be in scope.
PATHS_IN_CMD=$(echo "$COMMAND" | grep -oE '([~/./]?[a-zA-Z0-9_./-]{2,})' 2>/dev/null || true)
ANY_PATH=false
while IFS= read -r path; do
  [ -z "$path" ] && continue
  case "$path" in
    -*|/dev/null|/dev/stdin|/dev/stdout|/dev/stderr) continue ;;
  esac
  ANY_PATH=true
  if _path_in_scope "$path"; then
    exit 0
  fi
done <<< "$PATHS_IN_CMD"

if [ "$ANY_PATH" = false ]; then
  # No path-shaped tokens at all (e.g. `mkdir` with no arg) — allow
  exit 0
fi

if [ "$WRITE_TYPE" = "shell" ]; then
  echo "BLOCKED: Bash command writes outside the allowed scope." >&2
else
  echo "BLOCKED: Runtime write ($WRITE_TYPE) detected outside the allowed scope." >&2
fi
echo "Allowed paths: ${ALLOWED_PATHS[*]}" >&2
log_block "out-of-scope-bash-write" "${COMMAND:0:100}"
exit 2
