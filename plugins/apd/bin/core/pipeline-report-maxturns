#!/bin/bash
# APD MaxTurns Telemetry — analiziraj rapid agent re-dispatch pattern
#
# Detektuje maxTurn exhaust signal preko proxy metrike: per-agent_type broj
# rapid re-dispatch events (gap <RAPID_THRESHOLD seconds izmedju stop i sledeci
# start istog agent_type-a). Visok broj = verovatno hit maxTurn limit u toku
# task-a, pa orchestrator re-dispatched fresh agent sa istim scope-om.
#
# Usage:
#   pipeline-report-maxturns [--days N] [--threshold-seconds S]
#
# Default: poslednjih 30 dana, gap threshold 120s.
#
# Output: per agent_type rapid re-dispatch count + suggested action.

set -u

source "$(dirname "$0")/../lib/resolve-project.sh"
source "$(dirname "$0")/../lib/style.sh"

# --- Defaults ---
DAYS=30
RAPID_THRESHOLD=120

# --- Parse args ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --days)
            DAYS="$2"
            shift 2
            ;;
        --days=*)
            DAYS="${1#*=}"
            shift
            ;;
        --threshold-seconds)
            RAPID_THRESHOLD="$2"
            shift 2
            ;;
        --threshold-seconds=*)
            RAPID_THRESHOLD="${1#*=}"
            shift
            ;;
        *)
            shift
            ;;
    esac
done

HISTORY_LOG="$MEMORY_DIR/agent-history.log"

if [ ! -f "$HISTORY_LOG" ]; then
    echo "  ${MARK_SKIP} agent-history.log not found at $HISTORY_LOG" >&2
    echo "  Run at least one task pipeline first." >&2
    exit 0
fi

# --- Compute cutoff date (N days ago) ---
CUTOFF=$(date -v-${DAYS}d +"%Y-%m-%d" 2>/dev/null || date -d "${DAYS} days ago" +"%Y-%m-%d" 2>/dev/null || echo "1970-01-01")

# --- Box drawing for output ---
BOX_W=58
_dashes() {
    local n=$1 s=""
    for ((i=0; i<n; i++)); do s="${s}─"; done
    printf '%s' "$s"
}

echo ""
printf "  ${V}╭%s╮${R}\n" "$(_dashes $BOX_W)"
TITLE="MaxTurns Telemetry — last ${DAYS} days (threshold ${RAPID_THRESHOLD}s)"
TITLE_PAD=$(( (BOX_W - ${#TITLE}) / 2 ))
printf "  ${V}│${R}%${TITLE_PAD}s${V}${B}%s${R}%$(( BOX_W - TITLE_PAD - ${#TITLE} ))s${V}│${R}\n" "" "$TITLE" ""
printf "  ${V}╰%s╯${R}\n" "$(_dashes $BOX_W)"

# --- Parse history log + compute rapid re-dispatch per agent_type ---
RESULTS=$(mktemp)
trap 'rm -f "$RESULTS"' EXIT INT TERM

awk -F'|' -v cutoff="$CUTOFF" -v threshold="$RAPID_THRESHOLD" '
    $1 >= cutoff {
        if ($2 == "stop") {
            last_stop[$3] = $1
        } else if ($2 == "start" && last_stop[$3] != "") {
            cmd = "date -j -f \"%Y-%m-%d %H:%M:%S\" \"" $1 "\" +%s 2>/dev/null || date -d \"" $1 "\" +%s 2>/dev/null"
            cmd | getline now_epoch
            close(cmd)
            cmd = "date -j -f \"%Y-%m-%d %H:%M:%S\" \"" last_stop[$3] "\" +%s 2>/dev/null || date -d \"" last_stop[$3] "\" +%s 2>/dev/null"
            cmd | getline last_epoch
            close(cmd)
            gap = now_epoch - last_epoch
            if (gap > 0 && gap < threshold) {
                rapid[$3]++
                total_redispatch[$3] += gap
            }
            if ($2 == "start") {
                total_starts[$3]++
            }
        }
        if ($2 == "start") {
            total_starts[$3]++
        }
    }
    END {
        for (a in total_starts) {
            rcount = (a in rapid) ? rapid[a] : 0
            avg_gap = (rcount > 0) ? int(total_redispatch[a] / rcount) : 0
            printf "%s|%d|%d|%d\n", a, total_starts[a], rcount, avg_gap
        }
    }
' "$HISTORY_LOG" | sort -t'|' -k3 -rn > "$RESULTS"

# --- Output table ---
if [ ! -s "$RESULTS" ]; then
    echo "  ${MARK_SKIP} No agent dispatch events u poslednjih ${DAYS} dana." >&2
    exit 0
fi

printf "  ${B}%-30s %8s %8s %8s${R}\n" "Agent type" "Starts" "Rapid" "Avg gap"
echo "  $(_dashes 58)"

TOTAL_RAPID=0
TOTAL_STARTS=0
HAS_EXHAUST=false

while IFS='|' read -r agent_type starts rapid avg_gap; do
    [ -n "$agent_type" ] || continue

    TOTAL_STARTS=$((TOTAL_STARTS + starts))
    TOTAL_RAPID=$((TOTAL_RAPID + rapid))

    # Color the rapid count
    if [ "$rapid" -ge 5 ]; then
        rapid_colored="${RED}${B}${rapid}${R}"
        HAS_EXHAUST=true
    elif [ "$rapid" -ge 2 ]; then
        rapid_colored="${Y}${rapid}${R}"
    elif [ "$rapid" -gt 0 ]; then
        rapid_colored="${D}${rapid}${R}"
    else
        rapid_colored="${G}${rapid}${R}"
    fi

    gap_display="${avg_gap}s"
    [ "$rapid" -eq 0 ] && gap_display="—"

    printf "  %-30s %8d %18b %8s\n" "$agent_type" "$starts" "$rapid_colored" "$gap_display"
done < "$RESULTS"

echo "  $(_dashes 58)"
printf "  ${D}Total: %d starts, %d rapid re-dispatches${R}\n" "$TOTAL_STARTS" "$TOTAL_RAPID"
echo ""

# --- Suggested actions ---
echo "  ${B}Interpretation:${R}"
echo "  ${D}- Rapid re-dispatch (gap < ${RAPID_THRESHOLD}s) = proxy za maxTurn exhaust${R}"
echo "  ${D}- Agent hits limit, orchestrator dispatches fresh agent sa istim scope-om${R}"
echo "  ${D}- Re-dispatch ima 10+ turn re-read overhead (counterintuitive cost)${R}"
echo ""

if [ "$HAS_EXHAUST" = true ]; then
    echo "  ${B}Suggested actions:${R}"
    while IFS='|' read -r agent_type starts rapid avg_gap; do
        [ "$rapid" -ge 5 ] || continue
        # Try to read current maxTurns from agent file
        CURRENT_MT=""
        AGENT_FILE="$APD_AGENTS_DIR/${agent_type}.md"
        if [ -f "$AGENT_FILE" ]; then
            CURRENT_MT=$(grep -E '^maxTurns:' "$AGENT_FILE" 2>/dev/null | head -1 | awk '{print $2}')
        fi

        if [ -n "$CURRENT_MT" ]; then
            SUGGESTED=$((CURRENT_MT + 20))
            printf "  %s ${RED}%s${R} — current maxTurns=%d → consider raising to %d\n" "$MARK_FIX" "$agent_type" "$CURRENT_MT" "$SUGGESTED"
            printf "    ${D}Edit: %s frontmatter${R}\n" "$AGENT_FILE"
        else
            printf "  %s ${RED}%s${R} — %d rapid re-dispatch (gap avg %ds)\n" "$MARK_FIX" "$agent_type" "$rapid" "$avg_gap"
            printf "    ${D}Check %s for current maxTurns (file not found)${R}\n" "$AGENT_FILE"
        fi
    done < "$RESULTS"
else
    echo "  ${G}${MARK_PASS} No agent_type sa ≥5 rapid re-dispatches u poslednjih ${DAYS} dana.${R}"
    echo "  ${D}Trenutni maxTurns vrednosti adequate za observed task profile.${R}"
fi

echo ""
echo "  ${D}Override: --days N --threshold-seconds S${R}"
