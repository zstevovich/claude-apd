#!/bin/bash
# APD Pipeline Advance — advances pipeline step with timestamps
#
# Usage:
#   pipeline-advance spec "Task name"
#   pipeline-advance builder|reviewer|verifier
#   pipeline-advance reset|status|stats|metrics|rollback
#   pipeline-advance show [spec|plan|state|deferred]
#   pipeline-advance spinoff-finding <id> "<reason>"  (defer accepted out-of-scope finding)
#   pipeline-advance init "Description"  (first setup only)

source "$(dirname "$0")/../lib/resolve-project.sh"

mkdir -p "$PIPELINE_DIR"

# File lock — prevent concurrent pipeline operations (POSIX-compatible, no flock)
LOCK_DIR="$PIPELINE_DIR/.lock"
# Clean up legacy lock file (from old flock-based implementation)
[ -f "$LOCK_DIR" ] && rm -f "$LOCK_DIR"
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    # Lock already held. Decide between "stale" (>5 min — reclaim) and "active"
    # (someone else is running — bail out). The reclaim path must re-check the
    # mkdir return code so two concurrent stale-detecting processes can't both
    # think they own the lock.
    LOCK_AGE=0
    LOCK_MTIME=$(stat -f %m "$LOCK_DIR" 2>/dev/null || stat -c %Y "$LOCK_DIR" 2>/dev/null || echo 0)
    [ "$LOCK_MTIME" -gt 0 ] 2>/dev/null && LOCK_AGE=$(( $(date +%s) - LOCK_MTIME ))

    if [ "$LOCK_AGE" -gt 300 ]; then
        rmdir "$LOCK_DIR" 2>/dev/null
        if ! mkdir "$LOCK_DIR" 2>/dev/null; then
            echo "BLOCKED: Pipeline lock reclaimed by another session during stale cleanup." >&2
            echo "  Retry in a few seconds, or: rmdir .apd/pipeline/.lock" >&2
            exit 1
        fi
    else
        echo "BLOCKED: Pipeline is locked by another session." >&2
        echo "  Wait for the other session to finish or: rmdir .apd/pipeline/.lock" >&2
        exit 1
    fi
fi
# Auto-remove lock on exit
trap 'rmdir "$LOCK_DIR" 2>/dev/null; exit' EXIT INT TERM

# Breadcrumb from a prior killed reset — let the user see it once.
if [ -f "$PIPELINE_DIR/.reset-in-progress" ]; then
    echo "WARN: previous pipeline reset did not complete cleanly." >&2
    echo "  Inspect: ls -la $PIPELINE_DIR" >&2
    echo "  If the contents look fine, clear: rm $PIPELINE_DIR/.reset-in-progress" >&2
fi

# v6.15 — --skip-brainstorm REMOVED (deprecation shim, drop in v7.0).
# The brainstorm-marker gate + skip valve (v6.8.5/v6.8.8/v6.8.11) were replaced
# by the unconditional guide-marker gate (apd-pipeline-guide skill). The guide
# is non-interactive and cheap; there is nothing to skip, so no skip path exists.
# Strip the legacy flag + its reason from positional args, then hard-error —
# a silent fallback would resurrect the no-education path.
_legacy_skip_flag=false
_positional_args=()
_capture_reason=false
for _arg in "$@"; do
    if [ "$_capture_reason" = true ]; then
        _capture_reason=false
        continue
    fi
    if [ "$_arg" = "--skip-brainstorm" ]; then
        _legacy_skip_flag=true
        _capture_reason=true
        continue
    fi
    _positional_args+=("$_arg")
done
STEP="${_positional_args[0]:-}"
ARG="${_positional_args[1]:-}"
ARG2="${_positional_args[2]:-}"
if [ "$_legacy_skip_flag" = true ]; then
    echo "BLOCKED: --skip-brainstorm was removed in v6.15." >&2
    echo "" >&2
    echo "  The brainstorm skill no longer gates the pipeline. The spec gate now" >&2
    echo "  requires /apd-pipeline-guide (the pipeline operating manual) instead —" >&2
    echo "  it is non-interactive, ~2 minutes, and has NO skip path by design." >&2
    echo "" >&2
    echo "  Recovery: load /apd-pipeline-guide, let it write .guide-marker, then" >&2
    echo "  re-run:  bash $APD_SHORTCUT_DISPLAY pipeline spec \"$ARG\"" >&2
    exit 1
fi
NOW=$(date +%s)
NOW_HUMAN=$(date +"%Y-%m-%d %H:%M:%S")

# --- Visual helpers ---
source "$(dirname "$0")/../lib/style.sh"

# --- Agent validation ---
# Delegates to compiled Go binary for tamper-proof validation.
# Binary checks: timestamp format, agent_id hex, start/stop pairs, duration.
# Orchestrator cannot read binary source code to learn validation rules.
# Falls back to basic check if binary is not available.
validate_agent_entry() {
    local look_for_evt="$1"
    local agent_name="$2"
    local log_file="$3"

    # Resolve platform-specific binary
    local os_name arch_name validator
    os_name=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch_name=$(uname -m)
    [ "$arch_name" = "x86_64" ] && arch_name="amd64"
    validator="${APD_PLUGIN_ROOT}/bin/compiled/validate-agent-${os_name}-${arch_name}"

    if [ -x "$validator" ]; then
        # Use compiled binary (opaque to orchestrator)
        local result
        result=$("$validator" check -agent "$agent_name" -agents-log "$log_file" 2>&1)
        local exit_code=$?
        if [ $exit_code -ne 0 ]; then
            echo "  ${MARK_FAIL} $result" >&2
            return 1
        fi
        return 0
    fi

    # Binary not available. The compiled validator is the tamper-proof path;
    # the bash fallback is trivially satisfied by writing one forged line into
    # .agents. Fail closed by default. A user on an unsupported platform can
    # set APD_ALLOW_UNVALIDATED_AGENTS=1 to opt into the weaker bash check.
    if [ "${APD_ALLOW_UNVALIDATED_AGENTS:-0}" != "1" ]; then
        echo "  ${MARK_FAIL} validate-agent binary not found for ${os_name}-${arch_name}" >&2
        echo "  Expected: $validator" >&2
        echo "  Workaround (weak fallback): APD_ALLOW_UNVALIDATED_AGENTS=1 apd pipeline $STEP" >&2
        return 1
    fi
    if ! grep -q "|${look_for_evt}|${agent_name}|" "$log_file" 2>/dev/null; then
        echo "  ${MARK_FAIL} $agent_name: no ${look_for_evt} entry found" >&2
        return 1
    fi
    echo "  WARN: using unvalidated bash fallback (APD_ALLOW_UNVALIDATED_AGENTS=1)" >&2
    return 0
}

# Resolve compiled binary path (shared by all functions)
_os_name=$(uname -s | tr '[:upper:]' '[:lower:]')
_arch_name=$(uname -m)
[ "$_arch_name" = "x86_64" ] && _arch_name="amd64"
APD_VALIDATOR="${APD_PLUGIN_ROOT}/bin/compiled/validate-agent-${_os_name}-${_arch_name}"

# Create signed .done file via compiled binary (tamper-proof)
# Falls back to plain text if binary not available
create_done() {
    local step="$1"
    local task_name="${2:-}"
    if [ -x "$APD_VALIDATOR" ]; then
        if [ -n "$task_name" ]; then
            "$APD_VALIDATOR" advance -step "$step" -task "$task_name" -pipeline-dir "$PIPELINE_DIR" 2>&1
        else
            "$APD_VALIDATOR" advance -step "$step" -pipeline-dir "$PIPELINE_DIR" 2>&1
        fi
    else
        # Fallback: unsigned .done (old behavior)
        if [ -n "$task_name" ]; then
            echo "${NOW}|${NOW_HUMAN}|${task_name}" > "$PIPELINE_DIR/${step}.done"
        else
            echo "${NOW}|${NOW_HUMAN}" > "$PIPELINE_DIR/${step}.done"
        fi
    fi
}

# archive_rationale — append the current task's adversarial rationale to a permanent
# audit trail BEFORE pipeline state is wiped (spec re-advance + reset). Mirrors the
# agent-history.log archival pattern. Without this, dismiss-heavy runs (high Do-share,
# e.g. 11:1:10 / 8:1:7) lose their per-finding rationale on reset and cannot be
# retro-audited — the in-flight gate (warns + A>=1) was the only check. Best-effort;
# never blocks. Task name from spec.done (line1 col3); summary from .adversarial-summary.
archive_rationale() {
    # Skip verify-apd's synthetic Section 8 rationale (same rationale as #1 tagging).
    [ "${APD_AUDIT_SYNTHETIC:-}" = "1" ] && return 0
    local rat="$PIPELINE_DIR/.adversarial-rationale.md"
    local sup="$PIPELINE_DIR/.supervision-rationale.md"
    [ -s "$rat" ] || [ -s "$sup" ] || return 0
    [ -n "${MEMORY_DIR:-}" ] && [ -d "$MEMORY_DIR" ] || return 0
    local archive="$MEMORY_DIR/adversarial-rationale-archive.md"
    local ts task adv supline
    ts=$(date +"%Y-%m-%d %H:%M:%S")
    task=$(head -1 "$PIPELINE_DIR/spec.done" 2>/dev/null | cut -d'|' -f3)
    [ -n "$task" ] || task="(unknown)"
    adv=$(grep '^ADVERSARIAL:' "$PIPELINE_DIR/.adversarial-summary" 2>/dev/null | head -1)
    [ -n "$adv" ] || adv="ADVERSARIAL:n/a"
    {
        echo ""
        echo "<!-- ============================================================ -->"
        echo "## Archived $ts — $task"
        echo "**Summary:** $adv"
        echo ""
        if [ -s "$rat" ]; then
            cat "$rat"
            echo ""
        fi
        # v6.30 — supervision rationale rides in the same archive entry so a
        # dismiss-heavy supervision pass stays retro-auditable (same
        # ephemerality lesson as the adversarial rationale).
        if [ -s "$sup" ]; then
            supline=$(grep '^SUPERVISION:' "$PIPELINE_DIR/.supervision-summary" 2>/dev/null | head -1)
            echo "### Supervision rationale"
            echo "**Summary:** ${supline:-SUPERVISION:n/a}"
            echo ""
            cat "$sup"
            echo ""
        fi
    } >> "$archive" 2>/dev/null || true
}

# print_pipeline_state — read-only digest of pipeline state. The sanctioned
# alternative to bash `cat`/`ls` on .apd/pipeline (which guard-bash-scope blocks).
# Prints DIGESTS (counts/status lines) of pipeline-generated state, not raw
# fabricatable dumps: spec-card/plan are the orchestrator's own (full echo lives
# in `show spec|plan`), while .reviewed-files and adversarial state appear only as
# counts/summary here so a read cannot be repurposed to fake review/adversarial state.
print_pipeline_state() {
    local pd="$PIPELINE_DIR"
    echo ""
    echo "  State (read-only):"
    if [ -f "$pd/spec-card.md" ]; then
        local _crit
        _crit=$(grep -cE '^[[:space:]]*[-*]?[[:space:]]*\*{0,2}R[0-9]+\*{0,2}[:.) ]' "$pd/spec-card.md" 2>/dev/null)
        echo "    spec-card.md: present (${_crit:-0} R-criteria) — full text: apd pipeline show spec"
    else
        echo "    spec-card.md: none"
    fi
    if [ -f "$pd/implementation-plan.md" ]; then
        echo "    implementation-plan.md: present — full text: apd pipeline show plan"
    else
        echo "    implementation-plan.md: none"
    fi
    if [ -f "$pd/.reviewed-files" ]; then
        local _rc
        _rc=$(grep -c . "$pd/.reviewed-files" 2>/dev/null)
        echo "    reviewed-files: ${_rc:-0} file(s) covered"
    fi
    if [ -f "$pd/.adversarial-summary" ]; then
        local _adv
        _adv=$(grep '^ADVERSARIAL:' "$pd/.adversarial-summary" 2>/dev/null | head -1)
        echo "    adversarial: ${_adv:-n/a}"
    fi
    if [ -f "$pd/.adversarial-rationale.md" ]; then
        local _fc _ndo _ndr
        _fc=$(grep -c '^## Finding ' "$pd/.adversarial-rationale.md" 2>/dev/null)
        _ndo=$(grep -c '^\*\*Status:\*\* dismissed$' "$pd/.adversarial-rationale.md" 2>/dev/null)
        _ndr=$(grep -c '^\*\*Status:\*\* reviewer-self-dismissed$' "$pd/.adversarial-rationale.md" 2>/dev/null)
        echo "    rationale: present (${_fc:-0} findings, Do=${_ndo:-0} Dr=${_ndr:-0})"
    else
        echo "    rationale: none"
    fi
    if [ -f "$pd/.supervision-summary" ]; then
        local _sup _sfc
        _sup=$(grep '^SUPERVISION:' "$pd/.supervision-summary" 2>/dev/null | head -1)
        _sfc=""
        if [ -f "$pd/.supervision-rationale.md" ]; then
            _sfc=" ($(grep -c '^## Finding ' "$pd/.supervision-rationale.md" 2>/dev/null) rationale blocks)"
        fi
        echo "    supervision: ${_sup:-n/a}${_sfc}"
    fi
    [ -f "$pd/.builder-count" ]  && echo "    builder cycles:  $(cat "$pd/.builder-count" 2>/dev/null)"
    [ -f "$pd/.reviewer-count" ] && echo "    reviewer cycles: $(cat "$pd/.reviewer-count" 2>/dev/null)"
    if [ -f "$pd/.deferred-findings" ]; then
        local _dfc
        _dfc=$(grep -c . "$pd/.deferred-findings" 2>/dev/null)
        echo "    deferred (spinoff) findings: ${_dfc:-0} — see: apd pipeline show deferred"
    fi
}

# _supervision_issue <summary-file> <rationale-file> — v6.30 supervision gate
# structural checks, mirroring the adversarial rationale contract (count match,
# valid fields, T/A/D accounting, 100%-orchestrator-dismiss pattern). Prints the
# FIRST issue found as "code|detail"; prints nothing when structurally clean.
# The caller decides warn vs block (Phase 1 rollout default = warn).
_supervision_issue() {
    local sum="$1" rat="$2" line t a d fc sev st ra af s_do s_dr
    [ -f "$sum" ] || { echo "supervision-missing|no .supervision-summary"; return; }
    line=$(grep '^SUPERVISION:' "$sum" 2>/dev/null | head -1)
    [ -n "$line" ] || { echo "supervision-summary-malformed|no SUPERVISION:T:A:D line"; return; }
    t=$(echo "$line" | cut -d: -f2); a=$(echo "$line" | cut -d: -f3); d=$(echo "$line" | cut -d: -f4)
    t=${t:-0}; a=${a:-0}; d=${d:-0}
    case "${t}${a}${d}" in *[!0-9]*) echo "supervision-summary-malformed|non-numeric T/A/D ($line)"; return ;; esac
    if [ "$t" -gt 0 ]; then
        [ -f "$rat" ] || { echo "supervision-rationale-missing|T=$t"; return; }
        fc=$(grep -c '^## Finding ' "$rat" 2>/dev/null); fc=${fc:-0}
        if [ "$fc" -ne "$t" ]; then echo "supervision-rationale-count-mismatch|found=$fc expected=$t"; return; fi
        sev=$(grep -cE '^\*\*Severity:\*\* (critical|important|minor)$' "$rat" 2>/dev/null); sev=${sev:-0}
        st=$(grep -cE '^\*\*Status:\*\* (accepted|dismissed|reviewer-self-dismissed)$' "$rat" 2>/dev/null); st=${st:-0}
        ra=$(grep -cE '^\*\*Rationale:\*\* .+' "$rat" 2>/dev/null); ra=${ra:-0}
        if [ "$sev" -ne "$fc" ] || [ "$st" -ne "$fc" ] || [ "$ra" -ne "$fc" ]; then
            echo "supervision-rationale-malformed|sev=$sev stat=$st rat=$ra findings=$fc"; return
        fi
        af=$(grep -c '^\*\*Status:\*\* accepted$' "$rat" 2>/dev/null); af=${af:-0}
        s_do=$(grep -c '^\*\*Status:\*\* dismissed$' "$rat" 2>/dev/null); s_do=${s_do:-0}
        s_dr=$(grep -c '^\*\*Status:\*\* reviewer-self-dismissed$' "$rat" 2>/dev/null); s_dr=${s_dr:-0}
        if [ "$af" -ne "$a" ]; then echo "supervision-accepted-mismatch|rationale=$af summary=$a"; return; fi
        if [ $((s_do + s_dr)) -ne "$d" ]; then echo "supervision-status-mismatch|Do=$s_do Dr=$s_dr sum=$((s_do + s_dr)) D=$d"; return; fi
        if [ "$t" -ge 3 ] && [ "$a" -eq 0 ] && [ "$s_do" -ge 1 ]; then
            echo "supervision-100pct-orch-dismiss|T=$t Do=$s_do Dr=$s_dr"; return
        fi
    fi
    return 0
}

# Verify .done file signature
verify_done() {
    local step="$1"
    if [ -x "$APD_VALIDATOR" ]; then
        local result
        result=$("$APD_VALIDATOR" verify -step "$step" -pipeline-dir "$PIPELINE_DIR" 2>&1)
        if [ $? -ne 0 ]; then
            echo "BLOCKED: $result" >&2
            echo "" >&2
            echo "  The ${step}.done file was not created by pipeline-advance." >&2
            echo "  Use: bash $APD_SHORTCUT_DISPLAY pipeline ${step}" >&2
            log_block "forged-done-file" "${step}.done"
            return 1
        fi
    fi
    return 0
}

# --- Agent-evidence helpers — hook-non-delivery robustness (v6.x) -------------
# The .agents ledger is written by the CC SubagentStart/Stop hooks. Those can
# silently fail to fire (background dispatch, harness quirk, CC bug — observed
# 2026-06-04 and 2026-06-29), leaving .agents empty even though real agents ran
# → the builder/reviewer gates false-BLOCK. _reconstruct_from_transcripts
# rebuilds .agents from the CC subagent transcripts on disk (ground truth — the
# orchestrator cannot fabricate them). The scan helpers are factored out so the
# gate can re-scan after a fallback reconstruct. Single source of truth for
# "what counts as a real agent" — the gate fallback and the reconstruct-agents
# subcommand share the SAME reconstruct logic (no security-relevant drift).

# Rebuild .agents from CC subagent transcripts for the current task window.
# Sets RA_COUNT (new pairs written) and RA_BASE (transcript dir, global so the
# caller can report it). Returns 0 if it ran (even with 0 new pairs), 1 if a
# precondition is missing (no spec.done / no transcript dir) — silent, so the
# gate fallback can call it unconditionally.
_reconstruct_from_transcripts() {
    RA_COUNT=0
    [ -f "$PIPELINE_DIR/spec.done" ] || return 1
    local RA_SPEC_TS _meta _jsonl _id _stop _start _type _sh _eh
    local _alog="$PIPELINE_DIR/.agents"
    RA_SPEC_TS=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f1)
    # CC transcript dir: project path with every non-alnum char → '-'
    RA_BASE="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects/$(printf '%s' "$PROJECT_DIR" | sed 's#[^A-Za-z0-9]#-#g')"
    [ -d "$RA_BASE" ] || return 1
    [ "${RA_DRY_RUN:-0}" = "1" ] || touch "$_alog"
    for _meta in "$RA_BASE"/*/subagents/agent-*.meta.json; do
        [ -f "$_meta" ] || continue
        _jsonl="${_meta%.meta.json}.jsonl"
        [ -f "$_jsonl" ] || continue   # require the transcript itself = proof it ran
        _id=$(basename "$_meta" | sed 's/^agent-//; s/\.meta\.json$//')
        grep -qF "|${_id}" "$_alog" 2>/dev/null && continue           # already recorded
        _stop=$(stat -f %m "$_jsonl" 2>/dev/null || stat -c %Y "$_jsonl" 2>/dev/null || echo 0)
        [ "$_stop" -ge "$RA_SPEC_TS" ] 2>/dev/null || continue        # current-task window only
        _start=$(stat -f %m "$_meta" 2>/dev/null || stat -c %Y "$_meta" 2>/dev/null || echo "$_stop")
        [ "$_start" -lt "$_stop" ] 2>/dev/null || _start=$(( _stop - 60 ))
        _type=$(sed -n 's/.*"agentType"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_meta" | head -1)
        [ -n "$_type" ] || continue
        # Detect-only (dry-run): count what WOULD be recoverable, write nothing.
        if [ "${RA_DRY_RUN:-0}" = "1" ]; then RA_COUNT=$((RA_COUNT + 1)); continue; fi
        _sh=$(date -r "$_start" +"%Y-%m-%d %H:%M:%S" 2>/dev/null || date -d "@$_start" +"%Y-%m-%d %H:%M:%S" 2>/dev/null)
        _eh=$(date -r "$_stop" +"%Y-%m-%d %H:%M:%S" 2>/dev/null || date -d "@$_stop" +"%Y-%m-%d %H:%M:%S" 2>/dev/null)
        printf '%s|start|%s|%s\n' "$_sh" "$_type" "$_id" >> "$_alog"
        printf '%s|stop|%s|%s\n'  "$_eh" "$_type" "$_id" >> "$_alog"
        RA_COUNT=$((RA_COUNT + 1))
        [ "${RA_VERBOSE:-0}" = "1" ] && echo "  + ${_type} (${_id})  ${_sh} → ${_eh}"
    done
    [ "${RA_DRY_RUN:-0}" = "1" ] && return 0   # detect-only: write nothing, no audit log
    if [ -n "${MEMORY_DIR:-}" ] && [ -d "$MEMORY_DIR" ]; then
        echo "$(date +"%Y-%m-%d %H:%M:%S")|INFO|reconstruct-agents|rebuilt $RA_COUNT transcript-backed agent pair(s) from $RA_BASE" >> "$MEMORY_DIR/guard-audit.log"
    fi
    return 0
}

# Scan .agents for a post-spec, project-defined, validated builder stop event.
# Sets BUILDER_RAN + diagnostics (BLOCKED_AGENTS / SUSPICIOUS / STALE_DISPATCH).
# Reads AGENTS_LOG, SPEC_TS_HUMAN, APD_AGENTS_DIR. Factored so the gate can
# re-scan after a fallback reconstruct.
_scan_builder_ran() {
    BUILDER_RAN=""; BLOCKED_AGENTS=""; SUSPICIOUS=""; STALE_DISPATCH=""
    local REJECTED_PREFIXES="superpowers:" _ts _evt agent_type _id
    [ -f "$AGENTS_LOG" ] || return 0
    while IFS='|' read -r _ts _evt agent_type _id; do
        [ "$_evt" = "stop" ] || continue
        if echo "$agent_type" | grep -qE "^(${REJECTED_PREFIXES})"; then
            BLOCKED_AGENTS="${BLOCKED_AGENTS}${agent_type}, "; continue
        fi
        if [ -n "$_ts" ] && [ -n "$SPEC_TS_HUMAN" ] && [ "$_ts" \< "$SPEC_TS_HUMAN" ]; then
            [ -f "$APD_AGENTS_DIR/${agent_type}.md" ] && STALE_DISPATCH="${STALE_DISPATCH}${agent_type}, "
            continue
        fi
        if [ -f "$APD_AGENTS_DIR/${agent_type}.md" ]; then
            if validate_agent_entry "stop" "$agent_type" "$AGENTS_LOG"; then BUILDER_RAN="$agent_type"
            else SUSPICIOUS="${SUSPICIOUS}${agent_type}, "; fi
        fi
    done < "$AGENTS_LOG"
    return 0
}

# Scan .agents for a project-defined, validated reviewer stop event (name ~ review).
# Sets REVIEWER_RAN + diagnostics (BLOCKED_AGENTS / SUSPICIOUS). Reads AGENTS_LOG,
# APD_AGENTS_DIR. (Reviewer scan has no pre-spec STALE filter — mirrors original.)
_scan_reviewer_ran() {
    REVIEWER_RAN=""; BLOCKED_AGENTS=""; SUSPICIOUS=""
    local REJECTED_PREFIXES="superpowers:" _ts _evt agent_type _id
    [ -f "$AGENTS_LOG" ] || return 0
    while IFS='|' read -r _ts _evt agent_type _id; do
        [ "$_evt" = "stop" ] || continue
        if echo "$agent_type" | grep -qE "^(${REJECTED_PREFIXES})"; then
            BLOCKED_AGENTS="${BLOCKED_AGENTS}${agent_type}, "; continue
        fi
        if [ -f "$APD_AGENTS_DIR/${agent_type}.md" ] && echo "$agent_type" | grep -qiE 'review'; then
            if validate_agent_entry "stop" "$agent_type" "$AGENTS_LOG"; then REVIEWER_RAN="$agent_type"
            else SUSPICIOUS="${SUSPICIOUS}${agent_type}, "; fi
        fi
    done < "$AGENTS_LOG"
    return 0
}

case "$STEP" in
    spec)
        if [ -z "$ARG" ]; then
            echo "ERROR: Task name is required." >&2
            exit 1
        fi

        # Check if the previous session-log entry has unfilled [fill in] placeholders
        SESSION_LOG="$MEMORY_DIR/session-log.md"
        if [ -f "$SESSION_LOG" ]; then
            # Find the last entry — from the last ## [date] to end of file
            LAST_ENTRY_LINE=$(grep -n '^## \[' "$SESSION_LOG" | tail -1 | cut -d: -f1)
            if [ -n "$LAST_ENTRY_LINE" ]; then
                LAST_ENTRY=$(tail -n +"$LAST_ENTRY_LINE" "$SESSION_LOG")
            else
                LAST_ENTRY=""
            fi
            if echo "$LAST_ENTRY" | grep -q '\[fill in' 2>/dev/null; then
                LAST_TITLE=$(echo "$LAST_ENTRY" | head -1)
                echo "BLOCKED: Previous session-log entry is not filled in!" >&2
                echo "" >&2
                echo "  Entry: $LAST_TITLE" >&2
                echo "  Contains [fill in] placeholders." >&2
                echo "" >&2
                echo "  Fill in session-log.md before starting a new task:" >&2
                echo "  - What was done" >&2
                echo "  - Problems (or \"No problems\")" >&2
                echo "  - Guardrail that helped (or \"N/A\")" >&2
                echo "  - New rule (or \"None\")" >&2
                exit 1
            fi
        fi

        # Validate spec-card.md exists and has R* criteria (hard block)
        if [ ! -f "$PIPELINE_DIR/spec-card.md" ]; then
            echo "BLOCKED: spec-card.md not found." >&2
            echo "" >&2
            echo "  Write the spec card to .apd/pipeline/spec-card.md before advancing." >&2
            echo "  Acceptance criteria must use R1:, R2:, ... format." >&2
            exit 1
        fi
        if ! grep -qE '^[[:space:]]*-[[:space:]]+R[0-9]+[[:space:]]*:' "$PIPELINE_DIR/spec-card.md"; then
            echo "BLOCKED: spec-card.md has no R* acceptance criteria." >&2
            echo "" >&2
            echo "  Expected format in spec-card.md:" >&2
            echo "    - R1: First requirement" >&2
            echo "    - R2: Second requirement" >&2
            exit 1
        fi
        # Check criteria count — too many means feature should be decomposed
        # Only count R* lines within the Acceptance criteria section (between header and next ** section)
        MAX_CRITERIA=7
        CRITERIA_COUNT=$(sed -n '/Acceptance criteria/,/^\*\*[A-Z]/p' "$PIPELINE_DIR/spec-card.md" 2>/dev/null | grep -cE '^[[:space:]]*-[[:space:]]+R[0-9]+[[:space:]]*:' || echo 0)
        if [ "$CRITERIA_COUNT" -gt "$MAX_CRITERIA" ]; then
            echo "BLOCKED: spec-card.md has $CRITERIA_COUNT criteria (max $MAX_CRITERIA)." >&2
            echo "" >&2
            echo "  Decompose into smaller tasks — each task should be one pipeline cycle." >&2
            echo "  Large features = large rollbacks. Small tasks = safe commits." >&2
            exit 1
        fi

        # v6.15 — guide-marker hard gate, UNCONDITIONAL, NO skip path.
        # Every spec advance MUST be preceded by /apd-pipeline-guide skill load.
        # Skill writes .guide-marker on exit. Reset wipes it.
        #
        # Replaces the v6.8.5/v6.8.11 brainstorm-marker gate. Rationale for the
        # split (2026-06-10): apd-brainstorm carried two roles — clarification
        # dialogue (legitimately skippable when scope is pre-aligned) and the
        # pipeline tutor (never legitimately skippable). The skip valve discarded
        # education along with ceremony: orchestrators rationally skipped a skill
        # NAMED "brainstorm" when the task was clear, unaware it carried the gate
        # contract — the residual skip→BLOCK rate was exactly education-shaped
        # (forgotten Implements headers). The guide is non-interactive and ~10×
        # cheaper than one BLOCK loop, so the gate has no opt-out by design:
        # there is nothing interactive to skip, and reading the contract is
        # cheaper than negotiating about it. Brainstorm remains advisory for
        # genuinely unclear scope; it no longer gates anything.
        GUIDE_MARKER="$PIPELINE_DIR/.guide-marker"
        GUIDE_OK=false
        if [ -f "$GUIDE_MARKER" ]; then
            MARKER_TASK=$(cut -d'|' -f1 "$GUIDE_MARKER" 2>/dev/null)
            if [ "$MARKER_TASK" = "$ARG" ]; then
                GUIDE_OK=true
            fi
        fi
        if [ "$GUIDE_OK" = false ]; then
            echo "BLOCKED: Guide marker missing for spec advance ($CRITERIA_COUNT R-criteria declared)." >&2
            echo "" >&2
            echo "  /apd-pipeline-guide is the pipeline operating manual — MANDATORY on" >&2
            echo "  every task, even when the scope is perfectly clear. It carries:" >&2
            echo "    - the gate fired at each pipeline advance" >&2
            echo "    - implementation plan **Implements:** header contract (EVERY section)" >&2
            echo "    - adversarial rationale .md file contract" >&2
            echo "    - common BLOCK shapes + recovery, and the state read path" >&2
            echo "" >&2
            echo "  Way forward (there is no skip flag):" >&2
            echo "    Load /apd-pipeline-guide, walk through it, let it write" >&2
            echo "    .guide-marker with task name \"$ARG\", then re-run:" >&2
            echo "      bash $APD_SHORTCUT_DISPLAY pipeline spec \"$ARG\"" >&2
            echo "" >&2
            echo "  If the task scope is vague, load /apd-brainstorm FIRST (interactive" >&2
            echo "  clarification), converge with the user, then load the guide." >&2
            log_block "guide-marker-missing" "task=$ARG criteria=$CRITERIA_COUNT"
            exit 1
        fi

        # v6.3 D — max_defects immutability across rollback+re-advance for same task.
        # Existing .spec-hash check at verifier catches direct edits AFTER spec.done.
        # This check catches the loophole: rollback → edit spec-card.md → re-advance spec.
        # Reset wipes the snapshot — it is the explicit escape valve for a real pivot.
        SNAPSHOT_FILE="$PIPELINE_DIR/.spec-max-defects-history"
        CURRENT_MAX=$(grep -iE '^[-*_ 	]*adversarial[-*_ 	]*:.*max_defects[[:space:]]*[:=][[:space:]]*([0-9]+|unlimited)' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
            | sed -E 's/.*max_defects[[:space:]]*[:=][[:space:]]*//I' \
            | tr '[:upper:]' '[:lower:]' \
            | awk '{print $1}' \
            | head -1)
        # v6.9 — track whether field was explicitly present (before default fill)
        MAX_DEFECTS_PRESENT=false
        [ -n "$CURRENT_MAX" ] && MAX_DEFECTS_PRESENT=true
        [ -z "$CURRENT_MAX" ] && CURRENT_MAX="unlimited"

        # v6.9 — soft deprecation warn for explicit max_defects field.
        # Will be removed in v7.0. Verifier gate (v6.1 B2) + immutability check
        # (v6.3 D) STILL ACTIVE in v6.9 — graceful transition window. Rationale
        # gate (v6.7) structurally covers the misuse pattern that max_defects
        # was meant to prevent (per-finding rationale ≥40 chars dismissed,
        # 100%-Do hard-block, bulk-accept rationale validation).
        if [ "$MAX_DEFECTS_PRESENT" = true ]; then
            echo "" >&2
            echo "WARN: 'adversarial: max_defects=$CURRENT_MAX' is DEPRECATED as of v6.9." >&2
            echo "  Will be removed in v7.0. Field continues to function in v6.9 for" >&2
            echo "  graceful transition: verifier gate + immutability check both active." >&2
            echo "" >&2
            echo "  Why deprecated: rationale gate (v6.7) structurally covers misuse." >&2
            echo "  Migration: omit 'adversarial: max_defects=...' from spec-card.md." >&2
            echo "  Default (= unlimited) + rationale gate is the v7.0 baseline." >&2
            echo "" >&2
            if [ -n "${MEMORY_DIR:-}" ] && [ -d "$MEMORY_DIR" ]; then
                _ts=$(date +"%Y-%m-%d %H:%M:%S")
                echo "${_ts}|$(_audit_type INFO)|orchestrator|max-defects-deprecated|task=$ARG value=$CURRENT_MAX" >> "$MEMORY_DIR/guard-audit.log"
            fi
        fi

        if [ -f "$SNAPSHOT_FILE" ]; then
            PREV_TASK=$(cut -d'|' -f1 "$SNAPSHOT_FILE" 2>/dev/null)
            PREV_MAX=$(cut -d'|' -f2 "$SNAPSHOT_FILE" 2>/dev/null)
            if [ "$PREV_TASK" = "$ARG" ] && [ -n "$PREV_MAX" ] && [ "$PREV_MAX" != "unlimited" ]; then
                RAISED=false
                if [ "$CURRENT_MAX" = "unlimited" ]; then
                    RAISED=true
                elif [ "$CURRENT_MAX" -gt "$PREV_MAX" ] 2>/dev/null; then
                    RAISED=true
                fi
                if [ "$RAISED" = true ]; then
                    echo "BLOCKED: max_defects raised from $PREV_MAX to $CURRENT_MAX for the same task." >&2
                    echo "" >&2
                    echo "  Task '$ARG' was previously specced with max_defects=$PREV_MAX." >&2
                    echo "  Raising mid-pipeline defeats the severity gate (v6.1 B2)." >&2
                    echo "" >&2
                    echo "  Two ways forward:" >&2
                    echo "    (a) Lower (or keep) max_defects in spec-card.md and re-advance." >&2
                    echo "    (b) Reset the pipeline: pipeline-advance reset '<pivot rationale>'." >&2
                    log_block "max_defects-raised-mid-pipeline" "task=$ARG prev=$PREV_MAX new=$CURRENT_MAX"
                    exit 1
                fi
            fi
        fi

        # Archive agent log before clearing (permanent audit trail)
        if [ -f "$PIPELINE_DIR/.agents" ]; then
            cat "$PIPELINE_DIR/.agents" >> "$MEMORY_DIR/agent-history.log"
        fi
        # Archive the completing task's adversarial rationale before it is wiped
        # (spec re-advance is the most common rationale-loss point — new spec-card
        # is already on disk, old rationale would vanish silently otherwise).
        archive_rationale
        # v6.3 audit fix: also wipe .builder-count / .reviewer-count so a new
        # task doesn't inherit cycle counts from a prior task (would block first
        # dispatch with a misleading "task X has hit its budget" message).
        rm -f "$PIPELINE_DIR"/*.done "$PIPELINE_DIR/verified.timestamp" "$PIPELINE_DIR/.agents" "$PIPELINE_DIR/.trace-summary" "$PIPELINE_DIR/.adversarial-summary" "$PIPELINE_DIR/.adversarial-pending" "$PIPELINE_DIR/.adversarial-rationale.md" "$PIPELINE_DIR/.supervision-summary" "$PIPELINE_DIR/.supervision-rationale.md" "$PIPELINE_DIR/.spec-hash" "$PIPELINE_DIR/.reviewed-files" "$PIPELINE_DIR/.builder-count" "$PIPELINE_DIR/.reviewer-count" "$PIPELINE_DIR/.guide-marker" "$PIPELINE_DIR/.brainstorm-marker" "$PIPELINE_DIR/.deferred-findings"
        create_done "spec" "$ARG"
        # Freeze spec-card.md — hash for tamper detection
        shasum -a 256 "$PIPELINE_DIR/spec-card.md" | cut -d' ' -f1 > "$PIPELINE_DIR/.spec-hash"
        # v6.3 D — snapshot max_defects for next spec advance to compare against
        printf '%s|%s\n' "$ARG" "$CURRENT_MAX" > "$SNAPSHOT_FILE"
        apd_spec_header "$ARG"
        show_pipeline "builder"
        # GitHub sync (best-effort — never blocks pipeline)
        bash "$SCRIPT_DIR/gh-sync" spec "$ARG" 2>/dev/null || true
        # Pre-flight checklist
        echo "" >&2
        echo "    ${D}Next steps:${R}" >&2
        echo "    ${D}1. Write .apd/pipeline/implementation-plan.md (files + changes + ### Agents section)${R}" >&2
        echo "    ${D}2. Dispatch project builders: Agent({ subagent_type: \"<agent-name>\", ... })${R}" >&2
        echo "    ${D}3. Dispatch project reviewer: Agent({ subagent_type: \"code-reviewer\", ... })${R}" >&2
        echo "    ${D}   NEVER use superpowers: or feature-dev: agents — pipeline will BLOCK${R}" >&2
        # Model-profile reminder — ADVICE, never a gate. The profile (which model
        # the agents carry) is an economic judgment, not a safety floor, so it
        # must not block. But a passive line in CLAUDE.md gets skipped, so the
        # nudge belongs HERE: the moment the task scope exists, before builders
        # are dispatched (profile switch + /reload-plugins is still cheap now).
        _CUR_PROFILE=$(grep '^MODEL_PROFILE=' "$APD_CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2-)
        [ -z "$_CUR_PROFILE" ] && _CUR_PROFILE="none declared (agents run their own model/effort)"
        echo "" >&2
        echo "    ${D}Model profile: ${_CUR_PROFILE} — judge the fit for THIS task before dispatching:${R}" >&2
        echo "    ${D}  eco (trivial / copy / local) · cruise (standard) · burn (launch-critical / rule-1 path).${R}" >&2
        echo "    ${D}  Switch if it doesn't match: bash $APD_SHORTCUT_DISPLAY profile <name> + /reload-plugins (advisory — never blocks).${R}" >&2
        ;;

    builder)
        if [ ! -f "$PIPELINE_DIR/spec.done" ]; then
            echo "ERROR: Spec must be completed before builder!" >&2
            exit 1
        fi
        verify_done "spec" || exit 1

        # Verify implementation plan exists (hard block)
        if [ ! -f "$PIPELINE_DIR/implementation-plan.md" ]; then
            echo "BLOCKED: implementation-plan.md not found." >&2
            echo "" >&2
            echo "  Write the implementation plan to .apd/pipeline/implementation-plan.md" >&2
            echo "  List files to change with 1-2 sentences per file describing the change." >&2
            exit 1
        fi

        # v6.8.0 — plan-spec consistency gate. Verifies that every R-criterion
        # from spec-card.md is referenced in implementation-plan.md via a
        # **Implements:** header on at least one section, and that every plan
        # section either declares R-ids or `none`. Mode (strict|warn|off) is
        # read from spec-card.md `plan_consistency_gate:` field; v6.8.0
        # default is `warn` (issues do not block). v6.8.1 flips default to
        # `strict`. Opt-out: `plan_consistency_gate: off` in spec-card.md.
        if ! bash "$SCRIPT_DIR/verify-plan-spec"; then
            echo "" >&2
            echo "BLOCKED: plan-spec consistency check failed (strict mode)." >&2
            echo "" >&2
            echo "  Quick fix — every '### Section' in implementation-plan.md needs" >&2
            echo "  '**Implements:**' header on the line immediately below it:" >&2
            echo "" >&2
            echo "    ### Backend" >&2
            echo "    **Implements:** R1, R3            <- list R-ids from spec-card.md" >&2
            echo "" >&2
            echo "    - src/api.ts — endpoint" >&2
            echo "" >&2
            echo "    ### Files to modify" >&2
            echo "    **Implements:** none              <- scaffolding sections use 'none'" >&2
            echo "" >&2
            echo "    - file.ext — change" >&2
            echo "" >&2
            echo "  Every R-criterion from spec-card.md must appear in at least one" >&2
            echo "  section's **Implements:** line. Apply fix, then re-run:" >&2
            echo "    bash $APD_SHORTCUT_DISPLAY pipeline builder" >&2
            echo "" >&2
            echo "  Migration escape hatch (soft mode): add to spec-card.md:" >&2
            echo "    plan_consistency_gate: warn" >&2
            exit 1
        fi

        # v6.17.0 — regression surface gate. Verifies that the spec-card.md
        # `**Regression surface:**` block names the surrounding behaviour the
        # task touches indirectly, and that each `- RS<N>:` item carries a
        # `**Cover:**` value (coverage anchor). On a Human-gate path each item
        # must also carry an `**Evidence:**` attestation. Mode (strict|warn|off)
        # is read from spec-card.md `regression_gate:`; rollout default is
        # `warn`. `off` is ignored on a Human-gate path. The script logs its own
        # BLOCK; here we only translate exit 1 into an actionable message.
        if ! bash "$SCRIPT_DIR/verify-regression-surface"; then
            echo "" >&2
            echo "BLOCKED: regression surface check failed (strict mode)." >&2
            echo "" >&2
            echo "  Declare what the task touches indirectly, with coverage, in spec-card.md:" >&2
            echo "" >&2
            echo "    **Regression surface:**" >&2
            echo "    - RS1: <neighbouring behaviour> — **Cover:** existing <Suite>" >&2
            echo "    - RS2: <another> — **Cover:** new <TestName>" >&2
            echo "" >&2
            echo "  If the task touches no shared state, state it explicitly:" >&2
            echo "    **Regression surface:** none — <reason>" >&2
            echo "" >&2
            echo "  On a Human-gate path each RS item also needs **Evidence:** (≥40 chars):" >&2
            echo "    - RS1: ... — **Cover:** existing <Suite> **Evidence:** <Suite> green before+after, N tests unchanged" >&2
            echo "" >&2
            echo "  Apply fix, then re-run:" >&2
            echo "    bash $APD_SHORTCUT_DISPLAY pipeline builder" >&2
            echo "" >&2
            echo "  Migration escape hatch (soft mode, ignored on Human-gate paths):" >&2
            echo "    regression_gate: warn" >&2
            exit 1
        fi

        # Verify that a PROJECT-DEFINED builder agent ran
        # Superpowers agents that conflict with APD pipeline are rejected.
        # Other plugin agents (figma, context7, etc.) are allowed alongside project agents.
        #
        # v6.6.1 — only accept stop events with timestamp >= SPEC_TS. Defeats
        # the post-hoc pipeline-reconstruction bypass where orchestrator does
        # the work inline (no agent dispatches), then writes spec-card.md and
        # implementation-plan.md retroactively and chains pipeline-advance to
        # fabricate the gate sequence. Pre-spec events from previous tasks no
        # longer satisfy BUILDER_RAN.
        AGENTS_LOG="$PIPELINE_DIR/.agents"
        SPEC_TS=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f1)
        # v6.6.1 — also read human-format spec timestamp; .agents log uses
        # `YYYY-MM-DD HH:MM:SS` format which lexically (and chronologically)
        # compares correctly against the human field at spec.done column 2.
        SPEC_TS_HUMAN=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f2)
        # Scan factored into _scan_builder_ran so the gate can re-scan after a
        # hook-non-delivery fallback reconstruct (below). Sets BUILDER_RAN +
        # BLOCKED_AGENTS / SUSPICIOUS / STALE_DISPATCH.
        _scan_builder_ran
        # Codex runtime defaults to inline orchestration for APD builder work.
        # Subagents may exist, but APD cannot require them without an explicit
        # user delegation request. Skip the legacy CC agent-presence check when
        # the caller is Codex; verifier still enforces build + tests.
        if [ -z "${BUILDER_RAN:-}" ] && [ "${APD_RUNTIME:-}" = "codex" ]; then
            BUILDER_RAN="codex-orchestrator"
        fi
        if [ -z "${BUILDER_RAN:-}" ]; then
            echo "BLOCKED: No project Builder agent was dispatched!" >&2
            echo "" >&2
            # Hook-non-delivery hint: if real CC transcripts exist for this task
            # but .agents is empty (SubagentStart/Stop didn't fire — background
            # dispatch / harness), point at the EXPLICIT recovery. DETECT only
            # (dry-run count, writes nothing): the transcript-backed recovery
            # stays an explicit `reconstruct-agents` step, never an automatic gate
            # action — the transcript-trust boundary is never crossed silently
            # (CC transcript files are orchestrator-writable, so auto-applying
            # them would be a fabrication-assist path).
            if [ "${APD_RUNTIME:-}" != "codex" ]; then
                RA_DRY_RUN=1; _reconstruct_from_transcripts; RA_DRY_RUN=0
                if [ "${RA_COUNT:-0}" -gt 0 ]; then
                    echo "  ${RA_COUNT} CC transcript-backed agent(s) exist for this task but .agents is empty —" >&2
                    echo "  the SubagentStart/Stop hooks likely did not fire (background dispatch / harness)." >&2
                    echo "  If you DID dispatch real agents, recover explicitly:" >&2
                    echo "    bash $APD_SHORTCUT_DISPLAY pipeline reconstruct-agents   # rebuild .agents from transcripts" >&2
                    echo "    bash $APD_SHORTCUT_DISPLAY pipeline builder              # then re-run" >&2
                    echo "" >&2
                fi
            fi
            if [ -n "${STALE_DISPATCH:-}" ]; then
                echo "  Stale pre-spec dispatch detected: ${STALE_DISPATCH%, }" >&2
                echo "  These agents stopped BEFORE the current spec was signed —" >&2
                echo "  events from previous tasks do not count toward builder gate." >&2
                echo "  Dispatch builders again AFTER 'apd pipeline spec' completes." >&2
                echo "" >&2
            fi
            if [ -n "${SUSPICIOUS:-}" ]; then
                echo "  Suspicious dispatch detected: ${SUSPICIOUS%, }" >&2
                echo "  Agent entries look fabricated (wrong timestamp, zero duration, or missing start)." >&2
                echo "  Dispatch REAL agents — do not write to .agents directly." >&2
                echo "" >&2
            fi
            if [ -n "$BLOCKED_AGENTS" ]; then
                echo "  Rejected: ${BLOCKED_AGENTS%, }" >&2
                echo "  These are plugin agents, NOT project agents." >&2
                echo "" >&2
            fi
            echo "  Dispatch project builders using the Agent tool:" >&2
            echo "    Agent({ subagent_type: \"backend-api\", prompt: \"...\" })" >&2
            echo "" >&2
            echo "  NEVER use superpowers: or feature-dev: agents — pipeline will BLOCK." >&2
            echo "" >&2
            echo "  Project agents:" >&2
            if [ -d "$APD_AGENTS_DIR" ]; then
                for f in "$APD_AGENTS_DIR"/*.md; do
                    [ -f "$f" ] || continue
                    echo "    - $(basename "$f" .md)" >&2
                done
            fi
            exit 1
        fi

        # Verify all planned agents from implementation-plan.md were dispatched
        if [ -f "$PIPELINE_DIR/implementation-plan.md" ] && [ -f "$AGENTS_LOG" ]; then
            # Extract agents section — lines between "### Agents" and next "###" or empty line
            MISSING_AGENTS=""
            IN_AGENTS=false
            while IFS= read -r line; do
                if echo "$line" | grep -qE '^### Agents'; then
                    IN_AGENTS=true
                    continue
                fi
                if [ "$IN_AGENTS" = true ]; then
                    # Stop at next section or empty line
                    if echo "$line" | grep -qE '^###|^$'; then
                        break
                    fi
                    # Extract agent name from "- agent-name"
                    PLANNED=$(echo "$line" | sed -nE 's/^- ([a-zA-Z0-9_-]+).*/\1/p')
                    if [ -n "$PLANNED" ]; then
                        if ! grep -q "|stop|${PLANNED}|" "$AGENTS_LOG" 2>/dev/null; then
                            MISSING_AGENTS="${MISSING_AGENTS}${PLANNED}, "
                        fi
                    fi
                fi
            done < "$PIPELINE_DIR/implementation-plan.md"
            if [ -n "$MISSING_AGENTS" ]; then
                warn "Planned agents not dispatched: ${MISSING_AGENTS%, }" >&2
            fi
        fi

        # v6.3 C — builder cycle cap. Counts pipeline-advance builder calls
        # per task; blocks runaway re-dispatch loops. Default cap = 2 (allow
        # one re-dispatch after reviewer rejection). Override via spec-card:
        # `builder: max_cycles=N` or `builder: max_cycles=unlimited`. Wiped
        # by `pipeline-advance reset`; preserved across rollback + re-advance
        # so re-dispatch always costs a cycle.
        # v6.3 B — `pipeline_mode: polish` lowers default cap to 1 for polish
        # iterations (small fixes that should NOT need re-dispatch).
        PIPELINE_MODE=$(grep -iE '^[-*_ 	]*pipeline_mode[[:space:]]*[:=][[:space:]]*' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
            | sed -E 's/.*pipeline_mode[[:space:]]*[:=][[:space:]]*//I' \
            | awk '{print $1}' \
            | tr '[:upper:]' '[:lower:]' \
            | head -1)
        case "$PIPELINE_MODE" in
            polish) DEFAULT_BUILDER_CAP=1 ;;
            *)      DEFAULT_BUILDER_CAP=2 ;;
        esac
        BUILDER_COUNTER_FILE="$PIPELINE_DIR/.builder-count"
        BUILDER_MAX_CYCLES_RAW=$(grep -iE '^[-*_ 	]*builder[-*_ 	]*:.*max_cycles[[:space:]]*[:=][[:space:]]*([0-9]+|unlimited)' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
            | sed -E 's/.*max_cycles[[:space:]]*[:=][[:space:]]*//I' \
            | tr '[:upper:]' '[:lower:]' \
            | awk '{print $1}' \
            | head -1)
        BUILDER_MAX_CYCLES="${BUILDER_MAX_CYCLES_RAW:-$DEFAULT_BUILDER_CAP}"
        CURRENT_BUILDER_COUNT=$(cat "$BUILDER_COUNTER_FILE" 2>/dev/null || echo 0)
        case "$CURRENT_BUILDER_COUNT" in *[!0-9]*) CURRENT_BUILDER_COUNT=0 ;; esac
        NEW_BUILDER_COUNT=$((CURRENT_BUILDER_COUNT + 1))
        if [ "$BUILDER_MAX_CYCLES" != "unlimited" ] && [ "$NEW_BUILDER_COUNT" -gt "$BUILDER_MAX_CYCLES" ] 2>/dev/null; then
            CURRENT_TASK=$(head -1 "$PIPELINE_DIR/spec.done" 2>/dev/null | cut -d'|' -f3)
            echo "BLOCKED: builder dispatch #$NEW_BUILDER_COUNT exceeds max_cycles=$BUILDER_MAX_CYCLES." >&2
            echo "" >&2
            echo "  Task '$CURRENT_TASK' has hit its builder-cycle budget." >&2
            echo "  Re-dispatching now risks the runaway pattern from BambiProject" >&2
            echo "  Cycle 1 (3 builder cycles, ~28 min agent time, polish task)." >&2
            echo "" >&2
            echo "  Three ways forward:" >&2
            echo "    (a) STOP and review — is implementation-plan.md complete?" >&2
            echo "        Spec ambiguous? Adversarial flagging the same issue twice?" >&2
            echo "    (b) Decompose — split the spec into 2 smaller tasks, reset, restart." >&2
            echo "    (c) Raise cap — edit spec-card.md 'builder: max_cycles=N' with" >&2
            echo "        rationale, rollback to spec, re-advance." >&2
            log_block "max_builder_cycles-exceeded" "task=$CURRENT_TASK count=$NEW_BUILDER_COUNT cap=$BUILDER_MAX_CYCLES"
            exit 1
        fi
        echo "$NEW_BUILDER_COUNT" > "$BUILDER_COUNTER_FILE"

        ELAPSED=$(format_duration $((NOW - SPEC_TS)))
        create_done "builder"
        apd_header "Builder Complete" "+$ELAPSED"
        show_pipeline "reviewer"
        # GitHub sync (best-effort)
        bash "$SCRIPT_DIR/gh-sync" builder 2>/dev/null || true
        echo "" >&2
        echo "    ${D}Next:${R} Review the diff, then advance the reviewer gate" >&2
        ;;

    reviewer)
        if [ ! -f "$PIPELINE_DIR/builder.done" ]; then
            echo "ERROR: Builder must be completed before reviewer!" >&2
            exit 1
        fi
        verify_done "builder" || exit 1

        # Verify that a PROJECT-DEFINED reviewer agent ran
        AGENTS_LOG="$PIPELINE_DIR/.agents"
        # Scan factored into _scan_reviewer_ran so the gate can re-scan after a
        # hook-non-delivery fallback reconstruct (below).
        _scan_reviewer_ran
        # Codex runtime: orchestrator performs the review inline unless the
        # user explicitly requested delegated subagent review.
        if [ -z "${REVIEWER_RAN:-}" ] && [ "${APD_RUNTIME:-}" = "codex" ]; then
            REVIEWER_RAN="codex-orchestrator"
        fi
        if [ -z "${REVIEWER_RAN:-}" ]; then
            echo "BLOCKED: No project Reviewer agent was dispatched!" >&2
            echo "" >&2
            # Hook-non-delivery hint (see builder gate) — DETECT only (dry-run,
            # writes nothing); point at the EXPLICIT reconstruct-agents recovery,
            # never auto-apply (CC transcripts are orchestrator-writable).
            if [ "${APD_RUNTIME:-}" != "codex" ]; then
                RA_DRY_RUN=1; _reconstruct_from_transcripts; RA_DRY_RUN=0
                if [ "${RA_COUNT:-0}" -gt 0 ]; then
                    echo "  ${RA_COUNT} CC transcript-backed agent(s) exist for this task but .agents is empty —" >&2
                    echo "  the SubagentStart/Stop hooks likely did not fire (background dispatch / harness)." >&2
                    echo "  If you DID dispatch a real reviewer, recover explicitly:" >&2
                    echo "    bash $APD_SHORTCUT_DISPLAY pipeline reconstruct-agents   # rebuild .agents from transcripts" >&2
                    echo "    bash $APD_SHORTCUT_DISPLAY pipeline reviewer             # then re-run" >&2
                    echo "" >&2
                fi
            fi
            if [ -n "${SUSPICIOUS:-}" ]; then
                echo "  Suspicious dispatch detected: ${SUSPICIOUS%, }" >&2
                echo "  Agent entries look fabricated (wrong timestamp, zero duration, or missing start)." >&2
                echo "  Dispatch REAL agents — do not write to .agents directly." >&2
                echo "" >&2
            fi
            if [ -n "$BLOCKED_AGENTS" ]; then
                echo "  Rejected: ${BLOCKED_AGENTS%, }" >&2
                echo "  These are plugin agents, NOT project agents." >&2
                echo "" >&2
            fi
            echo "  Dispatch the project code-reviewer using the Agent tool:" >&2
            echo "    Agent({ subagent_type: \"code-reviewer\", prompt: \"Review...\" })" >&2
            echo "" >&2
            echo "  NEVER use superpowers:code-reviewer or feature-dev:code-reviewer." >&2
            echo "  If reviewer step fails, do NOT rollback code — fix the dispatch and retry." >&2
            exit 1
        fi

        # v6.3 B — reviewer cycle cap (mirror of v6.3 C builder cap).
        # Counts pipeline-advance reviewer calls per task; default cap = 2
        # (one initial + one re-dispatch). Override via spec-card:
        # `reviewer: max_cycles=N` or `reviewer: max_cycles=unlimited`.
        # `pipeline_mode: polish` lowers default to 1.
        PIPELINE_MODE_R=$(grep -iE '^[-*_ 	]*pipeline_mode[[:space:]]*[:=][[:space:]]*' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
            | sed -E 's/.*pipeline_mode[[:space:]]*[:=][[:space:]]*//I' \
            | awk '{print $1}' \
            | tr '[:upper:]' '[:lower:]' \
            | head -1)
        case "$PIPELINE_MODE_R" in
            polish) DEFAULT_REVIEWER_CAP=1 ;;
            *)      DEFAULT_REVIEWER_CAP=2 ;;
        esac
        REVIEWER_COUNTER_FILE="$PIPELINE_DIR/.reviewer-count"
        REVIEWER_MAX_CYCLES_RAW=$(grep -iE '^[-*_ 	]*reviewer[-*_ 	]*:.*max_cycles[[:space:]]*[:=][[:space:]]*([0-9]+|unlimited)' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
            | sed -E 's/.*max_cycles[[:space:]]*[:=][[:space:]]*//I' \
            | tr '[:upper:]' '[:lower:]' \
            | awk '{print $1}' \
            | head -1)
        REVIEWER_MAX_CYCLES="${REVIEWER_MAX_CYCLES_RAW:-$DEFAULT_REVIEWER_CAP}"
        CURRENT_REVIEWER_COUNT=$(cat "$REVIEWER_COUNTER_FILE" 2>/dev/null || echo 0)
        case "$CURRENT_REVIEWER_COUNT" in *[!0-9]*) CURRENT_REVIEWER_COUNT=0 ;; esac
        NEW_REVIEWER_COUNT=$((CURRENT_REVIEWER_COUNT + 1))
        if [ "$REVIEWER_MAX_CYCLES" != "unlimited" ] && [ "$NEW_REVIEWER_COUNT" -gt "$REVIEWER_MAX_CYCLES" ] 2>/dev/null; then
            CURRENT_TASK=$(head -1 "$PIPELINE_DIR/spec.done" 2>/dev/null | cut -d'|' -f3)
            echo "BLOCKED: reviewer dispatch #$NEW_REVIEWER_COUNT exceeds max_cycles=$REVIEWER_MAX_CYCLES." >&2
            echo "" >&2
            echo "  Task '$CURRENT_TASK' has hit its reviewer-cycle budget." >&2
            echo "  Repeated reviewer dispatches signal that the work isn't converging." >&2
            echo "" >&2
            echo "  Three ways forward:" >&2
            echo "    (a) STOP and review — is the reviewer flagging real bugs the" >&2
            echo "        builder isn't fixing? Or scope drift from the spec?" >&2
            echo "    (b) Decompose — reset, split into smaller tasks." >&2
            echo "    (c) Raise cap — edit spec-card.md 'reviewer: max_cycles=N'" >&2
            echo "        with rationale, rollback to builder, re-advance." >&2
            log_block "max_reviewer_cycles-exceeded" "task=$CURRENT_TASK count=$NEW_REVIEWER_COUNT cap=$REVIEWER_MAX_CYCLES"
            exit 1
        fi
        echo "$NEW_REVIEWER_COUNT" > "$REVIEWER_COUNTER_FILE"

        BUILDER_TS=$(head -1 "$PIPELINE_DIR/builder.done" | cut -d'|' -f1)
        ELAPSED=$(format_duration $((NOW - BUILDER_TS)))
        create_done "reviewer"

        # Capture authoritative file scope for reviewers (code-reviewer + adversarial-reviewer)
        # Uncommitted tracked changes + untracked files belonging to current pipeline work.
        # Prevents reviewers from drifting into previous commits when orchestrator
        # mis-computes the diff base (e.g. `git diff HEAD~1` instead of `git diff HEAD`).
        if command -v git >/dev/null 2>&1 && git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            {
                git -C "$PROJECT_DIR" diff --name-only HEAD 2>/dev/null
                git -C "$PROJECT_DIR" ls-files --others --exclude-standard 2>/dev/null
            } | sort -u > "$PIPELINE_DIR/.reviewed-files"
            REVIEWED_COUNT=$(wc -l < "$PIPELINE_DIR/.reviewed-files" | tr -d ' ')
            [ "$REVIEWED_COUNT" -gt 0 ] && ok "Reviewed files scope: $REVIEWED_COUNT files → .apd/pipeline/.reviewed-files"
        fi

        # Mark adversarial review as pending if agent exists
        if [ -f "$APD_AGENTS_DIR/adversarial-reviewer.md" ]; then
            # Check for opt-out in spec-card — only allowed for small tasks (<=2 criteria)
            ADV_OPT_OUT=false
            # v6.1.2: tolerate markdown bold/italic/list-item prefixes around
            # the directive — `**adversarial:** skip` etc. should opt out the
            # same as plain `adversarial: skip`.
            if [ -f "$PIPELINE_DIR/spec-card.md" ] && grep -qiE '^[-*_ 	]*adversarial[-*_ 	]*:.*skip' "$PIPELINE_DIR/spec-card.md" 2>/dev/null; then
                ADV_CRITERIA=$(sed -n '/Acceptance criteria/,/^\*\*[A-Z]/p' "$PIPELINE_DIR/spec-card.md" 2>/dev/null | grep -cE '^[[:space:]]*-[[:space:]]+R[0-9]+[[:space:]]*:' || echo 0)
                if [ "$ADV_CRITERIA" -le 2 ] 2>/dev/null; then
                    ADV_OPT_OUT=true
                    ok "Adversarial reviewer: skipped (opt-out, $ADV_CRITERIA criteria)"
                else
                    warn "Adversarial opt-out DENIED: $ADV_CRITERIA criteria (max 2 for opt-out)" >&2
                fi
            fi
            if [ "$ADV_OPT_OUT" = false ]; then
                echo "${NOW}" > "$PIPELINE_DIR/.adversarial-pending"
                ok "Adversarial reviewer: required before verifier"
            fi
        fi

        apd_header "Reviewer Complete" "+$ELAPSED"
        show_pipeline "verifier"
        # GitHub sync (best-effort)
        bash "$SCRIPT_DIR/gh-sync" reviewer 2>/dev/null || true
        echo "" >&2
        if [ "$ADV_OPT_OUT" = true ]; then
            echo "    ${D}Next (Lean):${R} advance the verifier gate — adversarial skipped per spec-card opt-out" >&2
        elif [ -f "$PIPELINE_DIR/.adversarial-pending" ]; then
            echo "    ${D}Next (Full):${R} run the adversarial pass and record the outcome, then advance the verifier gate" >&2
        else
            echo "    ${D}Next:${R} advance the verifier gate" >&2
        fi
        ;;

    verifier)
        AGENTS_LOG="$PIPELINE_DIR/.agents"
        if [ ! -f "$PIPELINE_DIR/reviewer.done" ]; then
            echo "ERROR: Reviewer must be completed before verifier!" >&2
            exit 1
        fi
        verify_done "reviewer" || exit 1
        REVIEWER_TS=$(head -1 "$PIPELINE_DIR/reviewer.done" | cut -d'|' -f1)
        SPEC_TS=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f1)
        ELAPSED=$(format_duration $((NOW - REVIEWER_TS)))
        TOTAL=$(format_duration $((NOW - SPEC_TS)))
        # Verify spec-card.md was not modified after spec step (frozen)
        if [ -f "$PIPELINE_DIR/.spec-hash" ] && [ -f "$PIPELINE_DIR/spec-card.md" ]; then
            ORIGINAL_HASH=$(cat "$PIPELINE_DIR/.spec-hash")
            CURRENT_HASH=$(shasum -a 256 "$PIPELINE_DIR/spec-card.md" | cut -d' ' -f1)
            if [ "$ORIGINAL_HASH" != "$CURRENT_HASH" ]; then
                echo "BLOCKED: spec-card.md was modified after spec step." >&2
                echo "" >&2
                echo "  Spec is frozen after approval. Do not add criteria mid-pipeline." >&2
                echo "  To change scope: pipeline-advance rollback → update spec → restart." >&2
                exit 1
            fi
        fi
        # Run spec traceability check (if spec-card.md exists)
        if [ -f "$PIPELINE_DIR/spec-card.md" ]; then
            TRACE_OUT=$(bash "$SCRIPT_DIR/verify-trace" 2>&1 1>"$PIPELINE_DIR/.trace-summary")
            TRACE_EXIT=$?
            # Show the report (was on stderr, captured above)
            [ -n "$TRACE_OUT" ] && echo "$TRACE_OUT" >&2
            if [ "$TRACE_EXIT" -ne 0 ]; then
                echo "" >&2
                echo "  Fix: Add @trace R* markers in test files for uncovered criteria." >&2
                echo "  Then re-run: pipeline-advance verifier" >&2
                exit 1
            fi
        fi

        # Verify adversarial ran AFTER reviewer (not parallel)
        if [ -f "$PIPELINE_DIR/.adversarial-pending" ] && [ -f "$PIPELINE_DIR/.adversarial-summary" ] && [ -f "$AGENTS_LOG" ]; then
            REVIEWER_TS=$(head -1 "$PIPELINE_DIR/reviewer.done" | cut -d'|' -f1)
            ADV_STOP=$(grep "|stop|adversarial-reviewer|" "$AGENTS_LOG" 2>/dev/null | tail -1 | cut -d'|' -f1)
            if [ -n "$ADV_STOP" ] && [ -n "$REVIEWER_TS" ]; then
                ADV_EPOCH=$(date -j -f "%Y-%m-%d %H:%M:%S" "$ADV_STOP" +%s 2>/dev/null || date -d "$ADV_STOP" +%s 2>/dev/null || echo 0)
                # Fail-closed: if the timestamp can't be parsed the .agents log is
                # tampered or format-drifted; the ordering check cannot be trusted,
                # so block rather than silently skip enforcement.
                if [ "$ADV_EPOCH" -le 0 ] 2>/dev/null; then
                    echo "BLOCKED: adversarial-reviewer timestamp unparseable ('$ADV_STOP')." >&2
                    echo "  .agents log may be corrupted or tampered. Inspect:" >&2
                    echo "    $PIPELINE_DIR/.agents" >&2
                    log_block "adversarial-timestamp-unparseable" "adversarial-reviewer"
                    exit 1
                fi
                if [ "$ADV_EPOCH" -lt "$REVIEWER_TS" ] 2>/dev/null; then
                    echo "BLOCKED: Adversarial reviewer ran BEFORE reviewer step completed." >&2
                    echo "" >&2
                    echo "  Pipeline flow: builder → reviewer → fix → adversarial" >&2
                    echo "  Adversarial must review the FINAL code after reviewer fixes." >&2
                    echo "  Re-dispatch adversarial-reviewer after reviewer is done." >&2
                    log_block "adversarial-before-reviewer" "adversarial-reviewer"
                    exit 1
                fi
            fi
        fi

        # Hard gate: adversarial reviewer must complete before verifier
        if [ -f "$PIPELINE_DIR/.adversarial-pending" ] && [ ! -f "$PIPELINE_DIR/.adversarial-summary" ]; then
            echo "BLOCKED: Adversarial reviewer has not been dispatched!" >&2
            echo "" >&2
            echo "  The adversarial-reviewer agent is required for this task." >&2
            echo "  Dispatch it using the Agent tool, then write results to:" >&2
            echo "    .apd/pipeline/.adversarial-summary" >&2
            echo "" >&2
            echo "  To skip for this task, add to spec-card.md:" >&2
            echo "    adversarial: skip — <reason>" >&2
            echo "  Then re-run: pipeline-advance rollback → pipeline-advance reviewer" >&2
            exit 1
        fi

        # Hard gate: adversarial summary must be backed by actual dispatch
        if [ -f "$PIPELINE_DIR/.adversarial-pending" ] && [ -f "$PIPELINE_DIR/.adversarial-summary" ]; then
            if [ -f "$AGENTS_LOG" ] && ! grep -q "|start|adversarial-reviewer|" "$AGENTS_LOG" 2>/dev/null; then
                echo "BLOCKED: Adversarial summary written but agent was never dispatched!" >&2
                echo "" >&2
                echo "  .adversarial-summary exists but no adversarial-reviewer in agent log." >&2
                echo "  You must dispatch the adversarial-reviewer agent before writing results." >&2
                echo "  Dispatch: Agent({ subagent_type: \"adversarial-reviewer\", prompt: \"...\" })" >&2
                log_block "adversarial-summary-without-dispatch" "adversarial-reviewer"
                exit 1
            fi
        fi

        # Severity gate (v6.1 B2): block when adversarial dismissed-defect count
        # exceeds the spec-card's `max_defects` budget.
        # Format in spec-card.md:  `adversarial: max_defects=N`  or  `=unlimited`
        # Default (field absent) = unlimited (backward compat with pre-v6.1).
        if [ -f "$PIPELINE_DIR/.adversarial-summary" ] && [ -f "$PIPELINE_DIR/spec-card.md" ]; then
            # v6.1.2: same bold/italic tolerance as the reviewer-step skip parser.
            MAX_DEFECTS_RAW=$(grep -iE '^[-*_ 	]*adversarial[-*_ 	]*:.*max_defects[[:space:]]*[:=][[:space:]]*([0-9]+|unlimited)' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
                | sed -E 's/.*max_defects[[:space:]]*[:=][[:space:]]*//I' \
                | tr '[:upper:]' '[:lower:]' \
                | awk '{print $1}' \
                | head -1)
            if [ -n "$MAX_DEFECTS_RAW" ] && [ "$MAX_DEFECTS_RAW" != "unlimited" ]; then
                ADV_LINE=$(grep '^ADVERSARIAL:' "$PIPELINE_DIR/.adversarial-summary" 2>/dev/null | head -1)
                ADV_D=$(echo "$ADV_LINE" | cut -d: -f4)
                ADV_D=${ADV_D:-0}
                if [ "$ADV_D" -gt "$MAX_DEFECTS_RAW" ] 2>/dev/null; then
                    echo "BLOCKED: adversarial summary has D=$ADV_D, spec-card.md sets max_defects=$MAX_DEFECTS_RAW." >&2
                    echo "" >&2
                    echo "  Three ways forward:" >&2
                    echo "    (a) Address findings via builder fix → re-dispatch adversarial-reviewer → re-record." >&2
                    echo "    (b) Raise threshold: rollback, edit spec-card.md  'adversarial: max_defects=N',  re-run." >&2
                    echo "    (c) Opt out for small tasks (≤2 R-criteria): 'adversarial: skip — <reason>'." >&2
                    log_block "max_defects-exceeded" "ADV_D=$ADV_D max_defects=$MAX_DEFECTS_RAW"
                    exit 1
                fi
            fi
        fi

        # v6.7 — Adversarial rationale gate.
        # Requires .adversarial-rationale.md with one structured block per finding.
        # Hard-blocks on missing/malformed file, status/count mismatch, and the
        # 100% orchestrator-dismiss pattern (T>=3 && A==0 && Do>=1) which is the
        # bypass signature documented in project-v6.7-adversarial-dismissal-quality.
        # Default ON; opt out per-task via spec-card.md `adversarial: rationale_gate=off`.
        if [ -f "$PIPELINE_DIR/.adversarial-summary" ]; then
            RATIONALE_GATE_RAW=""
            if [ -f "$PIPELINE_DIR/spec-card.md" ]; then
                RATIONALE_GATE_RAW=$(grep -iE '^[-*_ 	]*adversarial[-*_ 	]*:.*rationale_gate[[:space:]]*[:=][[:space:]]*(on|off)' "$PIPELINE_DIR/spec-card.md" 2>/dev/null \
                    | sed -E 's/.*rationale_gate[[:space:]]*[:=][[:space:]]*//I' \
                    | tr '[:upper:]' '[:lower:]' \
                    | awk '{print $1}' \
                    | head -1)
            fi
            if [ "$RATIONALE_GATE_RAW" != "off" ]; then
                RATIONALE_FILE="$PIPELINE_DIR/.adversarial-rationale.md"
                ADV_LINE=$(grep '^ADVERSARIAL:' "$PIPELINE_DIR/.adversarial-summary" 2>/dev/null | head -1)
                ADV_T=$(echo "$ADV_LINE" | cut -d: -f2); ADV_T=${ADV_T:-0}
                ADV_A=$(echo "$ADV_LINE" | cut -d: -f3); ADV_A=${ADV_A:-0}
                ADV_D=$(echo "$ADV_LINE" | cut -d: -f4); ADV_D=${ADV_D:-0}
                if [ "$ADV_T" -gt 0 ] 2>/dev/null; then
                    # v7.1 — file must exist
                    if [ ! -f "$RATIONALE_FILE" ]; then
                        echo "BLOCKED: Adversarial rationale file missing." >&2
                        echo "" >&2
                        echo "  Write per-finding rationales to .apd/pipeline/.adversarial-rationale.md" >&2
                        echo "  One block per finding, exact format:" >&2
                        echo "    ## Finding N — <one-line title>" >&2
                        echo "    **Severity:** critical | important | minor" >&2
                        echo "    **Status:** accepted | dismissed | reviewer-self-dismissed" >&2
                        echo "    **Rationale:** <text, required for dismissed/reviewer-self-dismissed>" >&2
                        echo "" >&2
                        echo "  Expected: T=$ADV_T findings (A=$ADV_A accepted, D=$ADV_D dismissed)." >&2
                        echo "  Then re-run: bash $APD_SHORTCUT_DISPLAY pipeline verifier" >&2
                        echo "" >&2
                        echo "  Per-task opt-out: spec-card.md  'adversarial: rationale_gate=off'." >&2
                        log_block "rationale-missing" "T=$ADV_T A=$ADV_A D=$ADV_D"
                        exit 1
                    fi
                    # v7.3 — finding block count must equal T
                    FINDING_COUNT=$(grep -c '^## Finding ' "$RATIONALE_FILE" 2>/dev/null); FINDING_COUNT=${FINDING_COUNT:-0}
                    if [ "$FINDING_COUNT" -ne "$ADV_T" ]; then
                        echo "BLOCKED: Rationale finding block count mismatch." >&2
                        echo "" >&2
                        echo "  Found $FINDING_COUNT '## Finding ' blocks; summary T=$ADV_T." >&2
                        echo "  Each adversarial finding must have its own ## Finding block." >&2
                        log_block "rationale-count-mismatch" "found=$FINDING_COUNT expected=$ADV_T"
                        exit 1
                    fi
                    # v7.4 — every block must have Severity + Status + Rationale fields
                    SEVERITY_COUNT=$(grep -cE '^\*\*Severity:\*\* (critical|important|minor)$' "$RATIONALE_FILE" 2>/dev/null); SEVERITY_COUNT=${SEVERITY_COUNT:-0}
                    STATUS_COUNT=$(grep -cE '^\*\*Status:\*\* (accepted|dismissed|reviewer-self-dismissed)$' "$RATIONALE_FILE" 2>/dev/null); STATUS_COUNT=${STATUS_COUNT:-0}
                    RATIONALE_COUNT=$(grep -cE '^\*\*Rationale:\*\* .+' "$RATIONALE_FILE" 2>/dev/null); RATIONALE_COUNT=${RATIONALE_COUNT:-0}
                    if [ "$SEVERITY_COUNT" -ne "$FINDING_COUNT" ] || [ "$STATUS_COUNT" -ne "$FINDING_COUNT" ] || [ "$RATIONALE_COUNT" -ne "$FINDING_COUNT" ]; then
                        echo "BLOCKED: Rationale file has malformed Finding blocks." >&2
                        echo "" >&2
                        echo "  Expected $FINDING_COUNT each of:" >&2
                        echo "    **Severity:** field (found $SEVERITY_COUNT)" >&2
                        echo "    **Status:** field   (found $STATUS_COUNT)" >&2
                        echo "    **Rationale:** field (found $RATIONALE_COUNT)" >&2
                        echo "" >&2
                        echo "  Each finding needs all three fields with valid values." >&2
                        log_block "rationale-malformed-fields" "sev=$SEVERITY_COUNT stat=$STATUS_COUNT rat=$RATIONALE_COUNT findings=$FINDING_COUNT"
                        exit 1
                    fi
                    # v7.5 — status counts must add up to summary A and D
                    ACCEPTED_F=$(grep -c '^\*\*Status:\*\* accepted$' "$RATIONALE_FILE" 2>/dev/null); ACCEPTED_F=${ACCEPTED_F:-0}
                    DISMISSED_O=$(grep -c '^\*\*Status:\*\* dismissed$' "$RATIONALE_FILE" 2>/dev/null); DISMISSED_O=${DISMISSED_O:-0}
                    DISMISSED_R=$(grep -c '^\*\*Status:\*\* reviewer-self-dismissed$' "$RATIONALE_FILE" 2>/dev/null); DISMISSED_R=${DISMISSED_R:-0}
                    STATUS_D_SUM=$((DISMISSED_O + DISMISSED_R))
                    if [ "$ACCEPTED_F" -ne "$ADV_A" ]; then
                        echo "BLOCKED: Rationale accepted count doesn't match summary." >&2
                        echo "" >&2
                        echo "  Rationale file: accepted=$ACCEPTED_F." >&2
                        echo "  Summary line:   A=$ADV_A." >&2
                        log_block "rationale-accepted-mismatch" "rationale=$ACCEPTED_F summary=$ADV_A"
                        exit 1
                    fi
                    if [ "$STATUS_D_SUM" -ne "$ADV_D" ]; then
                        echo "BLOCKED: Rationale statuses don't match summary dismissed count." >&2
                        echo "" >&2
                        echo "  Rationale file: dismissed=$DISMISSED_O, reviewer-self-dismissed=$DISMISSED_R, sum=$STATUS_D_SUM." >&2
                        echo "  Summary line:   D=$ADV_D." >&2
                        echo "" >&2
                        echo "  Reclassify Status fields so dismissed + reviewer-self-dismissed = D." >&2
                        log_block "rationale-status-mismatch" "Do=$DISMISSED_O Dr=$DISMISSED_R sum=$STATUS_D_SUM D=$ADV_D"
                        exit 1
                    fi
                    # v7.6 — hard gate: 100% orchestrator-dismissal pattern
                    if [ "$ADV_T" -ge 3 ] && [ "$ADV_A" -eq 0 ] && [ "$DISMISSED_O" -ge 1 ]; then
                        echo "BLOCKED: 100% orchestrator dismissal pattern detected." >&2
                        echo "" >&2
                        echo "  T=$ADV_T findings, A=0 accepted, Do=$DISMISSED_O orchestrator-dismissed, Dr=$DISMISSED_R reviewer-self-dismissed." >&2
                        echo "" >&2
                        echo "  At least one finding must be accepted (dispatch builder fix), OR" >&2
                        echo "  rationale must reclassify the dismissed entries to reviewer-self-dismissed" >&2
                        echo "  where the adversarial reviewer itself dismissed them inline." >&2
                        log_block "rationale-100pct-orch-dismiss" "T=$ADV_T Do=$DISMISSED_O Dr=$DISMISSED_R"
                        exit 1
                    fi
                    # v6.7 Phase 2 — soft quality warns. Walk each dismissed
                    # and reviewer-self-dismissed block. Flag rationale text
                    # under 40 chars and lazy-pattern matches. Non-blocking;
                    # surfaces in apd-finish closure output via stderr.
                    _Q_OUT=$(awk '
BEGIN { f=0; status=""; rationale=""; }
/^## Finding / {
    if (f>0) _check()
    f++
    status = ""
    rationale = ""
    next
}
/^\*\*Status:\*\* / { sub(/^\*\*Status:\*\* /, ""); status = $0; next }
/^\*\*Rationale:\*\* / { sub(/^\*\*Rationale:\*\* /, ""); rationale = $0; next }
END { if (f>0) _check() }
function _check() {
    if (status == "dismissed" || status == "reviewer-self-dismissed") {
        rlen = length(rationale)
        if (rlen < 40) {
            printf "! WARN Finding %d: rationale only %d chars (>=40 recommended)\n", f, rlen
        }
        lower = tolower(rationale)
        if (lower ~ /^(ok|n\/a|false positive|not applicable|skip|no)\.?$/) {
            printf "! WARN Finding %d: rationale matches lazy pattern (\"%s\")\n", f, rationale
        }
    }
}
' "$RATIONALE_FILE" 2>/dev/null)
                    if [ -n "$_Q_OUT" ]; then
                        echo "" >&2
                        echo "$_Q_OUT" >&2
                    fi
                fi
            fi
        fi

        # v6.30 — Supervision gate (profile-coupled frontier final review).
        # Applies ONLY when the declared MODEL_PROFILE has a `supervisor` row in
        # model-profiles.conf (v1: eco) AND adversarial ran (Full mode) — absent
        # row / no profile / Lean / pure Codex → inert by construction. The
        # supervisor reviews the FINAL diff (post-adversarial-fixes): R-criteria
        # still met, fix-of-findings collateral, Regression-surface claims vs
        # diff, commit verdict. NO spec-card opt-out BY DESIGN (user decision
        # 2026-07-05: a gameable required gate repeats the R-atomization lesson)
        # — the only ways out are `apd pipeline reset` or a profile change
        # (mid-pipeline refused). Phase 1 rollout default = warn (advisory);
        # Phase 2 flips SUPERVISION_GATE_DEFAULT to strict — one-line change.
        # ENV IS ONE-WAY (audit 2026-07-05 #1): APD_SUPERVISION_GATE=strict may
        # ESCALATE above the default; any downgrade attempt is IGNORED + logged.
        # No `off`, no synthetic skip — a gate an env prefix can silence is
        # cheaper to bypass than to satisfy, which broke the D3 design bar.
        SUPERVISION_GATE_DEFAULT="warn"
        SUP_PROFILE=$(grep '^MODEL_PROFILE=' "$APD_CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2-)
        SUP_ROW=""
        if [ -n "$SUP_PROFILE" ]; then
            SUP_CONF="$PROJECT_DIR/.apd/model-profiles.conf"
            [ -f "$SUP_CONF" ] || SUP_CONF="$APD_PLUGIN_ROOT/templates/model-profiles.conf"
            SUP_ROW=$(grep -v '^[[:space:]]*#' "$SUP_CONF" 2>/dev/null | awk -F'|' -v p="$SUP_PROFILE" '$1==p && $2=="supervisor" {print $3; exit}')
        fi
        if [ -n "$SUP_ROW" ] && [ -f "$PIPELINE_DIR/.adversarial-summary" ]; then
            SUP_MODE="$SUPERVISION_GATE_DEFAULT"
            if [ "${APD_SUPERVISION_GATE:-}" = "strict" ]; then
                SUP_MODE="strict"   # escalation is always allowed
            elif [ -n "${APD_SUPERVISION_GATE:-}" ] && [ "${APD_SUPERVISION_GATE:-}" != "$SUP_MODE" ]; then
                # Downgrade attempt (off/warn-below-default/junk) — ignored, audited.
                if [ "${APD_AUDIT_SYNTHETIC:-}" = "1" ]; then _sgt=SYNTHETIC; else _sgt=INFO; fi
                [ -d "$MEMORY_DIR" ] && echo "$(date +"%Y-%m-%d %H:%M:%S")|${_sgt}|orchestrator|supervision-gate-downgrade-ignored|requested=${APD_SUPERVISION_GATE} default=$SUP_MODE" >> "$MEMORY_DIR/guard-audit.log"
            fi
            SUP_ISSUE=$(_supervision_issue "$PIPELINE_DIR/.supervision-summary" "$PIPELINE_DIR/.supervision-rationale.md")
            # Fabrication check: summary present but supervisor never dispatched
            # (same class as adversarial-summary-without-dispatch).
            if [ -z "$SUP_ISSUE" ] && [ -f "$AGENTS_LOG" ] && ! grep -q "|start|supervisor|" "$AGENTS_LOG" 2>/dev/null; then
                SUP_ISSUE="supervision-summary-without-dispatch|no supervisor start in agent log"
            fi
            # Churn cap (plan D7): one pass + at most one re-check after fixes.
            # Counts STOPS, not starts (audit #6) — a maxTurn-exhausted dispatch
            # (start without stop, ~22% baseline) must not burn the budget.
            if [ -z "$SUP_ISSUE" ] && [ -f "$AGENTS_LOG" ]; then
                SUP_STOPS=$(grep -c "|stop|supervisor|" "$AGENTS_LOG" 2>/dev/null); SUP_STOPS=${SUP_STOPS:-0}
                if [ "$SUP_STOPS" -gt 2 ]; then
                    SUP_ISSUE="supervision-cycle-cap|stops=$SUP_STOPS cap=2"
                fi
            fi
            # Finality check (audit #5): supervision judges the FINAL diff, so
            # the last supervisor STOP must be the last agent activity on record
            # — any later builder/reviewer/adversarial stop means the reviewed
            # state is stale (the fix-of-findings gap this layer exists to
            # close). Timestamps share one format → lexical compare is safe.
            if [ -z "$SUP_ISSUE" ] && [ -f "$AGENTS_LOG" ]; then
                SUP_LAST_STOP=$(grep "|stop|supervisor|" "$AGENTS_LOG" 2>/dev/null | tail -1 | cut -d'|' -f1)
                if [ -z "$SUP_LAST_STOP" ]; then
                    SUP_ISSUE="supervision-not-final|no supervisor stop recorded (exhausted dispatch? re-dispatch and let it finish)"
                else
                    OTHER_LAST_STOP=$(grep "|stop|" "$AGENTS_LOG" 2>/dev/null | grep -v "|stop|supervisor|" | tail -1 | cut -d'|' -f1)
                    if [ -n "$OTHER_LAST_STOP" ] && [ "$OTHER_LAST_STOP" \> "$SUP_LAST_STOP" ]; then
                        SUP_ISSUE="supervision-not-final|agent activity after last supervisor stop ($OTHER_LAST_STOP > $SUP_LAST_STOP) — re-dispatch supervisor on the final state"
                    fi
                fi
            fi
            if [ -n "$SUP_ISSUE" ]; then
                SUP_CODE="${SUP_ISSUE%%|*}"; SUP_DETAIL="${SUP_ISSUE#*|}"
                if [ "$SUP_MODE" = "strict" ]; then
                    echo "BLOCKED: Supervision gate — ${SUP_CODE}." >&2
                    echo "" >&2
                    echo "  Profile '$SUP_PROFILE' carries a supervisor row: a supervision pass over" >&2
                    echo "  the FINAL diff is required before the verifier (Full mode)." >&2
                    echo "  Detail: $SUP_DETAIL" >&2
                    echo "" >&2
                    echo "  1. Dispatch: Agent({ subagent_type: \"supervisor\", prompt: \"Final review per charter\" })" >&2
                    echo "  2. Record:   .apd/pipeline/.supervision-summary   (SUPERVISION:T:A:D + Notes)" >&2
                    echo "  3. Triage:   .apd/pipeline/.supervision-rationale.md (same contract as adversarial)" >&2
                    echo "  Then re-run: bash $APD_SHORTCUT_DISPLAY pipeline verifier" >&2
                    echo "" >&2
                    echo "  No spec-card opt-out. Ways out: apd pipeline reset, or switch profile BEFORE spec." >&2
                    log_block "$SUP_CODE" "$SUP_DETAIL"
                    exit 1
                else
                    echo "" >&2
                    echo "! WARN Supervision gate (${SUP_CODE}): profile '$SUP_PROFILE' expects a" >&2
                    echo "  frontier supervision pass over the FINAL diff before the verifier." >&2
                    echo "  Detail: $SUP_DETAIL" >&2
                    echo "  Dispatch supervisor + record .supervision-summary / .supervision-rationale.md." >&2
                    echo "  (Advisory during rollout — this becomes a hard BLOCK in a future release.)" >&2
                    # Warn-path telemetry (audit #9): the strict-flip criterion is
                    # "how often did the warn fire and get ignored" — unmeasurable
                    # without this. INFO (not BLOCK) so session-log stays clean.
                    if [ "${APD_AUDIT_SYNTHETIC:-}" = "1" ]; then _sgt=SYNTHETIC; else _sgt=INFO; fi
                    [ -d "$MEMORY_DIR" ] && echo "$(date +"%Y-%m-%d %H:%M:%S")|${_sgt}|orchestrator|supervision-warn|$SUP_CODE profile=$SUP_PROFILE" >> "$MEMORY_DIR/guard-audit.log"
                fi
            else
                # Gate satisfied — log per-run supervisor model attribution
                # (plan §3.5; frontmatter model is the honest v1 source).
                SUP_MODEL=$(grep '^model:' "$CLAUDE_DIR/agents/supervisor.md" 2>/dev/null | head -1 | awk '{print $2}')
                SUP_SUM_LINE=$(grep '^SUPERVISION:' "$PIPELINE_DIR/.supervision-summary" 2>/dev/null | head -1)
                if [ "${APD_AUDIT_SYNTHETIC:-}" = "1" ]; then _sgt=SYNTHETIC; else _sgt=INFO; fi
                [ -d "$MEMORY_DIR" ] && echo "$(date +"%Y-%m-%d %H:%M:%S")|${_sgt}|orchestrator|supervision-pass|model=${SUP_MODEL:-unknown} ${SUP_SUM_LINE:-SUPERVISION:n/a} profile=$SUP_PROFILE" >> "$MEMORY_DIR/guard-audit.log"
            fi
        fi

        # Run build + tests. verify-all.sh lives IN THE PROJECT, not the plugin.
        # Search Codex-native location first, then legacy CC path, so pure-Codex
        # projects can keep their verifier entirely under .codex/.
        VERIFY_ALL=""
        for candidate in \
            "$PROJECT_DIR/.codex/bin/verify-all.sh" \
            "$CLAUDE_DIR/scripts/verify-all.sh"; do
            if [ -x "$candidate" ]; then
                VERIFY_ALL="$candidate"
                break
            fi
        done
        if [ -n "$VERIFY_ALL" ]; then
            echo "" >&2
            echo "  Running build + tests..." >&2
            VERIFY_OUT=$(bash "$VERIFY_ALL" 2>&1)
            VERIFY_EXIT=$?
            if [ $VERIFY_EXIT -ne 0 ]; then
                echo "BLOCKED: Build or tests failed." >&2
                echo "" >&2
                echo "$VERIFY_OUT" | tail -20 >&2
                echo "" >&2
                echo "  Fix the errors and re-run: bash $APD_SHORTCUT_DISPLAY pipeline verifier" >&2
                exit 1
            fi
            echo "  ${MARK_PASS} Build + tests passed" >&2
        fi

        create_done "verifier"
        # Cache timestamp — verify-all.sh skips rebuild if fresh (<120s)
        echo "$NOW" > "$PIPELINE_DIR/verified.timestamp"
        apd_header "COMMIT ALLOWED" "total: $TOTAL"
        show_pipeline ""
        echo "    Ready: APD_ORCHESTRATOR_COMMIT=1 git commit ..."
        echo "    ${D}After commit, before any new task: advance the reset step${R}" >&2
        # GitHub sync (best-effort)
        bash "$SCRIPT_DIR/gh-sync" verifier 2>/dev/null || true
        ;;

    reset)
        # Mark reset as in progress so a killed process leaves a breadcrumb the
        # next `pipeline-advance` call can warn about. The EXIT trap does not
        # remove this marker — only successful completion does.
        touch "$PIPELINE_DIR/.reset-in-progress" 2>/dev/null
        # Archive adversarial rationale before reset wipes it (state still intact here)
        archive_rationale
        # Auto-append to session-log before clearing flags
        if [ -f "$PIPELINE_DIR/spec.done" ]; then
            TASK_NAME=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f3 2>/dev/null)
            SPEC_TS=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f1 2>/dev/null)
            TOTAL=""
            if [ -f "$PIPELINE_DIR/verifier.done" ] && [ -n "$SPEC_TS" ]; then
                VERIFIER_TS=$(head -1 "$PIPELINE_DIR/verifier.done" | cut -d'|' -f1 2>/dev/null)
                TOTAL=" ($(format_duration $((VERIFIER_TS - SPEC_TS))))"
            fi
            # Append to metrics log
            METRICS_LOG="$MEMORY_DIR/pipeline-metrics.log"
            SPEC_TS_V=${SPEC_TS:-0}
            BUILDER_TS_V=$(head -1 "$PIPELINE_DIR/builder.done" | cut -d'|' -f1 2>/dev/null || echo 0)
            REVIEWER_TS_V=$(head -1 "$PIPELINE_DIR/reviewer.done" | cut -d'|' -f1 2>/dev/null || echo 0)
            VERIFIER_TS_V=$(head -1 "$PIPELINE_DIR/verifier.done" | cut -d'|' -f1 2>/dev/null || echo 0)
            STATUS="completed"
            if [ ! -f "$PIPELINE_DIR/verifier.done" ]; then STATUS="partial"; fi
            # Read adversarial stats for metrics
            ADV_T=0; ADV_A=0; ADV_D=0
            if [ -f "$PIPELINE_DIR/.adversarial-summary" ]; then
                IFS=: read -r _prefix ADV_T ADV_A ADV_D < "$PIPELINE_DIR/.adversarial-summary" 2>/dev/null || true
                ADV_T=${ADV_T:-0}; ADV_A=${ADV_A:-0}; ADV_D=${ADV_D:-0}
            fi
            # v6.7.1 — per-status dismissal counts + quality-warn count read
            # from .adversarial-rationale.md. Zero defaults when rationale gate
            # was opted out (or file absent for any reason): old-format logs
            # have 12 columns; the apd report parser tolerates that.
            ADV_DO=0; ADV_DR=0; ADV_W=0
            if [ -f "$PIPELINE_DIR/.adversarial-rationale.md" ]; then
                ADV_DO=$(grep -c '^\*\*Status:\*\* dismissed$' "$PIPELINE_DIR/.adversarial-rationale.md" 2>/dev/null); ADV_DO=${ADV_DO:-0}
                ADV_DR=$(grep -c '^\*\*Status:\*\* reviewer-self-dismissed$' "$PIPELINE_DIR/.adversarial-rationale.md" 2>/dev/null); ADV_DR=${ADV_DR:-0}
                ADV_W=$(awk '
BEGIN { f=0; s=""; r=""; w=0 }
/^## Finding / { if (f>0) _c(); f++; s=""; r=""; next }
/^\*\*Status:\*\* / { sub(/^\*\*Status:\*\* /, ""); s=$0; next }
/^\*\*Rationale:\*\* / { sub(/^\*\*Rationale:\*\* /, ""); r=$0; next }
END { if (f>0) _c(); print w+0 }
function _c() {
    if (s == "dismissed" || s == "reviewer-self-dismissed") {
        if (length(r) < 40) w++
        l = tolower(r)
        if (l ~ /^(ok|n\/a|false positive|not applicable|skip|no)\.?$/) w++
    }
}
' "$PIPELINE_DIR/.adversarial-rationale.md" 2>/dev/null)
                ADV_W=${ADV_W:-0}
            fi
            # v6.30 — supervision stats (columns 16-18; zero defaults when the
            # supervision layer didn't run — old 15-column rows stay valid, the
            # same backward-compat pattern as the v6.7.1 12→15 extension).
            SUP_T=0; SUP_A=0; SUP_D=0
            if [ -f "$PIPELINE_DIR/.supervision-summary" ]; then
                SUP_LINE=$(grep '^SUPERVISION:' "$PIPELINE_DIR/.supervision-summary" 2>/dev/null | head -1)
                if [ -n "$SUP_LINE" ]; then
                    SUP_T=$(echo "$SUP_LINE" | cut -d: -f2); SUP_T=${SUP_T:-0}
                    SUP_A=$(echo "$SUP_LINE" | cut -d: -f3); SUP_A=${SUP_A:-0}
                    SUP_D=$(echo "$SUP_LINE" | cut -d: -f4); SUP_D=${SUP_D:-0}
                fi
            fi
            # Agent dispatch counts — total starts and exhausted (start without matching stop = maxTurn hit)
            AGENTS_T=0; AGENTS_X=0
            if [ -f "$PIPELINE_DIR/.agents" ]; then
                source "$SCRIPT_DIR/../lib/agents-parse.sh"
                read -r AGENTS_T AGENTS_X < <(parse_agents_log "$PIPELINE_DIR/.agents")
                # Archive .agents NOW (before the metrics/session-log writes that
                # can crash halfway through). The agent log is the richest and
                # least-reconstructible record of the run — metrics can be
                # rebuilt from .done files, agent history cannot.
                case "$TASK_NAME" in
                    APD-VERIFY-*) : ;; # skip archive for synthetic test runs
                    *)            cat "$PIPELINE_DIR/.agents" >> "$MEMORY_DIR/agent-history.log" ;;
                esac
            fi
            # Skip metrics write for verify-apd test harness runs (task names APD-VERIFY-*)
            # These are synthetic pipelines from `apd verify` and pollute real run history.
            case "$TASK_NAME" in
                APD-VERIFY-*)
                    : # skip metrics write
                    ;;
                *)
                    echo "${NOW}|${TASK_NAME}|${SPEC_TS_V}|${BUILDER_TS_V}|${REVIEWER_TS_V}|${VERIFIER_TS_V}|${STATUS}|${ADV_T}|${ADV_A}|${ADV_D}|${AGENTS_T}|${AGENTS_X}|${ADV_DO}|${ADV_DR}|${ADV_W}|${SUP_T}|${SUP_A}|${SUP_D}" >> "$METRICS_LOG"
                    ;;
            esac

            SESSION_LOG="$MEMORY_DIR/session-log.md"
            if [ -f "$SESSION_LOG" ] && [ -n "$TASK_NAME" ]; then

                # --- Collect context ---

                # 1. Changed files — check last commit first, fall back to working tree
                CHANGED_SUMMARY=""
                if command -v git &>/dev/null && git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
                    # Try last commit (most common — reset happens after commit)
                    CHANGED_FILES=$(git -C "$PROJECT_DIR" diff --name-only HEAD~1 HEAD 2>/dev/null)
                    # Fall back to staged/unstaged changes
                    [ -z "$CHANGED_FILES" ] && CHANGED_FILES=$(git -C "$PROJECT_DIR" diff --cached --name-only 2>/dev/null)
                    [ -z "$CHANGED_FILES" ] && CHANGED_FILES=$(git -C "$PROJECT_DIR" diff --name-only HEAD 2>/dev/null)
                    if [ -n "$CHANGED_FILES" ]; then
                        FILE_COUNT=$(echo "$CHANGED_FILES" | wc -l | tr -d ' ')
                        # Extract top-level directories
                        TOP_DIRS=$(echo "$CHANGED_FILES" | sed 's|/.*||' | sort -u | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                        CHANGED_SUMMARY="${FILE_COUNT} files changed (${TOP_DIRS})"
                    else
                        CHANGED_SUMMARY="No changes detected in git"
                    fi
                else
                    CHANGED_SUMMARY="Git not available"
                fi

                # 2. Guard blocks during this task (filter by spec timestamp, not date)
                # v6.8.9 — filter by log_type=BLOCK only. INFO entries (e.g.
                # brainstorm-skipped audit trail from v6.8.8) i PERMISSION_DENIED
                # NE-broje se kao blocks. INFO events idu u SKIP_SUMMARY za
                # visibility BEZ false-positive "Problems detected" pattern-a.
                GUARD_SUMMARY="N/A"
                SKIP_SUMMARY=""
                AUDIT_LOG="$MEMORY_DIR/guard-audit.log"
                if [ -f "$AUDIT_LOG" ] && [ -n "$SPEC_TS" ]; then
                    SPEC_TIME=$(date -r "$SPEC_TS" +"%Y-%m-%d %H:%M" 2>/dev/null || date -d "@$SPEC_TS" +"%Y-%m-%d %H:%M" 2>/dev/null || echo "")
                    if [ -n "$SPEC_TIME" ]; then
                        # Only count blocks after this task's spec was created
                        BLOCKS=0
                        BLOCK_REASONS=""
                        SKIP_EVENTS=0
                        SKIP_REASONS=""
                        while IFS='|' read -r log_ts log_type log_agent log_reason log_cmd; do
                            # Skip orphan/garbage lines (legacy multi-line entries from pre-fix writers)
                            case "$log_ts" in
                                [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9][[:space:]][0-9][0-9]:[0-9][0-9]:[0-9][0-9]) ;;
                                *) continue ;;
                            esac
                            LOG_EPOCH=$(date -j -f "%Y-%m-%d %H:%M:%S" "$log_ts" +%s 2>/dev/null || date -d "$log_ts" +%s 2>/dev/null || echo 0)
                            if [ "$LOG_EPOCH" -eq 0 ] 2>/dev/null && [ -n "$log_ts" ]; then
                                continue
                            fi
                            if [ "$LOG_EPOCH" -ge "$SPEC_TS" ] 2>/dev/null; then
                                case "$log_type" in
                                    BLOCK)
                                        BLOCKS=$((BLOCKS + 1))
                                        BLOCK_REASONS="${BLOCK_REASONS}${log_reason}\n"
                                        ;;
                                    INFO)
                                        SKIP_EVENTS=$((SKIP_EVENTS + 1))
                                        SKIP_REASONS="${SKIP_REASONS}${log_reason}\n"
                                        ;;
                                    *) ;;  # PERMISSION_DENIED i ostali — ignorisani u summary
                                esac
                            fi
                        done < "$AUDIT_LOG"
                        if [ "$BLOCKS" -gt 0 ]; then
                            REASON_SUMMARY=$(printf '%b' "$BLOCK_REASONS" | sort | uniq -c | sort -rn | head -3 | awk '{print $2 " (" $1 "x)"}' | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                            GUARD_SUMMARY="${BLOCKS} blocks: ${REASON_SUMMARY}"
                        fi
                        if [ "$SKIP_EVENTS" -gt 0 ]; then
                            SKIP_REASON_SUMMARY=$(printf '%b' "$SKIP_REASONS" | sort | uniq -c | sort -rn | head -3 | awk '{print $2 " (" $1 "x)"}' | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                            SKIP_SUMMARY="${SKIP_EVENTS} info events: ${SKIP_REASON_SUMMARY}"
                        fi
                    fi
                fi

                # 3. Rollback detection — check if verifier.done is newer than reviewer.done
                # (indicates rollback was used and passed again)
                PROBLEMS="No problems"
                if [ -f "$PIPELINE_DIR/verifier.done" ] && [ -f "$PIPELINE_DIR/reviewer.done" ]; then
                    V_TS=$(head -1 "$PIPELINE_DIR/verifier.done" | cut -d'|' -f1 2>/dev/null || echo 0)
                    R_TS=$(head -1 "$PIPELINE_DIR/reviewer.done" | cut -d'|' -f1 2>/dev/null || echo 0)
                    B_TS=$(head -1 "$PIPELINE_DIR/builder.done" | cut -d'|' -f1 2>/dev/null || echo 0)
                    # If builder->reviewer took >60% of total time, possible problem
                    if [ "$V_TS" -gt 0 ] && [ "$SPEC_TS" -gt 0 ] && [ "$B_TS" -gt 0 ] && [ "$R_TS" -gt 0 ]; then
                        TOTAL_DUR=$((V_TS - SPEC_TS))
                        BUILD_DUR=$((R_TS - B_TS))
                        if [ "$TOTAL_DUR" -gt 0 ] && [ "$BUILD_DUR" -gt 0 ]; then
                            BUILD_PCT=$((BUILD_DUR * 100 / TOTAL_DUR))
                            if [ "$BUILD_PCT" -gt 60 ]; then
                                PROBLEMS="Builder->Reviewer took ${BUILD_PCT}% of total time (possible iterations)"
                            fi
                        fi
                    fi
                fi

                # If there are guard blocks, that's a problem
                if [ "$GUARD_SUMMARY" != "N/A" ]; then
                    if [ "$PROBLEMS" = "No problems" ]; then
                        PROBLEMS="Guard blocks detected (see Guardrail)"
                    fi
                fi

                # 4. Pipeline status
                PIPELINE_STATUS="Completed"
                if [ ! -f "$PIPELINE_DIR/verifier.done" ]; then
                    PIPELINE_STATUS="Partial (verifier not completed)"
                fi

                # 5. New rule — caller can pass via 2nd arg ("pipeline reset 'learning text'")
                #    Empty/missing → "None" (no manual session-log edit needed)
                if [ -n "$ARG" ]; then
                    # Collapse newlines/CR so it stays one log line
                    NEW_RULE="${ARG//$'\n'/ }"
                    NEW_RULE="${NEW_RULE//$'\r'/ }"
                else
                    NEW_RULE="None"
                fi

                # 6. Agents dispatched during this task
                AGENTS_SUMMARY="none"
                AGENTS_LOG="$PIPELINE_DIR/.agents"
                if [ -f "$AGENTS_LOG" ]; then
                    AGENT_LIST=$(grep '|stop|' "$AGENTS_LOG" | cut -d'|' -f3 | sort -u | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                    [ -n "$AGENT_LIST" ] && AGENTS_SUMMARY="$AGENT_LIST"
                fi

                # 7. Spec trace coverage
                TRACE_COVERAGE=""
                if [ -f "$PIPELINE_DIR/.trace-summary" ]; then
                    TRACE_LINE=$(cat "$PIPELINE_DIR/.trace-summary")
                    TRACE_COVERED=$(echo "$TRACE_LINE" | cut -d: -f2 | cut -d/ -f1)
                    TRACE_TOTAL=$(echo "$TRACE_LINE" | cut -d: -f2 | cut -d/ -f2)
                    TRACE_MISSING=$(echo "$TRACE_LINE" | cut -d: -f3)
                    if [ -n "$TRACE_TOTAL" ] && [ "$TRACE_TOTAL" != "0" ]; then
                        if [ -z "$TRACE_MISSING" ]; then
                            TRACE_COVERAGE="${TRACE_COVERED}/${TRACE_TOTAL} (all covered)"
                        else
                            TRACE_COVERAGE="${TRACE_COVERED}/${TRACE_TOTAL} (missing: ${TRACE_MISSING})"
                        fi
                    fi
                fi

                # 8. Adversarial review hit rate
                ADV_REVIEW=""
                if [ -f "$PIPELINE_DIR/.adversarial-summary" ]; then
                    ADV_LINE=$(head -1 "$PIPELINE_DIR/.adversarial-summary")
                    # Format: ADVERSARIAL:total:accepted:dismissed
                    ADV_TOTAL=$(echo "$ADV_LINE" | cut -d: -f2)
                    ADV_ACCEPTED=$(echo "$ADV_LINE" | cut -d: -f3)
                    ADV_DISMISSED=$(echo "$ADV_LINE" | cut -d: -f4)
                    if [ -n "$ADV_TOTAL" ] && [ "$ADV_TOTAL" != "0" ]; then
                        ADV_REVIEW="${ADV_TOTAL} findings (${ADV_ACCEPTED} accepted, ${ADV_DISMISSED} dismissed)"
                    fi
                fi

                # --- Generate entry ---
                # v6.8.9 — add Skip events line ONLY if SKIP_SUMMARY non-empty (no
                # noise for tasks bez INFO events; explicit visibility kad postoje).
                SKIP_LINE=""
                if [ -n "$SKIP_SUMMARY" ]; then
                    SKIP_LINE=$'\n'"**Skip events:** $SKIP_SUMMARY"
                fi
                cat >> "$SESSION_LOG" << EOF

## [$(date +%Y-%m-%d)] $TASK_NAME
**Status:** $PIPELINE_STATUS
**Spec coverage:** ${TRACE_COVERAGE:-N/A}
**Adversarial review:** ${ADV_REVIEW:-N/A}
**What was done:** $CHANGED_SUMMARY
**Agents:** $AGENTS_SUMMARY
**Problems:** $PROBLEMS
**Guardrail that helped:** $GUARD_SUMMARY${SKIP_LINE}
**New rule:** $NEW_RULE
**Pipeline duration:**$TOTAL
EOF
                echo "Session log updated (auto-summary): $TASK_NAME" >&2
            fi
        fi
        # .agents was already archived above (before metrics write).
        # GitHub sync — mark done (best-effort, before cleanup removes .gh-issue)
        bash "$SCRIPT_DIR/gh-sync" done 2>/dev/null || true
        rm -f "$PIPELINE_DIR"/*.done "$PIPELINE_DIR/verified.timestamp" "$PIPELINE_DIR/.agents" "$PIPELINE_DIR/.trace-summary" "$PIPELINE_DIR/.adversarial-summary" "$PIPELINE_DIR/.adversarial-pending" "$PIPELINE_DIR/.adversarial-rationale.md" "$PIPELINE_DIR/.supervision-summary" "$PIPELINE_DIR/.supervision-rationale.md" "$PIPELINE_DIR/spec-card.md" "$PIPELINE_DIR/implementation-plan.md" "$PIPELINE_DIR/.spec-hash" "$PIPELINE_DIR/.spec-max-defects-history" "$PIPELINE_DIR/.builder-count" "$PIPELINE_DIR/.reviewer-count" "$PIPELINE_DIR/.reviewed-files" "$PIPELINE_DIR/.guarded-writes" "$PIPELINE_DIR/.guide-marker" "$PIPELINE_DIR/.brainstorm-marker" "$PIPELINE_DIR/.deferred-findings"
        # Reset completed cleanly — drop the in-progress marker.
        rm -f "$PIPELINE_DIR/.reset-in-progress" 2>/dev/null
        echo "Pipeline reset. Ready for new task."
        ;;

    rollback)
        # Find the last completed step and remove it
        ROLLED_BACK=false
        for step in verifier reviewer builder spec; do
            if [ -f "$PIPELINE_DIR/$step.done" ]; then
                rm -f "$PIPELINE_DIR/$step.done"
                # If verifier rolled back, also remove cache timestamp and trace summary.
                # Supervision state falls too — it judged a FINAL diff that is no
                # longer final once anything re-runs (v6.30).
                [ "$step" = "verifier" ] && rm -f "$PIPELINE_DIR/verified.timestamp" "$PIPELINE_DIR/.trace-summary" "$PIPELINE_DIR/.adversarial-summary" "$PIPELINE_DIR/.adversarial-rationale.md" "$PIPELINE_DIR/.supervision-summary" "$PIPELINE_DIR/.supervision-rationale.md"
                # Rollback to reviewer must also clear the adversarial summary, else
                # the next verifier sees stale summary + new .adversarial-pending and
                # mis-reports "Adversarial ran BEFORE reviewer step completed" when
                # the real problem is the summary is from the previous run.
                [ "$step" = "reviewer" ] && rm -f "$PIPELINE_DIR/.adversarial-pending" "$PIPELINE_DIR/.reviewed-files" "$PIPELINE_DIR/.adversarial-summary" "$PIPELINE_DIR/.adversarial-rationale.md" "$PIPELINE_DIR/.supervision-summary" "$PIPELINE_DIR/.supervision-rationale.md"
                # implementation-plan.md is NOT deleted on rollback — it's part of the frozen spec
                apd_header "Rollback: $step"
                show_pipeline "$step"
                ROLLED_BACK=true
                break
            fi
        done

        if [ "$ROLLED_BACK" = false ]; then
            echo "No steps to roll back — pipeline is empty."
        fi
        ;;

    status)
        TASK="[no active task]"
        SPEC_TIME=""
        NEXT_STEP=""
        if [ -f "$PIPELINE_DIR/spec.done" ]; then
            TASK=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f3)
            SPEC_TIME=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f2)
            SPEC_TS=$(head -1 "$PIPELINE_DIR/spec.done" | cut -d'|' -f1)
        fi

        # Find next step
        for s in spec builder reviewer verifier; do
            if [ ! -f "$PIPELINE_DIR/$s.done" ]; then
                NEXT_STEP="$s"
                break
            fi
        done

        if [ -n "$SPEC_TIME" ]; then
            TOTAL_ELAPSED=$(format_duration $(($(date +%s) - SPEC_TS)))
            apd_header "$TASK" "$TOTAL_ELAPSED"
        else
            apd_header "Pipeline Status"
        fi
        show_pipeline "$NEXT_STEP"

        # Detailed timing below the box
        PREV_TS="${SPEC_TS:-}"
        for step in spec builder reviewer verifier; do
            if [ -f "$PIPELINE_DIR/$step.done" ]; then
                STEP_TS=$(head -1 "$PIPELINE_DIR/$step.done" | cut -d'|' -f1)
                if [ "$step" != "spec" ] && [ -n "$PREV_TS" ]; then
                    DELTA=$(format_duration $((STEP_TS - PREV_TS)))
                    sc=$(_step_color "$step")
                    printf "    %s■%s %-12s +%s\n" "$sc" "$R" "$step" "$DELTA"
                fi
                PREV_TS="$STEP_TS"
            else
                if [ -n "$PREV_TS" ]; then
                    WAITING=$(format_duration $(($(date +%s) - PREV_TS)))
                    sc=$(_step_color "$step")
                    printf "    %s□%s %-12s waiting %s\n" "$sc" "$R" "$step" "$WAITING"
                fi
                PREV_TS=""
            fi
        done
        print_pipeline_state
        ;;

    show)
        # Sanctioned read-only state inspection — replaces bash cat/ls on
        # .apd/pipeline (guard-blocked). spec/plan are the orchestrator's own
        # authored files (safe full echo); default prints the digest.
        case "$ARG" in
            spec)
                if [ -f "$PIPELINE_DIR/spec-card.md" ]; then
                    cat "$PIPELINE_DIR/spec-card.md"
                else
                    echo "spec-card.md: none"
                fi
                ;;
            plan)
                if [ -f "$PIPELINE_DIR/implementation-plan.md" ]; then
                    cat "$PIPELINE_DIR/implementation-plan.md"
                else
                    echo "implementation-plan.md: none"
                fi
                ;;
            deferred)
                if [ -n "${MEMORY_DIR:-}" ] && [ -f "$MEMORY_DIR/deferred-tasks.md" ]; then
                    cat "$MEMORY_DIR/deferred-tasks.md"
                else
                    echo "deferred-tasks.md: none — no findings spun off yet"
                    echo "  Record an accepted, out-of-scope finding with:"
                    echo "    apd pipeline spinoff-finding <id> \"<why out of scope + the follow-up task>\""
                fi
                ;;
            ""|state|status)
                print_pipeline_state
                ;;
            *)
                echo "Usage: apd pipeline show [spec|plan|state|deferred]" >&2
                echo "  reviewed-files + adversarial appear as digests in 'state'" >&2
                echo "  (raw generated state is not dumped — use 'state' for counts)" >&2
                echo "  deferred = the spun-off follow-up task backlog" >&2
                exit 1
                ;;
        esac
        ;;

    reconstruct-agents)
        # Recovery for a CC SubagentStop hook NON-DELIVERY (harness bug, observed
        # 2026-06-04): CC ran subagents but never fired SubagentStop, so .agents
        # is missing entries for agents that genuinely ran. Rebuild .agents from
        # the CC subagent TRANSCRIPTS on disk. The transcript file is CC ground
        # truth (written per agent; the orchestrator cannot fabricate it), so a
        # genuine hook-failure is recoverable while a phantom agent with no
        # transcript stays blocked. Loud audit trail. Distinguishes the true
        # case from fabrication, which orchestrator-written .agents cannot.
        if [ ! -f "$PIPELINE_DIR/spec.done" ]; then
            echo "BLOCKED: no active pipeline (spec.done missing) — nothing to scope reconstruction against." >&2
            exit 1
        fi
        # Shared with the builder/reviewer gate fallback (single source of truth
        # for "what counts as a real transcript-backed agent").
        RA_VERBOSE=1
        if ! _reconstruct_from_transcripts; then
            echo "BLOCKED: CC transcript dir not found: $RA_BASE" >&2
            echo "  Cannot reconstruct without CC subagent transcripts (ground truth)." >&2
            exit 1
        fi
        if [ "$RA_COUNT" -eq 0 ]; then
            echo "No transcript-backed agents to reconstruct (none after spec, or all already recorded)." >&2
        else
            echo "" >&2
            echo "Reconstructed $RA_COUNT agent pair(s) from CC transcripts — each backed by a real" >&2
            echo "subagent transcript on disk (NOT fabricated). Re-run 'apd pipeline builder'." >&2
        fi
        ;;

    spinoff-finding)
        # Third disposition for an adversarial finding: accept / dismiss / SPINOFF.
        # A finding that is REAL but OUT of the declared spec scope (and typically
        # beyond the builder/reviewer cycle cap) is NOT crammed into this commit —
        # it is recorded as a task SEED for a follow-up pipeline (its own spec +
        # fresh adversarial + red-green test), so a rule-1 fix gets the full
        # treatment it deserves. This is the sanctioned alternative to reaching
        # for `apd toggle off` (which disables the WHOLE enforcement layer) just
        # to land an out-of-scope fix. Does NOT touch the cycle cap and does NOT
        # touch the immutable spec-card. Guardrail: for an ACCEPTED, genuinely
        # out-of-scope finding only — reason mandatory (auditable), distinct from
        # a dismissal.
        FID="$ARG"
        FREASON="$ARG2"
        if [ -z "$FID" ] || [ -z "$FREASON" ]; then
            echo "BLOCKED: spinoff-finding needs a finding id AND a reason." >&2
            echo "" >&2
            echo "  Usage: apd pipeline spinoff-finding <id> \"<why out of scope + the follow-up task>\"" >&2
            echo "  Example: apd pipeline spinoff-finding 5 \\" >&2
            echo "    \"lost-update on update/remove; out of scope (spec = clamp + add-lock), needs own spec + red-green concurrency test\"" >&2
            echo "" >&2
            echo "  Use this for an ACCEPTED, genuinely out-of-scope finding — NOT a dismissal." >&2
            exit 1
        fi
        # Precondition: an adversarial OR supervision pass must be on record
        # (there is a finding). v6.30: supervision findings can be spun off too.
        if [ ! -f "$PIPELINE_DIR/.adversarial-summary" ] && [ ! -f "$PIPELINE_DIR/.adversarial-rationale.md" ] \
            && [ ! -f "$PIPELINE_DIR/.supervision-summary" ] && [ ! -f "$PIPELINE_DIR/.supervision-rationale.md" ]; then
            echo "BLOCKED: no adversarial or supervision review on record — nothing to spin off yet." >&2
            echo "  Run the adversarial pass first; spinoff-finding records a finding it surfaced." >&2
            exit 1
        fi
        if [ -z "${MEMORY_DIR:-}" ] || [ ! -d "$MEMORY_DIR" ]; then
            echo "BLOCKED: no memory dir resolved — cannot persist the deferred task seed." >&2
            exit 1
        fi
        SRC_TASK="(unknown)"
        [ -f "$PIPELINE_DIR/spec.done" ] && SRC_TASK=$(head -1 "$PIPELINE_DIR/spec.done" 2>/dev/null | cut -d'|' -f3)
        [ -n "$SRC_TASK" ] || SRC_TASK="(unknown)"
        DEFER_FILE="$MEMORY_DIR/deferred-tasks.md"
        FREASON_CLEAN="${FREASON//$'\n'/ }"
        FREASON_CLEAN="${FREASON_CLEAN//$'\r'/ }"
        ADV_LINE=$(grep '^ADVERSARIAL:' "$PIPELINE_DIR/.adversarial-summary" 2>/dev/null | head -1)
        SUP_LINE=$(grep '^SUPERVISION:' "$PIPELINE_DIR/.supervision-summary" 2>/dev/null | head -1)
        {
            echo ""
            echo "<!-- ============================================================ -->"
            echo "## [$(date +%Y-%m-%d)] Spinoff from \"$SRC_TASK\" — finding #$FID"
            echo "**Status:** deferred (accepted, out of current spec scope)"
            echo "**Source task:** $SRC_TASK"
            echo "**Source adversarial:** ${ADV_LINE:-n/a}"
            [ -n "$SUP_LINE" ] && echo "**Source supervision:** $SUP_LINE"
            echo "**Finding id:** $FID"
            echo "**Seed (why out of scope + follow-up task):** $FREASON_CLEAN"
            echo "**Next step:** open as its own APD task — full spec (R-criteria) + fresh adversarial + red-green test BEFORE fix."
        } >> "$DEFER_FILE"
        # Per-run marker so `apd pipeline show state` notes a spinoff happened.
        echo "$(date +"%Y-%m-%d %H:%M:%S")|#${FID}|${SRC_TASK}" >> "$PIPELINE_DIR/.deferred-findings"
        # Loud, auditable — a real disposition, not a bypass.
        if [ "${APD_AUDIT_SYNTHETIC:-}" = "1" ]; then _st=SYNTHETIC; else _st=INFO; fi
        echo "$(date +"%Y-%m-%d %H:%M:%S")|${_st}|orchestrator|finding-spinoff|task=$SRC_TASK id=$FID" >> "$MEMORY_DIR/guard-audit.log"
        echo ""
        echo "  Recorded finding #$FID as a deferred task seed → $DEFER_FILE"
        echo "  It will NOT be crammed into this run. Continue the current pipeline in scope;"
        echo "  open the spinoff as its own task (spec + fresh adversarial + red-green) next."
        echo "  Backlog: apd pipeline show deferred"
        ;;

    stats)
        SKIP_LOG="$MEMORY_DIR/pipeline-skip-log.md"
        if [ ! -f "$SKIP_LOG" ]; then
            echo "No skip log found."
            exit 0
        fi
        TOTAL_SKIPS=$(grep -c '^|[[:space:]]*[0-9]' "$SKIP_LOG" 2>/dev/null || echo 0)
        echo "Pipeline statistics:"
        echo "  Total skips: $TOTAL_SKIPS"
        if [ "$TOTAL_SKIPS" -gt 0 ]; then
            echo ""
            echo "Last 5:"
            grep '^|[[:space:]]*[0-9]' "$SKIP_LOG" | tail -5
        fi
        ;;

    metrics)
        METRICS_LOG="$MEMORY_DIR/pipeline-metrics.log"
        if [ ! -f "$METRICS_LOG" ] || [ ! -s "$METRICS_LOG" ]; then
            echo "No metrics — no tasks completed yet."
            exit 0
        fi

        TOTAL_TASKS=$(wc -l < "$METRICS_LOG" | tr -d ' ')
        COMPLETED=$(grep -c '|completed' "$METRICS_LOG" 2>/dev/null || echo 0)
        PARTIAL=$(grep -c '|partial' "$METRICS_LOG" 2>/dev/null || echo 0)
        SKIP_LOG="$MEMORY_DIR/pipeline-skip-log.md"
        TOTAL_SKIPS=0
        if [ -f "$SKIP_LOG" ]; then
            TOTAL_SKIPS=$(grep -c '^|[[:space:]]*[0-9]' "$SKIP_LOG" 2>/dev/null) || TOTAL_SKIPS=0
        fi

        # Calculate average durations
        TOTAL_DURATION=0
        FASTEST=999999
        SLOWEST=0
        SPEC_TO_BUILDER=0
        BUILDER_TO_REVIEWER=0
        REVIEWER_TO_VERIFIER=0
        VALID_COUNT=0

        while IFS='|' read -r _ts task_name spec_ts builder_ts reviewer_ts verifier_ts status _adv_t _adv_a _adv_d; do
            # Clean trailing whitespace
            verifier_ts=$(echo "$verifier_ts" | tr -d '[:space:]')
            spec_ts=$(echo "$spec_ts" | tr -d '[:space:]')
            builder_ts=$(echo "$builder_ts" | tr -d '[:space:]')
            reviewer_ts=$(echo "$reviewer_ts" | tr -d '[:space:]')
            status=$(echo "$status" | tr -d '[:space:]')

            if [ "$verifier_ts" -gt 0 ] 2>/dev/null && [ "$spec_ts" -gt 0 ] 2>/dev/null; then
                DUR=$((verifier_ts - spec_ts))
                TOTAL_DURATION=$((TOTAL_DURATION + DUR))
                [ "$DUR" -lt "$FASTEST" ] && FASTEST=$DUR
                [ "$DUR" -gt "$SLOWEST" ] && SLOWEST=$DUR
                VALID_COUNT=$((VALID_COUNT + 1))

                if [ "$builder_ts" -gt 0 ]; then
                    SPEC_TO_BUILDER=$((SPEC_TO_BUILDER + builder_ts - spec_ts))
                fi
                if [ "$reviewer_ts" -gt 0 ] && [ "$builder_ts" -gt 0 ]; then
                    BUILDER_TO_REVIEWER=$((BUILDER_TO_REVIEWER + reviewer_ts - builder_ts))
                fi
                if [ "$verifier_ts" -gt 0 ] && [ "$reviewer_ts" -gt 0 ]; then
                    REVIEWER_TO_VERIFIER=$((REVIEWER_TO_VERIFIER + verifier_ts - reviewer_ts))
                fi
            fi
        done < "$METRICS_LOG"

        if [ "$VALID_COUNT" -gt 0 ]; then
            AVG_DURATION=$(format_duration $((TOTAL_DURATION / VALID_COUNT)))
            FASTEST_FMT=$(format_duration $FASTEST)
            SLOWEST_FMT=$(format_duration $SLOWEST)
            AVG_S2B=$(format_duration $((SPEC_TO_BUILDER / VALID_COUNT)))
            AVG_B2R=$(format_duration $((BUILDER_TO_REVIEWER / VALID_COUNT)))
            AVG_R2V=$(format_duration $((REVIEWER_TO_VERIFIER / VALID_COUNT)))
        else
            AVG_DURATION="N/A"; FASTEST_FMT="N/A"; SLOWEST_FMT="N/A"
            AVG_S2B="N/A"; AVG_B2R="N/A"; AVG_R2V="N/A"
        fi

        SKIP_RATE="0%"
        if [ "$TOTAL_TASKS" -gt 0 ] && [ "$TOTAL_SKIPS" -gt 0 ]; then
            SKIP_RATE="$TOTAL_SKIPS/$((TOTAL_TASKS + TOTAL_SKIPS)) ($((TOTAL_SKIPS * 100 / (TOTAL_TASKS + TOTAL_SKIPS)))%)"
        fi

        apd_header "Pipeline Metrics"

        section "Overview"
        printf "    %-22s %s\n" "Total tasks:" "$TOTAL_TASKS ($COMPLETED completed, $PARTIAL partial)"
        printf "    %-22s %s\n" "Average duration:" "$AVG_DURATION"
        printf "    %-22s %s\n" "Fastest:" "$FASTEST_FMT"
        printf "    %-22s %s\n" "Slowest:" "$SLOWEST_FMT"
        printf "    %-22s %s\n" "Skip rate:" "$SKIP_RATE"

        section "Average per step"
        printf "    %-22s %s\n" "spec → builder:" "$AVG_S2B"
        printf "    %-22s %s\n" "builder → reviewer:" "$AVG_B2R"
        printf "    %-22s %s\n" "reviewer → verifier:" "$AVG_R2V"

        # Adversarial hit rate (cumulative). v6.7.1 adds Do/Dr/Warns columns
        # 13/14/15; old 12-col rows produce empty trailing fields that default
        # to 0 via ${var:-0}, so legacy logs render the same as before.
        ADV_TOTAL_SUM=0
        ADV_ACCEPTED_SUM=0
        ADV_DO_SUM=0
        ADV_DR_SUM=0
        ADV_W_SUM=0
        ADV_TASKS=0
        # v6.30: _rest sink — without it 18-col rows fold `|sup_t|sup_a|sup_d`
        # into adv_w and $((sum + adv_w)) evaluates `|` as BITWISE OR (audit #3:
        # row `…|2|4|2|2` yielded warns contribution 6, corrupting the warns=0
        # rubber-stamp discriminator).
        while IFS='|' read -r _ts _task _s _b _r _v _status adv_t adv_a adv_d _at _ax adv_do adv_dr adv_w _sup_t _sup_a _sup_d _rest; do
            adv_t=$(echo "${adv_t:-0}" | tr -d '[:space:]')
            adv_a=$(echo "${adv_a:-0}" | tr -d '[:space:]')
            adv_do=$(echo "${adv_do:-0}" | tr -d '[:space:]')
            adv_dr=$(echo "${adv_dr:-0}" | tr -d '[:space:]')
            adv_w=$(echo "${adv_w:-0}" | tr -d '[:space:]')
            [ "$adv_t" -gt 0 ] 2>/dev/null && {
                ADV_TOTAL_SUM=$((ADV_TOTAL_SUM + adv_t))
                ADV_ACCEPTED_SUM=$((ADV_ACCEPTED_SUM + adv_a))
                ADV_DO_SUM=$((ADV_DO_SUM + adv_do))
                ADV_DR_SUM=$((ADV_DR_SUM + adv_dr))
                ADV_W_SUM=$((ADV_W_SUM + adv_w))
                ADV_TASKS=$((ADV_TASKS + 1))
            }
        done < "$METRICS_LOG"

        if [ "$ADV_TASKS" -gt 0 ]; then
            ADV_RATE=$((ADV_ACCEPTED_SUM * 100 / ADV_TOTAL_SUM))
            section "Adversarial review"
            printf "    %-22s %s\n" "Hit rate:" "${ADV_RATE}% (${ADV_ACCEPTED_SUM}/${ADV_TOTAL_SUM} accepted across ${ADV_TASKS} tasks)"
            if [ "$ADV_DO_SUM" -gt 0 ] || [ "$ADV_DR_SUM" -gt 0 ]; then
                printf "    %-22s Do=%d (orchestrator) Dr=%d (reviewer-self)\n" "Dismissal split:" "$ADV_DO_SUM" "$ADV_DR_SUM"
            fi
            if [ "$ADV_W_SUM" -gt 0 ]; then
                printf "    %-22s %d (rationale text <40 chars or lazy pattern)\n" "Rationale warns:" "$ADV_W_SUM"
            fi
        fi

        section "Last 5"
        tail -5 "$METRICS_LOG" | while IFS='|' read -r _ts task_name spec_ts _b _r verifier_ts status _adv_t _adv_a _adv_d; do
            verifier_ts=$(echo "$verifier_ts" | tr -d '[:space:]')
            spec_ts=$(echo "$spec_ts" | tr -d '[:space:]')
            status=$(echo "$status" | tr -d '[:space:]')
            DUR="N/A"
            if [ "$verifier_ts" -gt 0 ] 2>/dev/null && [ "$spec_ts" -gt 0 ] 2>/dev/null; then
                DUR=$(format_duration $((verifier_ts - spec_ts)))
            fi
            ICON="${MARK_PASS}"
            [ "$status" = "partial" ] && ICON="${D}…${R}"
            printf "    %s %-24s %s\n" "$ICON" "$task_name" "$DUR"
        done
        echo ""
        ;;

    init)
        if [ -z "$ARG" ]; then
            echo "ERROR: Description for init is required." >&2
            exit 1
        fi

        # Init only allowed if no previous commits with APD (first setup).
        # Count commits touching any APD-owned dir — .claude/ for CC,
        # .codex/ for Codex, .apd/ for runtime-neutral state.
        APD_COMMIT_COUNT=$(git -C "$PROJECT_DIR" log --oneline --all -- .claude/ .codex/ .apd/ 2>/dev/null | wc -l | tr -d ' ')
        if [ "$APD_COMMIT_COUNT" -gt 2 ] && [ "${APD_FORCE_INIT:-}" != "1" ]; then
            echo "BLOCKED: Init is only for first project setup." >&2
            echo "" >&2
            echo "  This project already has $APD_COMMIT_COUNT commits." >&2
            echo "  Use the full pipeline: spec → builder → reviewer → verifier → commit" >&2
            echo "" >&2
            echo "  If this is truly a re-initialization, run:" >&2
            echo "    APD_FORCE_INIT=1 bash $APD_SHORTCUT_DISPLAY pipeline init \"$ARG\"" >&2
            exit 1
        fi

        create_done "spec" "INIT: ${ARG}"
        create_done "builder"
        create_done "reviewer"
        create_done "verifier"

        apd_header "Initial Setup"
        echo "    $ARG"
        echo "    All steps marked complete. Ready to commit."
        ;;

    *)
        echo "Usage:" >&2
        echo "  pipeline-advance spec \"Task name\"" >&2
        echo "  pipeline-advance builder|reviewer|verifier" >&2
        echo "  pipeline-advance reset|status|stats|metrics" >&2
        echo "  pipeline-advance show [spec|plan|state|deferred]  # read-only state inspection" >&2
        echo "  pipeline-advance reconstruct-agents       # rebuild .agents from CC transcripts (hook-failure recovery)" >&2
        echo "  pipeline-advance spinoff-finding <id> \"<reason>\"  # defer an accepted out-of-scope finding to a follow-up task" >&2
        echo "  pipeline-advance rollback" >&2
        echo "  pipeline-advance init \"Description\"     # First setup only" >&2
        echo "" >&2
        echo "  There is no skip command. Every feature goes through the full pipeline." >&2
        echo "  For hotfixes, use a separate terminal: git commit without APD prefix." >&2
        exit 1
        ;;
esac
