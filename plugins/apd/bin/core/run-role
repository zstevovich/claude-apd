#!/bin/bash
# APD Run Role — start a role's Claude Code session with its charter injected.
#
# A role carries its own identity in roles.conf (scope + boundary + profile);
# run-role turns that identity into a running session. The charter is built
# AUTOMATICALLY from the role's own fields and injected on --launch via
# `claude --append-system-prompt` — the user never writes it; the role defines
# what the session is and what it may touch.
#
# Two workspace classes, one launcher:
#   producer (worktree=yes) — owns its domain in its OWN git worktree (feature
#     branch + folder + isolated APD pipeline). run-role creates/reuses that
#     worktree, bootstraps config, runs the project's dev-env setup, then (with
#     --launch) enters CC in it.
#   operator (worktree=no)  — devops/debug/master manage shared state or
#     integrate, so they get NO worktree and charter-launch in the MAIN checkout.
#
# Without --launch, run-role only prepares (producer: the worktree; operator:
# nothing) and prints how to enter — preparing and spawning are different
# reversibility classes, so spawning stays opt-in.
#
# APD owns the worktree lifecycle here: CC's native `claude --worktree` is
# create-only (fatals on an existing worktree) and leaves stray directories on
# exit (measured), so run-role drives `git worktree add` itself with a stable
# `<role>-work` branch + `.claude/worktrees/<role>-work` path, and reuses an
# existing one instead of recreating it.
#
# Dev-env: a fresh worktree checks out only tracked files, so deps/DB/secrets
# are missing. If the project ships `.apd/dev-env-setup` (a tracked, idempotent
# script — usually a thin call to the project's own run.sh / start_apps.sh),
# run-role executes it. APD does not know the stack; the project does.
#
# Usage:
#   run-role <role>            producer: create/reuse worktree + dev-env, print enter cmd
#                              operator: print how to charter-launch in the main checkout
#   run-role <role> --launch   charter-launch CC as the role (producer: in its worktree;
#                              operator: in the main checkout) — charter injected automatically
#   run-role --list            list producer roles eligible for a worktree
#
# Guards (state-changing path — global rule 1):
#   E1 invoked inside a worktree     → BLOCK (run from the main checkout)
#   E2 operator role (worktree=no)   → no worktree; charter-launch in the main checkout (exit 0)
#   E7 non-git project               → BLOCK (worktrees need git)
#   E9 unknown role                  → BLOCK (not in roles.conf)
#   E4 worktree/branch collision     → reuse / attach / BLOCK (stray dir → manual cleanup)
#   E5 dev-env hook failure          → report, NEVER auto-delete the worktree
#   E3 worktree has active pipeline  → warn (resume, don't re-run)
#   E6 dirty main checkout           → warn (uncommitted main work is NOT in the worktree)
#   E11 --launch but no `claude` CLI → degrade to prepare-only + print the command
#
# Charter (--launch): built automatically from the role's roles.conf fields
# (scope + boundary + profile + workspace) and passed to `claude
# --append-system-prompt`, so the session knows its identity for the whole run.
# For producers, --launch also scrubs APD_PROJECT_DIR + CLAUDE_PLUGIN_ROOT so the
# new session resolves the worktree as its own project root (not a leaked
# main-checkout root, R6).
#
# Exit codes: 0 ok, 1 usage / unknown role / non-git, 2 collision / inside-worktree

set -u

source "$(dirname "$0")/../lib/resolve-project.sh"
source "$(dirname "$0")/../lib/style.sh"

ROLES_FILE="$APD_PLUGIN_ROOT/templates/roles.conf"
PROJECT_ROLES="$PROJECT_DIR/.apd/roles.conf"
[ -f "$PROJECT_ROLES" ] && ROLES_FILE="$PROJECT_ROLES"

BOOTSTRAP="$(dirname "$0")/worktree-bootstrap"

# --- Conf helpers (mirror bin/core/roles) ---
_rows() { grep -vE '^[[:space:]]*(#|$)' "$ROLES_FILE" 2>/dev/null; }
_role_row() { _rows | awk -F'|' -v r="$1" '$1==r { print; exit }'; }
_producer_roles() { _rows | awk -F'|' '$2=="yes" { print $1 }'; }

# Build the session charter from the role's own roles.conf fields. The user
# never writes this — the role definition carries its own identity, and
# --launch injects it verbatim as an appended system prompt so the spawned CC
# session knows what it is and what it may touch for the whole run.
# Args: role worktree-flag profile scope boundary
_role_charter() {
    local role="$1" wt="$2" profile="$3" scope="$4" boundary="$5" workspace
    if [ "$wt" = "yes" ]; then
        workspace="an isolated git worktree on branch '${role}-work' with its own APD pipeline (merge back via 'apd merge-role ${role}')"
    else
        workspace="the main checkout — an operator role: you manage shared state or integrate across roles, so you get NO isolated worktree"
    fi
    cat <<EOF
You are operating as the APD "${role}" role for this entire session.
Workspace: ${workspace}.
Scope — what this role owns and may change: ${scope}
Boundary — what this role must NOT do: ${boundary}
Default model profile for this role: ${profile}.
Stay strictly inside this scope and boundary for the whole session. If a task needs work outside them, stop and surface it for reassignment rather than crossing the boundary.
EOF
}

# Am I inside a linked worktree? (git-dir != git-common-dir) — same test the
# resolver uses, redefined here because the resolver unsets its copy.
_in_worktree() {
    local gd gcd
    gd=$(git rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
    gcd=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
    [ -n "$gcd" ] && [ "$gd" != "$gcd" ]
}

# --- Arg parsing ---
ROLE=""
LAUNCH=false
for arg in "$@"; do
    case "$arg" in
        --help|-h)
            sed -n '2,38p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        --launch) LAUNCH=true ;;
        --list|--list-roles)
            echo ""
            echo "  ${V}Producer roles${R} (eligible for a worktree):"
            for r in $(_producer_roles); do echo "    $r"; done
            echo ""
            echo "  Run: apd run-role <role>    Inspect: apd roles status <role>"
            exit 0
            ;;
        --*)
            err "Unknown flag: $arg"
            exit 1
            ;;
        *)
            if [ -z "$ROLE" ]; then ROLE="$arg"; else err "Unexpected argument: $arg"; exit 1; fi
            ;;
    esac
done

if [ -z "$ROLE" ]; then
    err "Usage: apd run-role <role> [--launch]   (--list for eligible roles)"
    exit 1
fi

# --- E9: role must exist in the registry ---
ROW=$(_role_row "$ROLE")
if [ -z "$ROW" ]; then
    apd_blocked "Unknown role: '$ROLE'"
    echo "  Known roles: $(_rows | cut -d'|' -f1 | tr '\n' ' ')" >&2
    echo "  Inspect: $APD_SHORTCUT_DISPLAY roles list" >&2
    exit 1
fi

IFS='|' read -r _r WT _profile _scope _boundary <<EOF
$ROW
EOF

# Charter is built once from the role's own fields and injected automatically on
# --launch — into the worktree for producers, into the main checkout for operators.
CHARTER=$(_role_charter "$ROLE" "$WT" "$_profile" "$_scope" "$_boundary")

# --- Operator role (worktree=no): no worktree, but it still gets a session.
# A worktree belongs to PRODUCERS of an artifact; operators (devops/debug/master)
# manage shared state or integrate, so they run in the MAIN checkout. They are
# NOT blocked — run-role just skips the worktree and charter-launches in place. ---
if [ "$WT" != "yes" ]; then
    apd_header "Run role: $ROLE (operator — main checkout)"
    echo ""
    echo "  workspace: main checkout (operator role — no worktree, by design)"
    echo "  profile:   $_profile"
    echo "  scope:     $_scope"
    echo ""
    if [ "$LAUNCH" = true ] && command -v claude >/dev/null 2>&1; then
        ok "Launching Claude Code as operator role '$ROLE' (charter injected automatically)."
        # No cd: operators work in the main checkout. Scrub leaked env so the new
        # session resolves the project from cwd, consistent with the producer path.
        unset APD_PROJECT_DIR CLAUDE_PLUGIN_ROOT
        exec claude --append-system-prompt "$CHARTER"
    fi
    # E11: --launch requested but no `claude` on PATH → print the manual command.
    [ "$LAUNCH" = true ] && warn "--launch requested but 'claude' is not on PATH — not spawned."
    ok "Operator role '$ROLE' runs in the main checkout. Start a charter-scoped session with:"
    echo ""
    echo "    $APD_SHORTCUT_DISPLAY run-role $ROLE --launch"
    echo ""
    echo "  ${D}--launch injects this role's scope/boundary as the session charter automatically.${R}"
    exit 0
fi

# --- E7: worktrees require git ---
if ! git rev-parse --show-toplevel >/dev/null 2>&1; then
    apd_blocked "Not a git repository — worktrees require git."
    echo "  Initialize git first (git init) or run from inside the repo." >&2
    exit 1
fi

# --- E1: must be invoked from the MAIN checkout, never from a worktree ---
if _in_worktree; then
    apd_blocked "run-role must be invoked from the MAIN checkout, not a worktree."
    echo "  You are inside a linked worktree. Nesting worktrees creates confusing" >&2
    echo "  sibling lineage. cd to the main checkout and run again." >&2
    exit 2
fi

MAIN_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
WT_DIR="$MAIN_ROOT/.claude/worktrees/${ROLE}-work"
BRANCH="${ROLE}-work"

apd_header "Run role: $ROLE"
echo ""
echo "  worktree: ${WT_DIR#"$MAIN_ROOT"/}"
echo "  branch:   $BRANCH"
echo ""

# --- E4: worktree / branch collision handling ---
_wt_registered() { git -C "$MAIN_ROOT" worktree list --porcelain 2>/dev/null | grep -qx "worktree $WT_DIR"; }
_branch_exists() { git -C "$MAIN_ROOT" branch --list "$BRANCH" 2>/dev/null | grep -q .; }

CREATED=false
if _wt_registered; then
    # (a) registered worktree at the expected path → reuse, idempotent
    ok "Reusing existing worktree (already registered)."
elif [ -e "$WT_DIR" ]; then
    # stray directory: exists on disk but not a registered worktree (CC native
    # leaves these on exit). Do NOT auto-delete — report and let the user clean.
    apd_blocked "A directory exists at the worktree path but is NOT a registered worktree (stray)."
    echo "  Clean it up, then re-run:" >&2
    echo "    rm -rf \"$WT_DIR\"" >&2
    echo "    git -C \"$MAIN_ROOT\" worktree prune" >&2
    exit 2
elif _branch_exists; then
    # (b) branch exists without a worktree → attach it (don't recreate the branch)
    if git -C "$MAIN_ROOT" worktree add "$WT_DIR" "$BRANCH" >/dev/null 2>&1; then
        fix "Attached existing branch '$BRANCH' to a new worktree."
        CREATED=true
    else
        apd_blocked "Branch '$BRANCH' exists but could not be attached (checked out elsewhere?)."
        echo "  git -C \"$MAIN_ROOT\" worktree list   # see where it's checked out" >&2
        exit 2
    fi
else
    # (c) fresh: new branch + worktree from current HEAD
    if git -C "$MAIN_ROOT" worktree add "$WT_DIR" -b "$BRANCH" >/dev/null 2>&1; then
        fix "Created worktree on new branch '$BRANCH' (from $(git -C "$MAIN_ROOT" rev-parse --abbrev-ref HEAD))."
        CREATED=true
    else
        apd_blocked "git worktree add failed."
        echo "  git -C \"$MAIN_ROOT\" worktree add \"$WT_DIR\" -b \"$BRANCH\"   # see the error" >&2
        exit 2
    fi
fi

# --- E8: bootstrap APD config into the worktree (no-op if already present) ---
if [ -x "$BOOTSTRAP" ]; then
    ( cd "$WT_DIR" && bash "$BOOTSTRAP" 2>&1 | sed 's/^/  /' )
fi

# --- E3: warn if the worktree already has an active pipeline ---
if [ -f "$WT_DIR/.apd/pipeline/spec-card.md" ]; then
    warn "Worktree has an ACTIVE pipeline (spec-card.md present) — resume it, don't re-run from scratch."
fi

# --- dev-env: run the project's idempotent setup hook if present ---
DEVENV="$WT_DIR/.apd/dev-env-setup"
if [ -f "$DEVENV" ]; then
    echo ""
    echo "  ${V}dev-env${R}: running .apd/dev-env-setup …"
    if ( cd "$WT_DIR" && bash "$DEVENV" 2>&1 | sed 's/^/    /' ); then
        ok "dev-env setup finished."
    else
        # E5: do NOT auto-delete the worktree — deletion is the irreversible
        # direction and the user may have half-set-up state worth keeping.
        warn "dev-env setup failed (worktree left in place). Fix the script and re-run run-role, or remove the worktree manually."
    fi
else
    echo ""
    echo "  ${D}No .apd/dev-env-setup found — install deps/DB manually if the worktree needs them.${R}"
    echo "  ${D}(Tip: add a tracked, idempotent .apd/dev-env-setup that calls your project's run script.)${R}"
fi

# --- E6: warn on a dirty main checkout (its uncommitted work is NOT in the worktree) ---
if [ -n "$(git -C "$MAIN_ROOT" status --porcelain 2>/dev/null)" ]; then
    echo ""
    warn "Main checkout has uncommitted changes — they are NOT in this worktree (it branched from committed HEAD)."
fi

# --- Launch (C2, opt-in) or prepare-only (print the command, does NOT spawn) ---
echo ""

if [ "$LAUNCH" = true ] && command -v claude >/dev/null 2>&1; then
    ok "Worktree ready — launching Claude Code as role '$ROLE' (charter injected automatically)."
    echo ""
    echo "  ${D}Merge back when done: commit on '$BRANCH', then from the main checkout"
    echo "  git merge $BRANCH (or open a PR). Remove: git worktree remove <path>.${R}"
    echo ""
    cd "$WT_DIR" || { err "cd to worktree failed: $WT_DIR"; exit 1; }
    # Scrub leaked env so the new CC session resolves the worktree as its own
    # project root (not a stale main-checkout root) — R6.
    unset APD_PROJECT_DIR CLAUDE_PLUGIN_ROOT
    exec claude --append-system-prompt "$CHARTER"
fi

# E11: --launch requested but no `claude` on PATH → degrade to prepare-only.
[ "$LAUNCH" = true ] && warn "--launch requested but 'claude' is not on PATH — prepared the worktree only."

ok "Worktree ready for role '$ROLE'. Enter it with:"
echo ""
echo "    cd \"$WT_DIR\" && claude"
echo ""
echo "  ${D}Merge back when done: commit on '$BRANCH', then from the main checkout"
echo "  git merge $BRANCH (or open a PR). Remove: git worktree remove <path>.${R}"
exit 0
