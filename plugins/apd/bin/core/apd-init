#!/bin/bash
# APD Init — initializes or updates APD environment in a project
#
# Two modes:
#   NEW PROJECT:      No .apd-config → creates everything from scratch
#   EXISTING PROJECT: .apd-config exists → gap analysis, fixes what's missing
#
# Uses userConfig env vars when available:
#   CLAUDE_PLUGIN_OPTION_PROJECT_NAME, CLAUDE_PLUGIN_OPTION_STACK, CLAUDE_PLUGIN_OPTION_AUTHOR_NAME

source "$(dirname "$0")/../lib/resolve-project.sh"

# APD version comes from the runtime-neutral VERSION file (resolve-project.sh)
APD_VER="${APD_VERSION:-0.0.0}"

# --version flag: show APD version and exit
if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
    echo "APD v${APD_VER} (plugin: $APD_PLUGIN_ROOT)"
    exit 0
fi

# --quick flag: skip verification (used by session-start)
QUICK=false
[ "${1:-}" = "--quick" ] && QUICK=true

# --- Eager version sync ---
# Plugin upgrade leaves $CLAUDE_DIR/.apd-version stale until the per-MODE path
# rewrites it. session-start reads it for the banner, and the per-MODE write
# (MODE=update §593) runs late — anything that exits early (errors, --version)
# would skip it. Sync up front so the banner is always correct.
if [ -d "$CLAUDE_DIR" ] && [ -n "$APD_VER" ] && [ "$APD_VER" != "0.0.0" ]; then
    PROJ_V=$(cat "$CLAUDE_DIR/.apd-version" 2>/dev/null | tr -d '[:space:]')
    if [ -n "$PROJ_V" ] && [ "$PROJ_V" != "$APD_VER" ]; then
        echo "$APD_VER" > "$CLAUDE_DIR/.apd-version"
    fi
fi

# --- Visual helpers ---
source "$(dirname "$0")/../lib/style.sh"

FIXES=0
SKIPS=0

apd_logo
apd_header "Init"
echo ""

# ===========================================================
# DETECT MODE
# ===========================================================
if [ -n "$APD_CONFIG_FILE" ] && [ -f "$APD_CONFIG_FILE" ]; then
    MODE="update"
    echo "  Mode: ${B}Update${R} (existing APD project at $APD_CONFIG_FILE)"
    PROJECT_NAME=$(grep '^PROJECT_NAME=' "$APD_CONFIG_FILE" 2>/dev/null | cut -d= -f2-)
    STACK=$(grep '^STACK=' "$APD_CONFIG_FILE" 2>/dev/null | cut -d= -f2-)
else
    MODE="new"
    echo "  Mode: ${B}New project${R}"
    # Read from userConfig or fallback
    PROJECT_NAME="${CLAUDE_PLUGIN_OPTION_PROJECT_NAME:-}"
    STACK="${CLAUDE_PLUGIN_OPTION_STACK:-}"
    AUTHOR="${CLAUDE_PLUGIN_OPTION_AUTHOR_NAME:-}"
fi
echo ""

# ===========================================================
# NEW PROJECT — create everything from scratch
# ===========================================================
if [ "$MODE" = "new" ]; then
    if [ -z "$PROJECT_NAME" ]; then
        err "PROJECT_NAME not set. Configure userConfig in plugin settings or set CLAUDE_PLUGIN_OPTION_PROJECT_NAME."
        exit 1
    fi
    if [ -z "$STACK" ]; then
        err "STACK not set. Configure userConfig in plugin settings or set CLAUDE_PLUGIN_OPTION_STACK."
        exit 1
    fi

    echo "  Project: $PROJECT_NAME"
    echo "  Stack:   $STACK"
    echo "  Author:  ${AUTHOR:-$(git config user.name 2>/dev/null || echo 'unknown')}"
    echo ""

    AUTHOR="${AUTHOR:-$(git config user.name 2>/dev/null || echo 'Developer')}"

    # Create directories
    mkdir -p "$CLAUDE_DIR/agents" "$CLAUDE_DIR/rules" "$CLAUDE_DIR/scripts" "$CLAUDE_DIR/bin" "$CLAUDE_DIR/memory" "$PROJECT_DIR/.apd/pipeline"

    # .apd-config
    cat > "$CLAUDE_DIR/.apd-config" << EOF
PROJECT_NAME=$PROJECT_NAME
APD_VERSION=$APD_VER
STACK=$STACK
EOF
    fix "Created .apd-config"

    # .apd-version
    echo "$APD_VER" > "$CLAUDE_DIR/.apd-version"
    fix "Created .apd-version"

    # Copy workflow.md
    if [ -f "$APD_PLUGIN_ROOT/rules/workflow.md" ]; then
        cp "$APD_PLUGIN_ROOT/rules/workflow.md" "$CLAUDE_DIR/rules/workflow.md"
        fix "Copied workflow.md"
    fi

    # Generate principles.md
    if [ -f "$APD_PLUGIN_ROOT/templates/principles/en.md" ]; then
        cp "$APD_PLUGIN_ROOT/templates/principles/en.md" "$CLAUDE_DIR/rules/principles.md"
        fix "Created principles.md"
    fi

    # Generate verify-all.sh from stack template
    VERIFY_TEMPLATE="$APD_PLUGIN_ROOT/templates/verify-all/${STACK}.sh"
    if [ -f "$VERIFY_TEMPLATE" ]; then
        cat > "$CLAUDE_DIR/scripts/verify-all.sh" << 'HEADER'
#!/bin/bash
# APD Verify All — runs verification for all changed components
# This script lives IN THE PROJECT (.claude/scripts/verify-all.sh), not in the plugin.

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$PROJECT_DIR" || exit 0

# Scope — "full" (default) or "fast" (build + touched tests only).
# Set by apd_verify_step(scope="fast") via APD_VERIFY_SCOPE env var.
# pipeline-advance verifier always runs with the default (unset → full).
export APD_VERIFY_SCOPE="${APD_VERIFY_SCOPE:-full}"

# Cache — skip if Verifier step already passed recently
VERIFIED_TS_FILE="$PROJECT_DIR/.apd/pipeline/verified.timestamp"
if [ -f "$VERIFIED_TS_FILE" ]; then
    VERIFIED_AT=$(cat "$VERIFIED_TS_FILE" 2>/dev/null | tr -d '[:space:]')
    NOW=$(date +%s)
    if [ -n "$VERIFIED_AT" ] && [ "$VERIFIED_AT" -gt 0 ] 2>/dev/null; then
        AGE=$((NOW - VERIFIED_AT))
        if [ "$AGE" -lt 120 ]; then
            echo "Verification skipped — Verifier passed ${AGE}s ago (cache <120s)" >&2
            exit 0
        fi
    fi
fi

ERRORS=()
CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null)
[ -z "$CHANGED_FILES" ] && CHANGED_FILES=$(git diff --name-only HEAD 2>/dev/null)

HEADER
        cat "$VERIFY_TEMPLATE" >> "$CLAUDE_DIR/scripts/verify-all.sh"
        cat >> "$CLAUDE_DIR/scripts/verify-all.sh" << 'FOOTER'

# Result
if [ ${#ERRORS[@]} -gt 0 ]; then
    echo "VERIFICATION FAILED:"
    for e in "${ERRORS[@]}"; do echo "  - $e"; done
    exit 1
fi
echo "Verification passed"
exit 0
FOOTER
        chmod +x "$CLAUDE_DIR/scripts/verify-all.sh"
        fix "Created verify-all.sh ($STACK)"
    else
        err "No verify-all template for stack: $STACK"
    fi

    # Memory files
    for file in MEMORY.md status.md session-log.md; do
        if [ ! -f "$CLAUDE_DIR/memory/$file" ]; then
            if [ -f "$APD_PLUGIN_ROOT/templates/memory/$file" ]; then
                cp "$APD_PLUGIN_ROOT/templates/memory/$file" "$CLAUDE_DIR/memory/$file"
            else
                touch "$CLAUDE_DIR/memory/$file"
            fi
            fix "Created memory/$file"
        fi
    done

    # Settings.json
    cat > "$CLAUDE_DIR/settings.json" << EOF
{
  "env": {
    "APD_PROJECT_NAME": "$PROJECT_NAME"
  },
  "permissions": {
    "allow": [
      "Edit(.claude/memory/**)",
      "Write(.claude/memory/**)",
      "Write(.apd/pipeline/spec-card.md)",
      "Write(.apd/pipeline/implementation-plan.md)",
      "Write(.apd/pipeline/.adversarial-summary)",
      "Edit(.apd/pipeline/spec-card.md)",
      "Edit(.apd/pipeline/implementation-plan.md)",
      "Edit(.apd/pipeline/.adversarial-summary)",
      "Write(**/.apd/pipeline/spec-card.md)",
      "Write(**/.apd/pipeline/implementation-plan.md)",
      "Write(**/.apd/pipeline/.adversarial-summary)",
      "Edit(**/.apd/pipeline/spec-card.md)",
      "Edit(**/.apd/pipeline/implementation-plan.md)",
      "Edit(**/.apd/pipeline/.adversarial-summary)",
      "Bash(bash .claude/bin/apd *)",
      "Bash(bash .claude/bin/apd pipeline *)"
    ],
    "deny": [
      "Bash(mkdir */.apd/pipeline/*)",
      "Bash(mkdir -p */.apd/pipeline/*)",
      "Bash(mkdir */.apd/pipeline)",
      "Bash(mkdir -p */.apd/pipeline)",
      "Bash(mkdir .apd/pipeline/*)",
      "Bash(mkdir -p .apd/pipeline/*)",
      "Bash(mkdir .apd/pipeline)",
      "Bash(mkdir -p .apd/pipeline)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[$PROJECT_NAME] Claude needs attention'"
          }
        ]
      }
    ]
  }
}
EOF
    fix "Created settings.json (superpowers disabled, attribution empty)"

    # Gitignore entries
    if [ -f "$APD_PLUGIN_ROOT/templates/gitignore-entries.txt" ]; then
        if [ ! -f "$PROJECT_DIR/.gitignore" ]; then
            cat "$APD_PLUGIN_ROOT/templates/gitignore-entries.txt" > "$PROJECT_DIR/.gitignore"
            fix "Created .gitignore"
        else
            while IFS= read -r entry; do
                [ -z "$entry" ] && continue
                [[ "$entry" == \#* ]] && continue
                if ! grep -qF "$entry" "$PROJECT_DIR/.gitignore" 2>/dev/null; then
                    echo "$entry" >> "$PROJECT_DIR/.gitignore"
                fi
            done < "$APD_PLUGIN_ROOT/templates/gitignore-entries.txt"
            fix "Updated .gitignore"
        fi
    fi

    # Git init if needed
    if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree &>/dev/null; then
        git -C "$PROJECT_DIR" init -q
        fix "Initialized git repo"
    fi

    echo ""
    echo "  ${B}NOTE:${R} CLAUDE.md and agents must be generated by the orchestrator"
    echo "  using the /apd-setup skill — they require project analysis."
    echo ""

    FIXES=$((FIXES + 1))
fi

# ===========================================================
# UPDATE MODE — gap analysis, fix what's missing
# ===========================================================
if [ "$MODE" = "update" ]; then
    echo "  Project: $PROJECT_NAME"
    echo "  Stack:   $STACK"
    echo ""

    # --- code-reviewer agent ---
    if [ -f "$CLAUDE_DIR/agents/code-reviewer.md" ]; then
        # Check model
        if grep -q 'model: opus' "$CLAUDE_DIR/agents/code-reviewer.md" 2>/dev/null; then
            ok "code-reviewer (opus/max)"
        else
            sed -i.bak 's/model:.*/model: opus/' "$CLAUDE_DIR/agents/code-reviewer.md" 2>/dev/null && rm -f "$CLAUDE_DIR/agents/code-reviewer.md.bak"
            fix "code-reviewer: fixed model to opus"
            FIXES=$((FIXES + 1))
        fi
        # Check scope directive (v4.7.10+) — regenerate if missing
        if ! grep -q 'reviewed-files' "$CLAUDE_DIR/agents/code-reviewer.md" 2>/dev/null; then
            if [ -f "$APD_PLUGIN_ROOT/templates/reviewer-template.md" ]; then
                sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g" "$APD_PLUGIN_ROOT/templates/reviewer-template.md" > "$CLAUDE_DIR/agents/code-reviewer.md"
                fix "code-reviewer: refreshed from template (added .reviewed-files scope directive)"
                FIXES=$((FIXES + 1))
            fi
        fi
    else
        if [ -f "$APD_PLUGIN_ROOT/templates/reviewer-template.md" ]; then
            sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g" "$APD_PLUGIN_ROOT/templates/reviewer-template.md" > "$CLAUDE_DIR/agents/code-reviewer.md"
            fix "Created code-reviewer.md (opus/max, read-only)"
            FIXES=$((FIXES + 1))
        fi
    fi

    # --- adversarial-reviewer agent (optional but recommended) ---
    if [ -f "$CLAUDE_DIR/agents/adversarial-reviewer.md" ]; then
        if grep -q 'model: sonnet' "$CLAUDE_DIR/agents/adversarial-reviewer.md" 2>/dev/null && grep -q 'memory: none' "$CLAUDE_DIR/agents/adversarial-reviewer.md" 2>/dev/null; then
            ok "adversarial-reviewer (sonnet/max, memory: none)"
        else
            sed -i.bak 's/model:.*/model: sonnet/' "$CLAUDE_DIR/agents/adversarial-reviewer.md" 2>/dev/null && rm -f "$CLAUDE_DIR/agents/adversarial-reviewer.md.bak"
            fix "adversarial-reviewer: fixed model to sonnet"
            FIXES=$((FIXES + 1))
        fi
        # Check scope directive (v4.7.10+) — regenerate if missing
        if ! grep -q 'reviewed-files' "$CLAUDE_DIR/agents/adversarial-reviewer.md" 2>/dev/null; then
            if [ -f "$APD_PLUGIN_ROOT/templates/adversarial-reviewer-template.md" ]; then
                sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g" "$APD_PLUGIN_ROOT/templates/adversarial-reviewer-template.md" > "$CLAUDE_DIR/agents/adversarial-reviewer.md"
                fix "adversarial-reviewer: refreshed from template (added .reviewed-files scope directive)"
                FIXES=$((FIXES + 1))
            fi
        fi
    else
        if [ -f "$APD_PLUGIN_ROOT/templates/adversarial-reviewer-template.md" ]; then
            sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g" "$APD_PLUGIN_ROOT/templates/adversarial-reviewer-template.md" > "$CLAUDE_DIR/agents/adversarial-reviewer.md"
            fix "Created adversarial-reviewer.md (sonnet/max, context-free review)"
            FIXES=$((FIXES + 1))
        fi
    fi

    # --- Clean APD-VERIFY pollution from pipeline-metrics.log (one-time) ---
    if [ -f "$MEMORY_DIR/pipeline-metrics.log" ]; then
        if grep -q '^[0-9]*|APD-VERIFY-' "$MEMORY_DIR/pipeline-metrics.log" 2>/dev/null; then
            POLLUTED=$(grep -c '^[0-9]*|APD-VERIFY-' "$MEMORY_DIR/pipeline-metrics.log" 2>/dev/null || echo 0)
            grep -v '^[0-9]*|APD-VERIFY-' "$MEMORY_DIR/pipeline-metrics.log" > "$MEMORY_DIR/pipeline-metrics.log.tmp" && \
                mv "$MEMORY_DIR/pipeline-metrics.log.tmp" "$MEMORY_DIR/pipeline-metrics.log"
            fix "pipeline-metrics.log: removed $POLLUTED APD-VERIFY test pollution entries"
            FIXES=$((FIXES + 1))
        fi
    fi

    # --- maxTurns in agents ---
    # Current targets (v4.7.13): builders 40, reviewers 30. Older projects may
    # still carry the previous 20/15 defaults which caused silent maxTurn exhaust
    # in real pipeline runs — bump those on refresh.
    for agent_file in "$CLAUDE_DIR/agents"/*.md; do
        [ -f "$agent_file" ] || continue
        AGENT_NAME=$(basename "$agent_file" .md)
        case "$AGENT_NAME" in
            code-reviewer|adversarial-reviewer) TARGET=30 ;;
            *)                                  TARGET=40 ;;
        esac
        if grep -q '^maxTurns:' "$agent_file" 2>/dev/null; then
            CURRENT_MT=$(grep '^maxTurns:' "$agent_file" | head -1 | awk '{print $2}')
            # Bump only legacy low defaults (20/15) — leave user overrides alone
            if [ "$CURRENT_MT" = "20" ] && [ "$TARGET" = "40" ]; then
                sed -i.bak "s/^maxTurns: 20$/maxTurns: 40/" "$agent_file" && rm -f "$agent_file.bak"
                fix "$AGENT_NAME: bumped maxTurns 20 → 40"
                FIXES=$((FIXES + 1))
            elif [ "$CURRENT_MT" = "15" ] && [ "$TARGET" = "30" ]; then
                sed -i.bak "s/^maxTurns: 15$/maxTurns: 30/" "$agent_file" && rm -f "$agent_file.bak"
                fix "$AGENT_NAME: bumped maxTurns 15 → 30"
                FIXES=$((FIXES + 1))
            else
                ok "$AGENT_NAME: maxTurns set ($CURRENT_MT)"
            fi
        else
            sed -i.bak "/^effort:/a\\
maxTurns: $TARGET" "$agent_file" 2>/dev/null && rm -f "$agent_file.bak"
            fix "$AGENT_NAME: added maxTurns: $TARGET"
            FIXES=$((FIXES + 1))
        fi
    done

    # --- Agent stale paths: bin/core/ → bin/adapter/cc/ ---
    for agent_file in "$CLAUDE_DIR/agents"/*.md; do
        [ -f "$agent_file" ] || continue
        AGENT_NAME=$(basename "$agent_file" .md)
        if grep -q 'bin/core/guard-scope\|bin/core/guard-bash-scope\|bin/core/guard-git\|bin/core/guard-secrets' "$agent_file" 2>/dev/null; then
            echo "  ${YELLOW}${B}STALE PATH:${R} $AGENT_NAME references bin/core/ guard paths — updating to bin/adapter/cc/" >&2
            # Single sed invocation with all four substitutions — one .bak to clean up,
            # atomic per-file (either all four apply or none).
            sed -i.bak \
                -e 's|bin/core/guard-scope|bin/adapter/cc/guard-scope|g' \
                -e 's|bin/core/guard-bash-scope|bin/adapter/cc/guard-bash-scope|g' \
                -e 's|bin/core/guard-git|bin/adapter/cc/guard-git|g' \
                -e 's|bin/core/guard-secrets|bin/adapter/cc/guard-secrets|g' \
                "$agent_file" && rm -f "${agent_file}.bak"
            fix "$AGENT_NAME: updated stale guard paths (core/ → adapter/cc/)"
            FIXES=$((FIXES + 1))
        fi
    done

    # Safety net: any leftover .bak files from interrupted sed runs in this or
    # a prior apd-init session. sed on macOS requires -i.bak so a partial failure
    # can leave these; clean them now.
    rm -f "$CLAUDE_DIR/agents"/*.bak 2>/dev/null || true

    # --- workflow.md ---
    if [ -f "$CLAUDE_DIR/rules/workflow.md" ]; then
        # Check for outdated references
        if grep -q 'CLAUDE_PLUGIN_ROOT' "$CLAUDE_DIR/rules/workflow.md" 2>/dev/null || grep -qF '.claude/.pipeline' "$CLAUDE_DIR/rules/workflow.md" 2>/dev/null; then
            cp "$APD_PLUGIN_ROOT/rules/workflow.md" "$CLAUDE_DIR/rules/workflow.md"
            fix "workflow.md: updated (stale paths)"
            FIXES=$((FIXES + 1))
        else
            ok "workflow.md"
        fi
    else
        if [ -f "$APD_PLUGIN_ROOT/rules/workflow.md" ]; then
            mkdir -p "$CLAUDE_DIR/rules"
            cp "$APD_PLUGIN_ROOT/rules/workflow.md" "$CLAUDE_DIR/rules/workflow.md"
            fix "Copied workflow.md"
            FIXES=$((FIXES + 1))
        fi
    fi

    # --- settings.json: remove stale SessionStart hooks ---
    # Plugin hooks.json handles SessionStart via ${CLAUDE_PLUGIN_ROOT}.
    # Old project setups may override it with hardcoded paths that no longer exist.
    if [ -f "$CLAUDE_DIR/settings.json" ] && grep -q '"SessionStart"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
        tmp=$(mktemp)
        python3 -c "
import json, sys
with open('$CLAUDE_DIR/settings.json') as f:
    data = json.load(f)
removed = False
if 'hooks' in data and 'SessionStart' in data['hooks']:
    del data['hooks']['SessionStart']
    removed = True
    if not data['hooks']:
        del data['hooks']
if removed:
    with open('$CLAUDE_DIR/settings.json', 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
    sys.exit(0)
sys.exit(1)
" 2>/dev/null
        if [ $? -eq 0 ]; then
            fix "Removed stale SessionStart hook from settings.json (plugin handles it)"
            FIXES=$((FIXES + 1))
        else
            ok "No stale SessionStart hooks"
        fi
    else
        ok "No stale SessionStart hooks"
    fi

    # --- settings.json: superpowers disabled ---
    if [ -f "$CLAUDE_DIR/settings.json" ]; then
        if grep -q '"superpowers@claude-plugins-official"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
            ok "superpowers disabled in settings"
        else
            # Add superpowers disable to enabledPlugins
            if grep -q '"enabledPlugins"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
                sed -i.bak '/"enabledPlugins".*{/a\
    "superpowers@claude-plugins-official": false,' "$CLAUDE_DIR/settings.json" 2>/dev/null && rm -f "$CLAUDE_DIR/settings.json.bak"
            else
                # Add enabledPlugins section before closing brace
                tmp=$(mktemp)
                awk '
                /^}$/ {
                    print "  ,\"enabledPlugins\": {"
                    print "    \"superpowers@claude-plugins-official\": false"
                    print "  }"
                    print "}"
                    next
                }
                { print }
                ' "$CLAUDE_DIR/settings.json" > "$tmp" && mv "$tmp" "$CLAUDE_DIR/settings.json"
            fi
            fix "Disabled superpowers in settings.json"
            FIXES=$((FIXES + 1))
        fi

        # Attribution
        if grep -q '"attribution"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
            ok "attribution configured"
        else
            tmp=$(mktemp)
            awk '
            /^}$/ {
                print "  ,\"attribution\": {"
                print "    \"commit\": \"\","
                print "    \"pr\": \"\""
                print "  }"
                print "}"
                next
            }
            { print }
            ' "$CLAUDE_DIR/settings.json" > "$tmp" && mv "$tmp" "$CLAUDE_DIR/settings.json"
            fix "Added attribution (empty, no AI signatures)"
            FIXES=$((FIXES + 1))
        fi

        # Permissions — auto-allow memory + pipeline writes + apd commands
        PERMS_MISSING=false
        for perm in "Write(.apd/pipeline/spec-card.md)" "Bash(bash .claude/bin/apd *)" "Write(**/.apd/pipeline/spec-card.md)"; do
            if ! grep -qF "$perm" "$CLAUDE_DIR/settings.json" 2>/dev/null; then
                PERMS_MISSING=true
                break
            fi
        done
        if [ "$PERMS_MISSING" = true ]; then
            # Rebuild permissions array with all required entries
            python3 -c "
import json, sys
with open('$CLAUDE_DIR/settings.json') as f:
    s = json.load(f)
required_allow = [
    'Edit(.claude/memory/**)', 'Write(.claude/memory/**)',
    'Write(.apd/pipeline/spec-card.md)', 'Write(.apd/pipeline/implementation-plan.md)',
    'Write(.apd/pipeline/.adversarial-summary)',
    'Write(**/.apd/pipeline/spec-card.md)', 'Write(**/.apd/pipeline/implementation-plan.md)',
    'Write(**/.apd/pipeline/.adversarial-summary)',
    'Edit(.apd/pipeline/spec-card.md)', 'Edit(.apd/pipeline/implementation-plan.md)',
    'Edit(.apd/pipeline/.adversarial-summary)',
    'Edit(**/.apd/pipeline/spec-card.md)', 'Edit(**/.apd/pipeline/implementation-plan.md)',
    'Edit(**/.apd/pipeline/.adversarial-summary)',
    'Bash(bash .claude/bin/apd *)', 'Bash(bash .claude/bin/apd pipeline *)'
]
required_deny = [
    'Bash(mkdir */.apd/pipeline/*)', 'Bash(mkdir -p */.apd/pipeline/*)',
    'Bash(mkdir */.apd/pipeline)', 'Bash(mkdir -p */.apd/pipeline)'
]
existing_allow = s.get('permissions', {}).get('allow', [])
existing_deny = s.get('permissions', {}).get('deny', [])
s.setdefault('permissions', {})['allow'] = list(dict.fromkeys(existing_allow + required_allow))
s.setdefault('permissions', {})['deny'] = list(dict.fromkeys(existing_deny + required_deny))
with open('$CLAUDE_DIR/settings.json', 'w') as f:
    json.dump(s, f, indent=2, ensure_ascii=False)
    f.write('\n')
" 2>/dev/null && fix "Updated permissions (pipeline + apd commands)" && FIXES=$((FIXES + 1)) || warn "Could not update permissions (python3 required)"
        else
            ok "permissions (pipeline + apd commands)"
        fi
    fi

    # --- Stale paths and legacy directories ---
    # Remove legacy script directories that confuse orchestrator
    for old_dir in "$CLAUDE_DIR/scripts.old" "$CLAUDE_DIR/scripts"; do
        if [ -d "$old_dir" ] && [ -f "$old_dir/pipeline-advance.sh" -o -f "$old_dir/guard-git.sh" ]; then
            rm -rf "$old_dir"
            fix "Removed legacy $(basename "$old_dir")/ directory"
            FIXES=$((FIXES + 1))
        fi
    done

    # Check for stale pipeline-advance references in project files
    STALE_FILES=""
    for check_file in "$CLAUDE_DIR/rules/workflow.md" "$PROJECT_DIR/CLAUDE.md" "$CLAUDE_DIR/memory/MEMORY.md"; do
        if [ -f "$check_file" ] && grep -qE 'pipeline-advance\.sh|scripts/pipeline-advance|bin/core/pipeline-advance' "$check_file" 2>/dev/null; then
            STALE_FILES="${STALE_FILES}$(basename "$check_file"), "
        fi
    done
    if [ -n "$STALE_FILES" ]; then
        warn "Stale pipeline-advance references in: ${STALE_FILES%, }"
        echo "    ${D}Correct command: bash .claude/bin/apd pipeline <command>${R}"
        [ "$QUICK" = false ] && FIXES=$((FIXES + 1))
    fi

    # --- Pipeline directory migration (.claude/.pipeline → .apd/pipeline) ---
    if [ -d "$CLAUDE_DIR/.pipeline" ]; then
        mkdir -p "$PROJECT_DIR/.apd/pipeline"
        # Move any existing state files
        if ls "$CLAUDE_DIR/.pipeline"/* 1>/dev/null 2>&1; then
            cp -a "$CLAUDE_DIR/.pipeline"/. "$PROJECT_DIR/.apd/pipeline/" 2>/dev/null
        fi
        rm -rf "$CLAUDE_DIR/.pipeline"
        fix "Migrated .claude/.pipeline/ → .apd/pipeline/"
        FIXES=$((FIXES + 1))
    fi
    # Ensure .apd/pipeline directory exists
    mkdir -p "$PROJECT_DIR/.apd/pipeline"

    # Update .gitignore: old entry → new entry
    if [ -f "$PROJECT_DIR/.gitignore" ]; then
        if grep -qF '.claude/.pipeline/' "$PROJECT_DIR/.gitignore" 2>/dev/null; then
            sed -i.bak 's|\.claude/\.pipeline/|.apd/pipeline/|g' "$PROJECT_DIR/.gitignore" && rm -f "$PROJECT_DIR/.gitignore.bak"
            fix "Updated .gitignore: .claude/.pipeline/ → .apd/pipeline/"
            FIXES=$((FIXES + 1))
        elif ! grep -qF '.apd/pipeline/' "$PROJECT_DIR/.gitignore" 2>/dev/null; then
            echo '.apd/pipeline/' >> "$PROJECT_DIR/.gitignore"
            fix "Added .apd/pipeline/ to .gitignore"
            FIXES=$((FIXES + 1))
        fi
    fi

    # Update old permission patterns in settings.json
    if [ -f "$CLAUDE_DIR/settings.json" ] && grep -qF '.pipeline/' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
        sed -i.bak 's|\.claude/\.pipeline/|.apd/pipeline/|g; s|\*\*/\.pipeline/|**/.apd/pipeline/|g; s|mkdir \*/\.pipeline|mkdir */.apd/pipeline|g; s|Write(\.pipeline/|Write(.apd/pipeline/|g; s|Edit(\.pipeline/|Edit(.apd/pipeline/|g' "$CLAUDE_DIR/settings.json" && rm -f "$CLAUDE_DIR/settings.json.bak"
        fix "Updated permission patterns in settings.json"
        FIXES=$((FIXES + 1))
    fi

    # --- Memory files ---
    for file in MEMORY.md status.md session-log.md; do
        if [ -f "$CLAUDE_DIR/memory/$file" ]; then
            ok "memory/$file"
        else
            mkdir -p "$CLAUDE_DIR/memory"
            touch "$CLAUDE_DIR/memory/$file"
            fix "Created memory/$file"
            FIXES=$((FIXES + 1))
        fi
    done

    # --- .apd-version ---
    CURRENT_VER=$(cat "$CLAUDE_DIR/.apd-version" 2>/dev/null | tr -d '[:space:]')
    PLUGIN_VER="$APD_VER"
    if [ "$CURRENT_VER" = "$PLUGIN_VER" ]; then
        ok ".apd-version ($CURRENT_VER)"
    else
        echo "$PLUGIN_VER" > "$CLAUDE_DIR/.apd-version"
        fix "Updated .apd-version: $CURRENT_VER → $PLUGIN_VER"
        FIXES=$((FIXES + 1))
    fi
fi

# ===========================================================
# CODEX ADAPTER — auto-run if .codex/ already exists
# Users who run Codex alongside CC will have a .codex/ dir; we register
# the MCP server + sandbox profiles + hooks.json for them here.
# Absent .codex/, do nothing — users bootstrap manually via
# `bash $APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config`
# ===========================================================
if [ -d "$PROJECT_DIR/.codex" ]; then
    echo ""
    section "Codex adapter"
    CODEX_INIT="$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config"
    if [ -x "$CODEX_INIT" ]; then
        CODEX_OUT=$(bash "$CODEX_INIT" "$PROJECT_DIR" 2>&1 || true)
        echo "$CODEX_OUT" | sed 's/^/  /'
        if echo "$CODEX_OUT" | grep -qE '^\[wrote\]'; then
            FIXES=$((FIXES + 1))
        fi
    else
        warn "Codex init script missing at $CODEX_INIT"
    fi
fi

# ===========================================================
# SUMMARY
# ===========================================================
echo ""
if [ "$FIXES" -gt 0 ]; then
    echo "  ${G}${FIXES} fix(es) applied.${R}"
else
    echo "  ${B}Everything up to date.${R}"
fi
echo ""

# Run verify-apd (skip in quick mode)
if [ "$QUICK" = true ]; then
    [ "$FIXES" -gt 0 ] && echo "  ${D}(quick mode: $FIXES fix(es) applied)${R}"
    exit 0
fi
echo "  Running verification..."
echo ""
bash "$SCRIPT_DIR/verify-apd"
