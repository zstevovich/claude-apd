#!/bin/bash
# APD Agent Tracker ŌĆö records agent start/stop events to pipeline state
# Writes to .apd/pipeline/.agents so pipeline-advance can verify
# that a real agent ran before marking a step complete.
#
# Interface: --event <SubagentStart|SubagentStop> --agent-type <name> --agent-id <id> [--raw-payload <json>]

source "$(dirname "$0")/../lib/resolve-project.sh"
[ "$APD_ACTIVE" = false ] && exit 0
source "$(dirname "$0")/../lib/style.sh"

EVENT=""
AGENT_TYPE=""
AGENT_ID=""
RAW_PAYLOAD=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --event)       EVENT="$2"; shift 2 ;;
    --agent-type)  AGENT_TYPE="$2"; shift 2 ;;
    --agent-id)    AGENT_ID="$2"; shift 2 ;;
    --raw-payload) RAW_PAYLOAD="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$AGENT_TYPE" ] || [ -z "$EVENT" ]; then
  exit 0
fi

# Debug log ŌĆö raw adapter payload for analysis
if [ -n "$RAW_PAYLOAD" ] && [ -d "$MEMORY_DIR" ]; then
  AGENT_DEBUG_LOG="$MEMORY_DIR/agent-dispatch-debug.log"
  echo "=== $(date +"%Y-%m-%d %H:%M:%S") | $EVENT | $AGENT_TYPE ===" >> "$AGENT_DEBUG_LOG"
  echo "$RAW_PAYLOAD" >> "$AGENT_DEBUG_LOG"
  echo "" >> "$AGENT_DEBUG_LOG"
fi

mkdir -p "$PIPELINE_DIR"
AGENTS_LOG="$PIPELINE_DIR/.agents"
NOW_HUMAN=$(date +"%Y-%m-%d %H:%M:%S")

# Agent display color
ac=$(_agent_color "$AGENT_TYPE")

case "$EVENT" in
  SubagentStart)
    # Adversarial pre-flight gate (v6.1 B1) ŌĆö hard block when adversarial
    # dispatched out of order. Runs BEFORE the start event is logged so a
    # blocked dispatch leaves no fake start in .agents.
    if echo "$AGENT_TYPE" | grep -qiE 'adversarial'; then
        if [ ! -f "$PIPELINE_DIR/reviewer.done" ]; then
            echo "" >&2
            echo "  ${RED}${B}BLOCKED:${R} ${RED}adversarial-reviewer dispatched before reviewer.done.${R}" >&2
            echo "  ${RED}Pipeline order: builder ŌåÆ reviewer (signs reviewer.done) ŌåÆ adversarial ŌåÆ verifier${R}" >&2
            echo "  ${RED}Dispatch the regular code-reviewer first; pipeline-advance reviewer will then create .adversarial-pending as the green light.${R}" >&2
            echo "" >&2
            log_block "adversarial-reviewer dispatched before reviewer.done" "agent_type=${AGENT_TYPE}"
            exit 2
        fi
        if [ ! -f "$PIPELINE_DIR/.adversarial-pending" ]; then
            echo "" >&2
            echo "  ${RED}${B}BLOCKED:${R} ${RED}adversarial-reviewer dispatched without .adversarial-pending marker.${R}" >&2
            echo "  ${RED}Adversarial is either opted-out (small task) or already recorded.${R}" >&2
            echo "  ${RED}Inspect: ls .apd/pipeline/ ŌĆö if .adversarial-summary exists, adversarial is done.${R}" >&2
            echo "" >&2
            log_block "adversarial-reviewer dispatched without .adversarial-pending" "agent_type=${AGENT_TYPE}"
            exit 2
        fi
    fi

    # Parallel same-type dispatch gate (framework backlog: BambiProject #48,
    # 2026-04-16). Block if a same-type agent started within the last N
    # seconds and has no matching stop event yet. Window configurable via
    # APD_PARALLEL_WINDOW (default 30s; set to 0 to disable). CC-only ŌĆö
    # Codex has no SubagentStart hook for this surface.
    PARALLEL_WINDOW_SEC=${APD_PARALLEL_WINDOW:-30}
    if [ -f "$AGENTS_LOG" ] && [ "$PARALLEL_WINDOW_SEC" -gt 0 ] 2>/dev/null; then
        LAST_LINE=$(awk -F'|' -v t="$AGENT_TYPE" '$2=="start" && $3==t' "$AGENTS_LOG" | tail -1)
        if [ -n "$LAST_LINE" ]; then
            LAST_TS=$(echo "$LAST_LINE" | cut -d'|' -f1)
            LAST_ID=$(echo "$LAST_LINE" | cut -d'|' -f4)
            if ! awk -F'|' -v id="$LAST_ID" '$2=="stop" && $4==id {found=1} END{exit !found}' "$AGENTS_LOG"; then
                LAST_EPOCH=$(date -j -f "%Y-%m-%d %H:%M:%S" "$LAST_TS" +%s 2>/dev/null || \
                             date -d "$LAST_TS" +%s 2>/dev/null || echo 0)
                NOW_EPOCH=$(date +%s)
                ELAPSED=$((NOW_EPOCH - LAST_EPOCH))
                if [ "$LAST_EPOCH" -ne 0 ] && [ "$ELAPSED" -lt "$PARALLEL_WINDOW_SEC" ]; then
                    echo "" >&2
                    echo "  ${RED}${B}BLOCKED:${R} ${RED}parallel dispatch of '${AGENT_TYPE}' within ${ELAPSED}s of previous start (window: ${PARALLEL_WINDOW_SEC}s).${R}" >&2
                    echo "  ${RED}Same-type parallelism causes Write/Edit races on the same files.${R}" >&2
                    echo "  ${RED}Wait for the previous '${AGENT_TYPE}' to stop, or dispatch a different agent type.${R}" >&2
                    echo "" >&2
                    log_block "parallel-same-agent" "agent_type=${AGENT_TYPE} elapsed=${ELAPSED}s prev_id=${LAST_ID:0:8}"
                    exit 2
                fi
            fi
        fi
    fi

    echo "${NOW_HUMAN}|start|${AGENT_TYPE}|${AGENT_ID}" >> "$AGENTS_LOG"
    printf "  %sŌśŁ%s %s%s%s%s\n" "$ac" "$R" "$ac" "$B" "$AGENT_TYPE" "$R" >&2
    # Pipeline step reminder ŌĆö warn if orchestrator skipped pipeline-advance
    if [ -f "$PIPELINE_DIR/spec.done" ] && [ ! -f "$PIPELINE_DIR/builder.done" ]; then
        # Builder dispatched without pipeline-advance builder
        echo "" >&2
        echo "  ${RED}${B}WARNING: pipeline-advance builder was NOT called before dispatching agent.${R}" >&2
        echo "  ${RED}Run: bash $APD_SHORTCUT_DISPLAY pipeline builder${R}" >&2
        echo "  ${RED}Pipeline will BLOCK at reviewer step without builder.done${R}" >&2
        echo "" >&2
    elif [ -f "$PIPELINE_DIR/builder.done" ] && [ ! -f "$PIPELINE_DIR/reviewer.done" ]; then
        # Reminder for regular reviewer dispatch
        if echo "$AGENT_TYPE" | grep -qiE 'review'; then
            echo "" >&2
            echo "  ${D}Reminder: Run 'bash $APD_SHORTCUT_DISPLAY pipeline reviewer' after review completes${R}" >&2
        fi
    fi
    ;;
  SubagentStop)
    echo "${NOW_HUMAN}|stop|${AGENT_TYPE}|${AGENT_ID}" >> "$AGENTS_LOG"
    printf "  %sŌśŁ%s %s%s%s %sdone%s\n" "$ac" "$R" "$ac" "$AGENT_TYPE" "$R" "$D" "$R" >&2
    ;;
esac

exit 0
