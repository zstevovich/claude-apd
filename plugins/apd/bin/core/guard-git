#!/bin/bash
# APD Guard — blocks unauthorized git operations
# Subagents must not commit, push, or perform destructive operations
#
# Interface: --command <cmd> --agent-id <id> --agent-type <type>

source "$(dirname "$0")/../lib/resolve-project.sh"
[ "$APD_ACTIVE" = false ] && exit 0

COMMAND=""
AGENT_ID=""
AGENT_TYPE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --command)    COMMAND="$2"; shift 2 ;;
    --agent-id)   AGENT_ID="$2"; shift 2 ;;
    --agent-type) AGENT_TYPE="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# Log function — logs blocked actions with agent context
log_block() {
  local reason="$1"
  local log_file="$MEMORY_DIR/guard-audit.log"
  if [ -d "$MEMORY_DIR" ]; then
    local agent_info="${AGENT_ID:-orchestrator}"
    [ -n "$AGENT_TYPE" ] && agent_info="${agent_info}(${AGENT_TYPE})"
    # Collapse newlines/CR so each event is exactly one log line
    local cmd="${RAW_COMMAND:-$COMMAND}"
    cmd="${cmd//$'\n'/ }"
    cmd="${cmd//$'\r'/ }"
    echo "$(date +%Y-%m-%d\ %H:%M:%S)|BLOCK|${agent_info}|${reason}|${cmd}" >> "$log_file" 2>/dev/null
  fi
}

RAW_COMMAND="$COMMAND"

if [ -z "$COMMAND" ]; then
  exit 0
fi
COMMAND=$(echo "$COMMAND" | tr -s ' ' | sed 's/^ //')
STRIPPED_CMD=$(echo "$COMMAND" | sed -E 's/^([A-Za-z_][A-Za-z0-9_]*=[^ ]* )*//')
NORMALIZED_GIT=$(echo "$STRIPPED_CMD" | sed -E 's/git[[:space:]]+(-[A-Za-z][[:space:]]+[^ ]+[[:space:]]+)*/git /g')

# Block --no-verify
if echo "$RAW_COMMAND" | grep -qE '(^| )--no-verify( |$)'; then
  echo "BLOCKED: --no-verify is not allowed. Hooks must pass." >&2
  log_block "--no-verify"
  exit 2
fi

# Block mass staging
# Trailing char class includes `=` so `git add --all=...` also trips; that form
# isn't accepted by git but we'd rather over-block than let a long-flag-with-
# equals variant slip past.
if echo "$NORMALIZED_GIT" | grep -qE "git add[[:space:]]+(\.([[:space:]]|$)|-[AuU]([[:space:]=]|$)|--all([[:space:]=]|$)|\*)"; then
  echo "BLOCKED: git add . / git add -A / git add --all is not allowed." >&2
  echo "Use: git add <file1> <file2> ..." >&2
  log_block "mass-staging"
  exit 2
fi

# --- git commit ---
if echo "$NORMALIZED_GIT" | grep -qiE "git commit"; then
  if echo "$COMMAND" | grep -qE "^APD_ORCHESTRATOR_COMMIT=1 "; then
    # Block commit -a even with prefix
    if echo "$NORMALIZED_GIT" | grep -qE "git commit[[:space:]]+.*(-a([[:space:]]|$)|--all([[:space:]]|$))"; then
      echo "BLOCKED: git commit -a / --all is not allowed. Stage files explicitly." >&2
      log_block "commit-all"
      exit 2
    fi

    # 1. Pipeline gate
    if [ -x "$SCRIPT_DIR/pipeline-gate" ]; then
      if ! bash "$SCRIPT_DIR/pipeline-gate" >&2; then
        echo "" >&2
        echo "BLOCKED: Pipeline steps are not completed. Commit rejected." >&2
        log_block "pipeline-incomplete"
        exit 2
      fi
    fi

    # 2. Verification (build + lint + test) — verify-all.sh lives in the PROJECT
    if [ -x "$CLAUDE_DIR/scripts/verify-all.sh" ]; then
      echo "-> Running pre-commit verification..." >&2
      if ! bash "$CLAUDE_DIR/scripts/verify-all.sh" >&2; then
        echo "BLOCKED: Verification failed. Commit rejected." >&2
        log_block "verify-failed"
        exit 2
      fi
    fi

    # Pipeline reset happens in PostToolUse hook (pipeline-post-commit)
    # — only AFTER a successful commit, not before
    echo "Pipeline + Verification passed — commit allowed." >&2
    exit 0
  else
    echo "BLOCKED: git commit is only allowed with APD_ORCHESTRATOR_COMMIT=1 prefix." >&2
    log_block "commit-no-prefix"
    exit 2
  fi
fi

# --- git push ---
if echo "$NORMALIZED_GIT" | grep -qiE "git push"; then
  if echo "$NORMALIZED_GIT" | grep -qE "git push.*(-f([[:space:]]|$)|--force([[:space:]]|$)|--force-with-lease([[:space:]]|$))"; then
    echo "BLOCKED: git push --force is not allowed." >&2
    log_block "force-push"
    exit 2
  fi
  if echo "$COMMAND" | grep -qE "^APD_ORCHESTRATOR_COMMIT=1 "; then
    exit 0
  else
    echo "BLOCKED: git push is only allowed with APD_ORCHESTRATOR_COMMIT=1 prefix." >&2
    log_block "push-no-prefix"
    exit 2
  fi
fi

# Block AI signatures
if echo "$RAW_COMMAND" | grep -qi "co-authored-by"; then
  echo "BLOCKED: AI signature (Co-Authored-By) is not allowed." >&2
  log_block "ai-signature"
  exit 2
fi

# .claude/ protection
if echo "$RAW_COMMAND" | grep -qiE "git add.*\.claude"; then
  if echo "$COMMAND" | grep -qE "^APD_ORCHESTRATOR_COMMIT=1 "; then
    exit 0
  else
    echo "BLOCKED: git add .claude/ is only allowed with APD_ORCHESTRATOR_COMMIT=1 prefix." >&2
    log_block "claude-dir-no-prefix"
    exit 2
  fi
fi

# Block destructive git operations
if echo "$NORMALIZED_GIT" | grep -qiE "git (reset[[:space:]]+--hard|clean[[:space:]]+-[fdx]|checkout[[:space:]]+--[[:space:]]|checkout[[:space:]]+\.([[:space:]]|$)|restore[[:space:]]|stash[[:space:]]+drop|tag[[:space:]]+-d([[:space:]]|$))"; then
  echo "BLOCKED: Destructive git operation is not allowed." >&2
  log_block "destructive-git"
  exit 2
fi

# branch -D (force delete)
if echo "$NORMALIZED_GIT" | grep -qE "git branch[[:space:]]+-D([[:space:]]|$)"; then
  echo "BLOCKED: git branch -D (force delete) is not allowed. Use -d for safe delete." >&2
  log_block "force-delete-branch"
  exit 2
fi

exit 0
