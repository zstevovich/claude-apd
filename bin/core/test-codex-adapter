        PASSES=$((PASSES + 1))
    else
        fail "adversarial summary wrong: $OUT"; FAILS=$((FAILS + 1))
    fi
    if echo "$OUT" | grep -q '"reviewed_files": 3'; then
        pass "reviewed_files count = 3"
        PASSES=$((PASSES + 1))
    else
        fail "reviewed_files wrong: $OUT"; FAILS=$((FAILS + 1))
    fi

    rm -rf "$PS"
fi

# -----------------------------------------------------------
# 21. apd cdx skills — hybrid install (direct-drop default, marketplace experimental)
# -----------------------------------------------------------
section "21. apd cdx skills"

SK_HOME="$(mktemp -d -t apd-sk.XXXXXX)"
SK_CODEX="$SK_HOME/.codex"
SK_BIN="$SK_HOME/bin"
mkdir -p "$SK_CODEX" "$SK_BIN"

# Canonical source lives under templates/codex/skills/ — every skill must have
# SKILL.md + agents/openai.yaml (with interface: block) so Codex loads it.
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    src="$APD_PLUGIN_ROOT/templates/codex/skills/$name"
    if [ -f "$src/SKILL.md" ]; then
        pass "source skill present: $name (SKILL.md)"
        PASSES=$((PASSES + 1))
    else
        fail "missing source SKILL.md: $name"
        FAILS=$((FAILS + 1))
    fi
    if [ -f "$src/agents/openai.yaml" ] && grep -q '^interface:' "$src/agents/openai.yaml"; then
        pass "source has agents/openai.yaml with interface block: $name"
        PASSES=$((PASSES + 1))
    else
        fail "missing or malformed source agents/openai.yaml: $name"
        FAILS=$((FAILS + 1))
    fi
    mp="$APD_PLUGIN_ROOT/templates/codex/marketplace/plugins/apd/skills/$name"
    if [ -L "$mp" ]; then
        tgt=$(readlink "$mp")
        case "$tgt" in
            *../../../../skills/$name|../../../../skills/$name)
                pass "marketplace skill is symlink to canonical source: $name"
                PASSES=$((PASSES + 1)) ;;
            *)
                fail "marketplace skill points elsewhere: $name → $tgt"
                FAILS=$((FAILS + 1)) ;;
        esac
    else
        fail "marketplace skill is not a symlink: $name (violates single-source rule)"
        FAILS=$((FAILS + 1))
    fi
done

# --- Direct-drop (default) ---
STATUS_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills status 2>&1)
if echo "$STATUS_OUT" | grep -q "Direct-drop"; then
    pass "status shows Direct-drop section"
    PASSES=$((PASSES + 1))
else
    fail "status missing Direct-drop section"
    FAILS=$((FAILS + 1))
fi
if echo "$STATUS_OUT" | grep -q "apd-brainstorm.*not installed"; then
    pass "status reports apd-brainstorm not installed before install"
    PASSES=$((PASSES + 1))
else
    fail "status did not report apd-brainstorm as uninstalled"
    FAILS=$((FAILS + 1))
fi

CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install >/dev/null 2>&1
ALL_LINKS=1
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    [ -L "$SK_CODEX/skills/$name" ] || ALL_LINKS=0
done
if [ "$ALL_LINKS" -eq 1 ]; then
    pass "default install creates 4 symlinks in ~/.codex/skills/"
    PASSES=$((PASSES + 1))
else
    fail "default install did not create all APD skill symlinks"
    FAILS=$((FAILS + 1))
fi

target=$(readlink "$SK_CODEX/skills/apd-tdd")
if [ "$target" = "$APD_PLUGIN_ROOT/templates/codex/skills/apd-tdd" ]; then
    pass "apd-tdd symlink points to canonical source"
    PASSES=$((PASSES + 1))
else
    fail "apd-tdd symlink drifts: $target"
    FAILS=$((FAILS + 1))
fi

if [ -f "$SK_CODEX/skills/apd-brainstorm/SKILL.md" ] && \
   grep -q "^name: apd-brainstorm$" "$SK_CODEX/skills/apd-brainstorm/SKILL.md"; then
    pass "SKILL.md reachable via symlink with correct frontmatter"
    PASSES=$((PASSES + 1))
else
    fail "SKILL.md content not reachable via symlink"
    FAILS=$((FAILS + 1))
fi

CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install apd-debug --copy >/dev/null 2>&1
if [ ! -L "$SK_CODEX/skills/apd-debug" ] && [ -d "$SK_CODEX/skills/apd-debug" ]; then
    pass "install --copy replaces symlink with real directory"
    PASSES=$((PASSES + 1))
else
    fail "install --copy did not switch to directory mode"
    FAILS=$((FAILS + 1))
fi

POST_STATUS=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills status 2>&1)
if echo "$POST_STATUS" | grep -q "apd-brainstorm.*symlink"; then
    pass "status reports symlinks after install"
    PASSES=$((PASSES + 1))
else
    fail "status did not reflect symlink install"
    FAILS=$((FAILS + 1))
fi
if echo "$POST_STATUS" | grep -q "apd-debug.*copy"; then
    pass "status reports copy-mode install"
    PASSES=$((PASSES + 1))
else
    fail "status did not reflect --copy install"
    FAILS=$((FAILS + 1))
fi

CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall >/dev/null 2>&1
ANY_LEFT=0
for name in apd-brainstorm apd-tdd apd-debug apd-finish; do
    [ -e "$SK_CODEX/skills/$name" ] && ANY_LEFT=1
done
if [ "$ANY_LEFT" -eq 0 ]; then
    pass "uninstall removes every apd-* skill"
    PASSES=$((PASSES + 1))
else
    fail "some apd-* skills survived uninstall"
    FAILS=$((FAILS + 1))
fi

mkdir -p "$SK_CODEX/skills/some-other-skill"
touch "$SK_CODEX/skills/some-other-skill/SKILL.md"
REFUSE_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall some-other-skill 2>&1)
if echo "$REFUSE_OUT" | grep -q "refuse"; then
    pass "uninstall refuses non-apd-* names"
    PASSES=$((PASSES + 1))
else
    fail "uninstall did not refuse non-apd-* name"
    FAILS=$((FAILS + 1))
fi
rm -rf "$SK_CODEX/skills/some-other-skill"

# --- Overwrite protection: user-modified install is preserved without --force ---
mkdir -p "$SK_CODEX/skills/apd-debug"
cat > "$SK_CODEX/skills/apd-debug/SKILL.md" <<'EOF'
---
name: apd-debug
description: USER CUSTOM VERSION
---
EOF
OVW_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install apd-debug --copy 2>&1)
if echo "$OVW_OUT" | grep -q "refuse"; then
    pass "install refuses to overwrite user-modified copy without --force"
    PASSES=$((PASSES + 1))
else
    fail "install silently overwrote user-modified copy"
    FAILS=$((FAILS + 1))
fi
if grep -q "USER CUSTOM VERSION" "$SK_CODEX/skills/apd-debug/SKILL.md" 2>/dev/null; then
    pass "user content preserved after refused install"
    PASSES=$((PASSES + 1))
else
    fail "user content lost even though install refused"
    FAILS=$((FAILS + 1))
fi
CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install apd-debug --copy --force >/dev/null 2>&1
if ! grep -q "USER CUSTOM VERSION" "$SK_CODEX/skills/apd-debug/SKILL.md" 2>/dev/null && \
   grep -q "^name: apd-debug$" "$SK_CODEX/skills/apd-debug/SKILL.md"; then
    pass "install --force overwrites user-modified copy with canonical"
    PASSES=$((PASSES + 1))
else
    fail "install --force did not overwrite as expected"
    FAILS=$((FAILS + 1))
fi
CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall >/dev/null 2>&1

# --- Guard against embedded .git in marketplace template (release blocker) ---
if [ ! -e "$APD_PLUGIN_ROOT/templates/codex/marketplace/.git" ]; then
    pass "marketplace template has no embedded .git (release-safe)"
    PASSES=$((PASSES + 1))
else
    fail "marketplace template contains embedded .git — would break git add as submodule"
    FAILS=$((FAILS + 1))
fi

# --- Marketplace (--marketplace, experimental) ---
cat > "$SK_BIN/codex" <<'EOF'
#!/bin/bash
set -euo pipefail
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CFG="$CODEX_HOME/config.toml"
mkdir -p "$CODEX_HOME"
if [ "${1:-}" = "marketplace" ] && [ "${2:-}" = "add" ] && [ -n "${3:-}" ]; then
  SRC="$3"
  [ -f "$CFG" ] && grep -q '^\[marketplaces\.codex-apd\]' "$CFG" 2>/dev/null && exit 0
  printf '\n[marketplaces.codex-apd]\nsource = "%s"\n' "$SRC" >> "$CFG"
  exit 0
fi
echo "fake codex: unsupported args: $*" >&2
exit 1
EOF
chmod +x "$SK_BIN/codex"

MP_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if echo "$MP_OUT" | grep -q "EXPERIMENTAL"; then
    pass "--marketplace install shows experimental warning"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install missing experimental warning"
    FAILS=$((FAILS + 1))
fi

if grep -q '^\[marketplaces\.codex-apd\]' "$SK_CODEX/config.toml" 2>/dev/null && \
   grep -qF "source = \"$APD_PLUGIN_ROOT/templates/codex/marketplace\"" "$SK_CODEX/config.toml"; then
    pass "--marketplace install registers codex-apd marketplace"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not register marketplace"
    FAILS=$((FAILS + 1))
fi

if grep -q '^\[plugins\."apd@codex-apd"\]' "$SK_CODEX/config.toml" 2>/dev/null && \
   grep -q '^enabled = true$' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "--marketplace install enables [plugins.\"apd@codex-apd\"]"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not enable plugin block"
    FAILS=$((FAILS + 1))
fi

REINSTALL_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if echo "$REINSTALL_OUT" | grep -q "already registered"; then
    pass "--marketplace reinstall is idempotent when marketplace already matches"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace reinstall did not report already registered"
    FAILS=$((FAILS + 1))
fi

python3 - "$SK_CODEX/config.toml" <<'PY'
import re, sys
path = sys.argv[1]
text = open(path).read()
text = re.sub(
    r'(?ms)^\[plugins\."apd@codex-apd"\][^\[]*?(?=^\[|\Z)',
    '[plugins."apd@codex-apd"]\nenabled = false\n\n',
    text,
)
open(path, 'w').write(text)
PY
HEAL_OUT=$(PATH="$SK_BIN:$PATH" CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills install --marketplace 2>&1)
if grep -q '^enabled = true$' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "--marketplace install self-heals disabled plugin block"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace install did not self-heal disabled plugin block"
    FAILS=$((FAILS + 1))
fi
if echo "$HEAL_OUT" | grep -q 'updated'; then
    pass "--marketplace self-heal reports plugin block update"
    PASSES=$((PASSES + 1))
else
    fail "--marketplace self-heal did not report update"
    FAILS=$((FAILS + 1))
fi

printf '\n[plugins."other@else"]\nenabled = true\n' >> "$SK_CODEX/config.toml"
UNINSTALL_OUT=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills uninstall --marketplace 2>&1)
if ! grep -q '^\[marketplaces\.codex-apd\]' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "uninstall --marketplace removes [marketplaces.codex-apd]"
    PASSES=$((PASSES + 1))
else
    fail "uninstall --marketplace left [marketplaces.codex-apd] in config.toml"
    FAILS=$((FAILS + 1))
fi
if ! grep -q '^\[plugins\."apd@codex-apd"\]' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "uninstall --marketplace removes [plugins.\"apd@codex-apd\"]"
    PASSES=$((PASSES + 1))
else
    fail "uninstall --marketplace left [plugins.\"apd@codex-apd\"] in config.toml"
    FAILS=$((FAILS + 1))
fi
if grep -q '^\[plugins\."other@else"\]' "$SK_CODEX/config.toml" 2>/dev/null; then
    pass "uninstall --marketplace preserves unrelated plugin blocks"
    PASSES=$((PASSES + 1))
else
    fail "uninstall --marketplace removed an unrelated plugin block"
    FAILS=$((FAILS + 1))
fi

FINAL_STATUS=$(CODEX_HOME="$SK_CODEX" bash "$APD_PLUGIN_ROOT/bin/apd" cdx skills status 2>&1)
if echo "$FINAL_STATUS" | grep -q "Marketplace (experimental"; then
    pass "status shows Marketplace (experimental) section"
    PASSES=$((PASSES + 1))
else
    fail "status missing Marketplace (experimental) section"
    FAILS=$((FAILS + 1))
fi
if echo "$FINAL_STATUS" | grep -q "marketplace:.*not registered"; then
    pass "status reports marketplace unregistered after uninstall --marketplace"
    PASSES=$((PASSES + 1))
else
    fail "status did not report marketplace unregistered"
    FAILS=$((FAILS + 1))
fi

rm -rf "$SK_HOME"

# -----------------------------------------------------------
# Summary
# -----------------------------------------------------------
echo ""
section "Summary"
echo "  ${G}PASS:${R} $PASSES"
echo "  ${R}FAIL:${R} $FAILS"

if [ "$FAILS" -eq 0 ]; then
    echo ""
    echo "  ${G}All Codex adapter checks passed.${R}"
    exit 0
else
    echo ""
    echo "  ${R}$FAILS check(s) failed — Codex adapter has regressions.${R}"
    exit "$FAILS"
fi
