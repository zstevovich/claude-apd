#!/bin/bash
# APD Test Codex Adapter — E2E smoke test for the Codex runtime adapter
#
# Builds a throwaway project with a known agent set, runs install-codex-config,
# and verifies every enforcement layer:
#   1. MCP server: syntactically valid, all expected tools registered
#   2. config.toml: [mcp_servers.apd] + per-agent [permissions.apd-<role>] blocks
#   3. hooks.json: PreToolUse Bash → guard-bash-scope
#   4. Idempotency: second run produces zero writes
#   5. Negative case: project without .codex/ dir doesn't trigger adapter
#   6. guard-scope: ALLOW and BLOCK both behave correctly
#   7. MCP Python helper: _project_dir() walks up to the right project root
#
# Standalone — does not require Codex CLI to be installed. Exercises the
# bash/Python surface the Codex runtime depends on.
#
# Usage: bash bin/core/test-codex-adapter
# Exit: 0 = pass, non-zero = number of failed checks

set -u

APD_PLUGIN_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

apd_header "Codex Adapter E2E Test"

SCRATCH="$(mktemp -d -t apd-cdx-test.XXXXXX)"
trap 'rm -rf "$SCRATCH"' EXIT

FAILS=0
PASSES=0

_check() {
    local label="$1"; shift
    if "$@" >/dev/null 2>&1; then
        pass "$label"
        PASSES=$((PASSES + 1))
    else
        fail "$label"
        FAILS=$((FAILS + 1))
    fi
}

_check_file_contains() {
    local label="$1" file="$2" pattern="$3"
    if [ -f "$file" ] && grep -qE "$pattern" "$file"; then
        pass "$label"
        PASSES=$((PASSES + 1))
    else
        fail "$label (file=$file, pattern=$pattern)"
        FAILS=$((FAILS + 1))
    fi
}

# -----------------------------------------------------------
# 1. MCP server surface
# -----------------------------------------------------------
section "1. MCP server"

_check "apd_mcp_server.py exists" test -f "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"
_check "Python syntax valid" python3 -m py_compile "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"

EXPECTED_TOOLS=(apd_ping apd_doctor apd_advance_pipeline apd_guard_write apd_verify_step apd_adversarial_pass)
for tool in "${EXPECTED_TOOLS[@]}"; do
    _check_file_contains "tool '$tool' registered" "$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py" "^def $tool\b"
done

# -----------------------------------------------------------
# 2. Scaffold a PURE-CODEX scratch project (no .claude/)
# -----------------------------------------------------------
section "2. Scratch project scaffold (pure Codex)"

mkdir -p "$SCRATCH/.codex"

_check "scratch dir has .codex" test -d "$SCRATCH/.codex"
_check "scratch dir has NO .claude/" test ! -e "$SCRATCH/.claude"

# -----------------------------------------------------------
# 3. First install-codex-config run — writes everything
# -----------------------------------------------------------
section "3. install-codex-config (first run)"

FIRST_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$SCRATCH" 2>&1)"
FIRST_EXIT=$?

[ "$FIRST_EXIT" -eq 0 ] && pass "exit code 0" && PASSES=$((PASSES + 1)) || { fail "exit code was $FIRST_EXIT"; FAILS=$((FAILS + 1)); }

echo "$FIRST_OUT" | grep -q "\[wrote\] \[mcp_servers.apd\]" && pass "wrote MCP block" && PASSES=$((PASSES + 1)) || { fail "did not write MCP block"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "per-agent sandbox profiles skipped" && pass "sandbox profiles deferred (MCP guard-scope path)" && PASSES=$((PASSES + 1)) || { fail "sandbox skip notice missing"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "PreToolUse Bash hook" && pass "wrote hooks.json" && PASSES=$((PASSES + 1)) || { fail "no hooks.json written"; FAILS=$((FAILS + 1)); }
echo "$FIRST_OUT" | grep -q "\.codex/bin/apd shortcut" && pass "wrote .codex/bin/apd shortcut" && PASSES=$((PASSES + 1)) || { fail "no apd shortcut created"; FAILS=$((FAILS + 1)); }
_check ".codex/bin/apd is executable" test -x "$SCRATCH/.codex/bin/apd"
echo "$FIRST_OUT" | grep -q "\.apd/config seed" && pass "seeded .apd/config (pure-Codex activation)" && PASSES=$((PASSES + 1)) || { fail "no .apd/config seed emitted"; FAILS=$((FAILS + 1)); }
_check ".apd/config exists" test -f "$SCRATCH/.apd/config"
_check "did NOT create .claude/ anywhere" test ! -e "$SCRATCH/.claude"
_check ".apd/rules/workflow.md scaffolded" test -f "$SCRATCH/.apd/rules/workflow.md"
_check ".apd/memory/MEMORY.md scaffolded" test -f "$SCRATCH/.apd/memory/MEMORY.md"
_check ".apd/memory/status.md scaffolded" test -f "$SCRATCH/.apd/memory/status.md"
_check ".apd/memory/session-log.md scaffolded" test -f "$SCRATCH/.apd/memory/session-log.md"
_check ".apd/agents/ scaffolded" test -d "$SCRATCH/.apd/agents"
_check ".apd/.apd-version scaffolded" test -f "$SCRATCH/.apd/.apd-version"
_check "AGENTS.md scaffolded at project root" test -f "$SCRATCH/AGENTS.md"
_check_file_contains "AGENTS.md references APD pipeline" "$SCRATCH/AGENTS.md" 'apd_advance_pipeline'
_check_file_contains "AGENTS.md has project name substituted" "$SCRATCH/AGENTS.md" "^# $(basename "$SCRATCH")$"
! grep -q "^\[permissions\." "$SCRATCH/.codex/config.toml" && pass "no broken [permissions.*] blocks emitted" && PASSES=$((PASSES + 1)) || { fail "broken permissions blocks present"; FAILS=$((FAILS + 1)); }

# -----------------------------------------------------------
# 4. Generated file content
# -----------------------------------------------------------
section "4. Generated file content"

CFG="$SCRATCH/.codex/config.toml"
HOOKS="$SCRATCH/.codex/hooks.json"

_check_file_contains "config.toml has [mcp_servers.apd]" "$CFG" '^\[mcp_servers\.apd\]'
_check_file_contains "hooks.json has PreToolUse" "$HOOKS" 'PreToolUse'
_check_file_contains "hooks.json routes to guard-bash-scope" "$HOOKS" 'guard-bash-scope'
_check_file_contains ".apd/config has PROJECT_NAME" "$SCRATCH/.apd/config" '^PROJECT_NAME='

if command -v python3 &>/dev/null; then
    _check "TOML parses cleanly" python3 -c "import tomllib; tomllib.load(open('$CFG','rb'))"
    _check "JSON parses cleanly" python3 -c "import json; json.load(open('$HOOKS'))"
else
    warn "python3 not found — skipping strict TOML/JSON parse checks"
fi

# -----------------------------------------------------------
# 5. Idempotency — second run produces no writes
# -----------------------------------------------------------
section "5. Idempotency"

SECOND_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$SCRATCH" 2>&1)"

if echo "$SECOND_OUT" | grep -q "\[wrote\]"; then
    fail "second run wrote something — not idempotent"
    FAILS=$((FAILS + 1))
else
    pass "second run produced zero writes"
    PASSES=$((PASSES + 1))
fi

if echo "$SECOND_OUT" | grep -q "already up to date"; then
    pass "second run reports 'already up to date'"
    PASSES=$((PASSES + 1))
else
    fail "second run missing 'already up to date'"
    FAILS=$((FAILS + 1))
fi

# -----------------------------------------------------------
# 6. guard-scope ALLOW + BLOCK behavior
# -----------------------------------------------------------
section "6. guard-scope enforcement"

# APD activation relies on .apd/config, which the installer seeded above.
# No need to touch .claude/ for a pure-Codex project.
if (cd "$SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-scope" --file-path "src/foo.ts" "src/" >/dev/null 2>&1); then
    pass "ALLOW: src/foo.ts with allowed=src/"
    PASSES=$((PASSES + 1))
else
    fail "src/foo.ts should have been allowed"
    FAILS=$((FAILS + 1))
fi

(cd "$SCRATCH" && bash "$APD_PLUGIN_ROOT/bin/core/guard-scope" --file-path "/tmp/escape.ts" "src/" >/dev/null 2>&1)
case $? in
    2) pass "BLOCK: /tmp/escape.ts rejected (exit 2)" ; PASSES=$((PASSES + 1)) ;;
    *) fail "BLOCK test did not return exit 2 (got $?)"; FAILS=$((FAILS + 1)) ;;
esac

# -----------------------------------------------------------
# 7. Python _project_dir walk-up
# -----------------------------------------------------------
section "7. Python project_dir resolution"

mkdir -p "$SCRATCH/subdir/deeper"
RESOLVED="$(cd "$SCRATCH/subdir/deeper" && python3 -c "
import sys; sys.path.insert(0, '$APD_PLUGIN_ROOT/mcp')
try:
    import apd_mcp_server as m
    print(m._project_dir())
except ImportError:
    # FastMCP import fails without mcp installed — fall back to direct source read
    import os; os.chdir('$SCRATCH/subdir/deeper')
    cur = os.getcwd()
    while cur != '/':
        for marker in ('.codex', 'AGENTS.md', '.claude', 'CLAUDE.md'):
            p = os.path.join(cur, marker)
            if os.path.isdir(p) or os.path.isfile(p):
                print(cur); sys.exit(0)
        cur = os.path.dirname(cur)
" 2>&1 | tail -1)"

SCRATCH_REAL="$(cd "$SCRATCH" && pwd -P)"
if [ "$RESOLVED" = "$SCRATCH_REAL" ] || [ "$RESOLVED" = "$SCRATCH" ]; then
    pass "walks up from subdir/deeper/ → $RESOLVED"
    PASSES=$((PASSES + 1))
else
    fail "expected $SCRATCH_REAL, got '$RESOLVED'"
    FAILS=$((FAILS + 1))
fi

# -----------------------------------------------------------
# 8. MCP bootstrap creates shortcut automatically on server start
# -----------------------------------------------------------
section "8. MCP bootstrap shortcut"

BOOT_DIR="$(mktemp -d -t apd-boot.XXXXXX)"
mkdir -p "$BOOT_DIR/.codex"
if command -v uv &>/dev/null; then
    (cd "$BOOT_DIR" && uv run --with mcp python -c "
import sys; sys.path.insert(0, '$APD_PLUGIN_ROOT/mcp')
import apd_mcp_server as m
m._bootstrap_shortcut()
" >/dev/null 2>&1)
    if [ -x "$BOOT_DIR/.codex/bin/apd" ]; then
        pass "bootstrap creates .codex/bin/apd when .codex/ exists"
        PASSES=$((PASSES + 1))
    else
        fail "bootstrap did not create .codex/bin/apd"
        FAILS=$((FAILS + 1))
    fi

    if [ ! -e "$BOOT_DIR/.claude" ]; then
        pass "bootstrap did NOT create .claude/ in Codex project"
        PASSES=$((PASSES + 1))
    else
        fail "bootstrap leaked .claude/ into Codex project"
        FAILS=$((FAILS + 1))
    fi

    NOCDX="$(mktemp -d -t apd-nocdx.XXXXXX)"
    (cd "$NOCDX" && uv run --with mcp python -c "
import sys; sys.path.insert(0, '$APD_PLUGIN_ROOT/mcp')
import apd_mcp_server as m
m._bootstrap_shortcut()
" >/dev/null 2>&1)
    if [ ! -e "$NOCDX/.codex" ] && [ ! -e "$NOCDX/.claude" ]; then
        pass "bootstrap skips dirs without .codex/"
        PASSES=$((PASSES + 1))
    else
        fail "bootstrap created a dir in a non-APD cwd"
        FAILS=$((FAILS + 1))
    fi
    rm -rf "$NOCDX"
else
    warn "uv not installed — skipping bootstrap checks"
fi
rm -rf "$BOOT_DIR"

# -----------------------------------------------------------
# 9. Negative path — apd-init on project WITHOUT .codex/ skips adapter
# -----------------------------------------------------------
section "9. Negative path"

NEG="$(mktemp -d -t apd-neg.XXXXXX)"
mkdir -p "$NEG/.apd"
cat > "$NEG/.apd/config" <<EOF
PROJECT_NAME=neg
APD_VERSION=test
STACK=test
EOF

NEG_OUT="$(APD_PROJECT_DIR="$NEG" bash "$APD_PLUGIN_ROOT/bin/core/apd-init" --quick 2>&1 || true)"
rm -rf "$NEG"

if echo "$NEG_OUT" | grep -q "Codex adapter"; then
    fail "apd-init triggered Codex section without .codex/ dir"
    FAILS=$((FAILS + 1))
else
    pass "apd-init skipped Codex section (no .codex/ dir)"
    PASSES=$((PASSES + 1))
fi

# -----------------------------------------------------------
# 10. Pipeline builder advances on pure-Codex (no sub-agents)
# -----------------------------------------------------------
section "10. Pipeline builder on pure-Codex"

_os=$(uname -s | tr '[:upper:]' '[:lower:]')
_arch=$(uname -m | tr '[:upper:]' '[:lower:]')
[ "$_arch" = "x86_64" ] && _arch="amd64"
[ "$_arch" = "aarch64" ] && _arch="arm64"
VALIDATOR="$APD_PLUGIN_ROOT/bin/compiled/validate-agent-${_os}-${_arch}"

if [ -x "$VALIDATOR" ]; then
    PC="$(mktemp -d -t apd-pc-pipe.XXXXXX)"
    mkdir -p "$PC/.codex/bin" "$PC/.apd/pipeline"
    cat > "$PC/.apd/config" <<EOF
PROJECT_NAME=pc-pipe
APD_VERSION=test
STACK=test
EOF
    ln -sf "$APD_PLUGIN_ROOT/bin/apd" "$PC/.codex/bin/apd"

    # Seed a signed spec.done straight through the validator so the pipeline
    # sees a valid spec step without having to craft a full spec-card.md.
    "$VALIDATOR" advance -step spec -task pc-smoke -pipeline-dir "$PC/.apd/pipeline" >/dev/null 2>&1
    echo "# plan" > "$PC/.apd/pipeline/implementation-plan.md"

    PC_BUILDER_OUT="$(APD_PROJECT_DIR="$PC" APD_RUNTIME=codex bash "$APD_PLUGIN_ROOT/bin/core/pipeline-advance" builder 2>&1)"
    PC_BUILDER_EXIT=$?

    if [ "$PC_BUILDER_EXIT" -eq 0 ] && [ -f "$PC/.apd/pipeline/builder.done" ]; then
        pass "builder advances without sub-agent dispatch on pure-Codex"
        PASSES=$((PASSES + 1))
    else
        fail "builder did not advance (exit=$PC_BUILDER_EXIT)"
        echo "    last line: $(echo "$PC_BUILDER_OUT" | tail -1)" >&2
        FAILS=$((FAILS + 1))
    fi

    if echo "$PC_BUILDER_OUT" | grep -q "\.claude/"; then
        fail "builder output leaked .claude/ path to Codex user"
        FAILS=$((FAILS + 1))
    else
        pass "builder output contains no .claude/ references"
        PASSES=$((PASSES + 1))
    fi

    rm -rf "$PC"
else
    warn "validator binary not found — skipping pure-Codex pipeline test"
fi

# -----------------------------------------------------------
# 11. Framework resolves agents from .apd/agents/ (runtime-neutral)
# -----------------------------------------------------------
section "11. Runtime-neutral agent registry"

NT="$(mktemp -d -t apd-nt.XXXXXX)"
mkdir -p "$NT/.codex" "$NT/.apd/agents"
cat > "$NT/.apd/config" <<EOF
PROJECT_NAME=nt
APD_VERSION=test
STACK=test
EOF
cat > "$NT/.apd/agents/backend-builder.md" <<'EOF'
---
name: backend-builder
model: sonnet
---
# SCOPE_PATHS: src/
EOF
cat > "$NT/.apd/agents/code-reviewer.md" <<'EOF'
---
name: code-reviewer
model: opus
---
# read-only
EOF

# Probe resolver directly — APD_AGENTS_DIR should point to .apd/agents/ on a
# project with no .claude/ tree.
RESOLVED_AGENTS="$(APD_PROJECT_DIR="$NT" bash -c "source $APD_PLUGIN_ROOT/bin/lib/resolve-project.sh; echo \$APD_AGENTS_DIR")"
EXPECTED_AGENTS="$NT/.apd/agents"
if [ "$RESOLVED_AGENTS" = "$EXPECTED_AGENTS" ]; then
    pass "APD_AGENTS_DIR resolves to .apd/agents/ on pure-Codex"
    PASSES=$((PASSES + 1))
else
    fail "APD_AGENTS_DIR expected $EXPECTED_AGENTS, got $RESOLVED_AGENTS"
    FAILS=$((FAILS + 1))
fi

# pipeline-doctor should list agents from .apd/agents/
DOC_OUT="$(APD_PROJECT_DIR="$NT" APD_RUNTIME=codex bash "$APD_PLUGIN_ROOT/bin/core/pipeline-doctor" 2>&1)"
if echo "$DOC_OUT" | grep -qE "backend-builder.*sonnet"; then
    pass "pipeline-doctor lists agents from .apd/agents/"
    PASSES=$((PASSES + 1))
else
    fail "pipeline-doctor did not find .apd/agents/backend-builder.md"
    FAILS=$((FAILS + 1))
fi

rm -rf "$NT"

# -----------------------------------------------------------
# 12. Hybrid project: scaffold SKIPPED when .claude/ exists
# -----------------------------------------------------------
section "12. Hybrid: no .apd/ scaffold leak"

HY="$(mktemp -d -t apd-hy.XXXXXX)"
mkdir -p "$HY/.codex" "$HY/.claude/memory" "$HY/.claude/rules" "$HY/.claude/agents"
# Simulate CC project with its own memory and rules already populated
echo "# CC memory" > "$HY/.claude/memory/MEMORY.md"
echo "# CC workflow" > "$HY/.claude/rules/workflow.md"
echo "PROJECT_NAME=hy" > "$HY/.claude/.apd-config"

HY_OUT="$(bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$HY" 2>&1)"

if echo "$HY_OUT" | grep -q "\.claude/ present — treating as CC/hybrid"; then
    pass "installer recognized hybrid project and skipped .apd/ scaffold"
    PASSES=$((PASSES + 1))
else
    fail "installer did not print hybrid-skip notice"
    FAILS=$((FAILS + 1))
fi

if [ ! -d "$HY/.apd/rules" ] && [ ! -d "$HY/.apd/memory" ] && [ ! -d "$HY/.apd/agents" ]; then
    pass "no .apd/rules/ .apd/memory/ .apd/agents/ created on hybrid"
    PASSES=$((PASSES + 1))
else
    fail "scaffold leaked .apd/ dirs on a hybrid project"
    FAILS=$((FAILS + 1))
fi

# AGENTS.md must not be injected on hybrid — user already has CLAUDE.md
if [ ! -f "$HY/AGENTS.md" ]; then
    pass "no AGENTS.md created on hybrid (CLAUDE.md is authoritative)"
    PASSES=$((PASSES + 1))
else
    fail "scaffold wrote AGENTS.md on a hybrid project"
    FAILS=$((FAILS + 1))
fi

# .apd/config still gets seeded (needed for activation even on hybrid that
# hasn't migrated) — but only if .claude/.apd-config doesn't exist. This
# hybrid has the legacy config, so .apd/config should NOT be created.
if [ ! -f "$HY/.apd/config" ]; then
    pass "hybrid with legacy .claude/.apd-config did not also get .apd/config"
    PASSES=$((PASSES + 1))
else
    fail "scaffold wrote .apd/config despite legacy CC config being present"
    FAILS=$((FAILS + 1))
fi

rm -rf "$HY"

# -----------------------------------------------------------
# 13. apd cdx agents — list + add + scope override
# -----------------------------------------------------------
section "13. apd cdx agents scaffold"

AG="$(mktemp -d -t apd-ag.XXXXXX)"
mkdir -p "$AG/.codex"
bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$AG" >/dev/null 2>&1

# list prints templates
AG_LIST_OUT="$(APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents list 2>&1)"
if echo "$AG_LIST_OUT" | grep -q "code-reviewer" && echo "$AG_LIST_OUT" | grep -q "backend-builder"; then
    pass "agents list shows core templates"
    PASSES=$((PASSES + 1))
else
    fail "agents list missing expected templates"
    FAILS=$((FAILS + 1))
fi

# add default template
AG_ADD_OUT="$(APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents add code-reviewer 2>&1)"
if [ -f "$AG/.apd/agents/code-reviewer.md" ]; then
    pass "agents add code-reviewer created file"
    PASSES=$((PASSES + 1))
else
    fail "code-reviewer.md not created"
    FAILS=$((FAILS + 1))
fi
if grep -q '^name: code-reviewer$' "$AG/.apd/agents/code-reviewer.md" 2>/dev/null; then
    pass "code-reviewer has expected frontmatter"
    PASSES=$((PASSES + 1))
else
    fail "code-reviewer frontmatter missing name"
    FAILS=$((FAILS + 1))
fi

# add with custom scope paths
APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents add backend-builder src/ api/ >/dev/null 2>&1
if grep -qE '^  - src/$' "$AG/.apd/agents/backend-builder.md" && grep -qE '^  - api/$' "$AG/.apd/agents/backend-builder.md"; then
    pass "agents add honors custom scope paths"
    PASSES=$((PASSES + 1))
else
    fail "custom scope paths did not land in scope: block"
    FAILS=$((FAILS + 1))
fi

# re-add without --force should fail
if APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents add code-reviewer >/dev/null 2>&1; then
    fail "re-add without --force unexpectedly succeeded"
    FAILS=$((FAILS + 1))
else
    pass "re-add without --force refused (idempotent guard)"
    PASSES=$((PASSES + 1))
fi

# --force overwrites
if APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents add code-reviewer --force >/dev/null 2>&1; then
    pass "--force permits overwrite"
    PASSES=$((PASSES + 1))
else
    fail "--force did not allow overwrite"
    FAILS=$((FAILS + 1))
fi

# unknown template fails cleanly
if APD_PROJECT_DIR="$AG" bash "$APD_PLUGIN_ROOT/bin/apd" cdx agents add nonsense-agent >/dev/null 2>&1; then
    fail "unknown template did not error"
    FAILS=$((FAILS + 1))
else
    pass "unknown template rejected with nonzero exit"
    PASSES=$((PASSES + 1))
fi

rm -rf "$AG"

# -----------------------------------------------------------
# 14. User-authored AGENTS.md is preserved
# -----------------------------------------------------------
section "14. AGENTS.md preservation"

UA="$(mktemp -d -t apd-ua.XXXXXX)"
mkdir -p "$UA/.codex"
echo "# My custom context — do not touch" > "$UA/AGENTS.md"
ORIG_SHA="$(shasum "$UA/AGENTS.md" | cut -d' ' -f1)"

bash "$APD_PLUGIN_ROOT/bin/adapter/cdx/install-codex-config" "$UA" >/dev/null 2>&1

NEW_SHA="$(shasum "$UA/AGENTS.md" | cut -d' ' -f1)"
if [ "$ORIG_SHA" = "$NEW_SHA" ]; then
    pass "existing AGENTS.md left untouched"
    PASSES=$((PASSES + 1))
else
    fail "installer overwrote a user-authored AGENTS.md"
    FAILS=$((FAILS + 1))
fi

rm -rf "$UA"

# -----------------------------------------------------------
# Summary
# -----------------------------------------------------------
echo ""
section "Summary"
echo "  ${G}PASS:${R} $PASSES"
echo "  ${R}FAIL:${R} $FAILS"

if [ "$FAILS" -eq 0 ]; then
    echo ""
    echo "  ${G}All Codex adapter checks passed.${R}"
    exit 0
else
    echo ""
    echo "  ${R}$FAILS check(s) failed — Codex adapter has regressions.${R}"
    exit "$FAILS"
fi
