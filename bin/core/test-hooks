#!/bin/bash
# APD Test Hooks — verifies that hooks and scripts are correctly configured
# Run after /apd-setup or manual setup

source "$(dirname "$0")/../lib/resolve-project.sh"

source "$(dirname "$0")/../lib/style.sh"

apd_header "Hook Verification"

# --- 1. Dependencies ---
section "Dependencies"

if command -v jq &>/dev/null; then
    pass "jq is installed ($(jq --version 2>&1))"
else
    fail "jq is NOT installed — guard-git, guard-scope, guard-secrets will not work"
fi

if command -v git &>/dev/null; then
    pass "git is installed"
else
    fail "git is NOT installed"
fi

# --- 2. Directories ---
section "Structure"

if [ -d "$CLAUDE_DIR" ]; then
    pass ".claude/ directory exists"
else
    fail ".claude/ directory DOES NOT EXIST"
fi

for dir in scripts rules memory agents; do
    if [ -d "$CLAUDE_DIR/$dir" ]; then
        pass ".claude/$dir/ exists"
    else
        fail ".claude/$dir/ DOES NOT EXIST"
    fi
done

# --- 3. Scripts ---
section "Scripts"

PLUGIN_SCRIPTS=(
    guard-git
    guard-scope
    guard-bash-scope
    guard-secrets
    guard-lockfile
    guard-permission-denied
    pipeline-advance
    pipeline-gate
    pipeline-post-commit
    rotate-session-log
    session-start
)

for script in "${PLUGIN_SCRIPTS[@]}"; do
    SCRIPT_PATH="$SCRIPT_DIR/$script"
    if [ ! -f "$SCRIPT_PATH" ]; then
        fail "$script DOES NOT EXIST (plugin: $SCRIPT_DIR)"
    elif [ ! -x "$SCRIPT_PATH" ]; then
        warn "$script exists but is NOT executable (chmod +x)"
    else
        pass "$script OK"
    fi
done

# Project script — verify-all.sh lives in the project
PROJECT_VERIFY="$CLAUDE_DIR/scripts/verify-all.sh"
if [ ! -f "$PROJECT_VERIFY" ]; then
    warn "verify-all.sh DOES NOT EXIST in the project (.claude/bin/) — create with /apd-setup"
elif [ ! -x "$PROJECT_VERIFY" ]; then
    warn "verify-all.sh exists but is NOT executable (chmod +x)"
else
    pass "verify-all.sh OK (project)"
fi

# --- 4. Settings.json ---
section "Settings"

SETTINGS="$CLAUDE_DIR/settings.json"
if [ ! -f "$SETTINGS" ]; then
    fail "settings.json DOES NOT EXIST"
else
    if ! jq empty "$SETTINGS" 2>/dev/null; then
        fail "settings.json is NOT valid JSON"
    else
        pass "settings.json is valid JSON"

        # Check hooks — plugin hooks.json is the source of truth (not project settings.json)
        PLUGIN_HOOKS="${APD_PLUGIN_ROOT}/hooks/hooks.json"
        if [ -f "$PLUGIN_HOOKS" ]; then
            HOOK_COUNT=$(jq '[.hooks.PreToolUse[]?.hooks[]? // empty] | length' "$PLUGIN_HOOKS" 2>/dev/null || echo 0)
            if [ "$HOOK_COUNT" -gt 0 ]; then
                pass "PreToolUse hooks configured ($HOOK_COUNT in plugin)"
            else
                fail "No PreToolUse hooks in plugin hooks.json"
            fi

            SESSION_HOOK=$(jq '.hooks.SessionStart // empty' "$PLUGIN_HOOKS" 2>/dev/null)
            if [ -n "$SESSION_HOOK" ] && [ "$SESSION_HOOK" != "null" ]; then
                pass "SessionStart hook configured (plugin)"
            else
                fail "SessionStart hook missing from plugin hooks.json"
            fi

            POST_HOOK=$(jq '.hooks.PostToolUse // empty' "$PLUGIN_HOOKS" 2>/dev/null)
            if [ -n "$POST_HOOK" ] && [ "$POST_HOOK" != "null" ]; then
                pass "PostToolUse hook configured (plugin)"
            else
                fail "PostToolUse hook missing from plugin hooks.json"
            fi
        else
            warn "Plugin hooks.json not found at $PLUGIN_HOOKS"
        fi
    fi
fi

# --- 5. Placeholder check ---
section "Placeholders"

PLACEHOLDER_FILES=(
    "$PROJECT_DIR/CLAUDE.md"
    "$CLAUDE_DIR/memory/MEMORY.md"
    "$CLAUDE_DIR/memory/status.md"
    "$CLAUDE_DIR/scripts/session-start"
    "$SETTINGS"
)

HAS_PLACEHOLDERS=false
for file in "${PLACEHOLDER_FILES[@]}"; do
    if [ -f "$file" ] && grep -q '{{[A-Z_]*}}' "$file" 2>/dev/null; then
        BASENAME=$(basename "$file")
        warn "$BASENAME contains unreplaced placeholders ({{...}})"
        HAS_PLACEHOLDERS=true
    fi
done

if [ "$HAS_PLACEHOLDERS" = false ]; then
    pass "All placeholders are replaced"
fi

# --- 6. Agents ---
section "Agents"

AGENT_COUNT=$(find "$CLAUDE_DIR/agents" -name "*.md" ! -name "TEMPLATE.md" 2>/dev/null | wc -l | tr -d ' ')
if [ "$AGENT_COUNT" -gt 0 ]; then
    pass "$AGENT_COUNT agent(s) defined"
    for agent_file in "$CLAUDE_DIR/agents"/*.md; do
        [ "$(basename "$agent_file")" = "TEMPLATE.md" ] && continue
        AGENT_NAME=$(basename "$agent_file" .md)
        if grep -q '{{' "$agent_file" 2>/dev/null; then
            warn "Agent $AGENT_NAME has unreplaced placeholders"
        else
            pass "Agent $AGENT_NAME OK"
        fi
    done
else
    warn "No agents defined (only TEMPLATE.md)"
fi

# --- 7. Pipeline test ---
section "Pipeline"

PIPELINE_OUTPUT=$(bash "$SCRIPT_DIR/pipeline-advance" status 2>&1)
if [ $? -eq 0 ]; then
    pass "pipeline-advance status works"
else
    fail "pipeline-advance status ERROR: $PIPELINE_OUTPUT"
fi

# --- Result ---
echo ""
echo "  ${B}PASS:${R} $PASS_COUNT  ${B}FAIL:${R} $FAIL_COUNT  ${B}WARN:${R} $WARN_COUNT"

if [ "$FAIL_COUNT" -gt 0 ]; then
    echo ""
    echo "Fix FAIL items before using the APD pipeline."
    exit 1
fi

if [ "$WARN_COUNT" -gt 0 ]; then
    echo ""
    echo "WARN items are recommendations — pipeline will work but may not be optimal."
fi

exit 0
