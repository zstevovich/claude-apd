#!/bin/bash
# APD Scope Guard — blocks Write/Edit operations outside the allowed scope
# Interface: --file-path <path> <allowed_path_1> <allowed_path_2> ...

source "$(dirname "$0")/../lib/resolve-project.sh"
source "$(dirname "$0")/../lib/style.sh"
[ "$APD_ACTIVE" = false ] && exit 0

FILE_PATH=""
ALLOWED_PATHS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --file-path) FILE_PATH="$2"; shift 2 ;;
    *) ALLOWED_PATHS+=("$1"); shift ;;
  esac
done

if [ ${#ALLOWED_PATHS[@]} -eq 0 ]; then
  exit 0
fi

if [ -z "$FILE_PATH" ]; then
  exit 0
fi

# Canonicalize the path so `src/../../escape/foo` cannot slip past a prefix
# match on `src/`. Try realpath first; fall back to cd+pwd on the parent dir
# (works for new files too, as long as the parent dir exists); final fallback
# leaves FILE_PATH as-is — the `..` substring check below catches anything
# the normalizer missed.
ABS_PATH=""
if command -v realpath >/dev/null 2>&1; then
  ABS_PATH=$(realpath "$FILE_PATH" 2>/dev/null || true)
fi
if [ -z "$ABS_PATH" ]; then
  FP_DIR=$(dirname "$FILE_PATH")
  if [ -d "$FP_DIR" ]; then
    ABS_PATH="$(cd "$FP_DIR" 2>/dev/null && pwd -P)/$(basename "$FILE_PATH")"
  fi
fi
[ -z "$ABS_PATH" ] && ABS_PATH="$FILE_PATH"

REL_PATH="${ABS_PATH#"$PROJECT_DIR"/}"

# Defense in depth: even if normalization failed, reject any path segment
# that still contains `..` (unresolved traversal means we can't trust the
# prefix match below).
case "/$REL_PATH/" in
  */../*|*/..|../*)
    echo "BLOCKED: File $FILE_PATH contains unresolved path traversal." >&2
    log_block "path-traversal" "$FILE_PATH"
    exit 2
    ;;
esac

if [[ "$REL_PATH" == /* ]]; then
  echo "BLOCKED: File $FILE_PATH is outside the project directory." >&2
  echo "Allowed paths: ${ALLOWED_PATHS[*]}" >&2
  log_block "out-of-scope-write" "$REL_PATH"
  exit 2
fi

for allowed in "${ALLOWED_PATHS[@]}"; do
  allowed="${allowed%/}/"
  if [[ "$REL_PATH" == "$allowed"* ]]; then
    exit 0
  fi
done

echo "BLOCKED: File $REL_PATH is outside the allowed scope." >&2
echo "Allowed paths: ${ALLOWED_PATHS[*]}" >&2
log_block "out-of-scope-write" "$REL_PATH"
exit 2
