#!/bin/bash
# Codex adapter — initialize APD entries in <project>/.codex/
#
# Writes into the project's Codex namespace only. Never touches .claude/.
# Idempotent for each step:
#   1. .codex/config.toml  → [mcp_servers.apd] (MCP server registration)
#   2. .codex/bin/apd      → shortcut to plugin entry point
#   3. .codex/hooks.json   → PreToolUse Bash → guard-bash-scope
#   4. Prints reminder to enable `codex_hooks` feature flag
#
# Per-agent filesystem isolation is handled at runtime by the MCP
# `apd_guard_write` tool, not by generated TOML blocks (see block 2 below).
#
# Usage: install-codex-config [project-dir]
#   project-dir defaults to current working directory
#
# Phase 2 promotion: this is the Codex variant of `apd init`. Safe to re-run.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

PROJECT_DIR="${1:-$(pwd)}"
if [ ! -d "$PROJECT_DIR" ]; then
    echo "ERROR: project-dir does not exist: $PROJECT_DIR" >&2
    exit 1
fi

CODEX_DIR="$PROJECT_DIR/.codex"
CONFIG_FILE="$CODEX_DIR/config.toml"
HOOKS_FILE="$CODEX_DIR/hooks.json"
MCP_SERVER="$APD_PLUGIN_ROOT/mcp/apd_mcp_server.py"
GUARD_BASH="$APD_PLUGIN_ROOT/bin/adapter/cdx/guard-bash-scope"

if [ ! -f "$MCP_SERVER" ]; then
    echo "ERROR: APD MCP server not found at $MCP_SERVER" >&2
    exit 2
fi
if ! command -v uv &>/dev/null; then
    echo "ERROR: \`uv\` is not installed. Install with: brew install uv" >&2
    exit 3
fi
if ! command -v python3 &>/dev/null; then
    echo "ERROR: \`python3\` is not on PATH. The MCP server and APD helpers" >&2
    echo "       (agents-scaffold, codex-doctor) require Python 3." >&2
    echo "       macOS:  xcode-select --install   (or brew install python3)" >&2
    echo "       Linux:  install python3 from your distro's package manager" >&2
    exit 4
fi
if ! command -v jq &>/dev/null; then
    echo "ERROR: \`jq\` is not on PATH. The Codex PreToolUse hook shim" >&2
    echo "       (bin/adapter/cdx/guard-bash-scope) uses jq to parse" >&2
    echo "       the Bash payload coming from Codex." >&2
    echo "       macOS:  brew install jq" >&2
    echo "       Linux:  apt install jq   (or your distro equivalent)" >&2
    exit 5
fi

mkdir -p "$CODEX_DIR"
CHANGES=0

_backup_if_exists() {
    local path="$1"
    [ -f "$path" ] && cp "$path" "${path}.bak.$(date +%s)"
    return 0
}

# -----------------------------------------------------------
# 1. MCP server registration / repair
# -----------------------------------------------------------
CFG_TMP="$(mktemp "${TMPDIR:-/tmp}/apd-cdx-config.XXXXXX")"
set +e
CFG_STATUS="$(
python3 - "$CONFIG_FILE" "$MCP_SERVER" "$CFG_TMP" <<'PY'
import json
import sys
from pathlib import Path

cfg_path = Path(sys.argv[1])
server = sys.argv[2]
out_path = Path(sys.argv[3])

text = cfg_path.read_text() if cfg_path.exists() else ""
desired_block = [
    "[mcp_servers.apd]",
    'command = "uv"',
    f'args = ["run", "--with", "mcp", "python", {json.dumps(server)}]',
]

def split_sections(raw: str) -> list[list[str]]:
    lines = raw.splitlines()
    if not lines:
        return []
    sections: list[list[str]] = []
    current: list[str] = []
    for line in lines:
        if line.startswith("[") and current:
            sections.append(current)
            current = [line]
        else:
            current.append(line)
    if current:
        sections.append(current)
    return sections

sections = split_sections(text)
current_blocks = [sec for sec in sections if sec and sec[0].strip() == "[mcp_servers.apd]"]
if len(current_blocks) == 1 and [line.rstrip() for line in current_blocks[0] if line.strip()] == desired_block:
    print("skip")
    raise SystemExit(0)

action = "updated" if current_blocks else "wrote"
new_sections: list[list[str]] = []
inserted = False
for sec in sections:
    if sec and sec[0].strip() == "[mcp_servers.apd]":
        if not inserted:
            new_sections.append(desired_block)
            inserted = True
        continue
    new_sections.append(sec)
if not inserted:
    new_sections.append(desired_block)

serialized = []
for sec in new_sections:
    block = "\n".join(line.rstrip() for line in sec).strip("\n")
    if block:
        serialized.append(block)

out_path.write_text("\n\n".join(serialized).rstrip() + "\n")
print(action)
raise SystemExit(10)
PY
)"
CFG_RC=$?
set -e
case "$CFG_RC" in
    0)
        rm -f "$CFG_TMP"
        echo "[skip] [mcp_servers.apd] already points to this plugin in $CONFIG_FILE"
        ;;
    10)
        _backup_if_exists "$CONFIG_FILE"
        mv "$CFG_TMP" "$CONFIG_FILE"
        if [ "$CFG_STATUS" = "updated" ]; then
            echo "[updated] [mcp_servers.apd] → $CONFIG_FILE"
        else
            echo "[wrote] [mcp_servers.apd] → $CONFIG_FILE"
        fi
        CHANGES=$((CHANGES + 1))
        ;;
    *)
        rm -f "$CFG_TMP"
        echo "ERROR: failed to update $CONFIG_FILE" >&2
        exit 6
        ;;
esac

# -----------------------------------------------------------
# 2. Per-agent sandbox profiles — INTENTIONALLY DISABLED
#    Real schema (probed against Codex 0.121.0):
#        [permissions.<name>.filesystem]
#        ":workspace/src" = "write"
#        ":workspace" = "read"
#    Two blockers for APD's original plan:
#      1. Codex 0.121.0 returns "not supported until the runtime
#         enforces FileSystemSandboxPolicy directly" — write perms
#         are parsed but not enforced at runtime yet.
#      2. Only one profile is active per session via
#         `default_permissions`. No dynamic per-agent switching.
#    Per-agent enforcement stays in the MCP `apd_guard_write` tool.
#    See memory: project-codex-permissions-schema-unknown.md
# -----------------------------------------------------------
echo "[info] per-agent sandbox profiles skipped — enforced via MCP apd_guard_write instead"

# -----------------------------------------------------------
# 3. .codex/bin/apd shortcut
#    Codex has no reliable SessionStart hook, so we drop a shell
#    wrapper the user can invoke from the project without memorizing
#    plugin paths: `bash .codex/bin/apd ...`.
# -----------------------------------------------------------
APD_SHORTCUT="$CODEX_DIR/bin/apd"
APD_ENTRY="$APD_PLUGIN_ROOT/bin/apd"
if [ -f "$APD_SHORTCUT" ] && grep -qF "$APD_ENTRY" "$APD_SHORTCUT" 2>/dev/null; then
    echo "[skip] .codex/bin/apd shortcut already points to this plugin"
else
    mkdir -p "$(dirname "$APD_SHORTCUT")"
    cat > "$APD_SHORTCUT" <<EOF
#!/bin/bash
# APD — shortcut to plugin entry point
# Auto-generated by install-codex-config
exec bash "$APD_ENTRY" "\$@"
EOF
    chmod +x "$APD_SHORTCUT"
    echo "[wrote] .codex/bin/apd shortcut → $APD_ENTRY"
    CHANGES=$((CHANGES + 1))
fi

# -----------------------------------------------------------
# 4. .apd/config seed (pure-Codex activation marker)
#    Only seed if neither the neutral .apd/config nor the legacy
#    CC .claude/.apd-config exists. Ensures a Codex-only user never
#    has to create anything under .claude/ to activate APD.
# -----------------------------------------------------------
APD_CONFIG_NEUTRAL="$PROJECT_DIR/.apd/config"
APD_CONFIG_LEGACY="$PROJECT_DIR/.claude/.apd-config"
if [ ! -f "$APD_CONFIG_NEUTRAL" ] && [ ! -f "$APD_CONFIG_LEGACY" ]; then
    mkdir -p "$PROJECT_DIR/.apd"
    APD_VER="$(tr -d '[:space:]' < "$APD_PLUGIN_ROOT/VERSION" 2>/dev/null)"
    [ -z "$APD_VER" ] && APD_VER=$(grep '"version"' "$APD_PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
    cat > "$APD_CONFIG_NEUTRAL" <<EOF
PROJECT_NAME=$(basename "$PROJECT_DIR")
APD_VERSION=${APD_VER:-unknown}
STACK=
EOF
    echo "[wrote] .apd/config seed (PROJECT_NAME=$(basename "$PROJECT_DIR"))"
    CHANGES=$((CHANGES + 1))
else
    echo "[skip] APD config already present — leaving alone"
fi

# -----------------------------------------------------------
# 4b. .apd/ scaffold (pure-Codex projects only)
#     Skipped entirely when .claude/ exists — that project is CC-native
#     or hybrid and its content already lives under .claude/.
# -----------------------------------------------------------
if [ ! -d "$PROJECT_DIR/.claude" ]; then
    APD_VER="$(tr -d '[:space:]' < "$APD_PLUGIN_ROOT/VERSION" 2>/dev/null)"
    [ -z "$APD_VER" ] && APD_VER=$(grep '"version"' "$APD_PLUGIN_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)

    # Workflow rules (orchestrator must follow these).
    # Rewrite CC-native shortcut paths to the Codex namespace so a pure-Codex
    # user never sees ".claude/bin/apd ..." in their workflow rules.
    if [ ! -f "$PROJECT_DIR/.apd/rules/workflow.md" ] && [ -f "$APD_PLUGIN_ROOT/rules/workflow.md" ]; then
        mkdir -p "$PROJECT_DIR/.apd/rules"
        sed 's|\.claude/bin/apd|.codex/bin/apd|g' \
            "$APD_PLUGIN_ROOT/rules/workflow.md" \
            > "$PROJECT_DIR/.apd/rules/workflow.md"
        echo "[wrote] .apd/rules/workflow.md (shortcut paths rewritten to .codex/)"
        CHANGES=$((CHANGES + 1))
    fi

    # Codex-native phase rules: brainstorm, tdd, debug, finish.
    # These mirror the CC skill content but are written as inline rule files
    # the orchestrator reads when entering each phase (Codex has no slash
    # commands / skills system the way CC does).
    CDX_RULES_SRC="$APD_PLUGIN_ROOT/templates/codex/rules"
    if [ -d "$CDX_RULES_SRC" ]; then
        mkdir -p "$PROJECT_DIR/.apd/rules"
        for rule in brainstorm tdd debug finish; do
            src="$CDX_RULES_SRC/$rule.md"
            dst="$PROJECT_DIR/.apd/rules/$rule.md"
            if [ -f "$src" ] && [ ! -f "$dst" ]; then
                cp "$src" "$dst"
                echo "[wrote] .apd/rules/$rule.md"
                CHANGES=$((CHANGES + 1))
            fi
        done
    fi

    # Memory tree — MEMORY index, status, session-log
    if [ ! -d "$PROJECT_DIR/.apd/memory" ]; then
        mkdir -p "$PROJECT_DIR/.apd/memory"
        for f in MEMORY.md status.md session-log.md; do
            if [ -f "$APD_PLUGIN_ROOT/templates/memory/$f" ]; then
                cp "$APD_PLUGIN_ROOT/templates/memory/$f" "$PROJECT_DIR/.apd/memory/$f"
            else
                touch "$PROJECT_DIR/.apd/memory/$f"
            fi
        done
        echo "[wrote] .apd/memory/{MEMORY,status,session-log}.md"
        CHANGES=$((CHANGES + 1))
    fi

    # Plugin version tag (informational, used by session-start banners)
    if [ ! -f "$PROJECT_DIR/.apd/.apd-version" ] && [ -n "${APD_VER:-}" ]; then
        echo "$APD_VER" > "$PROJECT_DIR/.apd/.apd-version"
        echo "[wrote] .apd/.apd-version ($APD_VER)"
        CHANGES=$((CHANGES + 1))
    fi

    # Empty agents/ placeholder so pipeline-doctor resolves to it
    if [ ! -d "$PROJECT_DIR/.apd/agents" ]; then
        mkdir -p "$PROJECT_DIR/.apd/agents"
        echo "[wrote] .apd/agents/ (populate with \`apd cdx agents add <name>\`)"
        CHANGES=$((CHANGES + 1))
    fi

    # AGENTS.md — Codex-native project context file (analogue of CLAUDE.md).
    # Only written if missing — never overwrites a user-authored file.
    AGENTS_TEMPLATE="$APD_PLUGIN_ROOT/templates/codex/AGENTS.md"
    if [ ! -f "$PROJECT_DIR/AGENTS.md" ] && [ -f "$AGENTS_TEMPLATE" ]; then
        sed "s/{{PROJECT_NAME}}/$(basename "$PROJECT_DIR")/g" "$AGENTS_TEMPLATE" > "$PROJECT_DIR/AGENTS.md"
        echo "[wrote] AGENTS.md (APD pipeline rules for Codex orchestrator)"
        CHANGES=$((CHANGES + 1))
    fi
else
    echo "[skip] .claude/ present — treating as CC/hybrid project; .apd/ scaffold not needed"
fi

# -----------------------------------------------------------
# 5. Repo-level hooks.json — merge PreToolUse Bash → guard-bash-scope
# -----------------------------------------------------------
HOOKS_TMP="$(mktemp "${TMPDIR:-/tmp}/apd-cdx-hooks.XXXXXX")"
set +e
HOOKS_STATUS="$(
python3 - "$HOOKS_FILE" "$GUARD_BASH" "$HOOKS_TMP" <<'PY'
import json
import sys
from pathlib import Path

hooks_path = Path(sys.argv[1])
guard_bash = sys.argv[2]
out_path = Path(sys.argv[3])

desired = {
    "type": "command",
    "command": f"bash {guard_bash}",
    "timeout": 5,
}

if hooks_path.exists():
    try:
        data = json.loads(hooks_path.read_text())
    except json.JSONDecodeError as exc:
        print(f"invalid JSON in {hooks_path}: {exc}", file=sys.stderr)
        raise SystemExit(1)
else:
    data = {}

if not isinstance(data, dict):
    print(f"{hooks_path} must contain a JSON object", file=sys.stderr)
    raise SystemExit(1)

hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict):
    print(f"{hooks_path}: top-level 'hooks' must be an object", file=sys.stderr)
    raise SystemExit(1)

pre = hooks.setdefault("PreToolUse", [])
if not isinstance(pre, list):
    print(f"{hooks_path}: hooks.PreToolUse must be an array", file=sys.stderr)
    raise SystemExit(1)

apd_marker = "guard-bash-scope"
bash_entries = [entry for entry in pre if isinstance(entry, dict) and entry.get("matcher") == "Bash"]
action = "skip"
desired_present = False
stale_slot = None

for entry in bash_entries:
    entry_hooks = entry.setdefault("hooks", [])
    if not isinstance(entry_hooks, list):
        print(f"{hooks_path}: Bash hook entry must contain a hooks array", file=sys.stderr)
        raise SystemExit(1)
    for idx, hook in enumerate(entry_hooks):
        if not isinstance(hook, dict):
            continue
        command = hook.get("command", "")
        if hook.get("type") == "command" and command == desired["command"]:
            desired_present = True
            if hook.get("timeout") != desired["timeout"]:
                entry_hooks[idx] = desired
                action = "updated"
            break
        if apd_marker in command:
            stale_slot = (entry_hooks, idx)
    if desired_present:
        break

if not desired_present:
    if stale_slot is not None:
        stale_slot[0][stale_slot[1]] = desired
        action = "updated"
    elif bash_entries:
        bash_entries[0]["hooks"].append(desired)
        action = "updated"
    else:
        pre.append({"matcher": "Bash", "hooks": [desired]})
        action = "wrote"

if action == "skip":
    print("skip")
    raise SystemExit(0)

out_path.write_text(json.dumps(data, indent=2) + "\n")
print(action)
raise SystemExit(10)
PY
)"
HOOKS_RC=$?
set -e
case "$HOOKS_RC" in
    0)
        rm -f "$HOOKS_TMP"
        echo "[skip] PreToolUse guard-bash-scope already wired in $HOOKS_FILE"
        ;;
    10)
        _backup_if_exists "$HOOKS_FILE"
        mv "$HOOKS_TMP" "$HOOKS_FILE"
        if [ "$HOOKS_STATUS" = "updated" ]; then
            echo "[updated] PreToolUse Bash hook → $HOOKS_FILE"
        else
            echo "[wrote] PreToolUse Bash hook → $HOOKS_FILE"
        fi
        CHANGES=$((CHANGES + 1))
        ;;
    *)
        rm -f "$HOOKS_TMP"
        echo "ERROR: failed to merge APD hook into $HOOKS_FILE" >&2
        exit 7
        ;;
esac

# -----------------------------------------------------------
# Summary + next-steps
# -----------------------------------------------------------
echo ""
if [ "$CHANGES" -eq 0 ]; then
    echo "APD Codex config already up to date — no changes."
else
    echo "APD Codex init: $CHANGES change(s) written."
fi
echo ""
echo "Next steps:"
STEP=1
if [ ! -d "$PROJECT_DIR/.claude" ]; then
    echo "  ${STEP}. Populate .apd/agents/ with roles you want APD to enforce:"
    echo "       apd cdx agents add code-reviewer"
    echo "       apd cdx agents add backend-builder src/ config/"
    STEP=$((STEP + 1))
    echo "  ${STEP}. Fill in AGENTS.md with your project context (stack, tests, conventions)."
    STEP=$((STEP + 1))
fi
echo "  ${STEP}. Enable Codex hooks feature flag (one-time, global):"
echo "       codex features enable codex_hooks"
STEP=$((STEP + 1))
echo "  ${STEP}. Start Codex from project root:"
echo "       cd \"$PROJECT_DIR\" && codex"
STEP=$((STEP + 1))
echo "  ${STEP}. Verify APD tools appear in the model's tool list, then try:"
echo "       \"run apd_ping\""
