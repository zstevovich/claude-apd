#!/bin/bash
# Codex adapter — SessionStart hook
#
# Wired into .codex/hooks.json by install-codex-config. Fires when a Codex
# TUI session opens in a project with APD configured. Parallel in intent to
# CC's bin/core/session-start, but narrower in scope because Codex 0.121.0
# does not fire SessionStart reliably in `codex exec` mode — the install-time
# shortcut + MCP defaultPrompt apd_doctor call covers exec sessions.
#
# What this does on every TUI open (idempotent, silent unless something
# changed):
#   1. Ensure .codex/bin/apd shortcut exists (drift guard; install-codex-config
#      writes it, but user may delete it)
#   2. Run apd-init --quick for gap analysis, cached 1h (same throttle as CC)
#
# Output strategy:
#   Codex captures hook stdout; keep it quiet unless the user needs to act.
#   All diagnostic lines go to the debug log under the plugin cache.

set -u

# Codex sends hook input on stdin as JSON. We do not need any field from it
# for session-start; just drain to avoid the pipe filling on caller side.
if [ ! -t 0 ]; then
    cat >/dev/null 2>&1 || true
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

_SS_LOG="$APD_PLUGIN_ROOT/cdx-session-start.log"
_ss_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") $1" >> "$_SS_LOG" 2>/dev/null || true; }
_ss_log "START pwd=$(pwd) PLUGIN_ROOT=$APD_PLUGIN_ROOT"

source "$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"
_ss_log "resolve: PROJECT_DIR=$PROJECT_DIR APD_ACTIVE=$APD_ACTIVE"
[ "$APD_ACTIVE" = false ] && { _ss_log "EXIT: APD_ACTIVE=false"; exit 0; }

# --- Shortcut drift guard ---
# install-codex-config writes .codex/bin/apd at install time. If the user
# deleted it, restore silently so `bash .codex/bin/apd ...` keeps working.
CODEX_APD="$PROJECT_DIR/.codex/bin/apd"
APD_ENTRY="$APD_PLUGIN_ROOT/bin/apd"
if [ -d "$PROJECT_DIR/.codex" ] && { [ ! -f "$CODEX_APD" ] || ! grep -qF "$APD_ENTRY" "$CODEX_APD" 2>/dev/null; }; then
    mkdir -p "$(dirname "$CODEX_APD")"
    cat > "$CODEX_APD" <<EOF
#!/bin/bash
# APD — shortcut to plugin entry point
# Auto-generated by cdx session-start
exec bash "$APD_ENTRY" "\$@"
EOF
    chmod +x "$CODEX_APD"
    _ss_log "shortcut: RESTORED"
fi

# --- Auto gap-analysis (throttled 1h, same pattern as CC session-start) ---
APD_INIT="$APD_PLUGIN_ROOT/bin/core/apd-init"
if [ -x "$APD_INIT" ]; then
    LAST_CHECK_FILE="$PIPELINE_DIR/.last-init-check"
    RUN_CHECK=true
    if [ -f "$LAST_CHECK_FILE" ]; then
        LAST_TS=$(cat "$LAST_CHECK_FILE" 2>/dev/null)
        NOW_TS=$(date +%s)
        if [ -n "$LAST_TS" ] && [ $((NOW_TS - LAST_TS)) -lt 3600 ] 2>/dev/null; then
            RUN_CHECK=false
        fi
    fi
    if [ "$RUN_CHECK" = true ]; then
        cd "$PROJECT_DIR" || { _ss_log "EXIT: cd failed"; exit 0; }
        bash "$APD_INIT" --quick >/dev/null 2>&1 || _ss_log "WARN: apd-init --quick exited $?"
        mkdir -p "$PIPELINE_DIR" 2>/dev/null
        date +%s > "$LAST_CHECK_FILE" 2>/dev/null || true
        _ss_log "gap-analysis: ran"
    else
        _ss_log "gap-analysis: skipped (cache fresh)"
    fi
fi

_ss_log "END"
exit 0
