#!/bin/bash
# apd cdx verify-setup — scaffold <project>/.codex/bin/verify-all.sh from a
# stack template so the Codex verifier step (apd_verify_step()) has something
# stack-appropriate to run.
#
# Subcommands:
#   list                   show available stack templates
#   <stack> [--force]      scaffold .codex/bin/verify-all.sh from templates/verify-all/<stack>.sh
#   help                   usage
#
# The fragment templates under templates/verify-all/ are body-only (they
# populate the ERRORS array). This script wraps the fragment with the same
# header + footer apd-init uses for CC, so the resulting script is
# standalone and stays in sync with the CC version.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

TEMPLATE_DIR="$APD_PLUGIN_ROOT/templates/verify-all"
if [ ! -d "$TEMPLATE_DIR" ]; then
    echo "ERROR: template dir missing at $TEMPLATE_DIR" >&2
    exit 2
fi

_list_stacks() {
    for f in "$TEMPLATE_DIR"/*.sh; do
        [ -f "$f" ] || continue
        printf "    %s\n" "$(basename "$f" .sh)"
    done
}

SUB="${1:-help}"
shift 2>/dev/null || true

case "$SUB" in
    list|--list|ls)
        echo ""
        echo "  ${V}Available stacks${R} (${TEMPLATE_DIR}):"
        echo ""
        _list_stacks
        echo ""
        ;;
    help|--help|-h|"")
        echo ""
        echo "  ${V}apd cdx verify-setup${R} — scaffold .codex/bin/verify-all.sh"
        echo ""
        echo "  Usage:"
        echo "    apd cdx verify-setup list             show available stacks"
        echo "    apd cdx verify-setup <stack>          scaffold for this stack"
        echo "    apd cdx verify-setup <stack> --force  overwrite existing"
        echo ""
        echo "  Stacks:"
        _list_stacks
        echo ""
        ;;
    *)
        STACK="$SUB"
        FORCE=0
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --force|-f) FORCE=1; shift ;;
                *) shift ;;
            esac
        done

        FRAGMENT="$TEMPLATE_DIR/$STACK.sh"
        if [ ! -f "$FRAGMENT" ]; then
            echo "ERROR: no template for stack '$STACK'. Available:" >&2
            _list_stacks >&2
            exit 1
        fi

        TARGET="$PROJECT_DIR/.codex/bin/verify-all.sh"
        if [ -f "$TARGET" ] && [ "$FORCE" != "1" ]; then
            echo "ERROR: $TARGET already exists (pass --force to overwrite)" >&2
            exit 1
        fi

        mkdir -p "$(dirname "$TARGET")"
        cat > "$TARGET" << 'HEADER'
#!/bin/bash
# APD Verify All — runs verification for all changed components.
# Lives at .codex/bin/verify-all.sh in the project (not in the plugin).
# Invoked by apd_verify_step() MCP tool and by the verifier step of
# pipeline-advance.

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$PROJECT_DIR" || exit 0

# Cache — skip if the Verifier step already passed recently (<120s)
VERIFIED_TS_FILE="$PROJECT_DIR/.apd/pipeline/verified.timestamp"
if [ -f "$VERIFIED_TS_FILE" ]; then
    VERIFIED_AT=$(cat "$VERIFIED_TS_FILE" 2>/dev/null | tr -d '[:space:]')
    NOW=$(date +%s)
    if [ -n "$VERIFIED_AT" ] && [ "$VERIFIED_AT" -gt 0 ] 2>/dev/null; then
        AGE=$((NOW - VERIFIED_AT))
        if [ "$AGE" -lt 120 ]; then
            echo "Verification skipped — Verifier passed ${AGE}s ago (cache <120s)" >&2
            exit 0
        fi
    fi
fi

ERRORS=()
CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null)
[ -z "$CHANGED_FILES" ] && CHANGED_FILES=$(git diff --name-only HEAD 2>/dev/null)

HEADER
        cat "$FRAGMENT" >> "$TARGET"
        cat >> "$TARGET" << 'FOOTER'

# Result
if [ ${#ERRORS[@]} -gt 0 ]; then
    echo "VERIFICATION FAILED:"
    for e in "${ERRORS[@]}"; do echo "  - $e"; done
    exit 1
fi
echo "Verification passed"
exit 0
FOOTER
        chmod +x "$TARGET"
        echo "  ${G}wrote${R}  $TARGET ($STACK)"
        echo ""
        echo "  Next: edit $TARGET to match your project's test + build commands."
        ;;
esac
