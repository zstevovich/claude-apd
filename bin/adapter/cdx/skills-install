#!/bin/bash
# apd cdx skills — install APD skills into a Codex home
#
# Two install modes, both pointing at the same canonical source under
# plugins/apd/ inside this plugin:
#
#   marketplace (default since v5.0.8)
#     Registers the plugin repo root as a local Codex marketplace and
#     enables [plugins."apd@codex-apd"]. Codex reads the manifest at
#     <repo-root>/.agents/plugins/marketplace.json (single source of
#     truth — same file Codex would fetch from `codex marketplace add
#     zstevovich/claude-apd`). On Codex 0.124+ this populates the plugin
#     cache and surfaces every APD skill in the `/` slash menu under the
#     APD plugin entry. This is the supported flow.
#
#   direct-drop (--legacy-symlink, deprecated)
#     Symlinks into ~/.codex/skills/<name>/. Used to be the default on
#     Codex 0.121.0 because the marketplace path was upstream-blocked
#     (openai/codex#18258). On 0.124+ the marketplace flow is stable and
#     this mode causes user-level symlinks to coexist with plugin-cache
#     skills, producing duplicates in the slash menu. Still available
#     behind --legacy-symlink for emergency / local-dev use; will be
#     removed in a future major.
#
# Subcommands:
#   status                                   show state of both install modes
#   install [--legacy-symlink]               install (default mode = marketplace)
#   uninstall [--legacy-symlink]             uninstall whichever mode was used
#   help                                     usage

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APD_PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$APD_PLUGIN_ROOT/bin/lib/resolve-project.sh"
source "$APD_PLUGIN_ROOT/bin/lib/style.sh"

# Canonical plugin package. Both install modes read from here; there is
# no longer a separate templates/codex/skills/ source.
PLUGIN_LAYOUT="$APD_PLUGIN_ROOT/plugins/apd"
SKILL_SRC_DIR="$PLUGIN_LAYOUT/skills"
# Marketplace root = plugin repo root. Codex looks for
# .agents/plugins/marketplace.json there for both local and remote
# (`codex marketplace add owner/repo`) installs — keeping these aligned
# is what makes the local --marketplace flag a true rehearsal of the
# remote install path.
MARKETPLACE_DIR="$APD_PLUGIN_ROOT"
MARKETPLACE_MANIFEST="$MARKETPLACE_DIR/.agents/plugins/marketplace.json"
MARKETPLACE_NAME="codex-apd"
PLUGIN_KEY="apd@$MARKETPLACE_NAME"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CODEX_CONFIG="$CODEX_HOME/config.toml"
CODEX_SKILLS_DIR="$CODEX_HOME/skills"
ALL_SKILLS=(apd-brainstorm apd-tdd apd-debug apd-finish)

if [ ! -d "$SKILL_SRC_DIR" ]; then
    echo "ERROR: APD skill sources missing at $SKILL_SRC_DIR" >&2
    exit 2
fi
for name in "${ALL_SKILLS[@]}"; do
    [ -f "$SKILL_SRC_DIR/$name/SKILL.md" ] || {
        echo "ERROR: source skill missing: $SKILL_SRC_DIR/$name/SKILL.md" >&2
        exit 2
    }
done

# -----------------------------------------------------------
# Argument parsing: subcommand + optional --marketplace
# -----------------------------------------------------------
SUB="${1:-help}"
shift 2>/dev/null || true
MODE="marketplace"
EXTRA_ARGS=()
while [ "$#" -gt 0 ]; do
    case "$1" in
        --marketplace|--experimental-marketplace) MODE="marketplace"; shift ;;
        --legacy-symlink|--direct|--symlink-mode) MODE="direct"; shift ;;
        *) EXTRA_ARGS+=("$1"); shift ;;
    esac
done

# Deprecation notice for the old direct-drop default. The flag still
# works but the mode is going to be removed in a future major.
if [ "$MODE" = "direct" ] && [ "$SUB" != "help" ]; then
    echo ""
    echo "  ${Y}DEPRECATED${R}  --legacy-symlink installs symlinks into ~/.codex/skills/."
    echo "  ${Y}!${R}           Codex 0.124+ surfaces APD skills via the plugin cache (marketplace"
    echo "  ${Y}!${R}           install), and these symlinks now produce duplicates in the slash"
    echo "  ${Y}!${R}           menu. Run \`apd cdx skills install\` (no flag) for the supported flow."
    echo "  ${Y}!${R}           This flag will be removed in a future major release."
    echo ""
fi

# -----------------------------------------------------------
# Marketplace helpers (only used when MODE=marketplace)
# -----------------------------------------------------------
_registered() {
    [ -f "$CODEX_CONFIG" ] && \
        grep -qE "^\[marketplaces\.$MARKETPLACE_NAME\]" "$CODEX_CONFIG"
}

_registered_source() {
    [ -f "$CODEX_CONFIG" ] || return 0
    awk -v mp="$MARKETPLACE_NAME" '
        $0 ~ "^\\[marketplaces\\." mp "\\]" { in_block = 1; next }
        in_block && /^\[/ { in_block = 0 }
        in_block && $1 == "source" { print; exit }
    ' "$CODEX_CONFIG" | sed -E 's/source *= *"(.*)"/\1/'
}

_plugin_enabled() {
    [ -f "$CODEX_CONFIG" ] || return 1
    python3 - "$CODEX_CONFIG" "$PLUGIN_KEY" <<'PY'
import re
import sys

cfg_path, plugin_key = sys.argv[1], sys.argv[2]
text = open(cfg_path).read()
pattern = re.compile(
    r'(?ms)^\[plugins\."' + re.escape(plugin_key) + r'"\][^\[]*?(?=^\[|\Z)'
)
match = pattern.search(text)
if not match:
    raise SystemExit(1)
block = match.group(0)
raise SystemExit(0 if re.search(r'(?m)^\s*enabled\s*=\s*true\s*$', block) else 1)
PY
}

_plugin_block_present() {
    [ -f "$CODEX_CONFIG" ] || return 1
    python3 - "$CODEX_CONFIG" "$PLUGIN_KEY" <<'PY'
import re
import sys

cfg_path, plugin_key = sys.argv[1], sys.argv[2]
text = open(cfg_path).read()
pattern = re.compile(
    r'(?ms)^\[plugins\."' + re.escape(plugin_key) + r'"\][^\[]*?(?=^\[|\Z)'
)
raise SystemExit(0 if pattern.search(text) else 1)
PY
}

_ensure_plugin_enabled() {
    python3 - "$CODEX_CONFIG" "$PLUGIN_KEY" <<'PY'
import re
import sys
from pathlib import Path

cfg_path = Path(sys.argv[1])
plugin_key = sys.argv[2]
text = cfg_path.read_text() if cfg_path.exists() else ""
desired = f'[plugins."{plugin_key}"]\nenabled = true\n'
pattern = re.compile(
    r'(?ms)^\[plugins\."' + re.escape(plugin_key) + r'"\][^\[]*?(?=^\[|\Z)'
)
match = pattern.search(text)
if match:
    if match.group(0).strip() == desired.strip():
        print("skip")
        raise SystemExit(0)
    new_text = pattern.sub(desired.rstrip() + "\n\n", text, count=1).rstrip() + "\n"
    cfg_path.write_text(new_text)
    print("updated")
    raise SystemExit(10)

new_text = text.rstrip()
if new_text:
    new_text += "\n\n"
new_text += desired
cfg_path.write_text(new_text)
print("wrote")
raise SystemExit(10)
PY
}

# -----------------------------------------------------------
# Direct-drop helpers
# -----------------------------------------------------------
_direct_installed_status() {
    local name="$1"
    local tgt="$CODEX_SKILLS_DIR/$name"
    if [ -L "$tgt" ]; then
        printf "${G}✓${R} symlink → %s" "$(readlink "$tgt")"
    elif [ -d "$tgt" ]; then
        printf "${G}✓${R} (copy)"
    else
        printf "${D}—${R} not installed"
    fi
}

case "$SUB" in
    status|list|ls)
        echo ""
        echo "  ${V}APD Codex skills — install status${R}"
        echo ""
        echo "  ${V}Source${R}            $SKILL_SRC_DIR"
        echo "  ${V}Codex home${R}        $CODEX_HOME"
        echo ""
        echo "  ${V}Marketplace (default since v5.0.8)${R}"
        if _registered; then
            src=$(_registered_source)
            printf "    %-18s  ${G}✓${R} registered (source: %s)\n" "marketplace:" "$src"
            if [ "$src" = "$MARKETPLACE_DIR" ]; then
                printf "    %-18s  ${G}✓${R} matches this plugin checkout\n" "alignment:"
            else
                printf "    %-18s  ${Y}!${R} points elsewhere\n" "alignment:"
            fi
        else
            printf "    %-18s  ${D}—${R} not registered\n" "marketplace:"
        fi
        if _plugin_enabled; then
            printf "    %-18s  ${G}✓${R} enabled\n" "plugin block:"
        else
            printf "    %-18s  ${D}—${R} not enabled\n" "plugin block:"
        fi
        echo ""
        echo "  ${V}Direct-drop (--legacy-symlink, deprecated — ~/.codex/skills/)${R}"
        for s in "${ALL_SKILLS[@]}"; do
            printf "    %-18s  %s\n" "$s" "$(_direct_installed_status "$s")"
        done
        echo ""
        ;;
    install|add)
        if [ "$MODE" = "marketplace" ]; then
            # -------- Marketplace mode (default since v5.0.8) --------
            if [ ! -f "$MARKETPLACE_MANIFEST" ]; then
                echo "ERROR: marketplace.json missing at $MARKETPLACE_MANIFEST" >&2
                exit 2
            fi
            if [ ! -f "$PLUGIN_LAYOUT/.codex-plugin/plugin.json" ]; then
                echo "ERROR: plugin manifest missing at $PLUGIN_LAYOUT/.codex-plugin/plugin.json" >&2
                exit 2
            fi
            if ! command -v codex >/dev/null 2>&1; then
                echo "ERROR: \`codex\` CLI not on PATH — install Codex first" >&2
                exit 1
            fi
            echo ""
            echo "  ${G}Marketplace mode${R} — registers $MARKETPLACE_NAME locally and enables"
            echo "  [plugins.\"$PLUGIN_KEY\"]. On Codex 0.124+ skills surface in the \`/\` slash"
            echo "  menu under the APD plugin. After this command, in a fresh TUI run"
            echo "  \`codex plugin marketplace upgrade $MARKETPLACE_NAME\` to refresh the cache."
            echo ""
            if _registered; then
                existing=$(_registered_source)
                if [ "$existing" = "$MARKETPLACE_DIR" ]; then
                    set +e
                    ENSURE_OUT="$(_ensure_plugin_enabled 2>&1)"
                    ENSURE_RC=$?
                    set -e
                    if [ "$ENSURE_RC" -eq 10 ]; then
                        echo "  ${G}updated${R}  [plugins.\"$PLUGIN_KEY\"] in $CODEX_CONFIG"
                    elif [ "$ENSURE_RC" -ne 0 ]; then
                        echo "$ENSURE_OUT" >&2
                        echo "ERROR: failed to enable [plugins.\"$PLUGIN_KEY\"] in $CODEX_CONFIG" >&2
                        exit 1
                    fi
                    echo "  ${G}already registered${R}  $MARKETPLACE_NAME → $MARKETPLACE_DIR"
                    exit 0
                fi
                echo "  ${Y}!${R} $MARKETPLACE_NAME marketplace already registered with a different source:"
                echo "      $existing"
                echo ""
                echo "  Remove the existing [marketplaces.$MARKETPLACE_NAME] block from"
                echo "  $CODEX_CONFIG and re-run with --marketplace."
                exit 1
            fi
            if ! codex marketplace add "$MARKETPLACE_DIR" 2>&1; then
                echo "ERROR: codex marketplace add failed" >&2
                exit 1
            fi
            set +e
            ENSURE_OUT="$(_ensure_plugin_enabled 2>&1)"
            ENSURE_RC=$?
            set -e
            if [ "$ENSURE_RC" -eq 10 ]; then
                echo "  ${G}enabled${R} [plugins.\"$PLUGIN_KEY\"] in $CODEX_CONFIG"
            elif [ "$ENSURE_RC" -ne 0 ]; then
                echo "$ENSURE_OUT" >&2
                echo "ERROR: failed to enable [plugins.\"$PLUGIN_KEY\"] in $CODEX_CONFIG" >&2
                exit 1
            fi
            echo ""
            echo "  ${G}registered${R} $MARKETPLACE_NAME marketplace"
            echo ""
            echo "  Next: in a fresh TUI run \`codex plugin marketplace upgrade $MARKETPLACE_NAME\`"
            echo "  to populate the plugin cache. Skills will appear under the APD plugin"
            echo "  entry in the \`/\` slash menu."
            exit 0
        fi

        # -------- Direct-drop mode (--legacy-symlink, deprecated) --------
        DIRECT_MODE="symlink"
        FORCE="false"
        NAMES=()
        for a in "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"; do
            case "$a" in
                --copy) DIRECT_MODE="copy" ;;
                --symlink) DIRECT_MODE="symlink" ;;
                --force|-f) FORCE="true" ;;
                *) NAMES+=("$a") ;;
            esac
        done
        [ "${#NAMES[@]}" -eq 0 ] && NAMES=("${ALL_SKILLS[@]}")

        mkdir -p "$CODEX_SKILLS_DIR"
        for name in "${NAMES[@]}"; do
            src="$SKILL_SRC_DIR/$name"
            tgt="$CODEX_SKILLS_DIR/$name"
            if [ ! -d "$src" ]; then
                echo "  ${RED}skip${R}  $name (no source at $src)"
                continue
            fi
            # Overwrite protection: symlinks are APD-managed (safe to replace).
            # Real dirs are replaced only if SKILL.md matches canonical (idempotent
            # re-install) OR --force is passed. Otherwise refuse to preserve
            # user-modified copies.
            if [ -L "$tgt" ]; then
                rm -f "$tgt"
            elif [ -d "$tgt" ]; then
                if [ "$FORCE" = "true" ]; then
                    rm -rf "$tgt"
                elif [ -f "$tgt/SKILL.md" ] && diff -q "$tgt/SKILL.md" "$src/SKILL.md" >/dev/null 2>&1; then
                    rm -rf "$tgt"
                else
                    echo "  ${RED}refuse${R}  $tgt exists and differs from canonical source"
                    echo "            pass --force to overwrite (or remove it manually first)"
                    continue
                fi
            elif [ -e "$tgt" ]; then
                echo "  ${RED}refuse${R}  $tgt exists and is neither symlink nor directory"
                continue
            fi
            if [ "$DIRECT_MODE" = "symlink" ]; then
                ln -s "$src" "$tgt"
                echo "  ${G}link${R}  $tgt → $src"
            else
                cp -r "$src" "$tgt"
                echo "  ${G}copy${R}  $tgt"
            fi
        done
        echo ""
        echo "  Restart Codex to pick up newly installed skills."
        echo "  Skills load as \$apd-brainstorm / \$apd-tdd / \$apd-debug / \$apd-finish."
        echo "  Note: direct-drop skills do NOT appear in the \`/\` slash menu —"
        echo "  that surface is plugin-scoped only (see \`--marketplace\` for WIP path)."
        ;;
    uninstall|remove|rm)
        if [ "$MODE" = "marketplace" ]; then
            # -------- Marketplace mode uninstall --------
            if [ ! -f "$CODEX_CONFIG" ]; then
                echo "  ${D}—${R} $CODEX_CONFIG missing — nothing to remove"
                exit 0
            fi
            if ! _registered && ! _plugin_block_present; then
                echo "  ${D}—${R} $MARKETPLACE_NAME not registered and [plugins.\"$PLUGIN_KEY\"] missing — nothing to remove"
                exit 0
            fi
            python3 - "$CODEX_CONFIG" "$MARKETPLACE_NAME" "$PLUGIN_KEY" <<'PY'
import re, sys
cfg_path, name, plugin_key = sys.argv[1], sys.argv[2], sys.argv[3]
with open(cfg_path) as f:
    text = f.read()
marketplace_pattern = re.compile(
    r'(?ms)^\[marketplaces\.' + re.escape(name) + r'\][^\[]*?(?=^\[|\Z)'
)
plugin_pattern = re.compile(
    r'(?ms)^\[plugins\."' + re.escape(plugin_key) + r'"\][^\[]*?(?=^\[|\Z)'
)
new = marketplace_pattern.sub('', text)
new = plugin_pattern.sub('', new)
new = re.sub(r'\n{3,}', '\n\n', new).rstrip() + '\n'
with open(cfg_path, 'w') as f:
    f.write(new)
PY
            echo "  ${G}removed${R} [marketplaces.$MARKETPLACE_NAME] from $CODEX_CONFIG"
            echo "  ${G}removed${R} [plugins.\"$PLUGIN_KEY\"] from $CODEX_CONFIG"
            echo ""
            echo "  Plugin cache under $CODEX_HOME/plugins/cache/$MARKETPLACE_NAME/ stays"
            echo "  until you delete it manually:"
            echo "      rm -rf $CODEX_HOME/plugins/cache/$MARKETPLACE_NAME"
            exit 0
        fi

        # -------- Direct-drop mode uninstall --------
        NAMES=("${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}")
        [ "${#NAMES[@]}" -eq 0 ] && NAMES=("${ALL_SKILLS[@]}")
        for name in "${NAMES[@]}"; do
            tgt="$CODEX_SKILLS_DIR/$name"
            case "$name" in
                apd-*) ;;
                *) echo "  ${RED}refuse${R} to uninstall non-apd-* skill: $name"; continue ;;
            esac
            if [ -L "$tgt" ]; then
                rm "$tgt"
                echo "  ${G}removed${R}  $tgt (symlink)"
            elif [ -d "$tgt" ] && [ -f "$tgt/SKILL.md" ] && grep -q "^name: $name$" "$tgt/SKILL.md"; then
                rm -rf "$tgt"
                echo "  ${G}removed${R}  $tgt (directory)"
            elif [ -e "$tgt" ]; then
                echo "  ${RED}skip${R}  $tgt — does not look like an APD-installed skill"
            else
                echo "  ${D}—${R}  $tgt (not installed)"
            fi
        done
        ;;
    help|--help|-h|"")
        echo ""
        echo "  ${V}apd cdx skills${R} — install APD skills into Codex"
        echo ""
        echo "  Usage:"
        echo "    apd cdx skills status                       show install status (both modes)"
        echo "    apd cdx skills install                      register local marketplace (default)"
        echo "    apd cdx skills install --legacy-symlink     symlinks into ~/.codex/skills/ (deprecated)"
        echo "    apd cdx skills install --legacy-symlink <name> ...   install named skills only"
        echo "    apd cdx skills install --legacy-symlink --copy       copy instead of symlink"
        echo "    apd cdx skills install --legacy-symlink --force      overwrite user-modified installs"
        echo "    apd cdx skills uninstall                    unregister marketplace"
        echo "    apd cdx skills uninstall --legacy-symlink   remove direct-drop install"
        echo ""
        echo "  Default (marketplace) registers $MARKETPLACE_NAME locally and enables"
        echo "  [plugins.\"$PLUGIN_KEY\"]. On Codex 0.124+ this surfaces every APD skill"
        echo "  in the \`/\` slash menu under the APD plugin entry. This is the"
        echo "  supported flow."
        echo ""
        echo "  --legacy-symlink is the old default (Codex 0.121 era). It installs"
        echo "  symlinks into $CODEX_SKILLS_DIR/<name>/. On 0.124+ these now coexist with"
        echo "  the plugin cache and produce duplicates in the slash menu. Kept behind"
        echo "  the flag for emergency / local-dev use; will be removed in a future major."
        echo ""
        echo "  Source:            $SKILL_SRC_DIR"
        echo "  Marketplace root:  $MARKETPLACE_DIR"
        echo "  Codex config:      $CODEX_CONFIG"
        echo ""
        ;;
    *)
        echo "Unknown subcommand: $SUB" >&2
        echo "Run: apd cdx skills help" >&2
        exit 1
        ;;
esac
