#!/bin/bash
# APD — single entry point for all APD commands
#
# Usage: apd <command> [args...]
#
# Commands:
#   pipeline <step>   Pipeline advance (spec/builder/reviewer/verifier/status/reset/rollback/metrics)
#   doctor            Pipeline diagnostics
#   init [--quick]    Initialize or update APD in a project
#   verify            Run full APD verification
#   trace             Check spec traceability
#   contracts         Check cross-layer type contracts
#   gh <step>         GitHub sync
#   report [--history [N]] Pipeline run report
#   test              Quick static hook test

CORE_DIR="$(cd "$(dirname "$0")/core" && pwd)"

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    pipeline|pl)
        exec bash "$CORE_DIR/pipeline-advance" "$@"
        ;;
    doctor|dr)
        exec bash "$CORE_DIR/pipeline-doctor" "$@"
        ;;
    init|setup)
        exec bash "$CORE_DIR/apd-init" "$@"
        ;;
    verify)
        exec bash "$CORE_DIR/verify-apd" "$@"
        ;;
    trace)
        exec bash "$CORE_DIR/verify-trace" "$@"
        ;;
    contracts)
        exec bash "$CORE_DIR/verify-contracts" "$@"
        ;;
    gh|github)
        exec bash "$CORE_DIR/gh-sync" "$@"
        ;;
    report|rp)
        exec bash "$CORE_DIR/pipeline-report" "$@"
        ;;
    test)
        exec bash "$CORE_DIR/test-hooks" "$@"
        ;;
    test-system|system-test)
        exec bash "$CORE_DIR/test-system" "$@"
        ;;
    cdx|codex)
        CDX_SUB="${1:-help}"
        shift 2>/dev/null || true
        CDX_DIR="$(cd "$(dirname "$0")/adapter/cdx" && pwd)"
        case "$CDX_SUB" in
            init|setup)
                exec bash "$CDX_DIR/install-codex-config" "$@"
                ;;
            agents)
                exec bash "$CDX_DIR/agents-scaffold" "$@"
                ;;
            doctor|dr)
                exec bash "$CDX_DIR/codex-doctor" "$@"
                ;;
            test)
                exec bash "$CORE_DIR/test-codex-adapter" "$@"
                ;;
            help|--help|-h|"")
                source "$(dirname "$0")/lib/style.sh"
                APD_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
                APD_VER="$(cat "$APD_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
                [ -z "$APD_VER" ] && APD_VER=$(grep '"version"' "$APD_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
                echo ""
                echo "  ${V}apd cdx${R} — Codex runtime adapter ${D}(APD v${APD_VER:-unknown})${R}"
                echo ""
                echo "  ${V}Setup${R}"
                echo "    init [project-dir]           Install APD into <project>/.codex/ and"
                echo "                                 scaffold .apd/{config,rules,memory,agents} +"
                echo "                                 AGENTS.md on pure-Codex projects"
                echo ""
                echo "  ${V}Agent scaffolding${R}"
                echo "    agents list                  Show available templates and installed agents"
                echo "    agents add <name> [scope..]  Copy a template into .apd/agents/<name>.md"
                echo "    agents add <name> --force    Overwrite an existing agent file"
                echo ""
                echo "    Templates: code-reviewer, backend-builder, frontend-builder,"
                echo "               testing, adversarial-reviewer"
                echo ""
                echo "  ${V}Diagnostics${R}"
                echo "    doctor                       Audit the pure-Codex setup (runtime-aware)"
                echo "    test                         Run E2E smoke test (60+ checks, no Codex CLI)"
                echo ""
                echo "  ${V}Prerequisites${R}"
                echo "    python3 on PATH                            (macOS: xcode-select --install)"
                echo "    brew install uv                            (MCP server runner)"
                echo "    brew install jq                            (Codex hook shim parses JSON stdin)"
                echo "    codex features enable codex_hooks          (one-time, global)"
                echo ""
                echo "  ${V}Typical pure-Codex flow${R}"
                echo "    apd cdx init"
                echo "    apd cdx agents add code-reviewer"
                echo "    apd cdx agents add backend-builder src/ config/"
                echo "    \$EDITOR AGENTS.md              ${D}# fill in stack + conventions${R}"
                echo "    codex                           ${D}# start session, try \"run apd_ping\"${R}"
                echo ""
                ;;
            *)
                echo "Unknown cdx subcommand: $CDX_SUB" >&2
                echo "Run: apd cdx help" >&2
                exit 1
                ;;
        esac
        ;;
    version|--version|-v)
        APD_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
        APD_VER="$(cat "$APD_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
        [ -z "$APD_VER" ] && APD_VER=$(grep '"version"' "$APD_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        echo "APD v${APD_VER:-unknown}"
        ;;
    help|--help|-h)
        source "$(dirname "$0")/lib/style.sh"
        APD_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
        APD_VER="$(cat "$APD_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
        [ -z "$APD_VER" ] && APD_VER=$(grep '"version"' "$APD_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
        apd_logo
        echo ""
        echo "  ${V}APD${R} — Agent Pipeline Development ${D}v${APD_VER:-unknown}${R}"
        echo ""
        echo "  Usage: apd <command> [args]"
        echo ""
        echo "  Commands:"
        echo "    pipeline <step>   Pipeline advance (spec/builder/reviewer/verifier/status/reset)"
        echo "    doctor            Pipeline diagnostics"
        echo "    init [--quick]    Initialize or update APD in a project"
        echo "    verify            Run full APD verification"
        echo "    trace             Check spec traceability"
        echo "    contracts         Check cross-layer type contracts"
        echo "    gh <step>         GitHub sync"
        echo "    report            Pipeline run report (--history [N] for history)"
        echo "    test              Quick static hook test"
        echo "    cdx <sub>         Codex runtime adapter (init|test) — see 'apd cdx help'"
        echo ""
        ;;
    *)
        if [ -x "$CORE_DIR/$CMD" ]; then
            exec bash "$CORE_DIR/$CMD" "$@"
        else
            echo "Unknown command: $CMD" >&2
            echo "Run: apd help" >&2
            exit 1
        fi
        ;;
esac
